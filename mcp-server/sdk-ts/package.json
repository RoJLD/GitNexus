{
  "name": "@gitnexus/copilot-sdk",
  "version": "0.1.0",
  "description": "TypeScript client SDK for the GitNexus Architect's Copilot AI REST surface (Tier 3.7 Phase B). Wraps /copilot/mcp-inventory, /copilot/blt-context, /copilot/cluster-context, /copilot/forge-context.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test dist/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "keywords": [
    "gitnexus",
    "architect-copilot",
    "mcp",
    "sdk",
    "tier-3.7"
  ]
}
