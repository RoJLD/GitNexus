+import { describe, it, expect, vi } from 'vitest';
+import { render, screen, fireEvent } from '@testing-library/react';
+import { GraphSidebar } from '@/components/GraphSidebar';
+import type { GraphConfigEntry } from '@/services/MultigraphLoader';
+
+const graphs: GraphConfigEntry[] = [
+  { name: 'ASTKG', path: '/x', schema_type: 'code-cognition', ttl_snapshot_hours: 1, privacy_class: 'SHARED' },
+  { name: 'Forge', path: '/y', schema_type: 'concept-forge', ttl_snapshot_hours: 1, privacy_class: 'SHARED' },
+];
+
+describe('GraphSidebar', () => {
+  it('renders graphs grouped by schema_type', () => {
+    render(<GraphSidebar graphs={graphs} onSelect={() => {}} selected={null} />);
+    expect(screen.getByText('ASTKG')).toBeInTheDocument();
+    expect(screen.getByText('Forge')).toBeInTheDocument();
+    expect(screen.getByText('code-cognition')).toBeInTheDocument();
+  });
+
+  it('calls onSelect when graph clicked', () => {
+    const onSelect = vi.fn();
+    render(<GraphSidebar graphs={graphs} onSelect={onSelect} selected={null} />);
+    fireEvent.click(screen.getByText('ASTKG'));
+    expect(onSelect).toHaveBeenCalledWith('ASTKG');
+  });
+});
