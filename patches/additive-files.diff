@@ -0,0 +1,70 @@
+/**
+ * SlippageBar — stacked horizontal bar with 4 segments
+ * (early / onTime / late / noTarget). Each segment's width is
+ * proportional to its count, so a visual glance tells you how much of
+ * the materialized population landed on time vs missed.
+ *
+ * The bar header displays `onTimePct` (formatted as a %). The pct
+ * denominator excludes `noTarget` (consistent with computeSlippage).
+ *
+ * Spec : docs/superpowers/specs/2026-05-26-roadmap-predictive-audit-design.md
+ */
+
+type Props = {
+  data: {
+    early: number;
+    onTime: number;
+    late: number;
+    noTarget: number;
+    onTimePct: number | null;
+  };
+};
+
+const SEGMENTS = [
+  { key: 'early', label: 'Early', color: '#3b82f6' },
+  { key: 'onTime', label: 'On time', color: '#10b981' },
+  { key: 'late', label: 'Late', color: '#ef4444' },
+  { key: 'noTarget', label: 'No target', color: '#9ca3af' },
+] as const;
+
+export default function SlippageBar({ data }: Props) {
+  const total = data.early + data.onTime + data.late + data.noTarget;
+  const pctText =
+    data.onTimePct == null ? '—' : `${(data.onTimePct * 100).toFixed(1)}%`;
+  return (
+    <div className="slippage-bar" data-testid="slippage-bar">
+      <header>
+        <strong>Slippage</strong>
+        <span className="on-time-pct" data-testid="on-time-pct">
+          {pctText} on time
+        </span>
+      </header>
+      <div className="bar" role="img" aria-label={`Slippage: ${pctText} on time`}>
+        {SEGMENTS.map((seg) => {
+          const count = data[seg.key];
+          const widthPct = total === 0 ? 0 : (count / total) * 100;
+          return (
+            <div
+              key={seg.key}
+              className={`segment segment-${seg.key}`}
+              data-testid={`segment-${seg.key}`}
+              title={`${seg.label}: ${count}`}
+              style={{
+                width: `${widthPct}%`,
+                background: seg.color,
+                display: 'inline-block',
+                height: 16,
+              }}
+            >
+              {widthPct > 8 && (
+                <span className="seg-label" style={{ color: 'white', fontSize: 10, padding: '0 4px' }}>
+                  {count}
+                </span>
+              )}
+            </div>
+          );
+        })}
+      </div>
+    </div>
+  );
+}
diff --git a/gitnexus-web/src/components/audit/VelocitySparkline.tsx b/gitnexus-web/src/components/audit/VelocitySparkline.tsx
new file mode 100644
index 00000000..9a0b0a7e
--- /dev/null
+++ b/gitnexus-web/src/components/audit/VelocitySparkline.tsx
@@ -0,0 +1,73 @@
+/**
+ * VelocitySparkline — a single-line SVG over the last N weeks of
+ * materialization counts, plus a big number for `currentCount` (matters
+ * in the configured window — default 28 days). Pattern mirrors the
+ * inline SVG style of GrowthChart.tsx (no chart lib).
+ *
+ * If `history` has fewer than 2 points the line is hidden (not enough
+ * to draw a slope); the currentCount remains visible.
+ *
+ * Spec : docs/superpowers/specs/2026-05-26-roadmap-predictive-audit-design.md
+ */
+
+const W = 240;
+const H = 56;
+const PAD = 4;
+
+type Props = {
+  data: {
+    windowDays: number;
+    currentCount: number;
+    history: { weekStarting: string; count: number }[];
+  };
+};
+
+export default function VelocitySparkline({ data }: Props) {
+  const history = data.history ?? [];
+  const max = Math.max(1, ...history.map((h) => h.count));
+  const innerW = W - PAD * 2;
+  const innerH = H - PAD * 2;
+  const step = history.length > 1 ? innerW / (history.length - 1) : 0;
+  const points = history
+    .map((h, i) => {
+      const x = PAD + i * step;
+      const y = PAD + innerH - (h.count / max) * innerH;
+      return `${x.toFixed(1)},${y.toFixed(1)}`;
+    })
+    .join(' ');
+  return (
+    <div className="velocity-sparkline" data-testid="velocity-sparkline">
+      <header>
+        <strong>Velocity</strong>
+        <span className="window">{data.windowDays}d window</span>
+      </header>
+      <div className="current-count" data-testid="current-count">
+        {data.currentCount}
+      </div>
+      {history.length >= 2 && (
+        <svg width={W} height={H} role="img" aria-label="Velocity sparkline">
+          <polyline
+            data-testid="sparkline-polyline"
+            fill="none"
+            stroke="#3b82f6"
+            strokeWidth={2}
+            points={points}
+          />
+          {history.map((h, i) => {
+            const x = PAD + i * step;
+            const y = PAD + innerH - (h.count / max) * innerH;
+            return (
+              <circle
+                key={h.weekStarting}
+                cx={x}
+                cy={y}
+                r={2}
+                fill="#3b82f6"
+              />
+            );
+          })}
+        </svg>
+      )}
+    </div>
+  );
+}
diff --git a/gitnexus-web/src/components/gantt/GanttAxis.tsx b/gitnexus-web/src/components/gantt/GanttAxis.tsx
new file mode 100644
index 00000000..3c8ded87
--- /dev/null
+++ b/gitnexus-web/src/components/gantt/GanttAxis.tsx
@@ -0,0 +1,69 @@
+/**
+ * GanttAxis — SVG header with monthly ticks + year labels + today line.
+ *
+ * Renders one vertical tick per month within the time window plus a red
+ * "today" line at the supplied `now` position. Consumed by GanttPanel
+ * inside its main SVG (translated by `labelWidth` so axis aligns with
+ * the bar area).
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-gantt-design.md
+ */
+
+import { dateScale } from '../../lib/gantt-layout';
+
+type Props = {
+  window: { start: Date; end: Date };
+  width: number;
+  height: number;
+  now: Date;
+};
+
+const MONTH_LABELS = [
+  'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
+  'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
+];
+
+export default function GanttAxis({ window, width, height, now }: Props) {
+  const scale = dateScale(window, width);
+  const months: Date[] = [];
+  const cursor = new Date(window.start);
+  cursor.setUTCDate(1);
+  // Reset to first day of the starting month so ticks always land on month boundaries.
+  while (cursor <= window.end) {
+    months.push(new Date(cursor));
+    cursor.setUTCMonth(cursor.getUTCMonth() + 1);
+  }
+  const todayX = scale(now);
+
+  return (
+    <svg width={width} height={height} className="gantt-axis">
+      {months.map((m, i) => {
+        const x = scale(m);
+        return (
+          <g key={i}>
+            <line
+              x1={x}
+              y1={0}
+              x2={x}
+              y2={height}
+              stroke="#444"
+              strokeWidth={1}
+            />
+            <text x={x + 4} y={height - 5} fontSize={10} fill="#888">
+              {MONTH_LABELS[m.getUTCMonth()]} &apos;{String(m.getUTCFullYear()).slice(-2)}
+            </text>
+          </g>
+        );
+      })}
+      <line
+        className="today"
+        x1={todayX}
+        y1={0}
+        x2={todayX}
+        y2={height}
+        stroke="#e74c3c"
+        strokeWidth={2}
+      />
+    </svg>
+  );
+}
diff --git a/gitnexus-web/src/components/gantt/GanttBar.tsx b/gitnexus-web/src/components/gantt/GanttBar.tsx
new file mode 100644
index 00000000..ba51c805
--- /dev/null
+++ b/gitnexus-web/src/components/gantt/GanttBar.tsx
@@ -0,0 +1,71 @@
+/**
+ * GanttBar — single bar primitive in the Gantt chart.
+ *
+ * Four shapes, one per ghost lifecycle state :
+ *   - solid  : materialized (plannedAt → materializedAt)
+ *   - dashed : planned and forecast (plannedAt → plannedFor target)
+ *   - dot    : planned with no horizon (single anchor point)
+ *   - grey   : cancelled (plannedAt → cancelledAt, dimmed)
+ *
+ * Each bar exposes its title via SVG <title> for native tooltip on hover.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-gantt-design.md
+ */
+
+import type { GanttBar as GanttBarData } from '../../lib/gantt-layout';
+
+type Props = {
+  bar: GanttBarData;
+  scale: (d: Date) => number;
+  y: number;
+  height: number;
+  title: string;
+};
+
+export default function GanttBar({ bar, scale, y, height, title }: Props) {
+  const x = scale(new Date(bar.startDate));
+
+  if (bar.kind === 'dot') {
+    return (
+      <circle cx={x} cy={y + height / 2} r={height / 3} fill={bar.color}>
+        <title>{title}</title>
+      </circle>
+    );
+  }
+
+  const xEnd = scale(new Date(bar.endDate as string));
+  const w = Math.max(2, xEnd - x);
+
+  if (bar.kind === 'solid') {
+    return (
+      <rect x={x} y={y} width={w} height={height} fill={bar.color} rx={2}>
+        <title>{title}</title>
+      </rect>
+    );
+  }
+
+  if (bar.kind === 'dashed') {
+    return (
+      <rect
+        x={x}
+        y={y}
+        width={w}
+        height={height}
+        fill="none"
+        stroke={bar.color}
+        strokeWidth={1.5}
+        strokeDasharray="4 3"
+        rx={2}
+      >
+        <title>{title}</title>
+      </rect>
+    );
+  }
+
+  // kind === 'grey' (cancelled)
+  return (
+    <rect x={x} y={y} width={w} height={height} fill="#888" opacity={0.4} rx={2}>
+      <title>{title}</title>
+    </rect>
+  );
+}
diff --git a/gitnexus-web/src/components/gantt/GanttRow.tsx b/gitnexus-web/src/components/gantt/GanttRow.tsx
