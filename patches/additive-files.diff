+import { useMemo, useState } from 'react';
+import {
+  X,
+  Loader2,
+  AlertCircle,
+  Download,
+  Target,
+  ChevronRight,
+  ChevronDown,
+  Sparkles,
+  Pause,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Dissonance panel — Tier 2.2.
+ *
+ * Header: purity score (0..1, higher = code matches declared domains)
+ * with a colored gauge, plus the totals (declared domains, files
+ * involved, communities seen).
+ *
+ * Body:
+ *   - Per-domain sections (collapsible) showing which communities the
+ *     domain spans, plus its dominant community and confidence.
+ *   - A flat "Misplaced files" list (the ones whose community ≠ their
+ *     domain's dominant). Click a file to highlight it in the live
+ *     graph — these are the refactor candidates.
+ *   - A small "domain declared but no symbols" section so the user
+ *     knows which paths their globs cover that gitnexus can't pin to
+ *     a community (typical for docs/configs).
+ *
+ * Position: top-right, same slot as Coupling/Ownership. Mutually
+ * exclusive with both via Timeline toggles. The data is essentially
+ * static for the current live graph — no point sharing the slot.
+ */
+
+const PANEL_WIDTH_PX = 420;
+
+function purityColor(p: number): string {
+  if (p >= 0.85) return 'text-emerald-300 bg-emerald-500/15 border-emerald-500/30';
+  if (p >= 0.6) return 'text-amber-300 bg-amber-500/15 border-amber-500/30';
+  return 'text-red-300 bg-red-500/15 border-red-500/30';
+}
+
+export const DissonancePanel = () => {
