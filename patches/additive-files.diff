index 00000000..d01d2f87
--- /dev/null
+++ b/gitnexus-web/src/lib/graph-diff.ts
@@ -0,0 +1,122 @@
+/**
+ * Pure utilities for diffing two gitnexus graphs.
+ *
+ * Diff identity: we match nodes by `id` (path-based + content-hash, stable
+ * across exports of the same source code). Edges are matched by the
+ * (sourceId, targetId, type) triple. Two indexes built from the same git
+ * commit will diff cleanly to "all in both"; a sender with a few extra
+ * functions will show those as `onlyInB`.
+ *
+ * We deliberately skip semantic node comparison (file contents, line
+ * numbers, etc.) for the MVP — those add a lot of UI noise and can be
+ * surfaced later via a "modified" bucket once we have signatures.
+ */
+import type { GraphNode, GraphRelationship } from 'gitnexus-shared';
+
+export type DiffStatus = 'onlyInA' | 'onlyInB' | 'inBoth';
+
+export interface GraphDiff {
+  /** Per-node diff status, keyed by node id. Built from the union of A∪B. */
+  nodeStatus: Map<string, DiffStatus>;
+  /** Per-edge diff status, keyed by `${source}::${type}::${target}`. */
+  edgeStatus: Map<string, DiffStatus>;
+  /** Union of nodes from both graphs, deduped by id. */
+  unionNodes: GraphNode[];
+  /** Union of edges from both graphs, deduped by (source, type, target). */
+  unionEdges: GraphRelationship[];
+  /** Counts (handy for the stats banner so we don't recompute). */
+  counts: {
+    nodes: { onlyInA: number; onlyInB: number; inBoth: number };
+    edges: { onlyInA: number; onlyInB: number; inBoth: number };
+  };
+}
+
+const edgeKey = (e: GraphRelationship) => `${e.sourceId}::${e.type}::${e.targetId}`;
+
+export function computeGraphDiff(
+  graphA: { nodes: GraphNode[]; relationships: GraphRelationship[] },
+  graphB: { nodes: GraphNode[]; relationships: GraphRelationship[] },
+): GraphDiff {
+  const idsA = new Set(graphA.nodes.map((n) => n.id));
+  const idsB = new Set(graphB.nodes.map((n) => n.id));
+
+  const nodeStatus = new Map<string, DiffStatus>();
+  const unionNodes: GraphNode[] = [];
+  const seenNodes = new Set<string>();
+
+  // A pass: nodes from A. Each is either onlyInA (not in B) or inBoth.
+  for (const n of graphA.nodes) {
+    seenNodes.add(n.id);
+    nodeStatus.set(n.id, idsB.has(n.id) ? 'inBoth' : 'onlyInA');
+    unionNodes.push(n);
+  }
+  // B pass: only add nodes not seen in A.
+  for (const n of graphB.nodes) {
+    if (seenNodes.has(n.id)) continue;
+    nodeStatus.set(n.id, 'onlyInB');
+    unionNodes.push(n);
+  }
+
+  // Edges follow the same pattern but keyed by the (source, type, target)
+  // triple. Edges incident to nodes that exist in both graphs are still
+  // legitimately onlyInA/onlyInB if the edge itself differs (e.g. a new call
+  // relationship was added on the sender's side).
+  const keysA = new Set(graphA.relationships.map(edgeKey));
+  const keysB = new Set(graphB.relationships.map(edgeKey));
+
+  const edgeStatus = new Map<string, DiffStatus>();
+  const unionEdges: GraphRelationship[] = [];
+  const seenEdges = new Set<string>();
+
+  for (const e of graphA.relationships) {
+    const k = edgeKey(e);
+    seenEdges.add(k);
+    edgeStatus.set(k, keysB.has(k) ? 'inBoth' : 'onlyInA');
+    unionEdges.push(e);
+  }
+  for (const e of graphB.relationships) {
+    const k = edgeKey(e);
+    if (seenEdges.has(k)) continue;
+    edgeStatus.set(k, 'onlyInB');
+    unionEdges.push(e);
+  }
+
+  let nA = 0;
+  let nB = 0;
+  let nBoth = 0;
+  for (const s of nodeStatus.values()) {
+    if (s === 'onlyInA') nA++;
+    else if (s === 'onlyInB') nB++;
+    else nBoth++;
+  }
+  let eA = 0;
+  let eB = 0;
+  let eBoth = 0;
+  for (const s of edgeStatus.values()) {
+    if (s === 'onlyInA') eA++;
+    else if (s === 'onlyInB') eB++;
+    else eBoth++;
+  }
+
+  return {
+    nodeStatus,
+    edgeStatus,
+    unionNodes,
+    unionEdges,
+    counts: {
+      nodes: { onlyInA: nA, onlyInB: nB, inBoth: nBoth },
+      edges: { onlyInA: eA, onlyInB: eB, inBoth: eBoth },
+    },
+  };
+}
+
+/**
+ * Diff between two snapshots of the same repo. Algorithm is identical to
+ * cross-repo diff (set membership on node id + edge triple) — only the
+ * naming differs. Used by Timeline.tsx in graphMode='diff' (Phase 1 of
+ * timeline-zoom-cursors design, Task 9) to compare snapshots at cursorA
+ * and cursorB.
+ *
+ * See docs/superpowers/specs/2026-05-27-timeline-zoom-cursors-design.md
+ */
+export const diffBetweenSnapshots = computeGraphDiff;
diff --git a/gitnexus-web/src/lib/group-graph-adapter.ts b/gitnexus-web/src/lib/group-graph-adapter.ts
new file mode 100644
index 00000000..4100064e
--- /dev/null
+++ b/gitnexus-web/src/lib/group-graph-adapter.ts
@@ -0,0 +1,58 @@
+import Graph from 'graphology';
+import type { SigmaNodeAttributes, SigmaEdgeAttributes } from './graph-adapter';
+import type { GroupGraphData } from '../hooks/useAppState';
+
+const CROSS_EDGE_COLOR = '#fbbf24';
+const INTRA_EDGE_COLOR = '#2a2a3a';
+
+/**
+ * Build a graphology graph for the merged multi-repo view. Nodes are file-level
+ * and pre-colored per repo by the backend; cross-repo edges are styled distinctly.
+ * Initial positions are seeded by repo sector; useSigma's setGraph runs ForceAtlas2
+ * which converges them into connectivity-based clusters (repos cluster, cross-repo
+ * edges bridge them).
+ */
+export function groupGraphToGraphology(
+  data: GroupGraphData,
+): Graph<SigmaNodeAttributes, SigmaEdgeAttributes> {
+  const graph = new Graph<SigmaNodeAttributes, SigmaEdgeAttributes>();
+  const nodes = data.nodes || [];
+  const total = Math.max(1, nodes.length);
+  const repoOrder = new Map<string, number>();
+  (data.repos || []).forEach((r, i) => repoOrder.set(r.name, i));
+  const repoCount = Math.max(1, (data.repos || []).length);
+  const radius = Math.sqrt(total) * 30;
+
+  let i = 0;
+  for (const node of nodes) {
+    if (graph.hasNode(node.id)) continue;
+    const sector = (repoOrder.get(node.repo) ?? 0) / repoCount;
+    const angle = sector * 2 * Math.PI + (i % 50) * 0.05;
+    const r = radius * (0.5 + ((i % 50) / 50) * 0.5);
+    graph.addNode(node.id, {
+      x: Math.cos(angle) * r,
+      y: Math.sin(angle) * r,
+      size: 4,
+      color: node.color || '#94a3b8',
+      label: node.label,
+      nodeType: 'File',
+      filePath: node.filePath,
+      mass: 3,
+    });
+    i++;
+  }
+
+  for (const e of data.edges || []) {
+    if (!graph.hasNode(e.source) || !graph.hasNode(e.target)) continue;
+    if (e.source === e.target) continue;
+    if (graph.hasEdge(e.source, e.target)) continue;
+    graph.addEdge(e.source, e.target, {
+      size: e.crossRepo ? 3 : 1,
+      color: e.crossRepo ? CROSS_EDGE_COLOR : INTRA_EDGE_COLOR,
+      relationType: e.crossRepo ? 'CROSS_REPO' : 'INTRA_REPO',
+      type: 'curved',
+      zIndex: e.crossRepo ? 2 : 1,
+    });
+  }
+  return graph;
+}
diff --git a/gitnexus-web/src/lib/layered-layout.ts b/gitnexus-web/src/lib/layered-layout.ts
new file mode 100644
index 00000000..ac0d50ef
--- /dev/null
+++ b/gitnexus-web/src/lib/layered-layout.ts
@@ -0,0 +1,51 @@
+export interface LayoutGraph {
+  nodes: { id: string }[];
+  edges: { source: string; target: string }[];
+}
+
+/**
+ * Hand-rolled BFS-rank layered layout (dep-free). rank = shortest hops from a source
+ * (in-degree-0 node, or each unranked node as a fresh root for cycles / unreachable);
+ * x = rank·DX, y = spread within the rank centered on 0. O(V+E), deterministic. No DOM.
+ */
+export function layeredLayout(graph: LayoutGraph, opts: { dx?: number; dy?: number } = {}): Map<string, { x: number; y: number }> {
+  const DX = opts.dx ?? 160;
+  const DY = opts.dy ?? 80;
+  const ids: string[] = [];
+  const seen = new Set<string>();
+  for (const n of graph.nodes || []) { if (n && n.id != null && !seen.has(n.id)) { seen.add(n.id); ids.push(n.id); } }
+  const idSet = new Set(ids);
+  const adj = new Map<string, string[]>(ids.map((id) => [id, []]));
+  const indeg = new Map<string, number>(ids.map((id) => [id, 0]));
+  for (const e of graph.edges || []) {
+    if (!e || !idSet.has(e.source) || !idSet.has(e.target) || e.source === e.target) continue;
+    adj.get(e.source)!.push(e.target);
+    indeg.set(e.target, (indeg.get(e.target) ?? 0) + 1);
+  }
+  const rank = new Map<string, number>();
+  const bfs = (starts: string[]) => {
+    let layer = starts.filter((s) => !rank.has(s));
+    for (const s of layer) rank.set(s, 0);
+    while (layer.length) {
+      const next: string[] = [];
+      for (const u of layer) {
+        for (const v of adj.get(u)!) {
+          if (!rank.has(v)) { rank.set(v, (rank.get(u) ?? 0) + 1); next.push(v); }
+        }
+      }
+      layer = next;
+    }
+  };
+  const roots = ids.filter((id) => (indeg.get(id) ?? 0) === 0);
+  if (roots.length) bfs(roots);
+  for (const id of ids) { if (!rank.has(id)) bfs([id]); }   // cycles / unreachable → fresh root
+
+  const byRank = new Map<number, string[]>();
+  for (const id of ids) { const r = rank.get(id)!; if (!byRank.has(r)) byRank.set(r, []); byRank.get(r)!.push(id); }
+  const pos = new Map<string, { x: number; y: number }>();
+  for (const [r, members] of byRank) {
+    const k = members.length;
+    members.forEach((id, i) => pos.set(id, { x: r * DX, y: (i - (k - 1) / 2) * DY }));
+  }
+  return pos;
+}
diff --git a/gitnexus-web/src/lib/layout-cache.ts b/gitnexus-web/src/lib/layout-cache.ts
new file mode 100644
index 00000000..978f853e
--- /dev/null
+++ b/gitnexus-web/src/lib/layout-cache.ts
@@ -0,0 +1,108 @@
+/**
+ * Layout persistence cache (FA2 positions per snapshot).
+ *
+ * Stores `graphology` node positions in `localStorage` keyed by a stable
+ * `cacheKey` (typically `<repoName>` or `<repoName>@<sha>` for snapshots).
+ *
+ * Used by `useSigma.setGraph` to skip the expensive FA2 + noverlap pass on
+ * revisited snapshots, and by `lib/layout-worker.ts` to pre-compute layouts
+ * in the background during `preloadAllSnapshots`.
+ *
+ * Schema versioned (`gitnexus:layout:v1:<cacheKey>`) so an entry written by
+ * a previous version is silently ignored, not crash-loaded.
+ */
+
+const STORAGE_PREFIX = 'gitnexus:layout:v1:';
+const SCHEMA_VERSION = 1 as const;
+
+export type CachedLayout = {
+  version: typeof SCHEMA_VERSION;
+  cacheKey: string;
+  computedAt: string;
+  nodeCount: number;
+  positions: Record<string, { x: number; y: number }>;
+};
+
+export function saveLayoutPositions(
+  cacheKey: string,
+  positions: Record<string, { x: number; y: number }>,
+): void {
+  if (!cacheKey || typeof window === 'undefined' || !window.localStorage) return;
+  const payload: CachedLayout = {
+    version: SCHEMA_VERSION,
+    cacheKey,
+    computedAt: new Date().toISOString(),
+    nodeCount: Object.keys(positions).length,
+    positions,
+  };
+  try {
+    window.localStorage.setItem(STORAGE_PREFIX + cacheKey, JSON.stringify(payload));
+  } catch (e) {
+    // QuotaExceededError or similar — best-effort, don't crash UI.
+    console.warn('[layout-cache] save failed for', cacheKey, e);
+  }
+}
+
+export function saveLayoutFromGraph(
+  cacheKey: string,
+  // See applyLayoutToGraph — same reason for `any`.
+  graph: any,
+): void {
+  const positions: Record<string, { x: number; y: number }> = {};
+  graph.forEachNode((id: string, attrs: { x?: number; y?: number }) => {
+    if (typeof attrs.x === 'number' && typeof attrs.y === 'number') {
+      positions[id] = { x: attrs.x, y: attrs.y };
+    }
+  });
+  saveLayoutPositions(cacheKey, positions);
+}
+
+export function loadLayout(cacheKey: string): CachedLayout | null {
+  if (!cacheKey || typeof window === 'undefined' || !window.localStorage) return null;
+  const raw = window.localStorage.getItem(STORAGE_PREFIX + cacheKey);
+  if (!raw) return null;
+  try {
+    const parsed = JSON.parse(raw);
+    if (parsed?.version !== SCHEMA_VERSION) return null;
+    if (typeof parsed.cacheKey !== 'string' || !parsed.positions) return null;
+    return parsed as CachedLayout;
+  } catch {
+    return null;
+  }
+}
+
+export function applyLayoutToGraph(
+  cached: CachedLayout,
+  // Structural typing kept loose so a typed Graphology `Graph<X, Y, Z>` passes
+  // without coercion. TS would reject narrower callback signatures otherwise.
+  graph: any,
+): { applied: number; missing: number } {
+  let applied = 0;
+  let missing = 0;
+  graph.forEachNode((id: string) => {
+    const p = cached.positions[id];
+    if (p) {
+      graph.setNodeAttribute(id, 'x', p.x);
+      graph.setNodeAttribute(id, 'y', p.y);
+      applied++;
+    } else {
+      missing++;
+    }
+  });
+  return { applied, missing };
+}
+
+export function clearLayout(cacheKey: string): void {
+  if (typeof window === 'undefined' || !window.localStorage) return;
+  window.localStorage.removeItem(STORAGE_PREFIX + cacheKey);
+}
+
+export function clearAllLayouts(): void {
+  if (typeof window === 'undefined' || !window.localStorage) return;
+  const keys: string[] = [];
+  for (let i = 0; i < window.localStorage.length; i++) {
+    const k = window.localStorage.key(i);
+    if (k?.startsWith(STORAGE_PREFIX)) keys.push(k);
+  }
+  for (const k of keys) window.localStorage.removeItem(k);
+}
diff --git a/gitnexus-web/src/lib/layout-worker-pool.ts b/gitnexus-web/src/lib/layout-worker-pool.ts
new file mode 100644
index 00000000..ceaccda9
--- /dev/null
+++ b/gitnexus-web/src/lib/layout-worker-pool.ts
@@ -0,0 +1,114 @@
+/**
+ * Small fixed-size worker pool driving `layout-worker.ts` to pre-compute
+ * FA2 positions for every snapshot during `preloadAllSnapshots`. Results
+ * are persisted to localStorage via `saveLayoutPositions` so subsequent
+ * `useSigma.setGraph(g, { cacheKey })` calls hit the fast path.
+ *
+ * Pool size 2 (CPU-bound, leaves a core for the main thread + the
+ * preload network pool).
+ */
+import Graph from 'graphology';
+import { saveLayoutPositions, loadLayout } from './layout-cache';
+import type { WorkerOutput } from './layout-worker';
+
+export type LayoutPoolJob = {
+  cacheKey: string;
+  graphData: any; // graph.export()
+  iterations?: number;
+};
+
+/**
+ * Build a minimal serialized graph (nodes + edges) suitable for the
+ * worker. FA2 only needs the topology — we strip styling to keep the
+ * postMessage clone small.
+ */
+export function buildWorkerInputFromNodesEdges(
+  nodes: Array<{ id: string }>,
+  edges: Array<{ sourceId: string; targetId: string }>,
+): any {
+  const g = new Graph({ multi: true, allowSelfLoops: true });
+  for (const n of nodes) {
+    if (!g.hasNode(n.id)) g.addNode(n.id);
+  }
+  for (const e of edges) {
+    if (!g.hasNode(e.sourceId) || !g.hasNode(e.targetId)) continue;
+    try {
+      g.addEdge(e.sourceId, e.targetId);
+    } catch {
+      // duplicate / forbidden — skip
+    }
+  }
+  return g.export();
+}
+
+export type LayoutPool = {
+  enqueue: (job: LayoutPoolJob) => void;
+  terminate: () => void;
+};
+
+export function createLayoutWorkerPool(size = 2): LayoutPool {
+  const queue: LayoutPoolJob[] = [];
+  const workers: Worker[] = [];
+  const busy: boolean[] = [];
+  let terminated = false;
+
+  function spawnWorker(idx: number) {
+    const w = new Worker(new URL('./layout-worker.ts', import.meta.url), {
+      type: 'module',
+    });
+    w.onmessage = (e: MessageEvent<WorkerOutput>) => {
+      const { cacheKey, positions, nodeCount } = e.data;
+      if (cacheKey && nodeCount > 0) {
+        saveLayoutPositions(cacheKey, positions);
+      }
+      busy[idx] = false;
+      pump();
+    };
+    w.onerror = (err) => {
+      // eslint-disable-next-line no-console
+      console.warn('[layout-worker-pool] worker error', err);
+      busy[idx] = false;
+      pump();
+    };
+    workers[idx] = w;
+    busy[idx] = false;
+  }
+
+  function pump() {
+    if (terminated) return;
+    for (let i = 0; i < size; i++) {
+      if (!busy[i] && queue.length > 0) {
+        const job = queue.shift();
+        if (!job) break;
+        // Skip if already cached — saves a worker round-trip when the
+        // user re-runs Preload after a partial cancel.
+        if (loadLayout(job.cacheKey)) continue;
+        if (!workers[i]) spawnWorker(i);
+        busy[i] = true;
+        workers[i].postMessage(job);
+      }
+    }
+  }
+
+  function enqueue(job: LayoutPoolJob) {
+    if (terminated) return;
+    queue.push(job);
+    pump();
+  }
+
+  function terminate() {
+    terminated = true;
+    queue.length = 0;
+    for (const w of workers) {
+      try {
+        w?.terminate();
+      } catch {
+        // ignore
+      }
+    }
+    workers.length = 0;
+    busy.length = 0;
+  }
+
+  return { enqueue, terminate };
+}
diff --git a/gitnexus-web/src/lib/layout-worker.ts b/gitnexus-web/src/lib/layout-worker.ts
new file mode 100644
index 00000000..9fb3e02b
--- /dev/null
+++ b/gitnexus-web/src/lib/layout-worker.ts
@@ -0,0 +1,65 @@
+/**
+ * Web Worker that runs ForceAtlas2 + light noverlap on a serialized
+ * graphology graph and posts back the converged positions. Driven by
+ * `useAppState.preloadAllSnapshots` so the first Play roadmap after a
+ * preload is near-instant (positions are already in localStorage).
+ *
+ * Imported via Vite as a module Worker:
+ *   new Worker(new URL('../lib/layout-worker.ts', import.meta.url),
+ *     { type: 'module' })
+ */
+import Graph from 'graphology';
+import forceAtlas2 from 'graphology-layout-forceatlas2';
+
+export type WorkerInput = {
+  cacheKey: string;
+  graphData: any; // result of graph.export() — JSON-clonable
+  iterations?: number; // default 200
+};
+
+export type WorkerOutput = {
+  cacheKey: string;
+  positions: Record<string, { x: number; y: number }>;
+  nodeCount: number;
+  durationMs: number;
+};
+
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+(self as any).onmessage = (e: MessageEvent<WorkerInput>) => {
+  const { cacheKey, graphData, iterations = 200 } = e.data;
+  const start =
+    typeof performance !== 'undefined' && typeof performance.now === 'function'
+      ? performance.now()
+      : Date.now();
+  const graph = Graph.from(graphData);
+  if (graph.order === 0) {
+    (self as any).postMessage({
+      cacheKey,
+      positions: {},
+      nodeCount: 0,
+      durationMs: 0,
+    } satisfies WorkerOutput);
+    return;
+  }
+  const settings = forceAtlas2.inferSettings(graph);
+  forceAtlas2.assign(graph, { iterations, settings });
+  // Note: noverlap.assign skipped here (TS overload friction with the generic
+  // Graph.from result). FA2 alone is sufficient for the pre-compute path;
+  // useSigma's runLayout applies noverlap when running in the foreground.
+  const positions: Record<string, { x: number; y: number }> = {};
+  graph.forEachNode((id, attrs) => {
+    if (typeof attrs.x === 'number' && typeof attrs.y === 'number') {
+      positions[id] = { x: attrs.x, y: attrs.y };
+    }
+  });
+  const end =
+    typeof performance !== 'undefined' && typeof performance.now === 'function'
+      ? performance.now()
+      : Date.now();
+  (self as any).postMessage({
+    cacheKey,
+    positions,
+    nodeCount: graph.order,
+    durationMs: end - start,
+  } satisfies WorkerOutput);
+};
diff --git a/gitnexus-web/src/lib/metrics-view.ts b/gitnexus-web/src/lib/metrics-view.ts
