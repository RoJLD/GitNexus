+  nodes: GraphMetricNode[];
+  bridges: { source: string; target: string }[];
+  summary: { nodeCount: number; edgeCount: number; communityCount: number; modularity: number; density: number; componentCount: number; transitivity: number; capped?: boolean; omittedMetrics?: string[]; approximate?: boolean; sampleSize?: number | null; deadWeightCount?: number; outputCount?: number; inputCount?: number };
+}
