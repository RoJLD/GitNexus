+function bowVectorFromLabels(labels) {
+  // Unit weight per label — labeled communities are roughly comparable
+  // in scope (community detection produces communities of broadly
+  // similar size). Weighting by community member count would skew
+  // toward huge communities and overpower the long tail. Keep it flat.
+  const v = new Map();
+  for (const label of labels) {
+    const tokens = tokenizeLabel(label);
+    const seen = new Set();
+    for (const t of tokens) {
+      // Count each token once per label (not once per occurrence inside
+      // a single label) — "API API gateway" shouldn't double-count.
+      if (seen.has(t)) continue;
+      seen.add(t);
+      v.set(t, (v.get(t) || 0) + 1);
+    }
+  }
+  return v;
