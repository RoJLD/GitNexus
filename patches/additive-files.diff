diff --git a/docker-server-semantic-labels.mjs b/docker-server-semantic-labels.mjs
new file mode 100644
index 00000000..254682a4
--- /dev/null
+++ b/docker-server-semantic-labels.mjs
@@ -0,0 +1,191 @@
+/**
+ * Semantic-labels cache — ROADMAP Tier 2.1, server side.
+ *
+ * Endpoints:
+ *   GET  /semantic-labels?repo=<base>
+ *        Reads the on-disk cache and returns it, or an empty payload
+ *        if no labels have been generated yet. Cheap and idempotent.
+ *
+ *   POST /semantic-labels?repo=<base>   body: { labels: {…}, provider?, model? }
+ *        Merges the incoming labels into the cache, last-write-wins
+ *        per communityId. We persist a tiny audit trail (when, with
+ *        which provider/model) so a future "regenerate stale labels"
+ *        feature can decide what's old.
+ *
+ * The LLM call itself is done by the *frontend* (`semantic-labeler.ts`),
+ * because the user already has provider credentials configured for the
+ * chat panel — no point asking them to re-enter API keys server-side
+ * or wiring per-provider clients here. This module just owns the cache.
+ *
+ * Cache file: <repoPath>/.gitnexus/semantic-labels.json
+ *
+ *   {
+ *     "schemaVersion": 1,
+ *     "labels": {
+ *       "community-id-1": {
+ *         "label": "Authentication",
+ *         "confidence": 0.85,
+ *         "evidenceNodes": ["src/auth/login.py:login", ...],
+ *         "labeledAt": "2026-05-22T10:00:00.000Z",
+ *         "provider": "anthropic",
+ *         "model": "claude-sonnet-4-20250514"
+ *       },
+ *       ...
+ *     }
+ *   }
+ */
+
+import { readFile, writeFile, mkdir } from 'node:fs/promises';
+import { join, dirname } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+const CACHE_FILENAME = 'semantic-labels.json';
+const SCHEMA_VERSION = 1;
+
+async function loadCache(cachePath) {
+  try {
+    const raw = await readFile(cachePath, 'utf8');
+    const parsed = JSON.parse(raw);
+    if (parsed?.schemaVersion === SCHEMA_VERSION && parsed?.labels && typeof parsed.labels === 'object') {
+      return parsed;
+    }
+    // Future-proofing: if the schema bumps, we won't error — we'll just
+    // start fresh rather than serve incompatible data.
+    return { schemaVersion: SCHEMA_VERSION, labels: {} };
+  } catch (err) {
+    if (err && err.code === 'ENOENT') {
+      return { schemaVersion: SCHEMA_VERSION, labels: {} };
+    }
+    throw err;
+  }
+}
+
+async function saveCache(cachePath, cache) {
+  await mkdir(dirname(cachePath), { recursive: true });
+  await writeFile(cachePath, JSON.stringify(cache, null, 2), 'utf8');
+}
+
+async function handleGet(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+  const cachePath = join(repoPath, '.gitnexus', CACHE_FILENAME);
+  const cache = await loadCache(cachePath);
+  res.writeHead(200, { 'Content-Type': 'application/json', 'Cache-Control': 'no-store' });
+  res.end(JSON.stringify({ repo: baseRepo, ...cache }));
+}
+
+async function handlePost(url, req, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  // Read JSON body (small — at most a few KB per repo's worth of labels).
+  let body = '';
+  for await (const chunk of req) body += chunk;
+  let payload;
+  try {
+    payload = body ? JSON.parse(body) : {};
+  } catch (err) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `invalid JSON: ${err.message}` }));
+    return;
+  }
+  const incoming = payload?.labels;
+  if (!incoming || typeof incoming !== 'object' || Array.isArray(incoming)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'body.labels must be an object {communityId: {...}}' }));
+    return;
+  }
+  const provider = typeof payload.provider === 'string' ? payload.provider : 'unknown';
+  const model = typeof payload.model === 'string' ? payload.model : 'unknown';
+  const now = new Date().toISOString();
+
+  const repoPath = repo.repoPath || repo.path;
+  const cachePath = join(repoPath, '.gitnexus', CACHE_FILENAME);
+  const cache = await loadCache(cachePath);
+
+  // Validate each entry, drop garbage rather than corrupting the cache.
+  let merged = 0;
+  for (const [communityId, entry] of Object.entries(incoming)) {
+    if (typeof communityId !== 'string' || communityId.length > 200) continue;
+    if (!entry || typeof entry !== 'object') continue;
+    const label = typeof entry.label === 'string' && entry.label.trim().length > 0
+      ? entry.label.trim().slice(0, 80)
+      : null;
+    if (!label) continue;
+    const confidence = typeof entry.confidence === 'number' && entry.confidence >= 0 && entry.confidence <= 1
+      ? entry.confidence
+      : 0.5;
+    const evidenceNodes = Array.isArray(entry.evidenceNodes)
+      ? entry.evidenceNodes.filter((s) => typeof s === 'string').slice(0, 20)
+      : [];
+    // Tier 2.5b.bis: accept optional embedding vector + provenance.
+    // We tolerate the absence of these (cache entries without embeddings
+    // are still valid — they just won't contribute to centroid cosine
+    // in /similarity). When present we sanity-check it's a numeric array
+    // of reasonable length (truncate at 4096 dims — current largest
+    // commodity model is 3072).
+    let embedding;
+    let embeddingProvider;
+    let embeddingModel;
+    if (Array.isArray(entry.embedding)) {
+      const cleaned = entry.embedding
+        .filter((n) => typeof n === 'number' && Number.isFinite(n))
+        .slice(0, 4096);
+      if (cleaned.length > 0) {
+        embedding = cleaned;
+        embeddingProvider = typeof entry.embeddingProvider === 'string' ? entry.embeddingProvider : provider;
+        embeddingModel = typeof entry.embeddingModel === 'string' ? entry.embeddingModel : model;
+      }
+    }
+    cache.labels[communityId] = {
+      label,
+      confidence,
+      evidenceNodes,
+      labeledAt: now,
+      provider,
+      model,
+      ...(embedding ? { embedding, embeddingProvider, embeddingModel } : {}),
+    };
+    merged++;
+  }
+
+  await saveCache(cachePath, cache);
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ok: true, merged, total: Object.keys(cache.labels).length }));
+}
+
+export async function handleSemanticLabelsRoute(req, url, res, opts) {
+  if (url.pathname !== '/semantic-labels') return false;
+  if (req.method === 'GET') {
+    await handleGet(url, res, opts);
+    return true;
+  }
+  if (req.method === 'POST') {
+    await handlePost(url, req, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-similarity.mjs b/docker-server-similarity.mjs
new file mode 100644
index 00000000..14bf10f1
--- /dev/null
+++ b/docker-server-similarity.mjs
@@ -0,0 +1,1074 @@
+/**
+ * Cross-repo similarity — ROADMAP Tier 2.5 (a + b).
+ *
+ * Endpoint:
+ *   GET /similarity?repos=A,B[,C,...][&windowDays=90]
+ *                  [&structuralThreshold=0.7][&semanticThreshold=0.7]
+ *                  [&temporalThreshold=0.5][&lexicalSemantic=true]
+ *
+ * Aggregates the per-repo analytics we already serve elsewhere (entropy,
+ * ownership, lifespan) into a single 5-dim "identity vector" per repo,
+ * then for every pair computes:
+ *
+ *   - structuralScore   cosine similarity on the identity vector
+ *   - temporalCoupling  Jaccard of windowed co-activity from git logs
+ *                       over the last `windowDays` days
+ *   - semanticScore     (Tier 2.5b) lexical similarity on the cached
+ *                       LLM labels from /semantic-labels — cosine on
+ *                       token-frequency vectors after lowercase +
+ *                       stopword filter. Returns null when neither repo
+ *                       has cached labels yet (run "Generate semantic
+ *                       labels" in DissonancePanel first).
+ *
+ *                       Why lexical and not true embeddings: half the
+ *                       chat providers (Anthropic, OpenRouter, MiniMax,
+ *                       GLM, …) don't expose embeddings APIs, and
+ *                       adding a separate "embeddings provider" config
+ *                       slot to support them all is its own 1-week
+ *                       design exercise. Lexical similarity ships
+ *                       today, works for 100% of provider setups, and
+ *                       gives a real signal (two repos with labels
+ *                       like {auth, login, password} vs {auth, sessions,
+ *                       jwt} will score high). True embeddings remain a
+ *                       documented upgrade path (2.5b.bis) — the
+ *                       endpoint shape stays the same when we swap.
+ *
+ * The position of each pair in the 2×2×2 cube is determined by the
+ * three thresholds. When semanticScore is null for a pair we collapse
+ * to the 4 cells of the structural × temporal plane for that pair only.
+ *
+ * --- Policy escape hatch ---
+ *
+ * `.gitnexus-policy.json` at the repo root (NOT yaml — same rationale
+ * as .gitnexus-domains.json: Node has no YAML in stdlib and pulling
+ * a parser for one config file isn't worth it):
+ *
+ *   {
+ *     "isolation_required": true,
+ *     "reason": "PCI compliance — code identique mais doit rester séparé",
+ *     "allow_merge_with": []
+ *   }
+ *
+ * When either side of a pair has `isolation_required: true` (and the
+ * other isn't on its `allow_merge_with` whitelist), the "Jumeaux actifs"
+ * / "Jumeaux isolés" quadrants are rewritten to
+ * "Jumeaux (isolation intentionnelle)" and the merge recommendation is
+ * stripped. The full policy object travels back in `pair.policyApplied`
+ * so the UI can show the reason.
+ *
+ * --- Warnings (auto-generated heuristics) ---
+ *
+ *   - LICENSE files diverge  (compares LICENSE / LICENSE.md / LICENSE.txt)
+ *   - Last commit > 6mo      (per repo, individual not pair)
+ *   - Distinct author sets   (no committer in common)
+ *
+ * Warnings are diagnostic only — they don't change the quadrant. The
+ * UI surfaces them as a "be careful, your data says…" banner.
+ */
+
+import { spawn } from 'node:child_process';
+import { readFile, stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { findRepoByName, SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+import { readdir } from 'node:fs/promises';
+import { getConfig } from './docker-server-config.mjs';
+import { getOrComputeRepoId } from './docker-server-repo-id.mjs';
+
+const MAX_REPOS = 8;
+const DEFAULT_WINDOW_DAYS = 90;
+const DEFAULT_STRUCTURAL = 0.7;
+const DEFAULT_SEMANTIC = 0.7;
+const DEFAULT_TEMPORAL = 0.5;
+const COUPLING_BUCKET_HOURS = 24;
+const STALE_REPO_DAYS = 180;
+const LICENSE_FILENAMES = ['LICENSE', 'LICENSE.md', 'LICENSE.txt', 'LICENCE', 'COPYING'];
+// Policy file name now lives in docker-server-config.mjs (Tier 2bis.4
+// unified config). The legacy filename is still supported via
+// getConfig() fallback.
+const SEMANTIC_LABELS_PATH = ['.gitnexus', 'semantic-labels.json'];
+
+// Identity Vector versions:
+//   v1 = 5 dims, ship-1 (Tier 2.5a). Frozen for backward compat.
+//   v2 = 10 dims (Tier 2.5c). Adds growthRate, churnConcentration,
+//        fileSizePareto, languageDiversity, treeDepth.
+const IDENTITY_DIMS_V1 = ['density', 'modularity', 'busFactorNorm', 'topAuthorShare', 'foundationalRatio'];
+const IDENTITY_DIMS_V2 = [
+  ...IDENTITY_DIMS_V1,
+  'growthRate',
+  'churnConcentration',
+  'fileSizePareto',
+  'languageDiversity',
+  'treeDepth',
+];
+const DEFAULT_IDENTITY_VERSION = 2;
+
+// File walk cap — we want stable signal, not exhaustive scan. Most
+// signals saturate well before 5000 files; bigger repos are usually
+// monorepos where the long tail is generated/vendored code that
+// pollutes more than it helps.
+const MAX_FILES_WALK = 5000;
+const IGNORED_DIRS = new Set([
+  'node_modules', '.git', '.venv', 'venv', '__pycache__', 'dist',
+  'build', 'target', '.next', '.nuxt', '.cache', '.gitnexus',
+  'coverage', '.pytest_cache', '.mypy_cache', '.tox',
+]);
+
+// Minimal bilingual stopword list — English + French, the two languages
+// labels actually appear in. Kept short on purpose: we want to filter
+// the obvious noise ("the", "of", "et", "la") without accidentally
+// dropping content words. Token frequency does most of the work; the
+// stopword list is just a polish step.
+const STOPWORDS = new Set([
+  // English
+  'the', 'and', 'or', 'a', 'an', 'of', 'to', 'in', 'on', 'for', 'with',
+  'by', 'from', 'at', 'as', 'is', 'are', 'be', 'was', 'were', 'this',
+  'that', 'these', 'those', 'it', 'its', 'into', 'over', 'between',
+  // French
+  'le', 'la', 'les', 'un', 'une', 'des', 'de', 'du', 'et', 'ou', 'à',
+  'au', 'aux', 'dans', 'pour', 'avec', 'par', 'sur', 'sous', 'sans',
+  'son', 'sa', 'ses', 'ce', 'cette', 'ces', 'qui', 'que', 'quoi', 'dont',
+]);
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+async function readMeta(repoPath) {
+  try {
+    return JSON.parse(await readFile(join(repoPath, '.gitnexus', 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+// Tier 2bis.4: policy read via the unified config parser. Falls back
+// to .gitnexus-policy.json with deprecation warning. Returns null when
+// no policy is declared (most common case). Returns { _error } on
+// malformed JSON so the caller can surface it without aborting the
+// pair scan.
+async function readPolicy(repoPath) {
+  try {
+    const cfg = await getConfig(repoPath);
+    return cfg.policy;
+  } catch (err) {
+    return { _error: err.message };
+  }
+}
+
+async function readSemanticLabels(repoPath) {
