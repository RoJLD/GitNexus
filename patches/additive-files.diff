index 00000000..3842afce
--- /dev/null
+++ b/gitnexus-web/src/components/SnapshotsPanel.tsx
@@ -0,0 +1,253 @@
+import { useEffect, useState } from 'react';
+import {
+  Camera,
+  Clock,
+  Layers,
+  Loader2,
+  Trash2,
+  ChevronRight,
+  AlertCircle,
+} from '@/lib/lucide-icons';
+import { BulkSnapshotModal } from './BulkSnapshotModal';
+
+/**
+ * Compact snapshots section shown inside the repo dropdown.
+ *
+ * Fetches /snapshots?repo=<active> on mount and on `refreshSignal` bumps,
+ * then renders a small list. Clicking a row switches to that snapshot via
+ * the host's onSwitchRepo (snapshots are real registered repos named
+ * `<repoName>@<shortHash>`). The trash icon deletes the snapshot.
+ *
+ * We intentionally don't show a loading skeleton — the request is local
+ * and fast, and a brief flash of "no snapshots" is less jarring than a
+ * spinner that flickers on every dropdown open.
+ */
+
+export interface SnapshotEntry {
+  key: string;
+  name: string;
+  path: string;
+  commit: {
+    hash: string;
+    shortHash: string;
+    message: string;
+    author: string;
+    email: string;
+    date: string;
+    parent: string | null;
+  };
+  // Baseline interne caché (commit-level time-travel §3.3) — exclu du listing
+  // par défaut côté serveur ; présent ici car on fetch avec ?includeHidden=true.
+  hidden?: boolean;
+}
+
+interface SnapshotsPanelProps {
+  repoName: string;
+  /** Bump to re-fetch (e.g. after a new snapshot is created). */
+  refreshSignal: number;
+  onSwitchRepo: (snapshotName: string) => void;
+  onChanged: () => void;
+}
+
+export const SnapshotsPanel = ({
+  repoName,
+  refreshSignal,
+  onSwitchRepo,
+  onChanged,
+}: SnapshotsPanelProps) => {
+  const [snapshots, setSnapshots] = useState<SnapshotEntry[]>([]);
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+  const [deleting, setDeleting] = useState<string | null>(null);
+  const [bulkOpen, setBulkOpen] = useState(false);
+  // Local refresh trigger so the panel re-fetches after a bulk run without
+  // depending on the parent's refreshSignal cadence.
+  const [localRefresh, setLocalRefresh] = useState(0);
+
+  useEffect(() => {
+    let cancelled = false;
+    setLoading(true);
+    setError(null);
+    fetch(`/snapshots?repo=${encodeURIComponent(repoName)}&includeHidden=true`, { cache: 'no-store' })
+      .then((r) => {
+        if (!r.ok) throw new Error(`HTTP ${r.status}`);
+        return r.json();
+      })
+      .then((data) => {
+        if (cancelled) return;
+        setSnapshots(Array.isArray(data.snapshots) ? data.snapshots : []);
+      })
+      .catch((err) => {
+        if (cancelled) return;
+        setError(err instanceof Error ? err.message : 'Failed to load snapshots');
+      })
+      .finally(() => {
+        if (!cancelled) setLoading(false);
+      });
+    return () => {
+      cancelled = true;
+    };
+  }, [repoName, refreshSignal, localRefresh]);
+
+  const handleDelete = async (snapshot: SnapshotEntry) => {
+    if (deleting) return;
+    setDeleting(snapshot.key);
+    try {
+      await fetch(
+        `/snapshot?repo=${encodeURIComponent(repoName)}&commit=${encodeURIComponent(snapshot.key)}`,
+        { method: 'DELETE' },
+      );
+      setSnapshots((prev) => prev.filter((s) => s.key !== snapshot.key));
+      onChanged();
+    } catch (err) {
+      setError(err instanceof Error ? err.message : 'Delete failed');
+    } finally {
+      setDeleting(null);
+    }
+  };
+
+  // Séparer les jalons visibles des baselines internes cachés (§3.3).
+  const visible = snapshots.filter((s) => !s.hidden);
+  const baselines = snapshots.filter((s) => s.hidden);
+
+  return (
+    <div>
+      {/* Header: title + bulk-capture entry point. Always visible so the
+          user has a discoverable way into the bulk flow even when zero
+          snapshots exist yet. */}
+      <div className="flex items-center gap-1.5 px-3 pt-2.5 pb-1.5">
+        <Clock className="h-3 w-3 text-text-muted" />
+        <span className="text-[10px] font-medium tracking-wider text-text-muted uppercase">
+          Snapshots of {repoName}
+        </span>
+        <button
+          type="button"
+          onClick={() => setBulkOpen(true)}
+          className="ml-auto flex items-center gap-1 rounded border border-border-subtle bg-elevated px-1.5 py-0.5 text-[10px] font-medium text-text-secondary transition-all hover:bg-hover hover:text-text-primary cursor-pointer"
+          title="Capture multiple snapshots over a time window (Phase 2)"
+        >
+          <Layers className="h-2.5 w-2.5" />
+          Capture history…
+        </button>
+      </div>
+
+      {/* Body: list / loading / error / empty */}
+      {loading && snapshots.length === 0 && (
+        <div className="px-4 py-2 text-[10px] text-text-muted">
+          <Loader2 className="inline h-3 w-3 animate-spin" /> Loading snapshots…
+        </div>
+      )}
+      {error && (
+        <div className="flex items-center gap-1.5 px-4 py-2 text-[10px] text-red-400">
+          <AlertCircle className="h-3 w-3" />
+          {error}
+        </div>
+      )}
+      {!loading && !error && visible.length === 0 && (
+        <div className="px-4 py-2 text-[10px] text-text-muted italic">
+          No snapshots yet. Click 📸 next to a repo for a single one, or "Capture history" above for many.
+        </div>
+      )}
+      {visible.map((s) => (
+        <div
+          key={s.key}
+          className="group flex items-center gap-2 px-4 py-1.5 transition-colors hover:bg-hover"
+        >
+          <button
+            type="button"
+            onClick={() => onSwitchRepo(s.name)}
+            className="flex min-w-0 flex-1 cursor-pointer items-center gap-2 text-left"
+            title={`${s.commit.message}\n\n${s.commit.author} <${s.commit.email}>\n${s.commit.date}\n${s.commit.hash}`}
+          >
+            <Camera className="h-3 w-3 shrink-0 text-text-muted" />
+            <span className="font-mono text-[11px] text-accent shrink-0">{s.commit.shortHash}</span>
+            <span className="flex-1 truncate text-[11px] text-text-secondary">
+              {s.commit.message || '(no message)'}
+            </span>
+            <span className="shrink-0 font-mono text-[10px] text-text-muted">
+              {formatRelative(s.commit.date)}
+            </span>
+            <ChevronRight className="h-3 w-3 shrink-0 text-text-muted/40 group-hover:text-accent" />
+          </button>
+          <button
+            type="button"
+            onClick={(e) => {
+              e.stopPropagation();
+              handleDelete(s);
+            }}
+            disabled={deleting === s.key}
+            className="cursor-pointer rounded p-1 text-text-muted/40 transition-all group-hover:text-text-muted hover:!text-red-400 disabled:opacity-50"
+            title={`Delete snapshot ${s.commit.shortHash}`}
+          >
+            {deleting === s.key ? (
+              <Loader2 className="h-3 w-3 animate-spin" />
+            ) : (
+              <Trash2 className="h-3 w-3" />
+            )}
+          </button>
+        </div>
+      ))}
+
+      {/* Baselines internes auto-seedés (commit-level time-travel §3.3) —
+          cachés du listing principal, promouvables en jalon. */}
+      {baselines.length > 0 && (
+        <div className="border-t border-border-subtle/50 pt-1">
+          <div className="px-3 py-1 text-[10px] font-medium tracking-wider text-text-muted uppercase">
+            Internal baselines (auto-seeded)
+          </div>
+          {baselines.map((s) => (
+            <div key={s.key} className="group flex items-center gap-2 px-4 py-1.5 hover:bg-hover">
+              <span className="shrink-0 font-mono text-[11px] text-violet-300">{s.commit.shortHash}</span>
+              <span className="flex-1 truncate text-[11px] text-text-muted">
+                {s.commit.message || '(no message)'}
+              </span>
+              <button
+                type="button"
+                onClick={async () => {
+                  await fetch(
+                    `/snapshot/promote?repo=${encodeURIComponent(repoName)}&commit=${encodeURIComponent(s.commit.hash)}`,
+                    { method: 'POST' },
+                  );
+                  setLocalRefresh((n) => n + 1);
+                  onChanged();
+                }}
+                className="shrink-0 rounded border border-violet-500/40 bg-violet-500/15 px-1.5 py-0.5 text-[10px] font-medium text-violet-200 transition-all hover:bg-violet-500/25"
+              >
+                Promouvoir en jalon
+              </button>
+            </div>
+          ))}
+        </div>
+      )}
+
+      <BulkSnapshotModal
+        repoName={repoName}
+        isOpen={bulkOpen}
+        onClose={() => setBulkOpen(false)}
+        onComplete={() => {
+          setLocalRefresh((n) => n + 1);
+          onChanged();
+        }}
+      />
+    </div>
+  );
+};
+
+// Compact "3d ago" / "5min ago" / "just now" formatter. The exact full
+// timestamp is in the tooltip; this is just for the row visual.
+function formatRelative(iso: string): string {
+  if (!iso) return '';
+  const then = new Date(iso).getTime();
+  if (!Number.isFinite(then)) return '';
+  const diffSec = Math.max(0, Math.floor((Date.now() - then) / 1000));
+  if (diffSec < 60) return 'just now';
+  const diffMin = Math.floor(diffSec / 60);
+  if (diffMin < 60) return `${diffMin}m ago`;
+  const diffHr = Math.floor(diffMin / 60);
+  if (diffHr < 24) return `${diffHr}h ago`;
+  const diffDay = Math.floor(diffHr / 24);
+  if (diffDay < 30) return `${diffDay}d ago`;
+  const diffMo = Math.floor(diffDay / 30);
+  if (diffMo < 12) return `${diffMo}mo ago`;
+  return `${Math.floor(diffMo / 12)}y ago`;
+}
