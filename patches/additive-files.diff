@@ -0,0 +1,44 @@
+import { useMemo } from 'react';
+import type { GraphConfigEntry } from '@/services/MultigraphLoader';
+
+interface GraphSidebarProps {
+  graphs: GraphConfigEntry[];
+  onSelect: (name: string) => void;
+  selected: string | null;
+}
+
+export function GraphSidebar({ graphs, onSelect, selected }: GraphSidebarProps) {
+  const grouped = useMemo(() => {
+    const m = new Map<string, GraphConfigEntry[]>();
+    for (const g of graphs) {
+      const k = g.schema_type;
+      if (!m.has(k)) m.set(k, []);
+      m.get(k)!.push(g);
+    }
+    return m;
+  }, [graphs]);
+
+  return (
+    <aside className="w-64 bg-slate-900 text-slate-100 p-4 overflow-y-auto" role="navigation">
+      <h2 className="text-lg font-semibold mb-3">Graphs</h2>
+      {[...grouped.entries()].map(([schemaType, list]) => (
+        <section key={schemaType} className="mb-4">
+          <h3 className="text-xs uppercase text-slate-400 mb-1">{schemaType}</h3>
+          <ul>
+            {list.map(g => (
+              <li
+                key={g.name}
+                className={`cursor-pointer py-1 px-2 rounded ${
+                  selected === g.name ? 'bg-violet-600' : 'hover:bg-slate-800'
+                }`}
+                onClick={() => onSelect(g.name)}
+              >
+                {g.name}
+              </li>
+            ))}
+          </ul>
+        </section>
+      ))}
+    </aside>
+  );
+}
