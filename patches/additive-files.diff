+import { useEffect, useRef } from 'react';
+import type { GraphConfigEntry } from '@/services/MultigraphLoader';
+
+export type ZoomLevel = 'meta' | 'graph' | 'node' | 'inspector';
+
+interface CanvasMultigraphProps {
+  selectedGraph: GraphConfigEntry | null;
+  zoomLevel: ZoomLevel;
+}
+
+export function CanvasMultigraph({ selectedGraph, zoomLevel }: CanvasMultigraphProps) {
+  const containerRef = useRef<HTMLDivElement>(null);
+
+  useEffect(() => {
+    if (!selectedGraph || !containerRef.current) return;
+    containerRef.current.dataset.graphName = selectedGraph.name;
+  }, [selectedGraph]);
+
+  if (!selectedGraph) {
+    return (
+      <main className="flex-1 flex items-center justify-center bg-slate-950 text-slate-400">
+        <div className="text-center">
+          <p>Select a graph from the sidebar to begin.</p>
+          <p className="text-xs mt-2" data-testid="canvas-mode">{zoomLevel}</p>
+        </div>
+      </main>
+    );
+  }
+
+  return (
+    <main className="flex-1 bg-slate-950 text-slate-100 p-4">
+      <header className="flex justify-between mb-2">
+        <h2 className="text-xl font-semibold">{selectedGraph.name}</h2>
+        <span className="text-xs" data-testid="canvas-mode">{zoomLevel}</span>
+      </header>
+      <div ref={containerRef} className="w-full h-[calc(100vh-8rem)] bg-slate-900 rounded" />
+    </main>
+  );
+}
