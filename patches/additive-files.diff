@@ -0,0 +1,51 @@
+/**
+ * TimelineReplay — Task 10.5.
+ *
+ * Fetches the snapshot timestamp list for a given graph name from the
+ * ELYSIUM analytics API (or an injected apiFetcher for tests) and
+ * exposes it for use by TimelineScrubber.
+ *
+ * API contract (default):
+ *   GET /api/timeline/:graph
+ *   → { graph: string; timestamps: string[] }
+ *
+ * Timestamps are ISO-like strings, e.g. "2026-05-29T00-00-00".
+ */
+
+export interface TimelineSnapshotList {
+  graph: string;
+  timestamps: string[];
+}
+
+interface TimelineReplayOpts {
+  /** Override the HTTP fetcher — primarily for unit tests. */
+  apiFetcher?: (graph: string) => Promise<TimelineSnapshotList>;
+}
+
+export class TimelineReplay {
+  private readonly fetcher: (graph: string) => Promise<TimelineSnapshotList>;
+
+  constructor(opts: TimelineReplayOpts = {}) {
+    this.fetcher =
+      opts.apiFetcher ??
+      (async (graph: string) => {
+        const res = await fetch(`/api/timeline/${encodeURIComponent(graph)}`);
+        if (!res.ok) throw new Error(`Timeline API HTTP ${res.status} for graph "${graph}"`);
+        return res.json() as Promise<TimelineSnapshotList>;
+      });
+  }
+
+  /**
+   * Returns the ordered list of snapshot timestamps for the given graph.
+   * Throws if the API response is missing the `timestamps` array.
+   */
+  async listSnapshots(graph: string): Promise<string[]> {
+    const data = await this.fetcher(graph);
+    if (!Array.isArray(data.timestamps)) {
+      throw new Error(
+        `Invalid timeline API response for graph "${graph}": timestamps[] missing`,
+      );
+    }
+    return data.timestamps;
+  }
+}
