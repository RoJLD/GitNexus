+/**
+ * Frontend client for the /clusters endpoint of the CORE.
+ * 30-second in-memory cache keyed by the cache identity
+ * `${repo}|${source ?? 'all'}` so a "filter by source" query doesn't
+ * stomp the unfiltered cache and vice-versa.
+ *
+ * See spec : docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ * (Section F — clusters-client service, Task 11).
+ */
+
+export type ClusterSource = 'declared' | 'auto';
+
+export type ClusterAggregate = {
+  total: number;
+  materialized: number;
+  planned: number;
+  expired: number;
+  cancelled: number;
+  completionPct: number;
+};
+
+export type ClusterRuntime = {
+  id: string;
+  source: ClusterSource;
+  title: string;
+  expectedBy?: string | null;
+  declaredStatus?: string | null;
+  memberIds: string[];
+  synthesizedStatus: 'planned' | 'shipped' | 'cancelled' | 'expired';
+  aggregate: ClusterAggregate;
+  plannedAt?: { commit: string; date: string } | null;
+  materializedAt?: { commit: string; date: string } | null;
+  cancelledAt?: { commit: string; date: string } | null;
+};
+
+export type ClustersResponse = {
+  syncedAt: string;
+  syncedCommit: string;
+  clusters: ClusterRuntime[];
+};
+
+const CACHE = new Map<string, { at: number; data: ClustersResponse }>();
+const TTL_MS = 30_000;
+
+function cacheKey(repo: string, source?: ClusterSource): string {
+  return `${repo}|${source ?? 'all'}`;
+}
+
+export async function fetchClusters(
+  repo: string,
+  opts: { source?: ClusterSource; refresh?: boolean } = {},
+): Promise<ClustersResponse | null> {
+  const now = Date.now();
+  const key = cacheKey(repo, opts.source);
+  const cached = CACHE.get(key);
+  if (!opts.refresh && cached && now - cached.at < TTL_MS) return cached.data;
+
+  const params = new URLSearchParams({ repo });
+  if (opts.source) params.set('source', opts.source);
+  const res = await fetch(`/clusters?${params.toString()}`);
+  if (res.status === 404) return null;
+  if (!res.ok) throw new Error(`Failed to fetch /clusters: ${res.status}`);
+  const data = (await res.json()) as ClustersResponse;
+  CACHE.set(key, { at: now, data });
+  return data;
+}
+
+export function invalidateClustersCache(repo?: string) {
+  if (!repo) {
+    CACHE.clear();
+    return;
+  }
+  for (const key of Array.from(CACHE.keys())) {
+    if (key.startsWith(`${repo}|`)) CACHE.delete(key);
+  }
+}
+
+/**
+ * Test seam — exported for unit tests only. Lets a test inject a
+ * synthetic cache entry without monkey-patching `fetch`.
+ */
+export function _seedCacheForTests(
+  repo: string,
+  data: ClustersResponse,
+  source?: ClusterSource,
+  atMs: number = Date.now(),
+) {
+  CACHE.set(cacheKey(repo, source), { at: atMs, data });
+}
