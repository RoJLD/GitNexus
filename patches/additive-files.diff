@@ -0,0 +1,43 @@
+import { describe, it, expect, vi } from 'vitest';
+import { MultigraphLoader, type MultigraphConfig } from '@/services/MultigraphLoader';
+
+describe('MultigraphLoader', () => {
+  it('loads config and returns graph entries', async () => {
+    const fakeConfig: MultigraphConfig = {
+      version: '1.0',
+      graphs: [
+        { name: 'ASTKG', path: '/data/projects/elysium/.agent/knowledge/brain/graph/elysium_graph',
+          schema_type: 'code-cognition', ttl_snapshot_hours: 1, privacy_class: 'SHARED' },
+        { name: 'Forge', path: '/data/projects/elysium/data/forge/forge_concept.kuzu',
+          schema_type: 'concept-forge', ttl_snapshot_hours: 1, privacy_class: 'SHARED' },
+      ],
+    };
+    const loader = new MultigraphLoader({
+      configFetcher: () => Promise.resolve(fakeConfig),
+    });
+    const graphs = await loader.listGraphs();
+    expect(graphs).toHaveLength(2);
+    expect(graphs[0].name).toBe('ASTKG');
+  });
+
+  it('throws when config missing graphs array', async () => {
+    const loader = new MultigraphLoader({
+      configFetcher: () => Promise.resolve({ version: '1.0' } as any),
+    });
+    await expect(loader.listGraphs()).rejects.toThrow(/graphs/);
+  });
+
+  it('uses default config path when no fetcher passed', async () => {
+    // Mock fetch globally
+    const mockResponse = {
+      ok: true,
+      status: 200,
+      json: async () => ({ version: '1.0', graphs: [] }),
+    };
+    vi.stubGlobal('fetch', vi.fn().mockResolvedValue(mockResponse));
+    const loader = new MultigraphLoader();
+    const graphs = await loader.listGraphs();
+    expect(graphs).toEqual([]);
+    vi.unstubAllGlobals();
+  });
+});
