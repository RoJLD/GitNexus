+/**
+ * Unit tests for TimelineReplay — Task 10.5.
+ * Run: npx vitest run test/unit/timeline-replay.test.ts
+ */
+
+import { describe, it, expect } from 'vitest';
+import { TimelineReplay } from '@/services/TimelineReplay';
+
+describe('TimelineReplay', () => {
+  it('builds snapshot list for a graph', async () => {
+    const replay = new TimelineReplay({
+      apiFetcher: () =>
+        Promise.resolve({
+          graph: 'ASTKG',
+          timestamps: ['2026-05-29T00-00-00', '2026-05-30T00-00-00'],
+        }),
+    });
+    const snaps = await replay.listSnapshots('ASTKG');
+    expect(snaps).toHaveLength(2);
+    expect(snaps[0]).toBe('2026-05-29T00-00-00');
+    expect(snaps[1]).toBe('2026-05-30T00-00-00');
+  });
+
+  it('throws on missing timestamps array', async () => {
+    const replay = new TimelineReplay({
+      apiFetcher: () => Promise.resolve({ graph: 'ASTKG' } as any),
+    });
+    await expect(replay.listSnapshots('ASTKG')).rejects.toThrow(
+      'timestamps[] missing',
+    );
+  });
+
+  it('throws when apiFetcher rejects (HTTP error simulation)', async () => {
+    const replay = new TimelineReplay({
+      apiFetcher: () => Promise.reject(new Error('Timeline API HTTP 404 for graph "Ghost"')),
+    });
+    await expect(replay.listSnapshots('Ghost')).rejects.toThrow('404');
+  });
+
+  it('returns empty array when timestamps is an empty list', async () => {
+    const replay = new TimelineReplay({
+      apiFetcher: () => Promise.resolve({ graph: 'Forge', timestamps: [] }),
+    });
+    const snaps = await replay.listSnapshots('Forge');
+    expect(snaps).toHaveLength(0);
+    expect(Array.isArray(snaps)).toBe(true);
+  });
+
+  it('preserves timestamp ordering as returned by API', async () => {
+    const ordered = [
+      '2026-01-01T00-00-00',
+      '2026-03-15T12-00-00',
+      '2026-05-30T23-59-59',
+    ];
+    const replay = new TimelineReplay({
+      apiFetcher: () => Promise.resolve({ graph: 'TechGenealogy', timestamps: ordered }),
+    });
+    const snaps = await replay.listSnapshots('TechGenealogy');
+    expect(snaps).toEqual(ordered);
+  });
+});
