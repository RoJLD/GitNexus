index 00000000..303835f0
--- /dev/null
+++ b/gitnexus-web/src/components/GhostFiltersSection.tsx
@@ -0,0 +1,194 @@
+/**
+ * GhostFiltersSection — the "Roadmap predictive" filter block embedded
+ * in the FileTreePanel's Filters tab. Lives as its own component so
+ * Task 10's test can render it in isolation without dragging the whole
+ * AppStateProvider into the test environment.
+ *
+ * Hierarchical UX :
+ *   - master toggle "Show ghosts"
+ *   - when on, 3 tier checkboxes ("1", "2", "3")
+ *   - plus a "Show cancelled ghosts" toggle
+ *
+ * Section I / Task 14 of the Ghost Cluster plan adds an independent
+ * sub-block for cluster halos with three knobs : master toggle
+ * "Show cluster halos", an "include auto-clusters" boolean, and a
+ * 3-way radio source filter (both / declared only / auto only). All
+ * three cluster props are optional so existing render sites that only
+ * care about ghosts still type-check.
+ *
+ * Section E / Task 10 of
+ * docs/superpowers/specs/2026-05-26-roadmap-predictive-augmented-graph-design.md
+ * Section I / Task 14 of
+ * docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ */
+
+import type { GhostFilters } from '../lib/ghost-layout';
+
+export type ClusterSourceFilter = 'both' | 'declared' | 'auto';
+
+type Props = {
+  ghostFilters: GhostFilters;
+  setGhostFilters: (next: GhostFilters) => void;
+  showClusterHalos?: boolean;
+  setShowClusterHalos?: (next: boolean) => void;
+  includeAutoClusters?: boolean;
+  setIncludeAutoClusters?: (next: boolean) => void;
+  clusterSourceFilter?: ClusterSourceFilter;
+  setClusterSourceFilter?: (next: ClusterSourceFilter) => void;
+  /** Augmented Timeline (Tier 3.x). When set, renders the "Lock ghosts
+   *  to today's view" sub-toggle below the per-Tier filters. Hidden
+   *  whenever the master "Show ghosts" toggle is off — locking
+   *  something invisible makes no sense. */
+  lockGhostsToHead?: boolean;
+  setLockGhostsToHead?: (next: boolean) => void;
+};
+
+const TIERS = ['1', '2', '3'] as const;
+const CLUSTER_SOURCES: ClusterSourceFilter[] = ['both', 'declared', 'auto'];
+
+export default function GhostFiltersSection({
+  ghostFilters,
+  setGhostFilters,
+  showClusterHalos,
+  setShowClusterHalos,
+  includeAutoClusters,
+  setIncludeAutoClusters,
+  clusterSourceFilter,
+  setClusterSourceFilter,
+  lockGhostsToHead,
+  setLockGhostsToHead,
+}: Props) {
+  const lockToggleEnabled = typeof setLockGhostsToHead === 'function';
+  // Sub-block is rendered when the parent wires the cluster props
+  // through — otherwise we degrade gracefully (e.g. early callers that
+  // only pre-date Task 14).
+  const clusterBlockEnabled =
+    typeof setShowClusterHalos === 'function' && typeof showClusterHalos === 'boolean';
+  return (
+    <section className="filter-section mt-6 border-t border-border-subtle pt-4">
+      <h3 className="mb-2 text-xs font-medium tracking-wide text-text-secondary uppercase">
+        Roadmap predictive
+      </h3>
+      <p className="mb-3 text-[11px] text-text-muted">
+        Overlay planned-but-unbuilt features on the graph
+      </p>
+
+      <label className="flex items-center gap-2 text-xs text-text-primary">
+        <input
+          type="checkbox"
+          checked={ghostFilters.showGhosts}
+          onChange={(e) =>
+            setGhostFilters({ ...ghostFilters, showGhosts: e.target.checked })
+          }
+        />
+        Show ghosts
+      </label>
+
+      {ghostFilters.showGhosts && (
+        <div className="mt-2 flex flex-col gap-1 pl-4">
+          {TIERS.map((t) => (
+            <label key={t} className="flex items-center gap-2 text-xs text-text-secondary">
+              <input
+                type="checkbox"
+                checked={ghostFilters.tiers.includes(t)}
+                onChange={(e) =>
+                  setGhostFilters({
+                    ...ghostFilters,
+                    tiers: e.target.checked
+                      ? [...ghostFilters.tiers, t].sort()
+                      : ghostFilters.tiers.filter((x) => x !== t),
+                  })
+                }
+              />
+              Tier {t}
+            </label>
+          ))}
+          <label className="mt-2 flex items-center gap-2 text-xs text-text-secondary">
+            <input
+              type="checkbox"
+              checked={ghostFilters.showCancelled}
+              onChange={(e) =>
+                setGhostFilters({ ...ghostFilters, showCancelled: e.target.checked })
+              }
+            />
+            Show cancelled ghosts
+          </label>
+
+          {/* Augmented Timeline — lock ghost layer to today's view.
+              When ON, the predictive layer ignores the cursor and
+              renders the live ghost set even when the user scrubs
+              into the past. Off by default; auto-detect takes over. */}
+          {lockToggleEnabled && (
+            <label
+              className="mt-2 flex items-center gap-2 text-xs text-text-secondary"
+              data-testid="lock-ghosts-to-head-label"
+            >
+              <input
+                type="checkbox"
+                checked={!!lockGhostsToHead}
+                onChange={(e) => setLockGhostsToHead?.(e.target.checked)}
+                data-testid="toggle-lock-ghosts-to-head"
+              />
+              Lock ghosts to today's view
+            </label>
+          )}
+        </div>
+      )}
+
+      {clusterBlockEnabled && (
+        <div className="mt-4 border-t border-border-subtle pt-3" data-testid="cluster-filters">
+          <label className="flex items-center gap-2 text-xs text-text-primary">
+            <input
+              type="checkbox"
+              checked={!!showClusterHalos}
+              onChange={(e) => setShowClusterHalos?.(e.target.checked)}
+              data-testid="toggle-show-cluster-halos"
+            />
+            Show cluster halos
+          </label>
+
+          {showClusterHalos && (
+            <div className="mt-2 flex flex-col gap-1 pl-4">
+              <label className="flex items-center gap-2 text-xs text-text-secondary">
+                <input
+                  type="checkbox"
+                  checked={!!includeAutoClusters}
+                  onChange={(e) => setIncludeAutoClusters?.(e.target.checked)}
+                  data-testid="toggle-include-auto-clusters"
+                />
+                Include auto-clusters
+              </label>
+              <div
+                role="radiogroup"
+                aria-label="Cluster source filter"
+                data-testid="cluster-source-radio"
+                className="mt-1 flex flex-col gap-1"
+              >
+                {CLUSTER_SOURCES.map((src) => (
+                  <label
+                    key={src}
+                    className="flex items-center gap-2 text-xs text-text-secondary"
+                  >
+                    <input
+                      type="radio"
+                      name="cluster-source-filter"
+                      value={src}
+                      checked={(clusterSourceFilter ?? 'both') === src}
+                      onChange={() => setClusterSourceFilter?.(src)}
+                      data-testid={`cluster-source-${src}`}
+                    />
+                    {src === 'both'
+                      ? 'Both (declared + auto)'
+                      : src === 'declared'
+                        ? 'Declared only'
+                        : 'Auto only'}
+                  </label>
+                ))}
+              </div>
+            </div>
+          )}
+        </div>
+      )}
+    </section>
+  );
+}
diff --git a/gitnexus-web/src/components/GhostTooltip.tsx b/gitnexus-web/src/components/GhostTooltip.tsx
new file mode 100644
index 00000000..dabff90b
--- /dev/null
+++ b/gitnexus-web/src/components/GhostTooltip.tsx
@@ -0,0 +1,95 @@
+/**
+ * GhostTooltip — popup rendered when a ghost node is clicked on the
+ * canvas. Shows the ghost's tier badge, title, description, the list
+ * of expected-link paths (each annotated ✓ matched / ✗ unmatched),
+ * any label-style expected links as small badges, and an "open in
+ * ROADMAP" button.
+ *
+ * Section D / Task 8 of
+ * docs/superpowers/specs/2026-05-26-roadmap-predictive-augmented-graph-design.md
+ */
+
+import type { GhostRuntime } from '../services/ghosts-client';
+
+type Props = {
+  ghost: GhostRuntime;
+  /** IDs of real graph nodes that match this ghost's expectedLinks. */
+  matchedNodeIds: string[];
+  onClose: () => void;
+  onOpenRoadmap: (ghostId: string) => void;
+};
+
+export default function GhostTooltip({
+  ghost,
+  matchedNodeIds,
+  onClose,
+  onOpenRoadmap,
+}: Props) {
+  const d = ghost.declared;
+  const tierLabel = d.tier ? `Tier ${d.tier}` : 'No tier';
+  const pathLinks = d.expectedLinks.filter((l) => l.kind === 'path');
+  const labelLinks = d.expectedLinks.filter((l) => l.kind === 'label');
+
+  const matchedSet = new Set(matchedNodeIds);
+  const isMatched = (val: string): boolean => {
+    for (const id of matchedSet) {
+      if (id.endsWith(val) || id.includes('/' + val)) return true;
+    }
+    return false;
+  };
+
+  return (
+    <div
+      className="ghost-tooltip pointer-events-auto absolute top-16 right-4 z-30 w-80 animate-fade-in rounded-lg border border-border-subtle bg-elevated/95 p-4 shadow-lg backdrop-blur-sm"
+      data-testid="ghost-tooltip"
+    >
+      <header className="mb-2 flex items-start gap-2">
+        <span className="badge tier rounded bg-accent/20 px-2 py-0.5 text-[11px] font-mono text-accent">
+          {tierLabel}
+        </span>
+        <h3 className="flex-1 text-sm font-semibold text-text-primary">{d.title}</h3>
+        <button
+          onClick={onClose}
+          aria-label="close"
+          className="rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+        >
+          ×
+        </button>
+      </header>
+      {d.description && (
+        <p className="description mb-3 text-xs text-text-secondary">{d.description}</p>
+      )}
+      <h4 className="mb-1 text-[11px] font-medium tracking-wide text-text-muted uppercase">
+        Expected links
+      </h4>
+      <ul className="mb-2 space-y-1">
+        {pathLinks.map((l, i) => (
+          <li key={i} className="flex items-center gap-2 text-xs">
+            <span className={isMatched(l.value) ? 'text-emerald-400' : 'text-rose-400'}>
+              {isMatched(l.value) ? '✓' : '✗'}
+            </span>
+            <code className="font-mono text-text-secondary">{l.value}</code>
+          </li>
+        ))}
+      </ul>
+      {labelLinks.length > 0 && (
+        <div className="mb-3 flex flex-wrap gap-1">
+          {labelLinks.map((l, i) => (
+            <span
+              key={i}
+              className="badge label rounded bg-border-subtle/40 px-2 py-0.5 text-[10px] font-mono text-text-secondary"
+            >
+              {l.value}
+            </span>
+          ))}
+        </div>
+      )}
+      <button
+        onClick={() => onOpenRoadmap(d.id)}
+        className="w-full rounded border border-border-subtle bg-elevated px-3 py-1.5 text-xs text-text-secondary transition-colors hover:bg-hover hover:text-text-primary"
+      >
+        Open in ROADMAP.md
+      </button>
+    </div>
+  );
+}
diff --git a/gitnexus-web/src/components/Graph3DCanvas.tsx b/gitnexus-web/src/components/Graph3DCanvas.tsx
new file mode 100644
index 00000000..4cc7c53e
--- /dev/null
+++ b/gitnexus-web/src/components/Graph3DCanvas.tsx
@@ -0,0 +1,632 @@
+/**
+ * Graph3DCanvas — 3D rendering surface for the knowledge graph.
+ *
+ * Uses react-force-graph-3d (Three.js + d3-force-3d). Mirrors the data flow
+ * of GraphCanvas + useSigma so the UX matches the 2D experience:
+ *   - Selection: target node gets bigger, neighbors brightened, non-neighbors
+ *     dimmed. Connected edges thicker.
+ *   - Highlights (AI citations, AI tool, query results): cyan accent.
+ *   - Blast radius: red accent.
+ *   - Diff mode: per-node and per-edge colors from the DIFF_COLORS palette.
+ *   - Depth filter: BFS-restricts visible nodes to N hops from selection.
+ *
+ * Mouse mapping (OrbitControls):
+ *   LEFT/MIDDLE-drag = rotate (CAD convention), RIGHT-drag = pan, wheel = zoom.
+ */
+
+import { useCallback, useEffect, useMemo, useRef, useState } from 'react';
+import * as THREE from 'three';
+import ForceGraph3D, { type ForceGraphMethods } from 'react-force-graph-3d';
+import type { GraphNode, NodeLabel } from 'gitnexus-shared';
+import {
+  Square,
+  ZoomIn,
+  ZoomOut,
+  Maximize2,
+  Play,
+  Pause,
+  Focus,
+  RotateCcw,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+import { NODE_COLORS, NODE_SIZES, EDGE_INFO, type EdgeType } from '../lib/constants';
+import { getResearchGraph, applyLens } from '../services/research-client';
+import { getGraphMetrics, getGraphLensMetrics, type SizeMetric } from '../services/graph-theory-client';
+import { researchTo3D } from '../lib/research-to-3d';
+import type { ResearchGraph } from '../lib/research-graph-adapter';
+
+// ── Palette ──────────────────────────────────────────────────────────────────
+// Kept in sync with useSigma.ts so 2D ↔ 3D toggling doesn't shift colors.
+const DIFF_COLORS: Record<'onlyInA' | 'onlyInB' | 'inBoth', string> = {
+  onlyInA: '#ef4444',
+  onlyInB: '#10b981',
+  inBoth: '#4b5563',
+};
+
+const hexToRgb = (hex: string): { r: number; g: number; b: number } => {
+  const m = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
+  return m
+    ? { r: parseInt(m[1], 16), g: parseInt(m[2], 16), b: parseInt(m[3], 16) }
+    : { r: 100, g: 100, b: 100 };
+};
+const rgbToHex = (r: number, g: number, b: number): string =>
+  '#' +
+  [r, g, b]
+    .map((x) => Math.max(0, Math.min(255, Math.round(x))).toString(16).padStart(2, '0'))
+    .join('');
+// Mix a color toward the dark background — preserves hue identity while
+// pushing the node into the visual "background".
+const dimColor = (hex: string, amount: number): string => {
+  const c = hexToRgb(hex);
+  const bg = { r: 18, g: 18, b: 28 };
+  return rgbToHex(
+    c.r * amount + bg.r * (1 - amount),
+    c.g * amount + bg.g * (1 - amount),
+    c.b * amount + bg.b * (1 - amount),
+  );
+};
+const brightenColor = (hex: string, factor: number): string => {
+  const c = hexToRgb(hex);
+  return rgbToHex(c.r * factor, c.g * factor, c.b * factor);
+};
+
+// ── Internal shapes ──────────────────────────────────────────────────────────
+
+interface Node3D {
+  id: string;
+  name: string;
+  label: NodeLabel | string;
+  baseColor: string;
+  val: number;
+  raw?: GraphNode;
+  research?: boolean;
+}
+
+interface Link3D {
+  // react-force-graph mutates source/target to Node3D objects after the sim
+  // initializes — handle both string-id and object forms when reading.
+  source: string | Node3D;
+  target: string | Node3D;
+  type: string;
+  baseColor: string;
+}
+
+const linkEnd = (e: string | Node3D): string => (typeof e === 'string' ? e : e.id);
+
+// ── Component ────────────────────────────────────────────────────────────────
+
+export const Graph3DCanvas = () => {
+  const {
+    graph,
+    setSelectedNode,
+    selectedNode: appSelectedNode,
+    visibleLabels,
+    visibleEdgeTypes,
+    depthFilter,
+    openCodePanel,
+    toggleViewDimension,
+    highlightedNodeIds,
+    aiCitationHighlightedNodeIds,
+    aiToolHighlightedNodeIds,
+    blastRadiusNodeIds,
+    isAIHighlightsEnabled,
+    diffData,
+  } = useAppState();
+
+  const fgRef = useRef<ForceGraphMethods<Node3D, Link3D> | undefined>(undefined);
+  const containerRef = useRef<HTMLDivElement | null>(null);
+  const [hoveredNodeName, setHoveredNodeName] = useState<string | null>(null);
+  const [size, setSize] = useState({ width: 0, height: 0 });
+  const [layoutRunning, setLayoutRunning] = useState(true);
+
+  // ── Research/lens overlay (parity with the 2D GraphCanvas toggle) ───────────
+  const researchName = new URLSearchParams(window.location.search).get('research');
+  const lensId = new URLSearchParams(window.location.search).get('lens');
+  const lensRepo = new URLSearchParams(window.location.search).get('repo');
+  const [researchData, setResearchData] = useState<ResearchGraph | null>(null);
+  const [metricsOn, setMetricsOn] = useState(false);
+  const [metricsById3D, setMetricsById3D] = useState<Map<string, { community: number } & Record<string, number>> | null>(null);
+  const [sizeMetric3D, setSizeMetric3D] = useState<SizeMetric>('pagerank');
+
+  useEffect(() => {
+    if (researchName) { getResearchGraph(researchName).then(setResearchData).catch((e) => console.error('research 3D load failed', e)); return; }
+    if (lensId && lensRepo) { applyLens(lensId, lensRepo).then(setResearchData).catch((e) => console.error('lens 3D load failed', e)); return; }
+    setResearchData(null);
+  }, [researchName, lensId, lensRepo]);
+
+  useEffect(() => {
+    const active = !!(researchName || (lensId && lensRepo));
+    if (!metricsOn || !active) { setMetricsById3D(null); return; }
+    let cancelled = false;
+    const p = researchName ? getGraphMetrics(researchName) : getGraphLensMetrics(lensId!, lensRepo!);
+    p.then((mm) => { if (!cancelled) setMetricsById3D(new Map(mm.nodes.map((n) => [n.id, n as unknown as { community: number } & Record<string, number>]))); })
+     .catch((e) => { if (!cancelled) console.error('3D metrics load failed', e); });
+    return () => { cancelled = true; };
+  }, [metricsOn, researchName, lensId, lensRepo]);
+
+  // ── Camera/layout controls ─────────────────────────────────────────────────
+  // TS quirk: cameraPosition()'s no-arg getter form isn't in the public types;
+  // cast through unknown to call it without arguments.
+  const readCamera = (): { x: number; y: number; z: number } | null => {
+    const fg = fgRef.current;
+    if (!fg) return null;
+    return (fg.cameraPosition as unknown as () => { x: number; y: number; z: number })();
+  };
+
+  const handleZoomIn = useCallback(() => {
+    const cam = readCamera();
+    if (!cam) return;
+    fgRef.current?.cameraPosition(
+      { x: cam.x * 0.8, y: cam.y * 0.8, z: cam.z * 0.8 },
+      undefined,
+      300,
+    );
+  }, []);
+
+  const handleZoomOut = useCallback(() => {
+    const cam = readCamera();
+    if (!cam) return;
+    fgRef.current?.cameraPosition(
+      { x: cam.x * 1.25, y: cam.y * 1.25, z: cam.z * 1.25 },
+      undefined,
+      300,
+    );
+  }, []);
+
+  const handleFit = useCallback(() => fgRef.current?.zoomToFit(400, 50), []);
+
+  const handleToggleLayout = useCallback(() => {
+    const fg = fgRef.current;
+    if (!fg) return;
+    if (layoutRunning) {
+      fg.pauseAnimation();
+    } else {
+      fg.resumeAnimation();
+      fg.d3ReheatSimulation();
+    }
+    setLayoutRunning((v) => !v);
+  }, [layoutRunning]);
+
+  // ── Effective highlight sets (mirrors GraphCanvas) ─────────────────────────
+  // AI citations / tools are only applied when the AI-highlights toggle is on;
+  // user query highlights are always applied.
+  const effectiveHighlighted = useMemo(() => {
+    if (!isAIHighlightsEnabled) return highlightedNodeIds;
+    const merged = new Set(highlightedNodeIds);
+    aiCitationHighlightedNodeIds.forEach((id) => merged.add(id));
+    aiToolHighlightedNodeIds.forEach((id) => merged.add(id));
+    return merged;
+  }, [
+    highlightedNodeIds,
+    aiCitationHighlightedNodeIds,
+    aiToolHighlightedNodeIds,
+    isAIHighlightsEnabled,
+  ]);
+
+  const effectiveBlast = useMemo(
+    () => (isAIHighlightsEnabled ? blastRadiusNodeIds : new Set<string>()),
+    [blastRadiusNodeIds, isAIHighlightsEnabled],
+  );
+
+  // ── Build the visible dataset ──────────────────────────────────────────────
+  // Order: label filter → depth filter (BFS from selection) → diff coloring.
+  const data = useMemo<{ nodes: Node3D[]; links: Link3D[] }>(() => {
+    if (researchData) {
+      const r = researchTo3D(researchData, metricsOn ? (metricsById3D ?? undefined) : undefined, sizeMetric3D);
+      return { nodes: r.nodes as Node3D[], links: r.links as Link3D[] };
+    }
+    if (!graph) return { nodes: [], links: [] };
+
+    const visibleLabelSet = new Set(visibleLabels);
+    let allowedIds = new Set<string>();
+    for (const n of graph.nodes) {
+      if (visibleLabelSet.has(n.label)) allowedIds.add(n.id);
+    }
+
+    // Depth filter: keep only nodes within `depthFilter` hops of the selected
+    // node (over edges that are also currently visible). Matches the 2D
+    // filterGraphByDepth behavior.
+    if (
+      appSelectedNode &&
+      depthFilter !== null &&
+      depthFilter !== undefined &&
+      allowedIds.has(appSelectedNode.id)
+    ) {
+      const visibleEdgeSet = new Set(visibleEdgeTypes);
+      const adj = new Map<string, string[]>();
+      for (const r of graph.relationships) {
+        if (!allowedIds.has(r.sourceId) || !allowedIds.has(r.targetId)) continue;
+        if (!visibleEdgeSet.has(r.type as EdgeType)) continue;
+        if (!adj.has(r.sourceId)) adj.set(r.sourceId, []);
+        if (!adj.has(r.targetId)) adj.set(r.targetId, []);
+        adj.get(r.sourceId)!.push(r.targetId);
+        adj.get(r.targetId)!.push(r.sourceId);
+      }
+      const reachable = new Set<string>([appSelectedNode.id]);
+      let frontier: string[] = [appSelectedNode.id];
+      for (let depth = 0; depth < depthFilter && frontier.length; depth++) {
+        const next: string[] = [];
+        for (const id of frontier) {
+          for (const neigh of adj.get(id) ?? []) {
+            if (!reachable.has(neigh)) {
+              reachable.add(neigh);
+              next.push(neigh);
+            }
+          }
+        }
+        frontier = next;
+      }
+      allowedIds = new Set([...allowedIds].filter((id) => reachable.has(id)));
+    }
+
+    const nodes: Node3D[] = [];
+    for (const n of graph.nodes) {
+      if (!allowedIds.has(n.id)) continue;
+      const diffStatus = diffData?.nodeStatus.get(n.id);
+      const baseColor = diffStatus
+        ? DIFF_COLORS[diffStatus]
+        : NODE_COLORS[n.label] ?? '#94a3b8';
+      nodes.push({
+        id: n.id,
+        name: n.properties.name ?? n.id,
+        label: n.label,
+        baseColor,
+        val: NODE_SIZES[n.label] ?? 3,
+        raw: n,
+      });
+    }
+
+    const visibleEdgeSet = new Set(visibleEdgeTypes);
+    const links: Link3D[] = [];
+    for (const r of graph.relationships) {
+      if (!allowedIds.has(r.sourceId) || !allowedIds.has(r.targetId)) continue;
+      if (!visibleEdgeSet.has(r.type as EdgeType)) continue;
+      const diffStatus = diffData?.edgeStatus.get(`${r.sourceId}::${r.type}::${r.targetId}`);
+      const baseColor = diffStatus
+        ? DIFF_COLORS[diffStatus]
+        : EDGE_INFO[r.type as EdgeType]?.color ?? '#475569';
+      links.push({ source: r.sourceId, target: r.targetId, type: r.type, baseColor });
+    }
+    return { nodes, links };
+  }, [graph, visibleLabels, visibleEdgeTypes, depthFilter, appSelectedNode, diffData, researchData, metricsOn, metricsById3D, sizeMetric3D]);
+
+  // Neighbor set for the current selection — drives the "bright neighbors, dim
+  // everything else" effect. Built from `data.links` (post-filter) so depth /
+  // visibility filters are respected.
+  const neighborIds = useMemo(() => {
+    if (!appSelectedNode) return new Set<string>();
+    const s = new Set<string>();
+    for (const l of data.links) {
+      const src = linkEnd(l.source);
+      const tgt = linkEnd(l.target);
+      if (src === appSelectedNode.id) s.add(tgt);
+      else if (tgt === appSelectedNode.id) s.add(src);
+    }
+    return s;
+  }, [data.links, appSelectedNode]);
+
+  // ── Styling functions ──────────────────────────────────────────────────────
+  // Priority order (mirrors useSigma):
+  //   blast radius → highlights (no selection) → selection (own/neighbor/other)
+  //                → base color
+  const nodeColorFn = useCallback(
+    (n: Node3D): string => {
+      if (effectiveBlast.has(n.id)) return '#ef4444';
+
+      const hasHighlights = effectiveHighlighted.size > 0;
+      if (hasHighlights && !appSelectedNode) {
+        return effectiveHighlighted.has(n.id) ? '#06b6d4' : dimColor(n.baseColor, 0.2);
+      }
+
+      if (appSelectedNode) {
+        if (n.id === appSelectedNode.id) return brightenColor(n.baseColor, 1.2);
+        if (neighborIds.has(n.id)) return n.baseColor;
+        return dimColor(n.baseColor, 0.25);
+      }
+      return n.baseColor;
+    },
+    [appSelectedNode, neighborIds, effectiveBlast, effectiveHighlighted],
+  );
+
+  const nodeValFn = useCallback(
+    (n: Node3D): number => {
+      if (effectiveBlast.has(n.id)) return n.val * 1.8;
+
+      const hasHighlights = effectiveHighlighted.size > 0;
+      if (hasHighlights && !appSelectedNode) {
+        return effectiveHighlighted.has(n.id) ? n.val * 1.6 : n.val * 0.5;
+      }
+
+      if (appSelectedNode) {
+        if (n.id === appSelectedNode.id) return n.val * 1.8;
+        if (neighborIds.has(n.id)) return n.val * 1.3;
+        return n.val * 0.6;
+      }
+      return n.val;
+    },
+    [appSelectedNode, neighborIds, effectiveBlast, effectiveHighlighted],
+  );
+
+  const linkColorFn = useCallback(
+    (l: Link3D): string => {
+      const src = linkEnd(l.source);
+      const tgt = linkEnd(l.target);
+
+      const hasHighlights = effectiveHighlighted.size > 0 || effectiveBlast.size > 0;
+      if (hasHighlights && !appSelectedNode) {
+        const isSrc = effectiveHighlighted.has(src) || effectiveBlast.has(src);
+        const isTgt = effectiveHighlighted.has(tgt) || effectiveBlast.has(tgt);
+        if (isSrc && isTgt) {
+          return effectiveBlast.has(src) && effectiveBlast.has(tgt) ? '#ef4444' : '#06b6d4';
+        }
+        return dimColor(l.baseColor, 0.08);
+      }
+
+      if (appSelectedNode) {
+        const connected = src === appSelectedNode.id || tgt === appSelectedNode.id;
+        return connected ? brightenColor(l.baseColor, 1.5) : dimColor(l.baseColor, 0.1);
+      }
+      return l.baseColor;
+    },
+    [appSelectedNode, effectiveBlast, effectiveHighlighted],
+  );
+
+  const linkWidthFn = useCallback(
+    (l: Link3D): number => {
+      const src = linkEnd(l.source);
+      const tgt = linkEnd(l.target);
+
+      const hasHighlights = effectiveHighlighted.size > 0 || effectiveBlast.size > 0;
+      if (hasHighlights && !appSelectedNode) {
+        const isSrc = effectiveHighlighted.has(src) || effectiveBlast.has(src);
+        const isTgt = effectiveHighlighted.has(tgt) || effectiveBlast.has(tgt);
+        if (isSrc && isTgt) return 2;
+        return 0.1;
+      }
+      if (appSelectedNode) {
+        const connected = src === appSelectedNode.id || tgt === appSelectedNode.id;
+        return connected ? 2 : 0.1;
+      }
+      return 0.4;
+    },
+    [appSelectedNode, effectiveBlast, effectiveHighlighted],
+  );
+
+  // Force a redraw when any styling input changes — react-force-graph caches
+  // node materials per session and won't otherwise pick up a recolored node.
+  useEffect(() => {
+    fgRef.current?.refresh();
+  }, [appSelectedNode, neighborIds, effectiveBlast, effectiveHighlighted, diffData]);
+
+  // ── Container sizing ──────────────────────────────────────────────────────
+  useEffect(() => {
+    const el = containerRef.current;
+    if (!el) return;
+    const update = () => setSize({ width: el.clientWidth, height: el.clientHeight });
+    update();
+    const obs = new ResizeObserver(update);
+    obs.observe(el);
+    return () => obs.disconnect();
+  }, []);
+
+  // ── Middle-button rotate ───────────────────────────────────────────────────
+  useEffect(() => {
+    const fg = fgRef.current;
+    if (!fg) return;
+    const controls = fg.controls() as { mouseButtons?: Record<string, number> } | undefined;
+    if (!controls) return;
+    controls.mouseButtons = {
+      LEFT: THREE.MOUSE.ROTATE,
+      MIDDLE: THREE.MOUSE.ROTATE,
+      RIGHT: THREE.MOUSE.PAN,
+    };
+  }, [size.width, size.height]);
+
+  // ── Focus on selected node (recenter camera) ───────────────────────────────
+  const focusOnSelected = useCallback(() => {
+    if (!appSelectedNode || !fgRef.current) return;
+    const node = data.nodes.find((n) => n.id === appSelectedNode.id) as
+      | (Node3D & { x?: number; y?: number; z?: number })
+      | undefined;
+    if (!node || node.x === undefined) return;
+    const distance = 120;
+    const distRatio = 1 + distance / Math.hypot(node.x ?? 1, node.y ?? 1, node.z ?? 1);
+    fgRef.current.cameraPosition(
+      {
+        x: (node.x ?? 0) * distRatio,
+        y: (node.y ?? 0) * distRatio,
+        z: (node.z ?? 0) * distRatio,
+      },
+      { x: node.x ?? 0, y: node.y ?? 0, z: node.z ?? 0 },
+      800,
+    );
+  }, [appSelectedNode, data.nodes]);
+
+  // Auto-focus on selection change (parity with 2D's focusNode-on-select).
+  useEffect(() => {
+    focusOnSelected();
+  }, [focusOnSelected]);
+
+  const handleClearSelection = useCallback(() => {
+    setSelectedNode(null);
+    fgRef.current?.zoomToFit(400, 50);
+  }, [setSelectedNode]);
+
+  return (
+    <div ref={containerRef} className="relative h-full w-full bg-void">
+      {/* Background gradient — matches GraphCanvas */}
+      <div className="pointer-events-none absolute inset-0">
+        <div
+          className="absolute inset-0"
+          style={{
+            background: `
+              radial-gradient(circle at 50% 50%, rgba(124, 58, 237, 0.03) 0%, transparent 70%),
+              linear-gradient(to bottom, #06060a, #0a0a10)
+            `,
+          }}
+        />
+      </div>
+
+      {size.width > 0 && size.height > 0 && (
+        <ForceGraph3D<Node3D, Link3D>
+          ref={fgRef}
+          width={size.width}
+          height={size.height}
+          graphData={data}
+          backgroundColor="rgba(0,0,0,0)"
+          nodeColor={nodeColorFn}
+          nodeVal={nodeValFn}
+          nodeLabel={(n) => n.name}
+          nodeOpacity={0.95}
+          nodeResolution={12}
+          linkColor={linkColorFn}
+          linkWidth={linkWidthFn}
+          linkOpacity={0.6}
+          linkDirectionalParticles={0}
+          enableNodeDrag={false}
+          controlType="orbit"
+          onNodeClick={(n) => {
+            if (n.research || !n.raw) return;
+            setSelectedNode(n.raw);
+            openCodePanel();
+          }}
+          onNodeHover={(n) => setHoveredNodeName(n ? n.name : null)}
+          onBackgroundClick={() => setSelectedNode(null)}
+        />
+      )}
+
+      {/* Hover tooltip (when nothing selected — selection pill takes over otherwise) */}
+      {hoveredNodeName && !appSelectedNode && (
+        <div className="pointer-events-none absolute top-4 left-1/2 z-20 -translate-x-1/2 animate-fade-in rounded-lg border border-border-subtle bg-elevated/95 px-3 py-1.5 backdrop-blur-sm">
+          <span className="font-mono text-sm text-text-primary">{hoveredNodeName}</span>
+        </div>
+      )}
+
+      {/* Selection info bar — parity with GraphCanvas */}
+      {appSelectedNode && (
+        <div className="absolute top-4 left-1/2 z-20 flex -translate-x-1/2 animate-slide-up items-center gap-2 rounded-xl border border-accent/30 bg-accent/20 px-4 py-2 backdrop-blur-sm">
+          <div className="h-2 w-2 animate-pulse rounded-full bg-accent" />
+          <span className="font-mono text-sm text-text-primary">
+            {appSelectedNode.properties.name}
+          </span>
+          <span className="text-xs text-text-muted">({appSelectedNode.label})</span>
+          <button
+            onClick={handleClearSelection}
+            className="ml-2 rounded px-2 py-0.5 text-xs text-text-secondary transition-colors hover:bg-white/10 hover:text-text-primary"
+          >
+            Clear
+          </button>
+        </div>
+      )}
+
+      {/* Hint badge — explains the middle-click rebind */}
+      <div className="pointer-events-none absolute bottom-4 left-4 z-10 rounded-md border border-border-subtle bg-elevated/80 px-2.5 py-1 font-mono text-[11px] text-text-muted backdrop-blur-sm">
+        left/middle-drag: rotate &middot; right-drag: pan &middot; wheel: zoom
+      </div>
+
+      {/* Layout indicator — parity with GraphCanvas */}
+      {layoutRunning && (
+        <div className="absolute bottom-4 left-1/2 z-10 flex -translate-x-1/2 animate-fade-in items-center gap-2 rounded-full border border-emerald-500/30 bg-emerald-500/20 px-3 py-1.5 backdrop-blur-sm">
+          <div className="h-2 w-2 animate-ping rounded-full bg-emerald-400" />
+          <span className="text-xs font-medium text-emerald-400">Layout optimizing...</span>
+        </div>
+      )}
+
+      {/* Bottom Right: zoom + focus + clear + layout controls */}
+      <div className="absolute right-4 bottom-4 z-10 flex flex-col gap-1">
+        <button
+          onClick={handleZoomIn}
+          className="flex h-9 w-9 items-center justify-center rounded-md border border-border-subtle bg-elevated text-text-secondary transition-colors hover:bg-hover hover:text-text-primary"
+          title="Zoom In"
+        >
+          <ZoomIn className="h-4 w-4" />
+        </button>
+        <button
+          onClick={handleZoomOut}
+          className="flex h-9 w-9 items-center justify-center rounded-md border border-border-subtle bg-elevated text-text-secondary transition-colors hover:bg-hover hover:text-text-primary"
+          title="Zoom Out"
+        >
+          <ZoomOut className="h-4 w-4" />
+        </button>
+        <button
+          onClick={handleFit}
+          className="flex h-9 w-9 items-center justify-center rounded-md border border-border-subtle bg-elevated text-text-secondary transition-colors hover:bg-hover hover:text-text-primary"
+          title="Fit to Screen"
+        >
+          <Maximize2 className="h-4 w-4" />
+        </button>
+
+        <div className="my-1 h-px bg-border-subtle" />
+
+        {appSelectedNode && (
+          <button
+            onClick={focusOnSelected}
+            className="flex h-9 w-9 items-center justify-center rounded-md border border-accent/30 bg-accent/20 text-accent transition-colors hover:bg-accent/30"
+            title="Focus on Selected Node"
+          >
+            <Focus className="h-4 w-4" />
+          </button>
+        )}
+
+        {appSelectedNode && (
+          <button
+            onClick={handleClearSelection}
+            className="flex h-9 w-9 items-center justify-center rounded-md border border-border-subtle bg-elevated text-text-secondary transition-colors hover:bg-hover hover:text-text-primary"
+            title="Clear Selection"
+          >
+            <RotateCcw className="h-4 w-4" />
+          </button>
+        )}
+
+        <div className="my-1 h-px bg-border-subtle" />
+
+        <button
+          onClick={handleToggleLayout}
+          className={`flex h-9 w-9 items-center justify-center rounded-md border transition-all ${
+            layoutRunning
+              ? 'animate-pulse border-accent bg-accent text-white shadow-glow'
+              : 'border-border-subtle bg-elevated text-text-secondary hover:bg-hover hover:text-text-primary'
+          } `}
+          title={layoutRunning ? 'Pause Layout' : 'Resume Layout'}
+        >
+          {layoutRunning ? <Pause className="h-4 w-4" /> : <Play className="h-4 w-4" />}
+        </button>
+      </div>
+
+      {/* Top Right: research/lens metrics controls + switch back to 2D */}
+      <div className="absolute top-4 right-4 z-20 flex items-center gap-2">
+        {(researchName || (lensId && lensRepo)) && (
+          <button
+            onClick={() => setMetricsOn((v) => !v)}
+            className={metricsOn
+              ? 'flex h-10 items-center gap-1.5 rounded-lg border border-indigo-400/40 bg-indigo-500/15 px-3 text-indigo-200'
+              : 'flex h-10 items-center gap-1.5 rounded-lg border border-border-subtle bg-elevated px-3 text-text-secondary transition-colors hover:bg-hover hover:text-text-primary'}
+            data-testid="metrics-toggle-3d" title={metricsOn ? 'Hide metrics' : 'Show metrics'}
+          ><span className="font-mono text-xs font-semibold">Metrics: {metricsOn ? 'on' : 'off'}</span></button>
+        )}
+        {metricsOn && (researchName || (lensId && lensRepo)) && (
+          <select
+            value={sizeMetric3D}
+            onChange={(e) => setSizeMetric3D(e.target.value as SizeMetric)}
+            className="flex h-10 items-center rounded-lg border border-indigo-400/40 bg-indigo-500/15 px-3 font-mono text-xs font-semibold text-indigo-200"
+            data-testid="metric-select-3d" title="Size metric"
+          >
+            <option value="degree">Degree</option><option value="pagerank">PageRank</option>
+            <option value="betweenness">Betweenness</option><option value="eigenvector">Eigenvector</option>
+            <option value="closeness">Closeness</option><option value="katz">Katz</option>
+            <option value="harmonic">Harmonic</option><option value="coreness">k-core</option>
+            <option value="clustering">Clustering</option>
+          </select>
+        )}
+        <button
+          onClick={toggleViewDimension}
+          className="flex h-10 items-center gap-1.5 rounded-lg border border-accent/40 bg-accent/15 px-3 text-accent transition-colors hover:bg-accent/25"
+          title="Switch to 2D view"
+        >
+          <Square className="h-4 w-4" />
+          <span className="font-mono text-xs font-semibold">2D</span>
