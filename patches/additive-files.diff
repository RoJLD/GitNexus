+    // Cache shape: { schemaVersion: 1, labels: { commId: { label, ... } } }
+    if (!parsed || typeof parsed.labels !== 'object') {
+      return { labels: [], embeddings: [], embeddingDim: 0 };
+    }
+    const labels = [];
+    const embeddings = [];
+    let embeddingDim = 0;
+    for (const entry of Object.values(parsed.labels)) {
+      if (!entry || typeof entry.label !== 'string' || entry.label.length === 0) continue;
+      labels.push(entry.label);
+      if (Array.isArray(entry.embedding) && entry.embedding.length > 0) {
+        if (embeddingDim === 0) embeddingDim = entry.embedding.length;
+        // Skip dimensionality mismatches — usually means the user
+        // switched embedding models. centroid cosine is meaningless
+        // across different vector spaces.
+        if (entry.embedding.length === embeddingDim) {
+          embeddings.push(entry.embedding);
+        }
+      }
+    }
+    return { labels, embeddings, embeddingDim };
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return { labels: [], embeddings: [], embeddingDim: 0 };
+    return { labels: [], embeddings: [], embeddingDim: 0 };
