+
+// 2D PCA projection of an N×D matrix → array of [x, y] per row.
+// Tier 2.6 — used by the Galaxy view to lay repos out in 2D where
+// distance ≈ structural similarity.
+//
+// Why PCA and not UMAP: this codebase has zero embedded-vector deps,
+// and UMAP-js would add ~50 KB to the bundle (or be a server-side
+// dep). For 5-10 repos, PCA captures enough of the variance to be
+// useful — UMAP's local-neighborhood preservation only pays off at
+// hundreds of points. Honest framing: this is "Galaxy v1 = PCA". If
+// we ever index hundreds of repos, 2.6.bis swaps in UMAP.
+//
+// Power-iteration approach (no SVD library needed):
+//   1. center the matrix (subtract column means)
+//   2. compute the D×D covariance matrix
+//   3. find the top 2 eigenvectors by deflated power iteration
+//   4. project: rows × top-2-eigvecs → N×2
+//
+// Edge cases: N<2 → returns null (can't project a single point).
+// N=2 → returns a horizontal line at y=0, points spaced by distance.
+function pcaProject2D(matrix) {
+  const N = matrix.length;
+  if (N < 2) return null;
+  const D = matrix[0].length;
+  if (D === 0) return null;
+  // For N=2, PCA degenerates — just project onto the line connecting them.
+  if (N === 2) {
+    let dot = 0;
+    for (let d = 0; d < D; d++) dot += (matrix[0][d] - matrix[1][d]) ** 2;
+    const dist = Math.sqrt(dot);
+    return [
+      [-dist / 2, 0],
+      [dist / 2, 0],
+    ];
+  }
+  // 1. Centre
+  const mean = new Array(D).fill(0);
+  for (const row of matrix) for (let d = 0; d < D; d++) mean[d] += row[d];
+  for (let d = 0; d < D; d++) mean[d] /= N;
+  const centred = matrix.map((row) => row.map((v, d) => v - mean[d]));
+  // 2. Covariance D×D
+  const cov = Array.from({ length: D }, () => new Array(D).fill(0));
+  for (const row of centred) {
+    for (let i = 0; i < D; i++) {
+      for (let j = i; j < D; j++) {
+        const v = row[i] * row[j];
+        cov[i][j] += v;
+        if (i !== j) cov[j][i] += v;
+      }
+    }
+  }
+  for (let i = 0; i < D; i++) for (let j = 0; j < D; j++) cov[i][j] /= N - 1;
+  // 3. Top-2 eigenvectors via power iteration with deflation
+  const pc1 = topEigenvector(cov, 200);
+  const cov2 = deflate(cov, pc1);
+  const pc2 = topEigenvector(cov2, 200);
+  // 4. Project
+  return centred.map((row) => [dotProd(row, pc1), dotProd(row, pc2)]);
+}
+
+function topEigenvector(matrix, iterations) {
+  const D = matrix.length;
+  // Deterministic seed to make the projection stable across requests —
+  // a random init would rotate the galaxy each refresh, which is
+  // disorienting. Start with a tilted unit vector that's never
+  // orthogonal to the data.
+  let v = new Array(D).fill(0).map((_, i) => Math.cos(i + 1));
+  v = normalize(v);
+  for (let k = 0; k < iterations; k++) {
+    const next = new Array(D).fill(0);
+    for (let i = 0; i < D; i++) {
+      for (let j = 0; j < D; j++) next[i] += matrix[i][j] * v[j];
+    }
+    const norm = Math.sqrt(next.reduce((s, x) => s + x * x, 0));
+    if (norm < 1e-12) return v;
+    for (let i = 0; i < D; i++) next[i] /= norm;
+    // Convergence check: dot ≈ 1 means we've stopped rotating.
+    if (Math.abs(dotProd(next, v)) > 1 - 1e-9) return next;
+    v = next;
+  }
+  return v;
+}
+
+function deflate(matrix, eigvec) {
+  // λ ≈ vᵀMv (Rayleigh quotient on the converged eigvec)
+  const Mv = new Array(eigvec.length).fill(0);
+  for (let i = 0; i < eigvec.length; i++) {
+    for (let j = 0; j < eigvec.length; j++) Mv[i] += matrix[i][j] * eigvec[j];
+  }
+  const lambda = dotProd(eigvec, Mv);
+  return matrix.map((row, i) => row.map((v, j) => v - lambda * eigvec[i] * eigvec[j]));
+}
+
+function dotProd(a, b) {
+  let s = 0;
+  for (let i = 0; i < a.length; i++) s += a[i] * b[i];
+  return s;
+}
+
+function normalize(v) {
+  const norm = Math.sqrt(v.reduce((s, x) => s + x * x, 0));
+  return norm > 0 ? v.map((x) => x / norm) : v.slice();
+}
+
+// Gini coefficient on a numeric distribution. Returns 0 for perfect
+// equality (all values equal), 1 for perfect inequality (all weight on
+// one item). Standard definition; we sort + use the cumulative-share
+// formula which is O(n log n) but doesn't matter here.
+function gini(values) {
+  if (!Array.isArray(values) || values.length === 0) return 0;
+  const sorted = values.slice().sort((a, b) => a - b);
+  const n = sorted.length;
+  let sum = 0;
+  let weightedSum = 0;
+  for (let i = 0; i < n; i++) {
+    sum += sorted[i];
+    weightedSum += (i + 1) * sorted[i];
+  }
+  if (sum === 0) return 0;
+  return (2 * weightedSum) / (n * sum) - (n + 1) / n;
+}
