+
+function cosineBow(va, vb) {
+  if (va.size === 0 || vb.size === 0) return 0;
+  let dot = 0;
+  let na = 0;
+  let nb = 0;
+  for (const [, x] of va) na += x * x;
+  for (const [, y] of vb) nb += y * y;
+  // Iterate the smaller map for dot product.
+  const [small, large] = va.size <= vb.size ? [va, vb] : [vb, va];
+  for (const [t, x] of small) {
+    const y = large.get(t);
+    if (y !== undefined) dot += x * y;
+  }
+  if (na === 0 || nb === 0) return 0;
+  return dot / (Math.sqrt(na) * Math.sqrt(nb));
