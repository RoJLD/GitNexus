+import { mapPositionToDate, snapToNearestSnapshot, applyWheelZoom } from '../lib/timeline-zoom';
+import { WHEEL_ZOOM_MIN_SPAN_MS, WHEEL_ZOOM_SENSITIVITY, WHEEL_ZOOM_SETTLE_MS } from '../config/ui-constants';
+
+/**
+ * Horizontal timeline rendered between the graph and the status bar.
+ *
+ * Shows every snapshot of the active "base" repo plus a "live" marker for
+ * the head-of-tree index. Each dot is positioned along the bar by its
+ * commit date (linearly, ignoring gaps — we want even visual spacing for
+ * scanability rather than literal chronological scale). Clicking a dot
+ * loads that point in time; the Play button walks through them
+ * automatically with a 2s frame so the user can watch the graph evolve.
+ *
+ * Hidden when the active repo has zero snapshots — there's nothing to
+ * navigate to. Hidden when active repo name is empty (onboarding state).
+ */
+
+interface SnapshotPoint {
+  name: string;
+  shortHash: string;
+  message: string;
+  author: string;
+  date: string; // ISO 8601 — sorts correctly as a string
+  isLive: boolean;
+}
+
+const FRAME_DELAY_MS = 2000;
+
+export const Timeline = () => {
+  const appState = useAppState();
+  // Augmented Timeline (Tier 3.x, Task 4 + Task 5) — read state defensively
+  // so this file compiles even before Task 5 lands the new useAppState
+  // fields. After Task 5 ships, the casts collapse to no-ops at runtime.
+  const lockGhostsToHead: boolean =
+    (appState as unknown as { lockGhostsToHead?: boolean }).lockGhostsToHead ?? false;
+  const setLockGhostsToHead =
+    (appState as unknown as { setLockGhostsToHead?: (v: boolean) => void })
+      .setLockGhostsToHead ?? (() => {});
+  const animationActive: boolean =
+    (appState as unknown as { animationActive?: boolean }).animationActive ?? false;
+  const setAnimationActive =
+    (appState as unknown as { setAnimationActive?: (v: boolean) => void })
+      .setAnimationActive ?? (() => {});
+  const ghostFilters = appState.ghostFilters;
+  const setGhostFilters = appState.setGhostFilters;
+  const {
+    projectName,
+    availableRepos,
+    switchRepo,
+    exitDiffMode,
+    diffMode,
+    churnActive,
+    churnLoading,
+    churnError,
+    churnTotalSnapshots,
+    enterChurnMode,
+    exitChurnMode,
+    couplingActive,
+    couplingLoading,
+    couplingError,
+    enterCouplingMode,
+    exitCouplingMode,
+    growthActive,
+    growthLoading,
