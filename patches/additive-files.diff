diff --git a/connectors/plane.mjs b/connectors/plane.mjs
new file mode 100644
index 00000000..69d006d8
--- /dev/null
+++ b/connectors/plane.mjs
@@ -0,0 +1,56 @@
+// upstream/connectors/plane.mjs
+//
+// Plane REST API connector (v1) for the roadmap-predictive Connector
+// framework. Endpoint:
+//   GET {apiUrl}/api/v1/workspaces/{slug}/projects/{projectId}/issues/
+// Auth via X-API-Key header.
+
+const DEFAULT_PAGE_SIZE = 100;
+
+export const planeConnector = {
+  name: 'plane',
+  configKey: 'connectors.plane',
+
+  async fetchOpenWorkItems(config) {
+    return fetchPlaneIssues(config, { stateFilter: 'open' });
+  },
+
+  async fetchClosedWorkItems(config) {
+    return fetchPlaneIssues(config, { stateFilter: 'closed' });
+  },
+};
+
+async function fetchPlaneIssues(config, { stateFilter }) {
+  const { apiUrl, workspaceSlug, projectId, apiKey } = config;
+  if (!apiUrl || !workspaceSlug || !projectId) {
+    throw new Error('Plane connector requires apiUrl, workspaceSlug, projectId');
+  }
+  if (!apiKey) {
+    throw new Error('Plane connector requires PLANE_API_KEY env var (or config.apiKey)');
+  }
+  const url = `${apiUrl.replace(/\/$/, '')}/api/v1/workspaces/${workspaceSlug}/projects/${projectId}/issues/?per_page=${DEFAULT_PAGE_SIZE}`;
+  const res = await fetch(url, { headers: { 'X-API-Key': apiKey, 'Accept': 'application/json' } });
+  if (!res.ok) throw new Error(`Plane API ${res.status}: ${await res.text()}`);
+  const body = await res.json();
+  const issues = body.results || [];
+  return issues
+    .map(i => ({
+      id: i.id,
+      title: i.name,
+      description: stripHtml(i.description_html || ''),
+      state: stateNameToCategory(i.state_detail?.name || i.state || ''),
+      dueDate: i.target_date,
+      externalUrl: `${apiUrl}/${workspaceSlug}/projects/${projectId}/issues/${i.id}`,
+    }))
+    .filter(i => stateFilter === 'open' ? i.state === 'open' : i.state === 'closed');
+}
+
+function stripHtml(s) {
+  return String(s).replace(/<[^>]+>/g, '').trim();
+}
+
+function stateNameToCategory(name) {
+  const lc = String(name).toLowerCase();
+  if (/done|complete|closed|cancel/i.test(lc)) return 'closed';
+  return 'open';
+}
diff --git a/docker-server-academic-json-importer.mjs b/docker-server-academic-json-importer.mjs
new file mode 100644
index 00000000..8f6dee08
--- /dev/null
+++ b/docker-server-academic-json-importer.mjs
@@ -0,0 +1,55 @@
+/**
+ * academic-json importer: read papers.json from the source dir and emit the
+ * generic sidecar ingest shape for the academic-literature schema
+ * (Paper/Author/Topic + AUTHORED/ABOUT). Pure Node, deterministic, offline.
+ * The PDF->papers.json extraction is a separate offline tool (tools/academic-extract.mjs).
+ */
+import { readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+
+const norm = (s) => String(s || '').trim().replace(/\s+/g, ' ');
+const slug = (s) => norm(s).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
+
+export async function importAcademicJson(absSourceDir) {
+  let doc;
+  try { doc = JSON.parse(await readFile(join(absSourceDir, 'papers.json'), 'utf8')); }
+  catch (e) { throw new Error(`cannot read papers.json in source: ${e.message}`); }
+  const papers = Array.isArray(doc.papers) ? doc.papers : [];
+
+  const nodes = [];
+  const edges = [];
+  const authors = new Map();
+  const topics = new Map();
+
+  const skipped = [];
+  const seenEdges = new Set();
+  for (const p of papers) {
+    if (p.id == null || p.id === '') { skipped.push({ reason: 'missing id', title: p.title ?? null }); continue; }
+    const paperId = String(p.id);
+    nodes.push({ table: 'Paper', props: { id: paperId, title: norm(p.title), year: Number(p.year) || 0, path: String(p.path || '') } });
+    for (const a of p.authors || []) {
+      const id = `author:${slug(a)}`;
+      if (!authors.has(id)) { authors.set(id, { table: 'Author', props: { id, name: norm(a) } }); }
+      const aEdgeId = `${id}->${paperId}`;
+      if (!seenEdges.has(aEdgeId)) { seenEdges.add(aEdgeId); edges.push({ table: 'AUTHORED', from: id, to: paperId, props: { id: aEdgeId } }); }
+    }
+    for (const t of p.topics || []) {
+      const id = `topic:${slug(t)}`;
+      if (!topics.has(id)) { topics.set(id, { table: 'Topic', props: { id, label: norm(t) } }); }
+      const tEdgeId = `${paperId}->${id}`;
+      if (!seenEdges.has(tEdgeId)) { seenEdges.add(tEdgeId); edges.push({ table: 'ABOUT', from: paperId, to: id, props: { id: tEdgeId } }); }
+    }
+  }
+  nodes.push(...authors.values(), ...topics.values());
+
+  const byTable = {};
+  for (const n of nodes) byTable[n.table] = (byTable[n.table] || 0) + 1;
+  const byKind = {};
+  for (const e of edges) byKind[e.table] = (byKind[e.table] || 0) + 1;
+
+  return {
+    schema_type: 'academic-literature', template: 'academic-literature', name: null, source: null, // name/source filled in by the caller (scaffold record)
+    nodes, edges,
+    report: { nodes: nodes.length, edges: edges.length, byType: byTable, byKind, unresolvedLinks: [], skipped },
+  };
+}
diff --git a/docker-server-auto-reindex.mjs b/docker-server-auto-reindex.mjs
new file mode 100644
index 00000000..dcc5e953
--- /dev/null
+++ b/docker-server-auto-reindex.mjs
@@ -0,0 +1,163 @@
+/**
+ * Auto-reindexing — detect new commits per repo and trigger an incremental
+ * `gitnexus analyze`. Runs in the web container (has git + access to the API
+ * server). See docs/superpowers/specs/2026-05-28-auto-reindexing-design.md
+ *
+ * This task adds the pure decision fn; Task 3 adds the I/O + route handler.
+ */
+
+import { execFile } from 'node:child_process';
+import { readFile, writeFile, mkdir } from 'node:fs/promises';
+import { join } from 'node:path';
+import { promisify } from 'node:util';
+
+/**
+ * Decide whether to trigger a reindex. Pure — no I/O.
+ *   enabled    : auto_reindex.onCommit from config
+ *   currentSha : `git rev-parse HEAD` result (null if unresolvable)
+ *   lastSha    : sidecar lastIndexedSha (null/undefined on first sight)
+ * First sight (lastSha null/undefined) returns false: the caller records the
+ * baseline SHA without an immediate reindex storm.
+ */
+export function shouldReindex({ enabled, currentSha, lastSha }) {
+  if (!enabled) return false;
+  if (!currentSha) return false;
+  if (lastSha === null || lastSha === undefined) return false;
+  return currentSha !== lastSha;
+}
+
+const execFileP = promisify(execFile);
+
+const SIDECAR_REL = ['.gitnexus', '_auto-reindex.json'];
+
+// `git -C <repoPath> rev-parse HEAD`, trimmed. null on any error (non-git
+// path, detached/empty repo, git missing). 5s timeout — rev-parse is instant.
+async function gitRevParse(repoPath) {
+  try {
+    const { stdout } = await execFileP('git', ['-C', repoPath, 'rev-parse', 'HEAD'], { timeout: 5000 });
+    const sha = stdout.trim();
+    return sha || null;
+  } catch {
+    return null;
+  }
+}
+
+async function readSidecar(repoPath) {
+  try {
+    const raw = await readFile(join(repoPath, ...SIDECAR_REL), 'utf8');
+    const obj = JSON.parse(raw);
+    return obj && typeof obj === 'object' ? obj : null;
+  } catch {
+    return null; // absent or unreadable → treat as first sight
+  }
+}
+
+async function writeSidecar(repoPath, data) {
+  try {
+    await mkdir(join(repoPath, '.gitnexus'), { recursive: true });
+    await writeFile(join(repoPath, ...SIDECAR_REL), JSON.stringify(data, null, 2), 'utf8');
+  } catch (e) {
+    process.stderr.write(`[auto-reindex] sidecar write failed for ${repoPath}: ${e && e.message || e}\n`);
+  }
+}
+
+/**
+ * Per-repo tick: if auto_reindex.onCommit and HEAD changed since last index,
+ * POST an incremental /api/analyze and record the new SHA (optimistic). Best-
+ * effort — any failure logs + returns. Called by the watches cron.
+ */
+export async function maybeReindexRepo(repo, apiBase) {
+  const repoPath = repo && (repo.repoPath || repo.path);
+  if (!repoPath || !repo.name || repo.name.includes('@')) return;
+
+  let cfg;
+  try {
+    const { getConfig } = await import('./docker-server-config.mjs');
+    cfg = await getConfig(repoPath);
+  } catch {
+    return;
+  }
+  const enabled = !!(cfg && cfg.auto_reindex && cfg.auto_reindex.onCommit);
+  if (!enabled) return;
+
+  const currentSha = await gitRevParse(repoPath);
+  if (!currentSha) return;
+
+  const sidecar = await readSidecar(repoPath);
+  const lastSha = sidecar ? sidecar.lastIndexedSha : null;
+
+  // First sight: record baseline, do not trigger.
+  if (lastSha === null || lastSha === undefined) {
+    await writeSidecar(repoPath, { lastIndexedSha: currentSha, lastTriggeredAt: null, lastJobId: null });
+    return;
+  }
+
+  if (!shouldReindex({ enabled, currentSha, lastSha })) return;
+
+  let jobId = null;
+  try {
+    const res = await fetch(`${apiBase}/api/analyze`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ path: repoPath }), // no force ⇒ incremental
+    });
+    const body = await res.json().catch(() => ({}));
+    jobId = body && body.jobId ? body.jobId : null;
+  } catch (e) {
+    process.stderr.write(`[auto-reindex] analyze trigger failed for ${repo.name}: ${e && e.message || e}\n`);
+    return; // don't update sidecar — retry next tick
+  }
+  await writeSidecar(repoPath, { lastIndexedSha: currentSha, lastTriggeredAt: new Date().toISOString(), lastJobId: jobId });
+  process.stderr.write(`[auto-reindex] triggered for ${repo.name} @ ${currentSha.slice(0, 8)} (job ${jobId})\n`);
+}
+
+async function fetchAllReposAR(apiBase) {
+  try {
+    const r = await fetch(`${apiBase}/api/repos`);
+    if (!r.ok) return [];
+    const data = await r.json();
+    const list = Array.isArray(data) ? data : data.repos;
+    return Array.isArray(list) ? list : [];
+  } catch {
+    return [];
+  }
+}
+
+/**
+ * GET /auto-reindex — read-only per-repo state (like GET /watches).
+ * Handler contract: returns true if it owned the route, false otherwise.
+ */
+export async function handleAutoReindexRoute(req, url, res, opts) {
+  if (url.pathname !== '/auto-reindex' || req.method !== 'GET') return false;
+  const apiBase = (opts && opts.api) || process.env.GITNEXUS_API || 'http://gitnexus:4747';
+  const filterRepo = url.searchParams.get('repo');
+  const repos = await fetchAllReposAR(apiBase);
+  const out = [];
+  for (const repo of repos) {
+    if (!repo || !repo.name || repo.name.includes('@')) continue;
+    if (filterRepo && repo.name !== filterRepo) continue;
+    const repoPath = repo.repoPath || repo.path;
+    if (!repoPath) continue;
+    let enabled = false;
+    try {
+      const { getConfig } = await import('./docker-server-config.mjs');
+      const cfg = await getConfig(repoPath);
+      enabled = !!(cfg && cfg.auto_reindex && cfg.auto_reindex.onCommit);
+    } catch { /* default false */ }
+    const headSha = await gitRevParse(repoPath);
+    const sidecar = await readSidecar(repoPath);
+    const lastIndexedSha = sidecar ? sidecar.lastIndexedSha || null : null;
+    out.push({
+      repo: repo.name,
+      enabled,
+      headSha,
+      lastIndexedSha,
+      lastTriggeredAt: sidecar ? sidecar.lastTriggeredAt || null : null,
+      lastJobId: sidecar ? sidecar.lastJobId || null : null,
+      dueNow: shouldReindex({ enabled, currentSha: headSha, lastSha: lastIndexedSha }),
+    });
+  }
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ reposScanned: filterRepo ? 1 : repos.length, autoReindex: out }));
+  return true;
+}
diff --git a/docker-server-baseline-seed.mjs b/docker-server-baseline-seed.mjs
new file mode 100644
index 00000000..46981a29
--- /dev/null
+++ b/docker-server-baseline-seed.mjs
@@ -0,0 +1,153 @@
+/**
+ * Baseline auto-seed (commit-level time-travel §3.3).
+ *
+ *   POST /snapshot/baseline-seed?repo=&commit=  → { jobId } (202), analyze
+ *        complet en arrière-plan via createSnapshot, puis écrit le marqueur
+ *        .hidden (baseline interne, exclu du listing UI).
+ *   GET  /snapshot/baseline-seed/:jobId         → { state, phase, snapshot?, error? }
+ *        (pollable ; pas de SSE — un chip de progression suffit).
+ *   POST /snapshot/promote?repo=&commit=        → supprime .hidden (devient un jalon).
+ *
+ * Jobs en mémoire (low-frequency, déclenché manuellement). Si le conteneur
+ * redémarre en plein seed, le snapshot partiel reste sur disque (createSnapshot
+ * est idempotent) ; seul le canal de progression est perdu.
+ */
+import { randomUUID } from 'node:crypto';
+import { rm, stat, writeFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import {
+  createSnapshot,
+  findRepoByName,
+  getCommitInfo,
+  hiddenMarkerPath,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+
+const jobs = new Map();
+// (repo\0commit) → jobId d'un seed en cours : dédup pour éviter deux
+// createSnapshot concurrents sur le même dossier (race rm+mkdir+clone).
+const inFlight = new Map();
+const FINISHED_TTL_MS = 60 * 1000;
+
+function reap() {
+  const now = Date.now();
+  for (const [id, j] of jobs) {
+    if (j.finishedAt && now - j.finishedAt > FINISHED_TTL_MS) jobs.delete(id);
+  }
+}
+
+async function handleSeed(url, res, opts) {
+  reap();
+  const repoName = url.searchParams.get('repo');
+  const commitRef = url.searchParams.get('commit');
+  if (!repoName || !commitRef) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo or commit' }));
+    return;
+  }
+  // Dédup : si un seed identique tourne déjà, renvoyer son jobId au lieu
+  // d'en lancer un second (qui racerait sur le rm+mkdir+clone du dossier).
+  const dedupKey = `${repoName} ${commitRef}`;
+  const runningId = inFlight.get(dedupKey);
+  if (runningId && jobs.get(runningId)?.state === 'running') {
+    res.writeHead(202, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ jobId: runningId, deduped: true }));
+    return;
+  }
+
+  const id = randomUUID();
+  const job = { id, state: 'running', phase: 'starting', snapshot: null, error: null, finishedAt: null };
+  jobs.set(id, job);
+  inFlight.set(dedupKey, id);
+
+  (async () => {
+    try {
+      const result = await createSnapshot({
+        repoName,
+        commitRef,
+        api: opts.api,
+        onPhase: (phase) => {
+          job.phase = phase;
+        },
+      });
+      // Marquer le snapshot comme baseline caché.
+      const marker = hiddenMarkerPath(result.snapshot.dir);
+      await writeFile(marker, 'baseline-seed\n', 'utf8');
+      job.snapshot = { name: result.snapshot.name, commit: result.snapshot.commit };
+      job.phase = 'done';
+      job.state = 'done';
+    } catch (err) {
+      job.state = 'failed';
+      job.error = err?.message || 'seed failed';
+    } finally {
+      job.finishedAt = Date.now();
+      if (inFlight.get(dedupKey) === id) inFlight.delete(dedupKey);
+    }
+  })();
+
+  res.writeHead(202, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ jobId: id }));
+}
+
+function handleSeedStatus(jobId, res) {
+  reap();
+  const job = jobs.get(jobId);
+  if (!job) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'job not found' }));
+    return;
+  }
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ state: job.state, phase: job.phase, snapshot: job.snapshot, error: job.error }));
+}
+
+async function handlePromote(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const commitRef = url.searchParams.get('commit');
+  if (!repoName || !commitRef) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo or commit' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  // Résoudre le ref → la clé de dossier (comme createSnapshot/list).
+  let key;
+  try {
+    const live = await findRepoByName(baseRepo, opts.api);
+    if (!live) throw new Error(`repo not found: ${baseRepo}`);
+    const info = await getCommitInfo(live.repoPath || live.path, commitRef);
+    key = safeSnapshotKey(info.shortHash);
+  } catch (err) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `commit not found: ${commitRef} (${err.message})` }));
+    return;
+  }
+  const snapshotDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(baseRepo), key);
+  const marker = hiddenMarkerPath(snapshotDir);
+  if (!(await stat(marker).catch(() => null))) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'no hidden baseline at this commit (already a milestone or unknown)' }));
+    return;
+  }
+  await rm(marker, { force: true });
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ok: true, name: `${baseRepo}@${key}` }));
+}
+
+export async function handleBaselineSeedRoute(req, url, res, opts) {
+  if (url.pathname === '/snapshot/baseline-seed' && req.method === 'POST') {
+    await handleSeed(url, res, opts);
+    return true;
+  }
+  const m = url.pathname.match(/^\/snapshot\/baseline-seed\/([A-Za-z0-9-]+)$/);
+  if (m && req.method === 'GET') {
+    handleSeedStatus(m[1], res);
+    return true;
+  }
+  if (url.pathname === '/snapshot/promote' && req.method === 'POST') {
+    await handlePromote(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-churn.mjs b/docker-server-churn.mjs
new file mode 100644
index 00000000..33f13d27
--- /dev/null
+++ b/docker-server-churn.mjs
@@ -0,0 +1,183 @@
+/**
+ * Churn analytics — Phase 4A of the time-travel feature.
+ *
+ * Endpoint:
+ *   GET /churn?repo=<baseRepoName>
+ *
+ * For the given base repo (e.g. "hmm_studio"), reads every snapshot it has
+ * (via the same on-disk layout the /snapshots endpoint walks) plus the
+ * live entry, queries each one for its full node-id list via the gitnexus
+ * Cypher API, and aggregates a presence count per node id.
+ *
+ * Returns:
+ *   {
+ *     totalSnapshots: number,           // includes the live entry
+ *     timeline: [{ name, isLive, date }],
+ *     perNode: { [nodeId]: number }     // count of snapshots in which this node exists
+ *   }
+ *
+ * The frontend turns that into a churn score:
+ *   stability = perNode[id] / totalSnapshots
+ *   churn     = 1 - stability
+ *
+ * Interpretation:
+ *   churn = 0     → node existed in every snapshot (load-bearing foundation)
+ *   churn = 1     → node exists in only one snapshot (ephemeral / very new / very old)
+ *   in between    → node has been added or removed at some point
+ *
+ * This is an MVP metric: it captures lifecycle (added/removed) but not
+ * content-level churn (a Function that exists throughout but whose body
+ * changed). For content churn we'd need to compare node properties
+ * snapshot-by-snapshot — doable in Phase 4B but heavier; let's see how
+ * useful the simpler metric proves first.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile, stat } from 'node:fs/promises';
+import { findRepoByName, SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+async function listSnapshotNamesAndDates(repoName) {
+  const repoSnapshotsDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(repoSnapshotsDir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    const commitPath = join(repoSnapshotsDir, e.name, 'commit.json');
+    try {
+      const commit = JSON.parse(await readFile(commitPath, 'utf8'));
+      out.push({
+        name: `${repoName}@${e.name}`,
+        date: commit.date,
+        isLive: false,
+      });
+    } catch {
+      // Skip directories without commit.json — half-built or stale.
+    }
+  }
+  return out;
+}
+
+// Fetch the node-id set for a given registered repo via Cypher. We use
+// /api/query because it's much cheaper than /api/graph — we don't need
+// edges, properties, or anything except the id list.
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) {
+    throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  }
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  // Be tolerant of shape variations across gitnexus versions.
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+async function handleChurn(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  // Always include the live entry as the most-recent point so churn
+  // distinguishes "in live but not in old snapshots" (new additions) from
+  // "in old snapshots but not in live" (deletions). Both are interesting.
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ];
+  // Order chronologically so the caller can interpret churn over time
+  // (Phase 4C will use this ordering for lifespan).
+  timeline.sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  if (timeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        totalSnapshots: timeline.length,
+        timeline,
+        perNode: {},
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) for meaningful churn.',
+      }),
+    );
+    return;
+  }
+
+  // Run the Cypher queries sequentially, not in parallel — the underlying
+  // gitnexus server holds at most one lbug connection per path, and
+  // concurrent requests against different snapshots would thrash the
+  // ensureLbugInitialized cache (close/open per call). Sequential is fast
+  // enough at our scale (~5 snapshots × ~50 ms = 250 ms total).
+  const perNode = Object.create(null);
+  const errors = [];
+  for (const point of timeline) {
+    try {
+      const ids = await fetchNodeIds(point.name, opts.api);
+      for (const id of ids) {
+        perNode[id] = (perNode[id] || 0) + 1;
+      }
+    } catch (err) {
+      errors.push({ snapshot: point.name, error: err?.message || 'fetch failed' });
+    }
+  }
+
+  // CSV branch: one row per node id, with the derived churn score so
+  // downstream tools (Excel, pandas) don't have to recompute it.
+  if (url.searchParams.get('format') === 'csv') {
+    const total = timeline.length;
+    const rows = Object.entries(perNode).map(([id, count]) => ({
+      nodeId: id,
+      presenceCount: count,
+      totalSnapshots: total,
+      churnScore: total > 0 ? 1 - count / total : 0,
+    }));
+    const csv = toCsv(rows, [
+      { key: 'nodeId' },
+      { key: 'presenceCount' },
+      { key: 'totalSnapshots' },
+      { key: 'churnScore' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-churn.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalSnapshots: timeline.length,
+      timeline,
+      perNode,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+export async function handleChurnRoute(req, url, res, opts) {
+  if (url.pathname === '/churn' && req.method === 'GET') {
+    await handleChurn(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-cluster-audit.mjs b/docker-server-cluster-audit.mjs
new file mode 100644
index 00000000..3a88f38b
--- /dev/null
+++ b/docker-server-cluster-audit.mjs
@@ -0,0 +1,63 @@
+/**
+ * GET /clusters — read the runtime clusters.json sidecar for a repo, with an
+ * optional `?source=declared|auto` filter.
+ *
+ * Section C Task 6 of the Ghost Cluster plan
+ * (docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md).
+ *
+ * Sibling of docker-server-ghost-audit.mjs : both are read-only HTTP wrappers
+ * over the runtime JSON written by `syncGhostsForRepo`. This handler does NOT
+ * trigger a sync — clients must POST /ghosts/sync first.
+ */
+import { readLatestClusters } from './docker-server-ghosts.mjs';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+export async function handleClusters(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const sourceFilter = url.searchParams.get('source'); // 'declared' | 'auto' | null
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: 'missing repo' }));
+  }
+  // Validate source before any I/O so a malformed query is a fast 400.
+  if (sourceFilter && sourceFilter !== 'declared' && sourceFilter !== 'auto') {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: `invalid source: ${sourceFilter}` }));
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      return res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+    }
+    const repoPath = repo.repoPath || repo.path;
+    const runtime = await readLatestClusters(repoPath);
+    if (!runtime) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      return res.end(JSON.stringify({ error: 'No clusters.json — run POST /ghosts/sync first.' }));
+    }
+    let clusters = runtime.clusters || [];
+    if (sourceFilter === 'declared' || sourceFilter === 'auto') {
+      clusters = clusters.filter(c => c.source === sourceFilter);
+    }
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ ...runtime, clusters }));
+  } catch (err) {
+    console.error('[clusters] get failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+/**
+ * Public dispatcher : returns true if the request matches GET /clusters and
+ * is fully handled, false otherwise. Registered in `docker-server.mjs` next
+ * to the other audit dispatchers.
+ */
+export async function handleClustersRoute(req, url, res, opts) {
+  if (url.pathname === '/clusters' && req.method === 'GET') {
+    await handleClusters(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-commit-footprint.mjs b/docker-server-commit-footprint.mjs
new file mode 100644
index 00000000..22952d68
--- /dev/null
+++ b/docker-server-commit-footprint.mjs
@@ -0,0 +1,195 @@
+/**
+ * Commit footprint — Tier 2bis.2 follow-up (commit overlay on graph).
+ *
+ * Endpoint:
+ *   GET /commit/footprint?repo=<base>&sha=<commit-sha>
+ *
+ * Returns the list of files touched by a single commit, with their
+ * add/modify/delete status. The frontend then resolves these to graph
+ * nodes (any node whose filePath matches a touched file, or whose
+ * owning file does) and highlights them on the currently-loaded graph.
+ *
+ * Result: clicking a bar in EntropyCommitTimeline → seeing exactly
+ * which part of the graph that commit touched, without paying the
+ * cost of snapshotting every commit.
+ *
+ * --- Honest framing ---
+ *
+ * This is NOT "the graph at commit X". It's "what commit X touched,
+ * highlighted on the graph of the nearest available snapshot". If the
+ * commit refactored a file that the snapshot doesn't know about (e.g.
+ * file was renamed twice since), the highlight will be incomplete.
+ *
+ * For real per-commit graphs, the path is incremental snapshotting
+ * (next chantier per ROADMAP — Tier 2bis.6 if/when we get to it).
+ *
+ * --- Response shape ---
+ *
+ *   {
+ *     "repo": "hmm_studio",
+ *     "sha": "abc123def...",
+ *     "shortSha": "abc123d",
+ *     "author": "Robin DENIS",
+ *     "date": "2026-02-10T14:30:00+01:00",
+ *     "message": "feat: add Gini coefficient to similarity v2",
+ *     "filesTouched": [
+ *       { "path": "src/foo.py", "status": "M" },
+ *       { "path": "src/bar.py", "status": "A" },
+ *       { "path": "tests/old_helper.py", "status": "D" }
+ *     ],
+ *     "stats": { "added": 1, "modified": 1, "deleted": 1, "total": 3 }
+ *   }
+ */
+
+import { spawn } from 'node:child_process';
+import { stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+// Parse `git show -s --format=…` output where we asked for SHA, ISO
+// date, author, subject (one per line, in that order).
+function parseShowHeader(stdout) {
+  const lines = stdout.split('\n');
+  return {
+    sha: (lines[0] || '').trim(),
+    date: (lines[1] || '').trim(),
+    author: (lines[2] || '').trim(),
+    message: lines.slice(3).join('\n').trim(),
+  };
+}
+
+// Parse `git show --name-status --pretty=format:` output:
+//   "M\tsrc/foo.py"
+//   "A\tsrc/bar.py"
+//   "D\ttests/old_helper.py"
+//   "R100\tsrc/old.py\tsrc/new.py"   (renames — keep the destination
+//                                     and surface it as a Modify since
+//                                     for graph-overlay purposes that's
+//                                     what matters)
+function parseNameStatus(stdout) {
+  const out = [];
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trim();
+    if (!line) continue;
+    const parts = line.split('\t');
+    const code = parts[0];
+    if (!code) continue;
+    if (code.startsWith('R') || code.startsWith('C')) {
+      const dest = parts[2];
+      if (dest) out.push({ path: dest, status: 'M' });
+    } else if (parts[1]) {
+      let status = code[0];
+      if (status !== 'A' && status !== 'M' && status !== 'D') status = 'M';
+      out.push({ path: parts[1], status });
+    }
+  }
+  return out;
+}
+
+async function handleCommitFootprint(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const sha = url.searchParams.get('sha');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  if (!sha) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing sha' }));
+    return;
+  }
+  // Allow short SHAs (≥4 chars per git's minimum), reject obvious
+  // junk to avoid passing weird strings to git.
+  if (!/^[0-9a-f]{4,64}$/i.test(sha)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `sha must be 4-64 hex chars, got: ${sha}` }));
+    return;
+  }
+
+  const baseRepo = repoName.split('@')[0];
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+  const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
+  if (!hasGit) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `${baseRepo} is not a git repository` }));
+    return;
+  }
+
+  // Two git invocations: header (sha+date+author+subject) and
+  // name-status. We could fold them with --pretty but parsing two
+  // simple outputs is cleaner than one composite one.
+  let headerOut, nameStatusOut;
+  try {
+    headerOut = await runCmd('git', [
+      '-C', repoPath, 'show', '-s', '--format=%H%n%aI%n%an%n%s', sha,
+    ]);
+  } catch (err) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `commit not found: ${sha} (${err.message})` }));
+    return;
+  }
+  try {
+    nameStatusOut = await runCmd('git', [
+      '-C', repoPath, 'show', '--name-status', '--no-renames', '--pretty=format:', sha,
+    ]);
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `name-status fetch failed: ${err.message}` }));
+    return;
+  }
+
+  const header = parseShowHeader(headerOut);
+  const filesTouched = parseNameStatus(nameStatusOut);
+  const stats = filesTouched.reduce(
+    (acc, f) => {
+      if (f.status === 'A') acc.added++;
+      else if (f.status === 'D') acc.deleted++;
+      else acc.modified++;
+      acc.total++;
+      return acc;
+    },
+    { added: 0, modified: 0, deleted: 0, total: 0 },
+  );
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({
+    repo: baseRepo,
+    sha: header.sha || sha,
+    shortSha: (header.sha || sha).slice(0, 7),
+    author: header.author,
+    date: header.date,
+    message: header.message,
+    filesTouched,
+    stats,
+  }));
+}
+
+export async function handleCommitFootprintRoute(req, url, res, opts) {
+  if (url.pathname === '/commit/footprint' && req.method === 'GET') {
+    await handleCommitFootprint(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-commits.mjs b/docker-server-commits.mjs
new file mode 100644
index 00000000..dd0accff
--- /dev/null
+++ b/docker-server-commits.mjs
@@ -0,0 +1,102 @@
+/**
+ * Commit lister — GET /commits?repo=&from=&to=&max=
+ *
+ * Alimente le mode "Commits" de la timeline (spec 2026-05-28 §3.2) : un
+ * `git log` léger pour que le frontend affiche un point par commit et
+ * reconstruise n'importe lequel via /graph/at-commit. Pas d'analyze, pas
+ * de DB — juste les metadata git. Newest-first, capé.
+ */
+import { runCmd, findRepoByName } from './docker-server-snapshots.mjs';
+
+const COMMIT_FMT = ['%H', '%h', '%s', '%an', '%ae', '%aI', '%P'].join('%x00');
+const DEFAULT_MAX = 200;
+const MAX_CAP = 2000;
+
+// Un ref git est sûr en argument positionnel s'il ne ressemble pas à une
+// option (pas de '-' en tête) et ne contient que des caractères légaux.
+// Les args passent par spawn (pas de shell) : ce garde évite juste qu'un
+// ref soit interprété comme un flag.
+export function isSafeRef(ref) {
+  return (
+    typeof ref === 'string' &&
+    ref.length > 0 &&
+    !ref.startsWith('-') &&
+    /^[A-Za-z0-9._/~^@-]+$/.test(ref) &&
+    !ref.includes('..') // pas de syntaxe de range (HEAD~5..main) — on veut un ref simple
+  );
+}
+
+// Parse la sortie `git log` (champs séparés par \0, lignes par \n) en
+// objets commit de la même forme que getCommitInfo / SnapshotEntry.commit.
+export function parseCommitLines(stdout) {
+  return String(stdout)
+    .split('\n')
+    .map((l) => l.trim())
+    .filter(Boolean)
+    .map((line) => {
+      const [hash, shortHash, message, author, email, date, parent] = line.split('\0');
+      return { hash, shortHash, message, author, email, date, parent: parent || null };
+    });
+}
+
+async function handleCommits(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const to = url.searchParams.get('to') || 'HEAD';
+  const from = url.searchParams.get('from') || null;
+  let max = Number(url.searchParams.get('max'));
+  if (!Number.isFinite(max) || max <= 0) max = DEFAULT_MAX;
+  max = Math.min(max, MAX_CAP);
+
+  if (!isSafeRef(to) || (from && !isSafeRef(from))) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'malformed from/to ref' }));
+    return;
+  }
+
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+
+  let out;
+  try {
+    out = await runCmd('git', ['-C', repoPath, 'log', `--format=${COMMIT_FMT}`, '-n', String(max), to, '--']);
+  } catch (err) {
+    // Repo trouvé + refs validés à ce stade : un échec git est inattendu (ex.
+    // repoPath pas un vrai repo git) → erreur interne, pas un 404.
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `git log failed: ${err.message}` }));
+    return;
+  }
+
+  let commits = parseCommitLines(out);
+  // Capturer le cap AVANT le slice `from` : sinon le slice peut faire
+  // repasser truncated à false alors que git a bien atteint le plafond.
+  const truncated = commits.length >= max;
+  if (from) {
+    const idx = commits.findIndex(
+      (c) => c.hash === from || c.hash.startsWith(from) || c.shortHash === from,
+    );
+    if (idx >= 0) commits = commits.slice(0, idx + 1);
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ repo: baseRepo, to, commits, truncated }));
+}
+
+export async function handleCommitsRoute(req, url, res, opts) {
+  if (url.pathname === '/commits' && req.method === 'GET') {
+    await handleCommits(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-config.mjs b/docker-server-config.mjs
new file mode 100644
index 00000000..2a0ee468
--- /dev/null
+++ b/docker-server-config.mjs
@@ -0,0 +1,335 @@
+/**
+ * Unified per-repo configuration parser — ROADMAP Tier 2bis.4.
+ *
+ * One file per repo to rule them all: `.gitnexus.json` at the repo
+ * root, with up to four sections:
+ *
+ *   {
+ *     "domains": {                            // consumed by /dissonance (Tier 2.2)
+ *       "auth":    ["src/auth/**", "src/middleware/auth*.py"],
+ *       "billing": ["src/billing/**"]
+ *     },
+ *     "policy": {                             // consumed by /similarity (Tier 2.5)
+ *       "isolation_required": false,
+ *       "reason": "",
+ *       "allow_merge_with": []
+ *     },
+ *     "budgets": {                            // reserved for Tier 3.6 (Architectural CI)
+ *       "entropy_max": 0.6,
+ *       "coupling_max_per_file": 5,
+ *       "bus_factor_min": 2
+ *     },
+ *     "watches": [                            // reserved for Tier 2bis.3 (alerting)
+ *       { "metric": "entropy", "threshold": 0.6, "op": ">", "webhook": "https://hooks..." }
+ *     ]
+ *   }
+ *
+ * --- Why JSON and not YAML ---
+ *
+ * Same rationale as `.gitnexus-domains.json` (Tier 2.2): Node has no
+ * YAML in stdlib. Pulling a YAML parser for a config file with 4
+ * top-level keys isn't worth it. The ROADMAP shows YAML as the spec
+ * example because that's how the original Phase 1 doc was written,
+ * but JSON is more honest about our dependency surface.
+ *
+ * --- Backward-compatibility ---
+ *
+ * The two legacy files keep working:
+ *
+ *   `.gitnexus-domains.json` (Tier 2.2)  →  emits a deprecation
+ *                                            warning to stderr on read,
+ *                                            still parsed into the
+ *                                            `domains` section
+ *   `.gitnexus-policy.json`  (Tier 2.5)  →  same, parsed into `policy`
+ *
+ * Precedence: `.gitnexus.json` wins. If both unified + legacy are
+ * present, unified takes priority and we log a warning that the
+ * legacy file is being shadowed.
+ *
+ * The two endpoints that currently read config (`/dissonance`,
+ * `/similarity`) go through `getConfig(repoPath)` instead of reading
+ * their respective legacy file directly. The legacy code paths in
+ * those endpoints are removed; the legacy file format is handled
+ * here. The example files in `patches/example-gitnexus-*.json` are
+ * kept as reference but the new canonical example is
+ * `patches/example-gitnexus.json`.
+ */
+
+import { readFile, stat } from 'node:fs/promises';
+import { join } from 'node:path';
+
+const UNIFIED_FILENAME = '.gitnexus.json';
+const LEGACY_DOMAINS_FILENAME = '.gitnexus-domains.json';
+const LEGACY_POLICY_FILENAME = '.gitnexus-policy.json';
+
+// One-shot warnings keyed by `${repoPath}:${legacyName}` so we don't
+// spam the log on every request hitting the same repo. Reset would
+// require a server restart which is fine for a deprecation hint.
+const _warnedFor = new Set();
+
+function warnOnce(repoPath, legacyName, msg) {
+  const key = `${repoPath}:${legacyName}`;
+  if (_warnedFor.has(key)) return;
+  _warnedFor.add(key);
+  process.stderr.write(`[gitnexus-config] ${msg}\n`);
+}
+
+async function readJsonIfExists(path) {
+  try {
+    const raw = await readFile(path, 'utf8');
+    return { exists: true, raw };
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return { exists: false, raw: null };
+    throw err;
+  }
+}
+
+function parseDomains(parsed, source) {
+  const domains = parsed?.domains;
+  if (!domains || typeof domains !== 'object' || Array.isArray(domains)) {
+    throw new Error(`${source}: "domains" must be an object { name: ["glob", ...], ... }`);
+  }
+  const out = {};
+  for (const [name, globs] of Object.entries(domains)) {
+    if (typeof name !== 'string' || name.length === 0) continue;
+    if (!Array.isArray(globs)) {
+      throw new Error(`${source}: domain "${name}" must map to an array of globs`);
+    }
+    const cleaned = globs.filter((g) => typeof g === 'string' && g.length > 0);
+    if (cleaned.length === 0) continue;
+    out[name] = cleaned;
+  }
+  return out;
+}
+
+function parsePolicy(parsed, source) {
+  const policy = parsed?.policy ?? parsed; // legacy file = top-level shape
+  if (!policy || typeof policy !== 'object' || Array.isArray(policy)) {
+    return null;
+  }
+  return {
+    isolation_required: !!policy.isolation_required,
+    reason: typeof policy.reason === 'string' ? policy.reason : null,
+    allow_merge_with: Array.isArray(policy.allow_merge_with)
+      ? policy.allow_merge_with.filter((s) => typeof s === 'string')
+      : [],
+    _source: source,
+  };
+}
+
+function parseBudgets(parsed) {
+  const budgets = parsed?.budgets;
+  if (!budgets || typeof budgets !== 'object') return null;
+  // Reserved for Tier 3.6 — minimal validation, just numeric coercion.
+  const out = {};
+  for (const [k, v] of Object.entries(budgets)) {
+    const n = Number(v);
+    if (Number.isFinite(n)) out[k] = n;
+  }
+  return Object.keys(out).length > 0 ? out : null;
+}
+
+function parseWatches(parsed) {
+  const watches = parsed?.watches;
+  if (!Array.isArray(watches)) return null;
+  // Reserved for Tier 2bis.3 — pass through with light validation.
+  return watches
+    .filter((w) => w && typeof w === 'object' && typeof w.metric === 'string')
+    .map((w) => ({
+      metric: w.metric,
+      threshold: Number(w.threshold),
+      op: typeof w.op === 'string' ? w.op : '>',
+      webhook: typeof w.webhook === 'string' ? w.webhook : null,
+    }));
+}
+
+// auto_snapshot section (Phase A of incremental-snapshots spec).
+// Light validation + sensible defaults. Returns null if absent so
+// callers can distinguish "user wants defaults" from "user explicitly
+// declared this".
+function parseAutoSnapshot(parsed) {
+  const a = parsed?.auto_snapshot;
+  if (!a || typeof a !== 'object') return null;
+  const clampNum = (v, min, max, fallback) => {
+    const n = Number(v);
+    if (!Number.isFinite(n)) return fallback;
+    return Math.max(min, Math.min(max, n));
+  };
+  const metric = a.metric === 'modularity' ? 'modularity' : 'density';
+  return {
+    topPercent: clampNum(a.topPercent, 0.1, 100, 10),
+    windowDays: clampNum(a.windowDays, 1, 3650, 90),
+    debounceDays: clampNum(a.debounceDays, 0, 365, 7),
+    minDelta: Math.max(0, Number(a.minDelta) || 0),
+    excludeMerges: a.excludeMerges !== false, // default true
+    metric,
+    dryRun: !!a.dryRun,
+    maxToCreate: clampNum(a.maxToCreate, 1, 100, 5),
+  };
+}
+
+// wiki section (Code Wiki web UI + auto-update). Only `autoEvery` is used
+// today (cron regen cadence: 'off' | '<n>h' | '<n>d'). Defaults to 'off' so
+// the wiki never auto-regenerates unless explicitly opted in per repo.
+function parseWiki(parsed) {
+  const w = parsed?.wiki;
+  const autoEvery = w && typeof w.autoEvery === 'string' ? w.autoEvery : 'off';
+  return { autoEvery };
+}
+
+// auto_reindex section (Auto-reindexing). Only `onCommit` today — when true,
+// the watches cron re-analyzes the repo on a HEAD SHA change. Default false.
+function parseAutoReindex(parsed) {
+  return { onCommit: !!(parsed?.auto_reindex?.onCommit) };
+}
+
+// incremental section (diff pre-warming, commit-level time-travel §3.4).
+// preWarm: la cron pré-génère les diffs des N derniers commits ; preWarmCommits: N.
+export function parseIncrementalConfig(parsed) {
+  const i = parsed?.incremental;
+  const n = Number(i?.preWarmCommits);
+  const k = Number(i?.preWarmPerTick);
+  return {
+    preWarm: !!(i && i.preWarm),
+    preWarmCommits: Number.isFinite(n) ? Math.max(1, Math.min(500, n)) : 50,
+    preWarmPerTick: Number.isFinite(k) ? Math.max(1, Math.min(100, k)) : 10,
+  };
+}
+
+/**
+ * Load and merge per-repo configuration from disk.
+ *
+ *   const cfg = await getConfig('/data/projects/hmm_studio');
+ *   // cfg = {
+ *   //   domains: { auth: ['src/auth/**'], ... } | null,
+ *   //   policy:  { isolation_required, reason, allow_merge_with, _source } | null,
+ *   //   budgets: { entropy_max, ... } | null,
+ *   //   watches: [{ metric, threshold, op, webhook }, ...] | null,
+ *   //   _sources: { domains: 'unified'|'legacy'|null, policy: 'unified'|'legacy'|null }
+ *   // }
+ *
+ * Every section can be null when the corresponding declaration is
+ * absent from the file (or no file exists). Callers must handle null.
+ * Never throws on missing-file; only throws on malformed JSON or
+ * structurally invalid sections.
+ */
+export async function getConfig(repoPath) {
+  if (!repoPath) {
+    return { domains: null, policy: null, budgets: null, watches: null, wiki: { autoEvery: 'off' }, auto_reindex: { onCommit: false }, incremental: { preWarm: false, preWarmCommits: 50, preWarmPerTick: 10 }, _sources: {} };
+  }
+
+  // Read all three candidates in parallel — they're tiny and most
+  // repos have at most one of them.
+  const [unified, legacyDomains, legacyPolicy] = await Promise.all([
+    readJsonIfExists(join(repoPath, UNIFIED_FILENAME)),
+    readJsonIfExists(join(repoPath, LEGACY_DOMAINS_FILENAME)),
+    readJsonIfExists(join(repoPath, LEGACY_POLICY_FILENAME)),
+  ]);
+
+  let domains = null;
+  let policy = null;
+  let budgets = null;
+  let watches = null;
+  let autoSnapshot = null;
+  let wiki = { autoEvery: 'off' };
+  let autoReindex = { onCommit: false };
+  let incremental = { preWarm: false, preWarmCommits: 50, preWarmPerTick: 10 };
+  const sources = { domains: null, policy: null };
+
+  if (unified.exists) {
+    let parsed;
+    try {
+      parsed = JSON.parse(unified.raw);
+    } catch (err) {
+      throw new Error(`Invalid JSON in ${UNIFIED_FILENAME}: ${err.message}`);
+    }
+    if (parsed?.domains) {
+      domains = parseDomains(parsed, UNIFIED_FILENAME);
+      sources.domains = 'unified';
+    }
+    if (parsed?.policy) {
+      policy = parsePolicy(parsed, UNIFIED_FILENAME);
+      sources.policy = 'unified';
+    }
+    budgets = parseBudgets(parsed);
+    watches = parseWatches(parsed);
+    autoSnapshot = parseAutoSnapshot(parsed);
+    wiki = parseWiki(parsed);
+    autoReindex = parseAutoReindex(parsed);
+    incremental = parseIncrementalConfig(parsed);
+
+    if (legacyDomains.exists) {
+      warnOnce(
+        repoPath,
+        LEGACY_DOMAINS_FILENAME,
+        `${repoPath}: ${LEGACY_DOMAINS_FILENAME} shadowed by ${UNIFIED_FILENAME}.domains — please delete the legacy file.`,
+      );
+    }
+    if (legacyPolicy.exists) {
+      warnOnce(
+        repoPath,
+        LEGACY_POLICY_FILENAME,
+        `${repoPath}: ${LEGACY_POLICY_FILENAME} shadowed by ${UNIFIED_FILENAME}.policy — please delete the legacy file.`,
+      );
+    }
+  }
+
+  // Fall back to legacy files for sections still unset.
+  if (domains === null && legacyDomains.exists) {
+    let parsed;
+    try {
+      parsed = JSON.parse(legacyDomains.raw);
+    } catch (err) {
+      throw new Error(`Invalid JSON in ${LEGACY_DOMAINS_FILENAME}: ${err.message}`);
+    }
+    domains = parseDomains(parsed, LEGACY_DOMAINS_FILENAME);
+    sources.domains = 'legacy';
+    warnOnce(
+      repoPath,
+      LEGACY_DOMAINS_FILENAME,
+      `${repoPath}: ${LEGACY_DOMAINS_FILENAME} is deprecated, migrate to ${UNIFIED_FILENAME}.domains (Tier 2bis.4).`,
+    );
+  }
+
+  if (policy === null && legacyPolicy.exists) {
+    let parsed;
+    try {
+      parsed = JSON.parse(legacyPolicy.raw);
+    } catch (err) {
+      throw new Error(`Invalid JSON in ${LEGACY_POLICY_FILENAME}: ${err.message}`);
+    }
+    policy = parsePolicy(parsed, LEGACY_POLICY_FILENAME);
+    sources.policy = 'legacy';
+    warnOnce(
+      repoPath,
+      LEGACY_POLICY_FILENAME,
+      `${repoPath}: ${LEGACY_POLICY_FILENAME} is deprecated, migrate to ${UNIFIED_FILENAME}.policy (Tier 2bis.4).`,
+    );
+  }
+
+  return { domains, policy, budgets, watches, autoSnapshot, wiki, auto_reindex: autoReindex, incremental, _sources: sources };
+}
+
+/**
+ * Used by /dissonance to surface the "no config" error with an
+ * example payload. Exposed so the example stays single-source.
+ */
+export const EXAMPLE_UNIFIED_CONFIG = {
+  domains: {
+    auth: ['src/auth/**', 'src/middleware/auth*.py'],
+    billing: ['src/billing/**', 'tests/billing/**'],
+    data: ['src/db/**', 'src/models/**'],
+  },
+  policy: {
+    isolation_required: false,
+    reason: '',
+    allow_merge_with: [],
+  },
+};
+
+/** Filename constants exposed for diagnostics / docs. */
+export const CONFIG_FILENAMES = {
+  unified: UNIFIED_FILENAME,
+  legacyDomains: LEGACY_DOMAINS_FILENAME,
+  legacyPolicy: LEGACY_POLICY_FILENAME,
+};
diff --git a/docker-server-connectors-core.mjs b/docker-server-connectors-core.mjs
