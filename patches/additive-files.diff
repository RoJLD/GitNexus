index 00000000..d616ecc4
--- /dev/null
+++ b/docker-server-connectors-core.mjs
@@ -0,0 +1,44 @@
+// upstream/docker-server-connectors-core.mjs
+//
+// Pure helpers for connector framework (Section B of the
+// roadmap-predictive Cleanup + Connectors plan, 2026-05-26).
+//
+// Exposes:
+//   - tokenize(s)           : string → token array (lowercase, alphanum)
+//   - jaccardSimilarity(a,b): array, array → number in [0, 1]
+//   - fuzzyMatchTicketToGhost(ticket, ghosts, threshold) :
+//       returns { ghost, score } | null
+
+export function tokenize(s) {
+  if (!s || typeof s !== 'string') return [];
+  return s.toLowerCase().split(/[^a-z0-9]+/).filter(Boolean);
+}
+
+export function jaccardSimilarity(a, b) {
+  const sa = new Set(a);
+  const sb = new Set(b);
+  if (sa.size === 0 && sb.size === 0) return 1;
+  let intersect = 0;
+  for (const x of sa) if (sb.has(x)) intersect++;
+  const union = sa.size + sb.size - intersect;
+  return union === 0 ? 0 : intersect / union;
+}
+
+export function fuzzyMatchTicketToGhost(ticket, ghosts, threshold = 0.7) {
+  const ticketTokens = [
+    ...tokenize(ticket.title || ''),
+    ...tokenize(ticket.description || ''),
+  ];
+  let best = null;
+  for (const g of ghosts || []) {
+    const ghostTokens = [
+      ...tokenize(g.title || ''),
+      ...tokenize(g.declared?.description || ''),
+    ];
+    const score = jaccardSimilarity(ticketTokens, ghostTokens);
+    if (score >= threshold && (!best || score > best.score)) {
+      best = { ghost: g, score };
+    }
+  }
+  return best;
+}
diff --git a/docker-server-connectors.mjs b/docker-server-connectors.mjs
new file mode 100644
index 00000000..d16bdbbc
--- /dev/null
+++ b/docker-server-connectors.mjs
@@ -0,0 +1,126 @@
+// upstream/docker-server-connectors.mjs
+//
+// `/ghosts/connector-suggestions` endpoint — reads .gitnexus.json's
+// `connectors.*` config for a repo, runs each enabled connector's
+// fetchOpenWorkItems + fetchClosedWorkItems, fuzzy-matches each ticket
+// against the latest ghosts, and returns
+//   { suggestions: [{ ghostId, connectorName, ticketRef, suggestedAction, ... }] }
+//
+// Connectors live under ./connectors/*.mjs. Each one must export an
+// object with `fetchOpenWorkItems(cfg)` and `fetchClosedWorkItems(cfg)`.
+
+import { fuzzyMatchTicketToGhost } from './docker-server-connectors-core.mjs';
+import { readLatestGhosts } from './docker-server-ghosts.mjs';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { planeConnector } from './connectors/plane.mjs';
+import { linearConnector } from './connectors/linear.mjs';
+import { githubConnector } from './connectors/github.mjs';
+import { jiraConnector } from './connectors/jira.mjs';
+import { readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+
+const CONNECTORS = {
+  plane: planeConnector,
+  linear: linearConnector,
+  github: githubConnector,
+  jira: jiraConnector,
+};
+
+async function loadConnectorConfig(repoPath) {
+  try {
+    const raw = await readFile(join(repoPath, '.gitnexus.json'), 'utf8');
+    const cfg = JSON.parse(raw);
+    return cfg?.connectors || {};
+  } catch { return {}; }
+}
+
+function envFor(name) {
+  switch (name) {
+    case 'plane': return process.env.PLANE_API_KEY;
+    case 'linear': return process.env.LINEAR_API_KEY;
+    case 'github': return process.env.GITHUB_TOKEN;
+    case 'jira': return process.env.JIRA_API_TOKEN;
+    default: return null;
+  }
+}
+
+export async function buildConnectorSuggestions(repoPath) {
+  const runtime = await readLatestGhosts(repoPath);
+  if (!runtime) return { suggestions: [] };
+  const ghosts = runtime.ghosts || [];
+  const connectorConfig = await loadConnectorConfig(repoPath);
+
+  const suggestions = [];
+  for (const [name, connector] of Object.entries(CONNECTORS)) {
+    const cfg = connectorConfig[name];
+    if (!cfg || cfg.enabled !== true) continue;
+    const apiKey = cfg.apiKey || envFor(name);
+    let openItems = [], closedItems = [];
+    try {
+      openItems = await connector.fetchOpenWorkItems({ ...cfg, apiKey });
+      closedItems = await connector.fetchClosedWorkItems({ ...cfg, apiKey });
+    } catch (err) {
+      suggestions.push({ connectorName: name, error: err.message });
+      continue;
+    }
+    for (const ticket of openItems) {
+      const match = fuzzyMatchTicketToGhost(ticket, ghosts, cfg.matchThreshold ?? 0.7);
+      if (match) {
+        suggestions.push({
+          ghostId: match.ghost.id,
+          connectorName: name,
+          ticketRef: ticket.id,
+          ticketTitle: ticket.title,
+          suggestedAction: 'reaffirm',
+          rationale: `${name} ticket "${ticket.title}" still open (score ${match.score.toFixed(2)})`,
+          externalUrl: ticket.externalUrl,
+        });
+      }
+    }
+    for (const ticket of closedItems) {
+      const match = fuzzyMatchTicketToGhost(ticket, ghosts, cfg.matchThreshold ?? 0.7);
+      if (match) {
+        suggestions.push({
+          ghostId: match.ghost.id,
+          connectorName: name,
+          ticketRef: ticket.id,
+          ticketTitle: ticket.title,
+          suggestedAction: 'cancel',
+          rationale: `${name} ticket "${ticket.title}" closed (score ${match.score.toFixed(2)})`,
+          externalUrl: ticket.externalUrl,
+        });
+      }
+    }
+  }
+  return { suggestions };
+}
+
+async function handleConnectorSuggestions(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: 'missing repo' }));
+  }
+  const repo = await findRepoByName(repoName, opts.api);
+  if (!repo) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+  }
+  const repoPath = repo.repoPath || repo.path;
+  try {
+    const result = await buildConnectorSuggestions(repoPath);
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(result));
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+export async function handleConnectorsRoute(req, url, res, opts) {
+  if (url.pathname === '/ghosts/connector-suggestions' && req.method === 'GET') {
+    await handleConnectorSuggestions(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-coupling-cross.mjs b/docker-server-coupling-cross.mjs
new file mode 100644
index 00000000..0f8e30ee
--- /dev/null
+++ b/docker-server-coupling-cross.mjs
@@ -0,0 +1,289 @@
+/**
+ * Cross-repo temporal coupling — ROADMAP Tier 1.2.
+ *
+ * Endpoint:
+ *   GET /coupling/cross?repos=A,B[,C][&windowHours=24][&top=100][&format=csv]
+ *
+ * Detects pairs of files in *different* repos that tend to change in
+ * the same time window. The signal is "hidden inter-service coupling"
+ * — when a contract change in repo A reliably triggers a follow-up in
+ * repo B, you have a soft dependency the repo graphs don't show.
+ *
+ * --- Why git log rather than snapshots ---
+ *
+ * The single-repo /coupling endpoint diffs snapshots because that's
+ * what gitnexus persists. Cross-repo is sparser: two repos rarely have
+ * snapshots taken at exactly the same time, so consecutive-snapshot
+ * diffing would miss the actual co-change events. Git commit dates are
+ * the source of truth — they're continuous, every change is timestamped
+ * the moment the developer committed, and the windowing approach maps
+ * naturally onto "what was touched in the same hour / day".
+ *
+ * --- Algorithm ---
+ *
+ *   1. For each repo, run `git log --pretty=format:%aI --name-only --no-merges`.
+ *      One row per (commit date ISO, file path) tuple.
+ *   2. Bucket each row into a window of `windowHours` hours
+ *      (rounded down from epoch). Same window → same bucket id.
+ *   3. For each bucket, collect the set of (repo, file) entries touched.
+ *   4. For every cross-repo pair within a bucket, increment a counter.
+ *   5. Jaccard per pair using the totals from step 2.
+ *
+ * Pairs are sorted by Jaccard desc, then count desc. We cap at `top`
+ * (default 100) so a multi-thousand-file scan doesn't ship a 5 MB
+ * response.
+ */
+
+import { spawn } from 'node:child_process';
+import { stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const DEFAULT_WINDOW_HOURS = 24;
+const DEFAULT_TOP = 100;
+const MAX_REPOS = 8;
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+/**
+ * Parse `git log --pretty=format:%aI --name-only --no-merges` output.
+ * Returns an array of { date: ISO, files: string[] } (one per commit).
+ *
+ * The format alternates:
+ *   <iso-date>\n
+ *   file1\n
+ *   file2\n
+ *   \n   (blank line between commits)
+ */
+function parseLog(stdout) {
+  const commits = [];
+  let date = null;
+  let files = [];
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      if (date !== null) {
+        commits.push({ date, files });
+        date = null;
+        files = [];
+      }
+      continue;
+    }
+    if (date === null) {
+      date = line;
+      continue;
+    }
+    files.push(line);
+  }
+  if (date !== null) commits.push({ date, files });
+  return commits;
+}
+
+function bucketIdOf(isoDate, windowMs) {
+  const t = Date.parse(isoDate);
+  if (!Number.isFinite(t)) return null;
+  return Math.floor(t / windowMs);
+}
+
+async function handleCouplingCross(url, res, opts) {
+  const reposParam = url.searchParams.get('repos');
+  if (!reposParam) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repos (comma-separated)' }));
+    return;
+  }
+  const repoNames = reposParam
+    .split(',')
+    .map((s) => s.trim())
+    .filter(Boolean)
+    .filter((s) => !s.includes('@')) // snapshots don't make sense cross-repo
+    .slice(0, MAX_REPOS);
+  if (repoNames.length < 2) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'need at least 2 distinct repos' }));
+    return;
+  }
+
+  const windowHours = Math.max(1, Math.min(720, Number(url.searchParams.get('windowHours')) || DEFAULT_WINDOW_HOURS));
+  const windowMs = windowHours * 3600 * 1000;
+  const top = Math.max(1, Math.min(1000, Number(url.searchParams.get('top')) || DEFAULT_TOP));
+
+  // Resolve each repo and pull its git log. Fail loudly on any
+  // not-found / not-git so the user fixes the input rather than
+  // silently getting empty data.
+  const repos = [];
+  for (const name of repoNames) {
+    const meta = await findRepoByName(name, opts.api);
+    if (!meta) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${name}` }));
+      return;
+    }
+    const repoPath = meta.repoPath || meta.path;
+    const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
+    if (!hasGit) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `${name} at ${repoPath} is not a git repo (cross-repo needs git history)` }));
+      return;
+    }
+    repos.push({ name, repoPath });
+  }
+
+  // Sequential log scans — these are I/O-bound but cheap; parallelizing
+  // doesn't help much and lets stderr from one repo bleed into another.
+  const allCommits = [];
+  for (const r of repos) {
+    let log;
+    try {
+      log = await runCmd('git', [
+        '-C',
+        r.repoPath,
+        'log',
+        '--pretty=format:%aI',
+        '--name-only',
+        '--no-merges',
+      ]);
+    } catch (err) {
+      res.writeHead(500, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `git log failed for ${r.name}: ${err.message}` }));
+      return;
+    }
+    const commits = parseLog(log);
+    for (const c of commits) {
+      for (const f of c.files) {
+        allCommits.push({ repo: r.name, date: c.date, file: f });
+      }
+    }
+  }
+
+  // Build per-bucket sets of (repo, file). Same-bucket = "touched in
+  // the same window". We use a colon-based composite key — neither
+  // repo names from /api/repos nor file paths contain whitespace
+  // sentinels like "~~::~~", so we use that as a delimiter.
+  const SEP = "~~::~~";
+  const PAIR_SEP = "~~//~~";
+  const bucketMembers = new Map();
+  const fileTotals = new Map();
+  const repoEarliest = new Map();
+  const repoLatest = new Map();
+
+  for (const { repo, date, file } of allCommits) {
+    const bid = bucketIdOf(date, windowMs);
+    if (bid === null) continue;
+    const key = repo + SEP + file;
+    let set = bucketMembers.get(bid);
+    if (!set) { set = new Set(); bucketMembers.set(bid, set); }
+    if (!set.has(key)) {
+      set.add(key);
+      fileTotals.set(key, (fileTotals.get(key) || 0) + 1);
+    }
+    if (!repoEarliest.has(repo) || date < repoEarliest.get(repo)) repoEarliest.set(repo, date);
+    if (!repoLatest.has(repo) || date > repoLatest.get(repo)) repoLatest.set(repo, date);
+  }
+
+  const splitEntry = (k) => {
+    const i = k.indexOf(SEP);
+    return [k.slice(0, i), k.slice(i + SEP.length)];
+  };
+
+  // For every bucket, all *cross-repo* pairs of members. Same-repo
+  // pairs are skipped — that is what the single-repo /coupling does.
+  const pairCount = new Map();
+  for (const set of bucketMembers.values()) {
+    if (set.size < 2) continue;
+    const arr = [...set];
+    for (let i = 0; i < arr.length; i++) {
+      const [repoA] = splitEntry(arr[i]);
+      for (let j = i + 1; j < arr.length; j++) {
+        const [repoB] = splitEntry(arr[j]);
+        if (repoA === repoB) continue;
+        const [p, q] = arr[i] < arr[j] ? [arr[i], arr[j]] : [arr[j], arr[i]];
+        const pairKey = p + PAIR_SEP + q;
+        pairCount.set(pairKey, (pairCount.get(pairKey) || 0) + 1);
+      }
+    }
+  }
+
+  // Compute Jaccard per pair.
+  const pairs = [];
+  for (const [key, count] of pairCount) {
+    const sepIdx = key.indexOf(PAIR_SEP);
+    const pa = key.slice(0, sepIdx);
+    const pb = key.slice(sepIdx + PAIR_SEP.length);
+    const [repoA, fileA] = splitEntry(pa);
+    const [repoB, fileB] = splitEntry(pb);
+    const cA = fileTotals.get(pa) || 1;
+    const cB = fileTotals.get(pb) || 1;
+    const jaccard = count / (cA + cB - count);
+    pairs.push({
+      a: { repo: repoA, path: fileA },
+      b: { repo: repoB, path: fileB },
+      count,
+      jaccard,
+    });
+  }
+  pairs.sort((x, y) => y.jaccard - x.jaccard || y.count - x.count);
+  const truncated = pairs.slice(0, top);
+
+  const meta = {
+    repos: repoNames,
+    windowHours,
+    totalBuckets: bucketMembers.size,
+    totalCrossPairs: pairs.length,
+    perRepoSpan: Object.fromEntries(
+      repoNames.map((name) => [
+        name,
+        {
+          earliest: repoEarliest.get(name) || null,
+          latest: repoLatest.get(name) || null,
+        },
+      ]),
+    ),
+  };
+
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = truncated.map((p) => ({
+      repoA: p.a.repo,
+      fileA: p.a.path,
+      repoB: p.b.repo,
+      fileB: p.b.path,
+      coChanges: p.count,
+      jaccard: p.jaccard,
+    }));
+    const csv = toCsv(rows, [
+      { key: 'repoA' },
+      { key: 'fileA' },
+      { key: 'repoB' },
+      { key: 'fileB' },
+      { key: 'coChanges' },
+      { key: 'jaccard' },
+    ]);
+    writeCsv(res, `${safeFilename(repoNames.join('-vs-'))}-coupling-cross.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ...meta, pairs: truncated }));
+}
+
+export async function handleCouplingCrossRoute(req, url, res, opts) {
+  if (url.pathname === '/coupling/cross' && req.method === 'GET') {
+    await handleCouplingCross(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-coupling.mjs b/docker-server-coupling.mjs
new file mode 100644
index 00000000..e1e2ebdf
--- /dev/null
+++ b/docker-server-coupling.mjs
@@ -0,0 +1,266 @@
+/**
+ * Temporal coupling analytics — Phase 4B.
+ *
+ * Endpoint:
+ *   GET /coupling?repo=<baseRepoName>&top=<n>
+ *
+ * Across the snapshot timeline of <baseRepoName> (snapshots + live), for
+ * each consecutive transition we extract the set of FILES touched (a file
+ * is "touched" if any node attributed to it was added or removed). For
+ * every pair of files in that set we increment a co-occurrence counter,
+ * and we expose the strongest couplings ranked by Jaccard similarity.
+ *
+ * Interpretation:
+ *   - High Jaccard between A and B → "they almost always change together"
+ *     This is the bread and butter of architectural reverse-engineering:
+ *     a strong but non-architectural link (e.g. login.py always changes
+ *     with auth_test.py) reveals hidden coupling, design rules, or
+ *     repeated patterns.
+ *   - Low individual count + high Jaccard → coupling could be coincidence.
+ *     We expose `count` so the UI can filter out rare-but-paired files.
+ *
+ * Granularity = file. The node graph has tens of thousands of nodes;
+ * coupling per function/class would be too noisy for a top-N list and
+ * harder to act on. Files are the natural unit for "what tends to change
+ * together" in most refactoring/patterns analyses.
+ *
+ * Response shape:
+ *   {
+ *     totalTransitions: number,
+ *     timeline: [{ name, isLive, date }],
+ *     fileChangeCount: { [filePath]: number },
+ *     pairs: [{ a, b, count, jaccard }],   // sorted desc by jaccard
+ *     errors?: [...]
+ *   }
+ */
+
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { readdir, readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import { SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const COUPLING_REGRESSION_THRESHOLD = Number(process.env.COUPLING_REGRESSION_THRESHOLD) || 0.5;
+
+async function listSnapshotNamesAndDates(repoName) {
+  const repoSnapshotsDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(repoSnapshotsDir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(
+        await readFile(join(repoSnapshotsDir, e.name, 'commit.json'), 'utf8'),
+      );
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built snapshot; skip
+    }
+  }
+  return out;
+}
+
+// Extract the owning file path from a node id. gitnexus IDs follow a few
+// conventions:
+//   File:<path>                              → the file itself
+//   Folder:<path>                            → not a file (skipped)
+//   Function:<path>:<name>[:<line>]          → owned by <path>
+//   Class:<path>:<name>[:<line>]             → owned by <path>
+//   Variable:<path>:<name>                   → owned by <path>
+//   Section:<path>:<L?>:<title>              → owned by <path>
+//   Community:<n>, Process:<n>, comm_<n>     → no file
+// We pick the segment immediately after the first ":" and treat it as the
+// owning file path. Returns null for things we can't attribute (e.g.
+// communities / processes — synthetic nodes).
+const NON_FILE_LABELS = new Set([
+  'Community',
+  'Process',
+  'Folder',
+  'Repository',
+  'Group',
+]);
+function fileOfNodeId(id) {
+  if (typeof id !== 'string' || !id.includes(':')) return null;
+  const colon = id.indexOf(':');
+  const label = id.slice(0, colon);
+  if (NON_FILE_LABELS.has(label)) return null;
+  // Synthetic ids like "comm_5" have no label / colon — already returned above.
+  const rest = id.slice(colon + 1);
+  // Everything up to the next ":" is the file path. Some node ids embed
+  // a path that itself contains nothing-but-letters (e.g. "Section:Quick" —
+  // but those are unlikely; we treat them as file path = `rest`).
+  const next = rest.indexOf(':');
+  return next === -1 ? rest : rest.slice(0, next);
+}
+
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+async function handleCoupling(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const top = Math.max(1, Math.min(500, Number(url.searchParams.get('top')) || 50));
+  const asOf = url.searchParams.get('asOf');
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ].sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  let effectiveTimeline = timeline;
+  if (asOf) {
+    const cut = Date.parse(asOf);
+    if (Number.isFinite(cut)) effectiveTimeline = timeline.filter((t) => Date.parse(t.date) <= cut);
+  }
+
+  if (effectiveTimeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        totalTransitions: 0,
+        timeline,
+        pairs: [],
+        fileChangeCount: {},
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) to compute coupling.',
+      }),
+    );
+    return;
+  }
+
+  // Collect each snapshot's node-id set sequentially (same reason as
+  // /churn: the gitnexus REST lbug cache is single-entry, parallel access
+  // would thrash it).
+  const idSets = [];
+  const errors = [];
+  for (const point of effectiveTimeline) {
+    try {
+      const ids = await fetchNodeIds(point.name, opts.api);
+      idSets.push(new Set(ids));
+    } catch (err) {
+      errors.push({ snapshot: point.name, error: err?.message || 'fetch failed' });
+      // Push an empty set so the downstream index alignment stays correct.
+      idSets.push(new Set());
+    }
+  }
+
+  // For each transition, build the set of FILES touched (any node added
+  // or removed maps to its owning file). Then bump cooccur for each pair.
+  const fileChangeCount = Object.create(null);
+  const pairCount = new Map(); // key: "a\0b" (sorted), val: count
+  const totalTransitions = idSets.length - 1;
+
+  for (let i = 0; i < totalTransitions; i++) {
+    const a = idSets[i];
+    const b = idSets[i + 1];
+    const touchedFiles = new Set();
+
+    // Added: in b but not in a.
+    for (const id of b) {
+      if (!a.has(id)) {
+        const file = fileOfNodeId(id);
+        if (file) touchedFiles.add(file);
+      }
+    }
+    // Removed: in a but not in b.
+    for (const id of a) {
+      if (!b.has(id)) {
+        const file = fileOfNodeId(id);
+        if (file) touchedFiles.add(file);
+      }
+    }
+
+    if (touchedFiles.size === 0) continue;
+
+    const filesArr = [...touchedFiles];
+    for (const f of filesArr) {
+      fileChangeCount[f] = (fileChangeCount[f] || 0) + 1;
+    }
+    // All unordered pairs of touched files. Sort the two paths so each
+    // pair has a canonical key regardless of which file is "a" or "b".
+    for (let x = 0; x < filesArr.length; x++) {
+      for (let y = x + 1; y < filesArr.length; y++) {
+        const [p, q] = filesArr[x] < filesArr[y]
+          ? [filesArr[x], filesArr[y]]
+          : [filesArr[y], filesArr[x]];
+        const key = `${p}\0${q}`;
+        pairCount.set(key, (pairCount.get(key) || 0) + 1);
+      }
+    }
+  }
+
+  // Compute Jaccard per pair. Symmetric measure: count(A ∩ B) / count(A ∪ B)
+  // where each "count" is the number of transitions touching that file (or
+  // both). |A ∪ B| = changes(A) + changes(B) - cooccur(A, B).
+  const pairs = [];
+  for (const [key, count] of pairCount) {
+    const [a, b] = key.split('\0');
+    const cA = fileChangeCount[a] || 1;
+    const cB = fileChangeCount[b] || 1;
+    const jaccard = count / (cA + cB - count);
+    pairs.push({ a, b, count, jaccard });
+  }
+  pairs.sort((x, y) => y.jaccard - x.jaccard || y.count - x.count);
+
+  const truncated = pairs.slice(0, top);
+
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(truncated, [
+      { key: 'a', header: 'fileA' },
+      { key: 'b', header: 'fileB' },
+      { key: 'count', header: 'coChanges' },
+      { key: 'jaccard' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-coupling.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalTransitions,
+      timeline,
+      fileChangeCount,
+      pairs: truncated,
+      pairsAboveThreshold: pairs.filter((p) => typeof p.jaccard === 'number' && p.jaccard >= COUPLING_REGRESSION_THRESHOLD).length,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+export async function handleCouplingRoute(req, url, res, opts) {
+  if (url.pathname === '/coupling' && req.method === 'GET') {
+    await handleCoupling(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-csv.mjs b/docker-server-csv.mjs
new file mode 100644
index 00000000..d9de47e6
--- /dev/null
+++ b/docker-server-csv.mjs
@@ -0,0 +1,57 @@
+/**
+ * Minimal CSV serialization for the analytics endpoints' `?format=csv`
+ * branch. Tiny and self-contained — we don't pull in a CSV lib for the
+ * three operations we actually do (string quoting, joining, header
+ * row).
+ */
+
+/**
+ * Quote a single CSV cell. RFC 4180 rules:
+ *   - wrap in double quotes if the value contains `,`, `"`, CR, or LF
+ *   - inside the quotes, escape `"` as `""`
+ * Numbers / booleans are stringified untouched, null/undefined render
+ * as empty.
+ */
+function csvCell(v) {
+  if (v == null) return '';
+  const s = typeof v === 'string' ? v : String(v);
+  if (/[",\r\n]/.test(s)) return `"${s.replace(/"/g, '""')}"`;
+  return s;
+}
+
+/**
+ * Convert an array of row objects to a CSV string.
+ *   columns: ordered list of { key, header? }
+ * If `header` is omitted, `key` doubles as the header label.
+ *
+ * Streaming wasn't worth the complexity at our scale — analytics
+ * payloads are <100k rows in practice and fit in memory comfortably.
+ */
+export function toCsv(rows, columns) {
+  const header = columns.map((c) => csvCell(c.header ?? c.key)).join(',');
+  const body = rows
+    .map((row) => columns.map((c) => csvCell(row[c.key])).join(','))
+    .join('\n');
+  return header + '\n' + body + (body ? '\n' : '');
+}
+
+/**
+ * Helper for endpoint handlers: write the response with the right
+ * headers and a download-friendly filename derived from the repo name.
+ */
+export function writeCsv(res, filename, csv) {
+  res.writeHead(200, {
+    'Content-Type': 'text/csv; charset=utf-8',
+    'Content-Disposition': `attachment; filename="${filename}"`,
+    'Cache-Control': 'no-store',
+  });
+  res.end(csv);
+}
+
+/**
+ * Sanitize a string so it's safe as part of a CSV filename — keep
+ * alphanumerics, dashes, underscores, dots; replace the rest with `_`.
+ */
+export function safeFilename(s) {
+  return String(s).replace(/[^A-Za-z0-9._-]/g, '_').slice(0, 80) || 'export';
+}
diff --git a/docker-server-dissonance.mjs b/docker-server-dissonance.mjs
new file mode 100644
index 00000000..449ec76d
--- /dev/null
+++ b/docker-server-dissonance.mjs
@@ -0,0 +1,341 @@
+/**
+ * Dissonance analytics — ROADMAP Tier 2.2.
+ *
+ * Endpoint:
+ *   GET /dissonance?repo=<baseRepoName>[&format=csv]
+ *
+ * Reads `<repoPath>/.gitnexus-domains.json` (a user-curated mapping of
+ * domain names to file-path globs) and compares the *declared* domain
+ * partition with gitnexus's *detected* community partition. Returns:
+ *
+ *   - per-file rows showing its declared domain, its dominant community,
+ *     and whether the two agree
+ *   - a contingency matrix domain × community (counts of files)
+ *   - a global "domain purity" score in [0,1]:
+ *       purity = Σ_d max_c |files(d) ∩ files(c)| / total_files
+ *     A purity of 1 means each domain lives entirely in one community —
+ *     architectural code-to-domain alignment. Lower = more leaky.
+ *   - a "misplaced" list: files whose community doesn't match the
+ *     majority community of their declared domain. These are the
+ *     candidates for refactoring or for re-categorisation.
+ *
+ * --- Why this design ---
+ *
+ * gitnexus's community detection runs on CALLS edges, so communities
+ * primarily group Functions/Classes/Methods. We climb back to the
+ * owning file via DEFINES (single hop), then pick the community that
+ * "wins" for each file by symbol count. Files with no defined symbols
+ * (configs, docs) have no community attribution — we list them
+ * separately so the user can decide whether to ignore them or extend
+ * their domain definition.
+ *
+ * --- The .gitnexus-domains.json format ---
+ *
+ * Lives at the repo root. JSON because Node has no YAML in stdlib and
+ * pulling a parser for one config file isn't worth it.
+ *
+ *   {
+ *     "domains": {
+ *       "auth":    ["src/auth/**", "src/middleware/auth*.py"],
+ *       "billing": ["src/billing/**", "tests/billing/**"],
+ *       "data":    ["src/db/**", "src/models/**"]
+ *     }
+ *   }
+ *
+ * Globs support `**` (any subpath including empty), `*` (any path
+ * segment, no slashes), and literal characters. First match wins —
+ * order domains from most specific to least specific in your file.
+ */
+
+import { readFile, stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+import { getConfig, CONFIG_FILENAMES, EXAMPLE_UNIFIED_CONFIG } from './docker-server-config.mjs';
+
+const DOMAINS_FILENAME = CONFIG_FILENAMES.legacyDomains;
+
+/**
+ * Convert a glob with `**` and `*` into a RegExp. Anchored at both
+ * ends. Doesn't try to be a full minimatch — supports just what the
+ * config format actually uses.
+ */
+function globToRegex(glob) {
+  // Escape regex metacharacters first.
+  let re = glob.replace(/[.+^$(){}|[\]\\]/g, '\\$&');
+  // Then translate ** → any (including empty + slashes) and * → no slash
+  // We use placeholders to avoid the single-* substitution catching the
+  // chars we just emitted for **.
+  re = re.replace(/\*\*/g, 'XGLOBSTARX').replace(/\*/g, 'XSTARX');
+  re = re.replace(/XGLOBSTARX/g, '.*').replace(/XSTARX/g, '[^/]*');
+  return new RegExp('^' + re + '$');
+}
+
+// Compile a validated { name: [globs] } map (from getConfig) into the
+// [{ name, patterns, regexes }] shape this module operates on. Globs
+// → regexes once, reused per request. Validation (presence, shape)
+// happens inside getConfig — this function only compiles.
+function compileDomains(domainsMap) {
+  return Object.entries(domainsMap).map(([name, patterns]) => ({
+    name,
+    patterns,
+    regexes: patterns.map(globToRegex),
+  }));
+}
+
+function classifyFile(filePath, domains) {
+  // First-match-wins, matching the user's mental model: explicit ordering
+  // in the config file controls which domain claims overlapping files.
+  for (const d of domains) {
+    for (const re of d.regexes) {
+      if (re.test(filePath)) return d.name;
+    }
+  }
+  return null;
+}
+
+/**
+ * For each file, find the community where it has the most defined
+ * symbols. Returns Map<filePath, { communityId, label, symbolCount }>.
+ *
+ * Files with no symbol-bearing children (e.g. README.md, mkdocs.yml)
+ * are absent from the map — we surface them in the "unclassified"
+ * bucket of the response.
+ */
+async function fetchFileCommunities(repoName, api) {
+  // The relationship is stored as a generic `CodeRelation` with a `type`
+  // property. We pull file + community + a count of symbols per file
+  // per community in one go, then pick the majority per file in JS.
+  const cypher = `
+    MATCH (f:File)-[:CodeRelation {type: 'DEFINES'}]->(s)
+          -[:CodeRelation {type: 'MEMBER_OF'}]->(c:Community)
+    RETURN f.filePath AS file, c.id AS community, c.heuristicLabel AS label, count(s) AS cnt
+  `;
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher, repo: repoName }),
+  });
+  if (!resp.ok) {
+    throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  }
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+
+  // Bucket by file, then pick the row with the highest cnt.
+  const perFile = new Map(); // file → [{community, label, cnt}, ...]
+  for (const row of rows) {
+    const file = row.file ?? row['f.filePath'];
+    const community = row.community ?? row['c.id'];
+    const label = row.label ?? row['c.heuristicLabel'] ?? null;
+    const cnt = Number(row.cnt ?? row['count(s)'] ?? 0);
+    if (typeof file !== 'string' || typeof community !== 'string') continue;
+    const arr = perFile.get(file) || [];
+    arr.push({ community, label, cnt });
+    perFile.set(file, arr);
+  }
+
+  const dominant = new Map();
+  for (const [file, arr] of perFile) {
+    arr.sort((a, b) => b.cnt - a.cnt);
+    const top = arr[0];
+    dominant.set(file, {
+      communityId: top.community,
+      label: top.label,
+      symbolCount: top.cnt,
+      // Confidence = winner share. 1 = unambiguous owner; 0.5 = split.
+      confidence: arr.reduce((s, x) => s + x.cnt, 0)
+        ? top.cnt / arr.reduce((s, x) => s + x.cnt, 0)
+        : 0,
+    });
+  }
+  return dominant;
+}
+
+async function handleDissonance(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+
+  // Tier 2bis.4: read via the unified config parser. Returns the
+  // domains section whether it comes from .gitnexus.json or the
+  // legacy .gitnexus-domains.json (with deprecation warning).
+  let cfg;
+  try {
+    cfg = await getConfig(repoPath);
+  } catch (err) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+    return;
+  }
+  if (!cfg.domains || Object.keys(cfg.domains).length === 0) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        error: `No domain mapping at ${repoPath}. Create either ${CONFIG_FILENAMES.unified} (preferred — unified config) or ${CONFIG_FILENAMES.legacyDomains} (legacy) to enable dissonance analysis.`,
+        example: EXAMPLE_UNIFIED_CONFIG,
+      }),
+    );
+    return;
+  }
+  const domains = compileDomains(cfg.domains);
+
+  // Get the file→community map. If gitnexus has no communities for this
+  // repo (e.g. it hasn't been analyzed with that phase), we still emit
+  // a sensible response with everything in "unclassified".
+  let fileToCommunity;
+  try {
+    // Snapshot support: query the snapshot graph (full repoName incl. @sha) but
+    // keep the LIVE domain config (domains rarely change per snapshot). Best-effort
+    // — if the snapshot graph isn't loaded in the API, fetchFileCommunities yields
+    // no communities and the caller handles it gracefully.
+    fileToCommunity = await fetchFileCommunities(repoName, opts.api);
+  } catch (err) {
+    res.writeHead(502, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `community lookup failed: ${err.message}` }));
+    return;
+  }
+
+  // Collect all files involved (declared OR community-assigned). We need
+  // every file even if it has only a domain (so we can flag "domain
+  // declared but no symbols/community").
+  const allFiles = new Set();
+  for (const f of fileToCommunity.keys()) allFiles.add(f);
+  // For the declared side, we don't enumerate files — instead we apply
+  // globs against the set we already have. That keeps the response
+  // bounded to files gitnexus actually knows about.
+
+  // Per-file rows + contingency.
+  const rows = [];
+  const contingency = {}; // domain → { community → count }
+  const filesByDomain = {}; // domain → string[]
+  const filesByCommunity = {}; // communityId → string[]
+  let totalAttributed = 0;
+  let totalDomainAttributed = 0;
+
+  for (const file of allFiles) {
+    const domain = classifyFile(file, domains);
+    const comm = fileToCommunity.get(file) || null;
+    rows.push({
+      file,
+      domain: domain ?? null,
+      communityId: comm?.communityId ?? null,
+      communityLabel: comm?.label ?? null,
+      confidence: comm?.confidence ?? null,
+      symbolCount: comm?.symbolCount ?? 0,
+    });
+    if (domain && comm) {
+      contingency[domain] ??= {};
+      contingency[domain][comm.communityId] = (contingency[domain][comm.communityId] || 0) + 1;
+      filesByDomain[domain] ??= [];
+      filesByDomain[domain].push(file);
+      filesByCommunity[comm.communityId] ??= [];
+      filesByCommunity[comm.communityId].push(file);
+      totalAttributed++;
+    }
+    if (domain) totalDomainAttributed++;
+  }
+
+  // Per-domain majority community + purity contribution.
+  const perDomain = [];
+  let weightedPuritySum = 0;
+  for (const [domain, byComm] of Object.entries(contingency)) {
+    const total = Object.values(byComm).reduce((s, c) => s + c, 0);
+    const ranked = Object.entries(byComm)
+      .map(([cid, cnt]) => ({ communityId: cid, count: cnt, share: cnt / total }))
+      .sort((a, b) => b.count - a.count);
+    const dominant = ranked[0];
+    perDomain.push({
+      domain,
+      filesTotal: total,
+      dominantCommunity: dominant.communityId,
+      dominantShare: dominant.share,
+      communitiesTouched: ranked.length,
+      breakdown: ranked,
+    });
+    weightedPuritySum += dominant.count;
+  }
+  const purity = totalAttributed > 0 ? weightedPuritySum / totalAttributed : 0;
+
+  // Misplaced files: file is in a community that's not its domain's
+  // dominant community. Surfaces the concrete refactor candidates.
+  const dominantByDomain = Object.fromEntries(
+    perDomain.map((d) => [d.domain, d.dominantCommunity]),
+  );
+  const misplaced = [];
+  for (const r of rows) {
+    if (!r.domain || !r.communityId) continue;
+    const expected = dominantByDomain[r.domain];
+    if (expected && r.communityId !== expected) {
+      misplaced.push({
+        file: r.file,
+        domain: r.domain,
+        actualCommunity: r.communityId,
+        actualCommunityLabel: r.communityLabel,
+        expectedCommunity: expected,
+        confidence: r.confidence,
+      });
+    }
+  }
+  misplaced.sort((a, b) => a.domain.localeCompare(b.domain) || a.file.localeCompare(b.file));
+
+  // Files with a domain but no community signal (typical for configs /
+  // docs). Surfaced separately so users can decide between extending
+  // their domain definition vs ignoring them.
+  const domainWithoutCommunity = rows
+    .filter((r) => r.domain && !r.communityId)
+    .map((r) => ({ file: r.file, domain: r.domain }));
+
+  // CSV branch: long-format per-file rows.
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(rows, [
+      { key: 'file' },
+      { key: 'domain' },
+      { key: 'communityId' },
+      { key: 'communityLabel' },
+      { key: 'symbolCount' },
+      { key: 'confidence' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-dissonance.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      repo: baseRepo,
+      totals: {
+        filesKnown: allFiles.size,
+        filesWithDomain: totalDomainAttributed,
+        filesAttributed: totalAttributed, // both domain AND community
+        domainsDeclared: domains.length,
+        communitiesSeen: Object.keys(filesByCommunity).length,
+      },
+      purity,
+      dissonance: 1 - purity,
+      perDomain,
+      misplaced,
+      domainWithoutCommunity,
+      contingency,
+    }),
+  );
+}
+
+export async function handleDissonanceRoute(req, url, res, opts) {
+  if (url.pathname === '/dissonance' && req.method === 'GET') {
+    await handleDissonance(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-entropy-commits.mjs b/docker-server-entropy-commits.mjs
new file mode 100644
index 00000000..eb95d3a9
--- /dev/null
+++ b/docker-server-entropy-commits.mjs
@@ -0,0 +1,350 @@
+/**
+ * Commit-level entropy delta — ROADMAP Tier 2bis.2.
+ *
+ * Endpoint:
+ *   GET /entropy/commits?repo=<base>[&from=<sha|iso>][&to=<sha|iso>]
+ *                       [&days=<N>][&format=csv]
+ *
+ * For each commit in the window, attribute a fraction of the entropy
+ * delta observed between the bracketing snapshots, proportional to
+ * the number of files that commit touched. Surfaces the PRs / commits
+ * that started a degradation (or improvement).
+ *
+ * --- Why an attribution-based MVP instead of per-commit re-analysis ---
+ *
+ * The ROADMAP spec proposes "compute Leiden modularity delta on the
+ * touched files + their import-graph neighbors" per commit. That's a
+ * per-commit graph rebuild, which means N×gitnexus analyze runs per
+ * window — minutes of latency, brittle on dirty working trees.
+ *
+ * The MVP here is different and explicit about it: we read the
+ * existing snapshot timeline (which gitnexus already produces and our
+ * /entropy endpoint already serves), compute the entropy deltas
+ * between adjacent snapshots, and distribute each delta to the
+ * commits that landed in that window, weighted by `filesTouched`.
+ *
+ * Honest framing:
+ *   - When two commits land in the same snapshot window, we can't tell
+ *     which one caused the delta. We split it proportionally.
+ *   - When 30 days separate two snapshots and one commit touched 1 file
+ *     while another touched 200, the big one absorbs nearly all the
+ *     attributed delta.
+ *   - Density/modularity are GLOBAL metrics — moving a function from
+ *     A to B can swing them even when nothing was "added" or "deleted".
+ *
+ * This is "bon enough pour détecter les sauts" (per the ROADMAP). For
+ * true per-commit causal entropy, snapshot every commit (Tier 1.x
+ * already supports this via the bulk snapshot endpoint).
+ *
+ * --- Response shape ---
+ *
+ *   {
+ *     "repo": "hmm_studio",
+ *     "method": "interpolation-by-touched-files",
+ *     "windowsCount": 5,
+ *     "totalCommits": 42,
+ *     "snapshotsUsed": ["2026-01-15", "2026-02-15", ..., "live"],
+ *     "commits": [
+ *       {
+ *         "sha": "abc123",
+ *         "shortSha": "abc123d",
+ *         "author": "Marie",
+ *         "date": "2026-02-10T14:30:00Z",
+ *         "filesTouched": 12,
+ *         "snapshotWindow": ["2026-02-01T00:00:00Z", "2026-02-15T00:00:00Z"],
+ *         "windowDensityDelta": -0.012,
+ *         "windowModularityDelta": +0.003,
+ *         "attributedDensityDelta": -0.003,
+ *         "attributedModularityDelta": +0.0008
+ *       },
+ *       ...
+ *     ],
+ *     "windows": [
+ *       { "from": "2026-01-15...", "to": "2026-02-15...",
+ *         "densityDelta": -0.012, "modularityDelta": +0.003,
+ *         "commitsInWindow": 11, "filesTouchedInWindow": 47 }
+ *     ]
+ *   }
+ *
+ * `from` / `to` accept either commit SHAs (mapped to their dates via
+ * git) or ISO dates. `days=N` is shorthand for "last N days from now".
+ * Defaults to days=90 if no window provided.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile, stat } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+import { runCmd, parseGitLog, resolveWindowEnd } from './docker-server-git-utils.mjs';
+
+const DEFAULT_DAYS = 90;
+
+async function readMeta(storagePath) {
+  try {
+    return JSON.parse(await readFile(join(storagePath, 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+function computeEntropyFromStats(stats) {
+  const nodes = Number(stats?.nodes) || 0;
+  const edges = Number(stats?.edges) || 0;
+  const communities = Number(stats?.communities) || 0;
+  const denom = nodes * (nodes - 1);
+  const density = denom > 0 ? (2 * edges) / denom : 0;
+  const modularity = nodes > 0 ? communities / nodes : 0;
+  return { density, modularity };
+}
+
+async function loadSnapshotEntropyTimeline(repoName, liveEntry) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') entries = [];
+    else throw err;
+  }
+  const points = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    let commit;
+    try {
+      commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+    } catch {
+      continue; // half-built snapshot, skip
+    }
+    const meta = await readMeta(join(dir, e.name, 'source', '.gitnexus'));
+    points.push({
+      name: `${repoName}@${e.name}`,
+      sha: e.name,
+      date: commit.date,
+      ...computeEntropyFromStats(meta?.stats || {}),
+    });
+  }
+  // Append the live point if we have stats.
+  const liveStats = liveEntry?.stats || {};
+  const liveMeta = await readMeta(
+    join('/data/projects', repoName, '.gitnexus'),
+  ).catch(() => null);
+  points.push({
+    name: repoName,
+    sha: 'HEAD',
+    date: liveEntry?.indexedAt || new Date().toISOString(),
+    isLive: true,
+    ...computeEntropyFromStats(liveMeta?.stats || liveStats),
+  });
+  // Sort chronologically. Some snapshot dirs can have weird dates if
+  // the commits were rebased; sort defends against that.
+  points.sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+  return points;
+}
+
+async function handleEntropyCommits(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+  const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
+  if (!hasGit) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `${baseRepo} is not a git repo (commit-level entropy needs git history)` }));
+    return;
+  }
+
+  // Resolve window.
+  const days = Number(url.searchParams.get('days'));
+  let fromIso, toIso;
+  try {
+    fromIso = await resolveWindowEnd(repoPath, url.searchParams.get('from'));
+    toIso = await resolveWindowEnd(repoPath, url.searchParams.get('to'));
+  } catch (err) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+    return;
+  }
+  if (!fromIso || !toIso) {
+    const windowDays = Number.isFinite(days) && days > 0 ? Math.min(3650, days) : DEFAULT_DAYS;
+    const now = Date.now();
+    if (!toIso) toIso = new Date(now).toISOString();
+    if (!fromIso) fromIso = new Date(now - windowDays * 24 * 3600 * 1000).toISOString();
+  }
+
+  // Pull the git log in the window.
+  let logOut;
+  try {
+    logOut = await runCmd('git', [
+      '-C', repoPath, 'log',
+      `--since=${fromIso}`, `--until=${toIso}`,
+      '--pretty=format:%H%x09%aI%x09%an', '--name-only', '--no-merges',
+    ]);
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `git log failed: ${err.message}` }));
+    return;
+  }
+  const allCommits = parseGitLog(logOut);
+
+  // Build the snapshot entropy timeline.
+  const snapshotPoints = await loadSnapshotEntropyTimeline(baseRepo, live);
+
+  if (snapshotPoints.length < 2) {
+    // Need at least 2 snapshots to compute any delta.
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({
+      repo: baseRepo,
+      method: 'interpolation-by-touched-files',
+      windowsCount: 0,
+      totalCommits: allCommits.length,
+      snapshotsUsed: snapshotPoints.map((p) => p.date),
+      warning: 'Need at least 2 snapshots (or 1 snapshot + live) to compute entropy deltas. Run /snapshot/bulk to seed the timeline.',
+      commits: allCommits.map((c) => ({
+        sha: c.sha, shortSha: c.sha.slice(0, 7), author: c.author, date: c.date,
+        filesTouched: c.files.length,
+        snapshotWindow: null,
+        windowDensityDelta: null, windowModularityDelta: null,
+        attributedDensityDelta: null, attributedModularityDelta: null,
+      })),
+      windows: [],
+    }));
+    return;
+  }
+
+  // For each adjacent snapshot pair, compute the deltas + bucket the
+  // commits in [pair.from.date, pair.to.date).
+  const windows = [];
+  for (let i = 0; i < snapshotPoints.length - 1; i++) {
+    const a = snapshotPoints[i];
+    const b = snapshotPoints[i + 1];
+    windows.push({
+      from: a.date,
+      to: b.date,
+      densityDelta: (b.density - a.density) || 0,
+      modularityDelta: (b.modularity - a.modularity) || 0,
+      commits: [], // filled below
+    });
+  }
+
+  // Assign each commit to its window (the one whose [from, to)
+  // contains the commit date). Commits outside any window are simply
+  // attributed null (still returned for visibility).
+  const stragglers = [];
+  for (const c of allCommits) {
+    const t = Date.parse(c.date);
+    if (!Number.isFinite(t)) {
+      stragglers.push(c);
+      continue;
+    }
+    let assigned = false;
+    for (const w of windows) {
+      const ws = Date.parse(w.from);
+      const we = Date.parse(w.to);
+      if (Number.isFinite(ws) && Number.isFinite(we) && t >= ws && t < we) {
+        w.commits.push(c);
+        assigned = true;
+        break;
+      }
+    }
+    if (!assigned) stragglers.push(c);
+  }
+
+  // Per-window: sum filesTouched, then split deltas.
+  const windowSummaries = windows.map((w) => {
+    const filesTouched = w.commits.reduce((s, c) => s + c.files.length, 0);
+    return {
+      from: w.from,
+      to: w.to,
+      densityDelta: w.densityDelta,
+      modularityDelta: w.modularityDelta,
+      commitsInWindow: w.commits.length,
+      filesTouchedInWindow: filesTouched,
+    };
+  });
+
+  const commitsOut = [];
+  for (const w of windows) {
+    const total = w.commits.reduce((s, c) => s + c.files.length, 0);
+    for (const c of w.commits) {
+      const share = total > 0 ? c.files.length / total : 0;
+      commitsOut.push({
+        sha: c.sha,
+        shortSha: c.sha.slice(0, 7),
+        author: c.author,
+        date: c.date,
+        filesTouched: c.files.length,
+        snapshotWindow: [w.from, w.to],
+        windowDensityDelta: w.densityDelta,
+        windowModularityDelta: w.modularityDelta,
+        attributedDensityDelta: w.densityDelta * share,
+        attributedModularityDelta: w.modularityDelta * share,
+      });
+    }
+  }
+  for (const c of stragglers) {
+    commitsOut.push({
+      sha: c.sha, shortSha: c.sha.slice(0, 7),
+      author: c.author, date: c.date,
+      filesTouched: c.files.length,
+      snapshotWindow: null,
+      windowDensityDelta: null, windowModularityDelta: null,
+      attributedDensityDelta: null, attributedModularityDelta: null,
+    });
+  }
+  // Order: most-recent first (matches the user's mental model of
+  // walking back through history). Stragglers (no window) at the end.
+  commitsOut.sort((a, b) => {
+    const aw = a.snapshotWindow ? 0 : 1;
+    const bw = b.snapshotWindow ? 0 : 1;
+    if (aw !== bw) return aw - bw;
+    return (b.date || '').localeCompare(a.date || '');
+  });
+
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(commitsOut, [
+      { key: 'sha' }, { key: 'shortSha' }, { key: 'author' }, { key: 'date' },
+      { key: 'filesTouched' },
+      { key: 'attributedDensityDelta' }, { key: 'attributedModularityDelta' },
+      { key: 'windowDensityDelta' }, { key: 'windowModularityDelta' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-entropy-commits.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({
+    repo: baseRepo,
+    method: 'interpolation-by-touched-files',
+    from: fromIso,
+    to: toIso,
+    windowsCount: windows.length,
+    totalCommits: allCommits.length,
+    commitsAttributed: commitsOut.length - stragglers.length,
+    commitsStraggler: stragglers.length,
+    snapshotsUsed: snapshotPoints.map((p) => p.date),
+    commits: commitsOut,
+    windows: windowSummaries,
+  }));
+}
+
+export async function handleEntropyCommitsRoute(req, url, res, opts) {
+  if (url.pathname === '/entropy/commits' && req.method === 'GET') {
+    await handleEntropyCommits(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-entropy.mjs b/docker-server-entropy.mjs
new file mode 100644
index 00000000..c57e279d
--- /dev/null
+++ b/docker-server-entropy.mjs
@@ -0,0 +1,178 @@
+/**
+ * Structural entropy / health metrics — Tier 1.4 of the ROADMAP.
+ *
+ * Endpoint:
+ *   GET /entropy?repo=<baseRepoName>
+ *
+ * For each snapshot (+ live), exposes a small set of *interpretable*
+ * structural-health metrics extracted from the snapshot's own
+ * `.gitnexus/meta.json`. We deliberately avoid inventing a single
+ * "magic score" — the underlying numbers are simple, defensible, and
+ * the UI can derive a top-line indicator (density delta vs first
+ * snapshot) without us baking opinions into the wire format.
+ *
+ * Returned per point:
+ *   nodes        — total node count (gitnexus stat)
+ *   edges        — total edge count (gitnexus stat)
+ *   communities  — number of communities detected by gitnexus
+ *   density      — graph density = 2*edges / (nodes*(nodes-1)).
+ *                  Range [0, 1]. Real-world healthy projects are
+ *                  typically << 0.01; numbers approaching 0.1 hint at
+ *                  "everything-touches-everything" monolithic shape.
+ *   modularity   — communities / nodes. Higher = more autonomous units
+ *                  (services / packages); lower = monolith.
+ *   filesCount   — file count for cross-referencing growth charts
+ *
+ * Reading from meta.json keeps this endpoint cheap (~5ms total even
+ * for many snapshots) — we never touch the lbug database for these,
+ * so it doesn't trigger the per-path connection cache.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+function compute(stats) {
+  const nodes = Number(stats?.nodes) || 0;
+  const edges = Number(stats?.edges) || 0;
+  const communities = Number(stats?.communities) || 0;
+  const filesCount = Number(stats?.files) || 0;
+  // Density: undefined for graphs with <2 nodes (no possible edges).
+  // Reporting 0 in that edge case avoids special-casing in the UI.
+  const denom = nodes * (nodes - 1);
+  const density = denom > 0 ? (2 * edges) / denom : 0;
+  // Modularity ratio: 0 when no communities, else communities/nodes.
+  // Always in [0, 1] (can't have more communities than nodes).
+  const modularity = nodes > 0 ? communities / nodes : 0;
+  return { nodes, edges, communities, density, modularity, filesCount };
+}
+
+async function readMeta(storagePath) {
+  try {
+    return JSON.parse(await readFile(join(storagePath, 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+async function listSnapshotMetas(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    const snapshotDir = join(dir, e.name);
+    // commit.json gives us the date, meta.json gives us the stats.
+    let commit = null;
+    let meta = null;
+    try {
+      commit = JSON.parse(await readFile(join(snapshotDir, 'commit.json'), 'utf8'));
+    } catch {
+      continue; // half-built; skip
+    }
+    meta = await readMeta(join(snapshotDir, 'source', '.gitnexus'));
+    out.push({
+      name: `${repoName}@${e.name}`,
+      date: commit.date,
+      isLive: false,
+      stats: meta?.stats || {},
+    });
+  }
+  return out;
+}
+
+async function handleEntropy(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  // Live stats are right there in the registry response.
+  const liveStats = liveEntry.stats || {};
+  // Live entry needs its meta.json too if we want full parity with snapshots —
+  // the registry view is sometimes thinned. Best-effort fallback.
+  const liveMeta = await readMeta(
+    join('/data/projects', baseRepo, '.gitnexus'),
+  ).catch(() => null);
+  const livePoint = {
+    name: baseRepo,
+    date: liveEntry.indexedAt,
+    isLive: true,
+    stats: liveMeta?.stats || liveStats,
+  };
+
+  const snapshots = await listSnapshotMetas(baseRepo);
+  const points = [...snapshots, livePoint].sort((a, b) =>
+    (a.date || '').localeCompare(b.date || ''),
+  );
+
+  const timeline = points.map((p) => ({
+    name: p.name,
+    date: p.date,
+    isLive: p.isLive,
+    ...compute(p.stats),
+  }));
+
+  // Headline number: density of the most-recent point vs the first.
+  // > 1 = densifying (less modular over time); < 1 = simplifying.
+  const first = timeline[0];
+  const last = timeline[timeline.length - 1];
+  const densityTrend = first && first.density > 0 ? last.density / first.density : null;
+
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(timeline, [
+      { key: 'name', header: 'snapshotName' },
+      { key: 'date' },
+      { key: 'isLive' },
+      { key: 'nodes' },
+      { key: 'edges' },
+      { key: 'communities' },
+      { key: 'density' },
+      { key: 'modularity' },
+      { key: 'filesCount' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-entropy.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalPoints: timeline.length,
+      timeline,
+      headline: {
+        currentDensity: last?.density ?? 0,
+        currentModularity: last?.modularity ?? 0,
+        densityTrend,
+      },
+    }),
+  );
+}
+
+export async function handleEntropyRoute(req, url, res, opts) {
+  if (url.pathname === '/entropy' && req.method === 'GET') {
+    await handleEntropy(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-ghost-audit-core.mjs b/docker-server-ghost-audit-core.mjs
new file mode 100644
index 00000000..325cefe7
--- /dev/null
+++ b/docker-server-ghost-audit-core.mjs
@@ -0,0 +1,249 @@
+/**
+ * Pure functions for the roadmap-predictive Audit view.
+ * No I/O. Imports from docker-server-ghosts-core.mjs only if needed.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-audit-design.md
+ */
+
+function derivedStatus(g) {
+  if (g.cancelledAt) return 'cancelled';
+  if (g.materializedAt) return 'materialized';
+  return 'planned';
+}
+
+export function computeSummary(ghosts) {
+  const counts = { total: 0, materialized: 0, planned: 0, cancelled: 0 };
+  for (const g of ghosts) {
+    counts.total += 1;
+    counts[derivedStatus(g)] += 1;
+  }
+  const cancellationRate = counts.total === 0 ? 0 : counts.cancelled / counts.total;
+  return { ...counts, cancellationRate };
+}
+
+// --- Target date parsing ---
+
+const ISO_RE = /^\d{4}-\d{2}-\d{2}/;
+const QUARTER_RE = /^(\d{4})-Q([1-4])$/;
+const MONTH_RE = /^(\d{4})-(\d{2})$/;
+
+export function parseTargetDate(s) {
+  if (!s || typeof s !== 'string') return null;
+  const q = s.match(QUARTER_RE);
+  if (q) {
+    const year = Number(q[1]);
+    const lastMonthOfQuarter = Number(q[2]) * 3; // 3, 6, 9, 12
+    return new Date(Date.UTC(year, lastMonthOfQuarter, 0)); // day 0 of next month = last of this
+  }
+  const m = s.match(MONTH_RE);
+  if (m) {
+    return new Date(Date.UTC(Number(m[1]), Number(m[2]), 0));
+  }
+  if (ISO_RE.test(s)) {
+    const d = new Date(s);
+    return isNaN(d.getTime()) ? null : d;
+  }
+  return null;
+}
+
+// --- Slippage ---
+
+function bucketStart(s) {
+  const q = s?.match?.(QUARTER_RE);
+  if (q) {
+    const year = Number(q[1]);
+    const firstMonthOfQuarter = (Number(q[2]) - 1) * 3; // 0, 3, 6, 9
+    return new Date(Date.UTC(year, firstMonthOfQuarter, 1));
+  }
+  const m = s?.match?.(MONTH_RE);
+  if (m) {
+    return new Date(Date.UTC(Number(m[1]), Number(m[2]) - 1, 1));
+  }
+  return null; // for ISO, start === end
+}
+
+export function computeSlippage(ghosts) {
+  const out = { early: 0, onTime: 0, late: 0, noTarget: 0, onTimePct: null };
+  for (const g of ghosts) {
+    if (!g.materializedAt) continue;
+    const target = parseTargetDate(g.declared?.plannedFor);
+    if (!target) { out.noTarget += 1; continue; }
+    const matDate = new Date(g.materializedAt.date);
+    const start = bucketStart(g.declared.plannedFor) ?? target;
+    if (matDate < start) out.early += 1;
+    else if (matDate <= target) out.onTime += 1;
+    else out.late += 1;
+  }
+  const denom = out.early + out.onTime + out.late;
+  out.onTimePct = denom === 0 ? null : out.onTime / denom;
+  return out;
+}
+
+// --- Lead time ---
+
+const DAY = 86_400_000;
+
+function percentile(sortedAsc, p) {
+  if (sortedAsc.length === 0) return null;
+  const idx = (sortedAsc.length - 1) * p;
+  const lo = Math.floor(idx);
+  const hi = Math.ceil(idx);
+  if (lo === hi) return sortedAsc[lo];
+  return sortedAsc[lo] + (sortedAsc[hi] - sortedAsc[lo]) * (idx - lo);
+}
+
+export function computeLeadTime(ghosts) {
+  const leadTimes = [];
+  for (const g of ghosts) {
+    if (!g.materializedAt || !g.plannedAt) continue;
+    const dt = (new Date(g.materializedAt.date) - new Date(g.plannedAt.date)) / DAY;
+    if (dt >= 0) leadTimes.push(dt);
+  }
+  if (leadTimes.length === 0) {
+    return { medianDays: null, p25Days: null, p75Days: null, maxDays: null, distribution: [] };
+  }
+  leadTimes.sort((a, b) => a - b);
+  const dist = [
+    { bucket: '0-7d',   count: 0 },
+    { bucket: '7-14d',  count: 0 },
+    { bucket: '14-30d', count: 0 },
+    { bucket: '30d+',   count: 0 },
+  ];
+  for (const lt of leadTimes) {
+    if (lt < 7) dist[0].count += 1;
+    else if (lt < 14) dist[1].count += 1;
+    else if (lt < 30) dist[2].count += 1;
+    else dist[3].count += 1;
+  }
+  return {
+    medianDays: percentile(leadTimes, 0.5),
+    p25Days: percentile(leadTimes, 0.25),
+    p75Days: percentile(leadTimes, 0.75),
+    maxDays: leadTimes[leadTimes.length - 1],
+    distribution: dist,
+  };
+}
+
+// --- Plan churn ---
+
+function sameLinks(a, b) {
+  if (!Array.isArray(a) || !Array.isArray(b) || a.length !== b.length) return false;
+  for (let i = 0; i < a.length; i++) {
+    if (a[i].kind !== b[i].kind || a[i].value !== b[i].value) return false;
+  }
+  return true;
+}
+
+export function computePlanChurn(snapshots) {
+  const empty = { totalGhostsWithChurn: 0, avgChurnPerGhost: 0, topChurners: [] };
+  if (!Array.isArray(snapshots) || snapshots.length < 2) return empty;
+
+  // Sort by date ASC so consecutive comparison is chronological.
+  const sorted = [...snapshots].sort((a, b) => new Date(a.date) - new Date(b.date));
+  const churnById = new Map();
+
+  for (let i = 1; i < sorted.length; i++) {
+    const prevById = new Map(sorted[i - 1].ghosts.map(g => [g.id, g]));
+    for (const curr of sorted[i].ghosts) {
+      const prev = prevById.get(curr.id);
+      if (!prev) continue;
+      const deltas = [];
+      if (prev.declared.description !== curr.declared.description) deltas.push('description');
+      if (!sameLinks(prev.declared.expectedLinks ?? [], curr.declared.expectedLinks ?? [])) deltas.push('expectedLinks');
+      if (deltas.length > 0) {
+        const entry = churnById.get(curr.id) ?? { churn: 0, deltas: [] };
+        entry.churn += 1;
+        entry.deltas.push(...deltas);
+        churnById.set(curr.id, entry);
+      }
+    }
+  }
+
+  const all = [...churnById.entries()].map(([id, x]) => ({ id, ...x }));
+  const topChurners = all.sort((a, b) => b.churn - a.churn).slice(0, 10);
+  const totalChurn = all.reduce((sum, x) => sum + x.churn, 0);
+  return {
+    totalGhostsWithChurn: all.length,
+    avgChurnPerGhost: all.length === 0 ? 0 : totalChurn / all.length,
+    topChurners,
+  };
+}
+
+// --- Velocity ---
+
+function isoWeekStart(date) {
+  const d = new Date(date);
+  const day = d.getUTCDay() || 7; // Monday=1, Sunday=7
+  d.setUTCDate(d.getUTCDate() - day + 1);
+  d.setUTCHours(0, 0, 0, 0);
+  return d.toISOString().slice(0, 10);
+}
+
+export function computeVelocity(ghosts, opts = {}) {
+  const windowDays = opts.windowDays ?? 28;
+  const now = opts.now ?? new Date();
+  const cutoff = new Date(now.getTime() - windowDays * DAY);
+
+  let currentCount = 0;
+  const weekly = new Map();
+
+  for (const g of ghosts) {
+    if (!g.materializedAt) continue;
+    const matDate = new Date(g.materializedAt.date);
+    if (isNaN(matDate.getTime())) continue;
+    if (matDate >= cutoff && matDate <= now) currentCount += 1;
+    const wk = isoWeekStart(matDate);
+    weekly.set(wk, (weekly.get(wk) ?? 0) + 1);
+  }
+
+  const allWeeks = [...weekly.entries()].sort((a, b) => a[0].localeCompare(b[0]));
+  const history = allWeeks.slice(-26).map(([weekStarting, count]) => ({ weekStarting, count }));
+
+  return { windowDays, currentCount, history };
+}
+
+// --- Expired (Update 1 — 6th audit metric) ---
+
+/**
+ * Counts and lists ghosts whose declared.expectedBy has passed (with grace period)
+ * and that have not been materialized or cancelled. Critical = past expiry by > 50%
+ * of the original time-to-expiry from plannedAt.date (so "tier-3-2" with
+ * plannedAt 2026-01-01, expectedBy 2026-04-30, now 2026-05-26+ becomes critical).
+ *
+ * @param {Array} ghosts  runtime ghost objects (with .declared, .plannedAt, .materializedAt, .cancelledAt).
+ * @param {{ gracePeriodDays?: number, now?: Date }} opts
+ * @returns {{ total: number, critical: number, expiredButRecent: number, list: Array }}
+ */
+export function computeExpired(ghosts, opts = {}) {
+  const gracePeriodDays = opts.gracePeriodDays ?? 30;
+  const now = opts.now ? new Date(opts.now) : new Date();
+  const out = { total: 0, critical: 0, expiredButRecent: 0, list: [] };
+  for (const g of ghosts || []) {
+    if (g.materializedAt || g.cancelledAt) continue;
+    const expectedByStr = g.declared?.expectedBy;
+    if (!expectedByStr) continue;
+    const expectedByDate = parseTargetDate(expectedByStr);
+    if (!expectedByDate) continue;
+    const expiryWithGrace = new Date(expectedByDate.getTime() + gracePeriodDays * 86400000);
+    if (now <= expiryWithGrace) continue;
+    const daysPastExpiry = Math.floor((now - expiryWithGrace) / 86400000);
+    // critical = > 50% past the original plannedAt→expectedBy span
+    const plannedAtDate = g.plannedAt?.date ? new Date(g.plannedAt.date) : null;
+    let alertLevel = 'expiredButRecent';
+    if (plannedAtDate) {
+      const originalSpanMs = expectedByDate - plannedAtDate;
+      if (originalSpanMs > 0 && (now - expectedByDate) > 0.5 * originalSpanMs) alertLevel = 'critical';
+    }
+    out.total += 1;
+    if (alertLevel === 'critical') out.critical += 1;
+    else out.expiredButRecent += 1;
+    out.list.push({
+      id: g.id,
+      expectedBy: expectedByStr,
+      daysPastExpiry,
+      alertLevel,
+    });
+  }
+  out.list.sort((a, b) => b.daysPastExpiry - a.daysPastExpiry);
+  return out;
+}
diff --git a/docker-server-ghost-audit.mjs b/docker-server-ghost-audit.mjs
new file mode 100644
index 00000000..db635faf
--- /dev/null
+++ b/docker-server-ghost-audit.mjs
@@ -0,0 +1,137 @@
+/**
+ * I/O wrapper for the roadmap-predictive Audit view.
+ * Reads CORE sidecars (.gitnexus/ghosts.json and snapshots/*\/ghosts.json),
+ * computes metrics via pure fns, optionally caches.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-audit-design.md
+ */
+import { readFile, writeFile, stat, readdir, mkdir, access } from 'node:fs/promises';
+import { join } from 'node:path';
+import {
+  computeSummary, computeLeadTime, computeSlippage,
+  computePlanChurn, computeVelocity, computeExpired,
+} from './docker-server-ghost-audit-core.mjs';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+async function fileExists(p) { try { await access(p); return true; } catch { return false; } }
+
+async function readJsonOrNull(p) {
+  try { return JSON.parse(await readFile(p, 'utf8')); } catch { return null; }
+}
+
+async function loadLatestGhosts(repoPath) {
+  return readJsonOrNull(join(repoPath, '.gitnexus', 'ghosts.json'));
+}
+
+async function loadAllSnapshots(repoPath) {
+  const snapshotsDir = join(repoPath, '.gitnexus', 'snapshots');
+  if (!(await fileExists(snapshotsDir))) return [];
+  const entries = await readdir(snapshotsDir);
+  const out = [];
+  for (const sha of entries) {
+    const ghostsPath = join(snapshotsDir, sha, 'ghosts.json');
+    if (!(await fileExists(ghostsPath))) continue;
+    const data = await readJsonOrNull(ghostsPath);
+    if (data) out.push({ sha, date: data.syncedAt ?? null, ghosts: data.ghosts ?? [] });
+  }
+  return out;
+}
+
+export async function buildAudit(repoPath, opts = {}) {
+  const latest = await loadLatestGhosts(repoPath);
+  if (!latest) return null; // signals 404 to the route handler
+  const ghosts = latest.ghosts ?? [];
+  const snapshots = await loadAllSnapshots(repoPath);
+  return {
+    computedAt: new Date().toISOString(),
+    cached: false,
+    summary: computeSummary(ghosts),
+    leadTime: computeLeadTime(ghosts),
+    slippage: computeSlippage(ghosts),
+    planChurn: computePlanChurn(snapshots),
+    velocity: computeVelocity(ghosts, { windowDays: opts.windowDays ?? 28 }),
+    expired: computeExpired(ghosts, { gracePeriodDays: 30, now: new Date() }),
+  };
+}
+
+// --- Cache invalidation ---
+
+export async function isCacheValid(cachePath, repoPath) {
+  const cs = await stat(cachePath).catch(() => null);
+  if (!cs) return false;
+  const cacheMtime = cs.mtime.getTime();
+  const latest = await stat(join(repoPath, '.gitnexus', 'ghosts.json')).catch(() => null);
+  if (latest && latest.mtime.getTime() > cacheMtime) return false;
+  const snapshotsDir = join(repoPath, '.gitnexus', 'snapshots');
+  if (await fileExists(snapshotsDir)) {
+    const entries = await readdir(snapshotsDir);
+    for (const sha of entries) {
+      const p = join(snapshotsDir, sha, 'ghosts.json');
+      const s = await stat(p).catch(() => null);
+      if (s && s.mtime.getTime() > cacheMtime) return false;
+    }
+  }
+  return true;
+}
+
+export async function computeAudit(repoPath, opts = {}) {
+  const cachePath = join(repoPath, '.gitnexus', 'ghost-audit-cache.json');
+  if (await isCacheValid(cachePath, repoPath)) {
+    const cached = await readJsonOrNull(cachePath);
+    if (cached) return { ...cached, cached: true };
+  }
+  const fresh = await buildAudit(repoPath, opts);
+  if (fresh === null) return null;
+  await mkdir(join(repoPath, '.gitnexus'), { recursive: true });
+  await writeFile(cachePath, JSON.stringify(fresh, null, 2) + '\n');
+  return { ...fresh, cached: false };
+}
+
+// --- HTTP route handler ---
+// Resolves repo from ?repo via findRepoByName, then delegates to computeAudit.
+// Same shape as handleGhostsGet in docker-server-ghosts.mjs.
+
+export async function handleGhostAudit(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+      return;
+    }
+    const repoPath = repo.repoPath || repo.path;
+    const windowDaysRaw = url.searchParams.get('windowDays');
+    const windowDays = windowDaysRaw ? Number(windowDaysRaw) : undefined;
+    const audit = await computeAudit(repoPath, { windowDays });
+    if (!audit) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: 'No ghosts.json — run POST /ghosts/sync first.' }));
+      return;
+    }
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(audit));
+  } catch (err) {
+    console.error('[ghost-audit] failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+/**
+ * Public dispatcher : returns true if the request matches /ghost-audit
+ * (and is fully handled), false otherwise. Registered in `docker-server.mjs`
+ * next to the other analytics dispatchers.
+ */
+export async function handleGhostAuditRoute(req, url, res, opts) {
+  if (url.pathname === '/ghost-audit' && req.method === 'GET') {
+    await handleGhostAudit(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-ghost-cleanup-core.mjs b/docker-server-ghost-cleanup-core.mjs
new file mode 100644
index 00000000..0c5c0fd0
--- /dev/null
+++ b/docker-server-ghost-cleanup-core.mjs
@@ -0,0 +1,55 @@
+// upstream/docker-server-ghost-cleanup-core.mjs
+//
+// Pure fns for LLM-assisted cleanup-at-expiration.
+// No I/O. Backend builds the prompt context, frontend calls the LLM.
+
+const VALID_ACTIONS = new Set(['reaffirm', 'cancel', 'ship-as-other']);
+
+export function buildCleanupPrompt({ ghost, matchedNodes, recentCommits }) {
+  const links = (ghost.declared?.expectedLinks || [])
+    .map(l => `  - ${l.kind}: ${l.value}`)
+    .join('\n') || '  (none)';
+  const matched = matchedNodes && matchedNodes.length
+    ? matchedNodes.map(n => `  - ${n}`).join('\n')
+    : '  (no matching nodes)';
+  const commits = recentCommits && recentCommits.length
+    ? recentCommits.map(c => `  - ${c}`).join('\n')
+    : '  (no recent commits)';
+  return [
+    `You are helping clean up a roadmap.`,
+    ``,
+    `This ghost has expired ${ghost.daysPastExpiry} days past its expectedBy:`,
+    `  Title: ${ghost.title}`,
+    `  Description: ${ghost.declared?.description || '(none)'}`,
+    `  expectedBy: ${ghost.declared?.expectedBy || '(unspecified)'}`,
+    `  expectedLinks:`,
+    links,
+    ``,
+    `Nodes in the current graph that partially match its expectedLinks:`,
+    matched,
+    ``,
+    `Recent commits (3 months):`,
+    commits,
+    ``,
+    `Propose one action from: reaffirm | cancel | ship-as-other`,
+    `If ship-as-other, name the other ghost / shipped feature that now covers this need in the rationale.`,
+    ``,
+    `Respond as strict JSON:`,
+    `{ "action": "<action>", "rationale": "<short>", "confidence": <0-1> }`,
+  ].join('\n');
+}
+
+export function parseCleanupResponse(text) {
+  if (!text || typeof text !== 'string') return null;
+  let stripped = text.trim();
+  const fence = stripped.match(/^```(?:json)?\s*([\s\S]*?)\s*```$/);
+  if (fence) stripped = fence[1].trim();
+  let obj;
+  try { obj = JSON.parse(stripped); } catch { return null; }
+  if (!obj || typeof obj !== 'object') return null;
+  if (!VALID_ACTIONS.has(obj.action)) return null;
+  if (typeof obj.rationale !== 'string') return null;
+  const confidence = Number(obj.confidence);
+  if (!Number.isFinite(confidence) || confidence < 0 || confidence > 1) return null;
+  return { action: obj.action, rationale: obj.rationale, confidence };
+}
diff --git a/docker-server-ghost-cleanup.mjs b/docker-server-ghost-cleanup.mjs
new file mode 100644
index 00000000..24517f0a
--- /dev/null
+++ b/docker-server-ghost-cleanup.mjs
@@ -0,0 +1,87 @@
+// upstream/docker-server-ghost-cleanup.mjs
+import { execFile } from 'node:child_process';
+import { promisify } from 'node:util';
+import { buildCleanupPrompt } from './docker-server-ghost-cleanup-core.mjs';
+import { computeExpired } from './docker-server-ghost-audit-core.mjs';
+import { matchExpectedLinks } from './docker-server-ghosts-core.mjs';
+import { readLatestGhosts } from './docker-server-ghosts.mjs';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+const execFileP = promisify(execFile);
+
+async function getRecentCommits(repoPath, days = 90) {
+  try {
+    const { stdout } = await execFileP(
+      'git',
+      ['log', `--since=${days} days ago`, '--pretty=format:%h %s'],
+      { cwd: repoPath, maxBuffer: 4 * 1024 * 1024 },
+    );
+    return stdout.split('\n').filter(Boolean).slice(0, 50);
+  } catch {
+    return [];
+  }
+}
+
+export async function buildCleanupPrompts(repoPath) {
+  const runtime = await readLatestGhosts(repoPath);
+  if (!runtime) return { expired: [] };
+  const expired = computeExpired(runtime.ghosts || [], { gracePeriodDays: 30, now: new Date() });
+  if (expired.total === 0) return { expired: [] };
+
+  const allFiles = new Set();
+  for (const g of runtime.ghosts || []) {
+    if (g.links) for (const l of g.links) if (l.file) allFiles.add(l.file);
+  }
+  const recentCommits = await getRecentCommits(repoPath, 90);
+
+  const out = [];
+  for (const entry of expired.list) {
+    const ghost = (runtime.ghosts || []).find(g => g.id === entry.id);
+    if (!ghost) continue;
+    const { matched } = matchExpectedLinks(ghost.declared, [...allFiles]);
+    const prompt = buildCleanupPrompt({
+      ghost: { ...ghost, daysPastExpiry: entry.daysPastExpiry },
+      matchedNodes: matched.map(m => m.matchedPath),
+      recentCommits,
+    });
+    out.push({
+      id: entry.id,
+      title: ghost.declared?.title || entry.id,
+      expectedBy: ghost.declared?.expectedBy,
+      daysPastExpiry: entry.daysPastExpiry,
+      alertLevel: entry.alertLevel,
+      prompt,
+    });
+  }
+  return { expired: out };
+}
+
+export async function handleGhostsCleanupPrompt(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: 'missing repo' }));
+  }
+  const repo = await findRepoByName(repoName, opts.api);
+  if (!repo) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+  }
+  const repoPath = repo.repoPath || repo.path;
+  try {
+    const result = await buildCleanupPrompts(repoPath);
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(result));
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+export async function handleGhostsCleanupRoute(req, url, res, opts) {
+  if (url.pathname === '/ghosts/cleanup-prompt' && req.method === 'POST') {
+    await handleGhostsCleanupPrompt(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-ghosts-core.mjs b/docker-server-ghosts-core.mjs
new file mode 100644
index 00000000..ff876f38
--- /dev/null
+++ b/docker-server-ghosts-core.mjs
@@ -0,0 +1,570 @@
+/**
+ * Pure functions for the roadmap-predictive CORE.
+ * No I/O, no fs, no fetch — testable in isolation.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-core-design.md
+ */
+
+const TABLE_ROW_RE = /^\|\s*(\d+)\s*\|\s*(.+?)\s*\|\s*(.+?)\s*\|\s*$/;
+const TABLE_HEADER_RE = /^\|\s*#\s*\|/;
+const TABLE_SEP_RE = /^\|[\s:-]+\|/;
+const SHIPPED_SECTION_RE = /^##\s+✅\s+Déjà livré\s*$/i;
+// Managed section appended by scripts/ghost-from-spec.mjs. Rows here
+// emit ghosts with status='planned' (vs 'materialized' for Déjà livré).
+// Cf. docs/superpowers/specs/2026-05-26-roadmap-predictive-brainstorm-hook-design.md
+const FROM_SPEC_SECTION_RE = /^##\s+🧪\s+From spec brainstorms\s*$/i;
+const FROM_SPEC_TABLE_HEADER_RE = /^\|\s*Spec\s*\|/i;
+const FROM_SPEC_ROW_RE = /^\|\s*\[([^\]]+)\]\(([^)]+)\)\s*\|\s*(.+?)\s*\|\s*(.+?)\s*\|\s*(.+?)\s*\|\s*$/;
+const BACKTICK_RE = /`([^`]+)`/g;
+const TIER_HEADING_RE = /^###\s+(\d+(?:\.\d+)*)\s*[—-]\s*(.+?)\s*(✅|🗑️|⏳|🔬)?\s*$/;
+const PROMISE_RE = /^\*\*Promesse\*\*\s*:\s*(.+)$/;
+const FIRST_STEP_RE = /^\*\*Premier pas\*\*\s*:\s*(.+)$/;
+const CANCELLED_EMOJIS = ['🗑️', '~~'];
+
+function statusFromEmoji(emoji) {
+  if (emoji === '✅') return 'materialized';
+  if (CANCELLED_EMOJIS.includes(emoji)) return 'cancelled';
+  return 'planned';
+}
+
+function slugify(s) {
+  return s
+    .toLowerCase()
+    .replace(/[^a-z0-9]+/g, '-')
+    .replace(/^-+|-+$/g, '')
+    .slice(0, 60);
+}
+
+function stripBold(s) {
+  return s.replace(/\*\*(.+?)\*\*/g, '$1');
+}
+
+function extractExpectedLinks(cell) {
+  const links = [];
+  const ticked = [...cell.matchAll(BACKTICK_RE)].map(m => m[1]);
+  for (const t of ticked) {
+    const isPath = t.includes('/') || t.startsWith('?') || /\.(mjs|ts|tsx|js|jsx|json|yaml|yml|md|css)$/.test(t);
+    links.push({ kind: isPath ? 'path' : 'label', value: t });
+  }
+  return links;
+}
+
+export function parseRoadmap(md) {
+  if (!md || typeof md !== 'string') return [];
+  const lines = md.split('\n');
+  const ghosts = [];
+
+  // --- Pass A : table "Déjà livré" rows (UNCHANGED from Task 1) ---
+  // + managed "🧪 From spec brainstorms" section (Brainstorm-hook Update 2026-05-27).
+  // Both sections share the same control flow, only `defaultStatus` differs.
+  let inGhostTableSection = false;
+  let defaultStatus = null; // 'materialized' for Déjà livré, 'planned' for From spec brainstorms
+  let inTable = false;
+  let tableHasSep = false;
+  let isSpecTable = false; // true when parsing the 4-col Spec/Tier/Title/Links shape
+
+  for (const line of lines) {
+    if (SHIPPED_SECTION_RE.test(line)) {
+      inGhostTableSection = true;
+      defaultStatus = 'materialized';
+      isSpecTable = false;
+      inTable = false;
+      tableHasSep = false;
+      continue;
+    }
+    if (FROM_SPEC_SECTION_RE.test(line)) {
+      inGhostTableSection = true;
+      defaultStatus = 'planned';
+      isSpecTable = true;
+      inTable = false;
+      tableHasSep = false;
+      continue;
+    }
+    if (line.startsWith('## ') && !SHIPPED_SECTION_RE.test(line) && !FROM_SPEC_SECTION_RE.test(line)) {
+      inGhostTableSection = false;
+      defaultStatus = null;
+      isSpecTable = false;
+      inTable = false;
+      tableHasSep = false;
+      continue;
+    }
+    if (!inGhostTableSection) continue;
+    if (isSpecTable) {
+      if (FROM_SPEC_TABLE_HEADER_RE.test(line)) { inTable = true; tableHasSep = false; continue; }
+    } else {
+      if (TABLE_HEADER_RE.test(line)) { inTable = true; tableHasSep = false; continue; }
+    }
+    if (inTable && !tableHasSep && TABLE_SEP_RE.test(line)) { tableHasSep = true; continue; }
+    if (inTable && tableHasSep) {
+      if (line.trim() === '') continue;
+      if (isSpecTable) {
+        const m = line.match(FROM_SPEC_ROW_RE);
+        if (!m) { inTable = false; continue; }
+        const [, specLabel, , rawTier, rawTitle, rawLinks] = m;
+        const title = stripBold(rawTitle).trim();
+        const tier = rawTier.trim();
+        ghosts.push({
+          id: `spec-${specLabel.trim()}`,
+          tier: tier === '—' || tier === '' ? null : tier,
+          title,
+          description: '',
+          status: defaultStatus,
+          expectedLinks: extractExpectedLinks(rawLinks),
+          dependsOn: [],
+        });
+      } else {
+        const m = line.match(TABLE_ROW_RE);
+        if (!m) { inTable = false; continue; }
+        const [, num, rawTitle, rawLinks] = m;
+        const title = stripBold(rawTitle).trim();
+        ghosts.push({
+          id: `${num}-${slugify(title)}`,
+          tier: null,
+          title,
+          description: '',
+          status: defaultStatus,
+          expectedLinks: extractExpectedLinks(rawLinks),
+          dependsOn: [],
+        });
+      }
+    }
+  }
+
+  // --- Pass B : Tier subsections ---
+  let currentTier = null;
+  let currentTitle = null;
+  let currentEmoji = null;
+  let currentDescription = '';
+  let currentLinks = [];
+  let readingPromise = false;
+  let readingFirstStep = false;
+
+  function flushTier() {
+    if (currentTier === null) return;
+    ghosts.push({
+      id: `tier-${currentTier.replace(/\./g, '-')}-${slugify(currentTitle)}`,
+      tier: currentTier,
+      title: currentTitle,
+      description: currentDescription.trim(),
+      status: statusFromEmoji(currentEmoji),
+      expectedLinks: currentLinks,
+      dependsOn: [],
+    });
+    currentTier = null;
+    currentTitle = null;
+    currentEmoji = null;
+    currentDescription = '';
+    currentLinks = [];
+    readingPromise = false;
+    readingFirstStep = false;
+  }
+
+  for (const line of lines) {
+    const m = line.match(TIER_HEADING_RE);
+    if (m) {
+      flushTier();
+      currentTier = m[1];
+      currentTitle = stripBold(m[2]).trim();
+      currentEmoji = m[3] ?? null;
+      continue;
+    }
+    if (currentTier === null) continue;
+
+    const pm = line.match(PROMISE_RE);
+    if (pm) {
+      readingPromise = true;
+      readingFirstStep = false;
+      currentDescription = pm[1];
+      continue;
+    }
+    const fm = line.match(FIRST_STEP_RE);
+    if (fm) {
+      readingPromise = false;
+      readingFirstStep = true;
+      currentLinks.push(...extractExpectedLinks(fm[1]));
+      continue;
+    }
+    if (line.startsWith('### ') || line.startsWith('## ')) {
+      flushTier();
+      continue;
+    }
+    if (readingPromise && line.trim() && !line.startsWith('**')) {
+      currentDescription += ' ' + line.trim();
+    } else if (readingFirstStep && line.trim() && !line.startsWith('**')) {
+      currentLinks.push(...extractExpectedLinks(line));
+    } else if (line.trim() === '') {
+      readingPromise = false;
+      readingFirstStep = false;
+    }
+  }
+  flushTier();
+
+  return ghosts;
+}
+
+/**
+ * Walk the parsed ghosts and warn (stderr) for each planned ghost
+ * lacking an expectedBy hint. Caller can suppress by passing
+ * { silent: true }. Hard-error never happens — this is a soft warning
+ * to support gradual migration.
+ */
+export function warnMissingExpectedBy(ghosts, opts = {}) {
+  if (opts.silent) return;
+  for (const g of ghosts) {
+    if (g.status === 'planned' && !g.expectedBy) {
+      console.warn(`[ghosts] WARNING: ghost "${g.id}" is planned but has no expectedBy. Add one to ROADMAP.md to enable cleanup-at-expiration.`);
+    }
+  }
+}
+
+// --- YAML rendering ---
+// Tiny deterministic serializer. Avoids js-yaml dep + lets us audit
+// the output trivially.
+
+function yamlScalar(s) {
+  if (s === null || s === undefined) return 'null';
+  if (typeof s === 'number' || typeof s === 'boolean') return String(s);
+  const str = String(s);
+  if (str === '') return "''";
+  if (/[`*'?>|{[#&!%@:]/.test(str) || /^[-"]/.test(str) || /\n/.test(str)) {
+    return "'" + str.replace(/'/g, "''") + "'";
+  }
+  return str;
+}
+
+function yamlInlineList(arr) {
+  if (arr.length === 0) return '[]';
+  return '[' + arr.map(yamlScalar).join(', ') + ']';
+}
+
+export function renderRoadmapYml(ghosts, opts = {}) {
+  const lines = [];
+  if (!Array.isArray(ghosts) || ghosts.length === 0) {
+    lines.push('ghosts: []');
+  } else {
+    const sorted = [...ghosts].sort((a, b) => (a.id || '').localeCompare(b.id || ''));
+    lines.push('ghosts:');
+    for (const g of sorted) {
+      lines.push(`  - id: ${yamlScalar(g.id)}`);
+      if (g.tier !== null && g.tier !== undefined) {
+        lines.push(`    tier: ${yamlScalar(g.tier)}`);
+      } else {
+        lines.push(`    tier: null`);
+      }
+      lines.push(`    title: ${yamlScalar(g.title)}`);
+      lines.push(`    description: ${yamlScalar(g.description || '')}`);
+      lines.push(`    status: ${yamlScalar(g.status)}`);
+      // expectedBy (Update 1b from external review — emit even if null/absent)
+      lines.push(`    expectedBy: ${yamlScalar(g.expectedBy ?? null)}`);
+      if (!g.expectedLinks || g.expectedLinks.length === 0) {
+        lines.push(`    expectedLinks: []`);
+      } else {
+        lines.push(`    expectedLinks:`);
+        for (const link of g.expectedLinks) {
+          lines.push(`      - kind: ${yamlScalar(link.kind)}`);
+          lines.push(`        value: ${yamlScalar(link.value)}`);
+        }
+      }
+      lines.push(`    dependsOn: ${yamlInlineList(g.dependsOn || [])}`);
+    }
+  }
+
+  // Section B Task 5 of the Ghost Cluster plan: emit declared clusters in
+  // roadmap.yml so downstream readers see them alongside ghosts. Auto-derived
+  // clusters are NOT emitted here — they only exist in the runtime
+  // clusters.json sidecar (they would mutate roadmap.yml on every dependsOn
+  // edit, which is noise).
+  const clusters = Array.isArray(opts?.clusters) ? opts.clusters : [];
+  if (clusters.length > 0) {
+    const sortedClusters = [...clusters].sort((a, b) => (a.id || '').localeCompare(b.id || ''));
+    lines.push('clusters:');
+    for (const c of sortedClusters) {
+      lines.push(`  - id: ${yamlScalar(c.id)}`);
+      lines.push(`    title: ${yamlScalar(c.title)}`);
+      if (c.expectedBy) lines.push(`    expectedBy: ${yamlScalar(c.expectedBy)}`);
+      if (!c.memberIds || c.memberIds.length === 0) {
+        lines.push(`    members: []`);
+      } else {
+        lines.push(`    members:`);
+        for (const m of c.memberIds) lines.push(`      - ${yamlScalar(m)}`);
+      }
+      if (c.declaredStatus) lines.push(`    status: ${yamlScalar(c.declaredStatus)}`);
+    }
+  }
+
+  return lines.join('\n') + '\n';
+}
+
+// --- Expected-link matching ---
+
+function pathToRegex(pattern) {
+  let re = '';
+  let i = 0;
+  while (i < pattern.length) {
+    const c = pattern[i];
+    if (c === '*' && pattern[i + 1] === '*') { re += '.*'; i += 2; }
+    else if (c === '*') { re += '[^/]*'; i++; }
+    else if (c === '?') { re += '[^/]'; i++; }
+    else if (/[.+^${}()|[\]\\]/.test(c)) { re += '\\' + c; i++; }
+    else { re += c; i++; }
+  }
+  return new RegExp(re + '$');
+}
+
+function matchPattern(pattern, files) {
+  const hasWildcard = /[*?]/.test(pattern);
+  if (hasWildcard) {
+    const re = pathToRegex(pattern);
+    return files.filter(f => re.test(f));
+  }
+  return files.filter(f => f.endsWith(pattern) || f.includes('/' + pattern));
+}
+
+export function matchExpectedLinks(ghost, changedFiles) {
+  const matched = [];
+  const unmatched = [];
+  if (!ghost || !Array.isArray(ghost.expectedLinks)) {
+    return { matched, unmatched };
+  }
+  for (const link of ghost.expectedLinks) {
+    if (link.kind !== 'path') continue;
+    const hits = matchPattern(link.value, changedFiles || []);
+    if (hits.length > 0) {
+      for (const h of hits) {
+        matched.push({ pattern: link.value, matchedPath: h });
+      }
+    } else {
+      unmatched.push(link.value);
+    }
+  }
+  return { matched, unmatched };
+}
+
+// --- Target date parsing (for expectedBy) ---
+
+const QUARTER_RE = /^(\d{4})-Q([1-4])$/;
+const MONTH_RE = /^(\d{4})-(\d{2})$/;
+const ISO_PREFIX_RE = /^\d{4}-\d{2}-\d{2}/;
+
+export function parseTargetDate(s) {
+  if (!s || typeof s !== 'string') return null;
+  const q = s.match(QUARTER_RE);
+  if (q) {
+    const year = Number(q[1]);
+    const lastMonthOfQuarter = Number(q[2]) * 3;
+    return new Date(Date.UTC(year, lastMonthOfQuarter, 0));
+  }
+  const m = s.match(MONTH_RE);
+  if (m) {
+    return new Date(Date.UTC(Number(m[1]), Number(m[2]), 0));
+  }
+  if (ISO_PREFIX_RE.test(s)) {
+    const d = new Date(s);
+    return isNaN(d.getTime()) ? null : d;
+  }
+  return null;
+}
+
+// --- Status computation ---
+
+const DEFAULT_GRACE_DAYS = 30;
+const DAY_MS = 86_400_000;
+
+export function computeStatus(ghost, ctx) {
+  if (!ghost) return 'planned';
+  if (ghost.status === 'materialized' || ghost.status === 'cancelled') {
+    return ghost.status;
+  }
+  // ghost.status === 'planned' (or unset)
+  const pathLinks = (ghost.expectedLinks || []).filter(l => l.kind === 'path');
+
+  // Auto-match : if all path links are touched by changedFiles → materialized
+  if (pathLinks.length > 0) {
+    const { matched } = matchExpectedLinks(ghost, ctx?.changedFiles || []);
+    const matchedPatterns = new Set(matched.map(m => m.pattern));
+    if (pathLinks.every(l => matchedPatterns.has(l.value))) {
+      return 'materialized';
+    }
+  }
+
+  // Update 1c : expired check
+  if (ghost.expectedBy) {
+    const target = parseTargetDate(ghost.expectedBy);
+    if (target) {
+      const grace = (ctx?.gracePeriodDays ?? DEFAULT_GRACE_DAYS) * DAY_MS;
+      const now = ctx?.now ?? new Date();
+      if (now.getTime() > target.getTime() + grace) {
+        return 'expired';
+      }
+    }
+  }
+
+  return 'planned';
+}
+
+// --- Clusters parser ---
+
+const CLUSTERS_SECTION_RE = /^##\s+🔗\s+Clusters\s*$/i;
+const CLUSTER_HEADING_RE = /^###\s+(.+?)\s*$/;
+const CLUSTER_EXPECTEDBY_RE = /^\*\*ExpectedBy\*\*\s*:\s*(.+)$/i;
+const CLUSTER_MEMBERS_RE = /^\*\*Members\*\*\s*:\s*(.+)$/i;
+const CLUSTER_STATUS_RE = /^\*\*Status\*\*\s*:\s*(.+)$/i;
+
+export function parseClusters(md) {
+  if (!md || typeof md !== 'string') return [];
+  const lines = md.split('\n');
+  const out = [];
+  let inSection = false;
+  let current = null;
+
+  function flush() {
+    if (current) out.push(current);
+    current = null;
+  }
+
+  for (const line of lines) {
+    if (CLUSTERS_SECTION_RE.test(line)) {
+      inSection = true;
+      continue;
+    }
+    if (inSection && line.startsWith('## ') && !CLUSTERS_SECTION_RE.test(line)) {
+      flush();
+      inSection = false;
+      continue;
+    }
+    if (!inSection) continue;
+
+    const heading = line.match(CLUSTER_HEADING_RE);
+    if (heading) {
+      flush();
+      const title = heading[1].trim();
+      current = {
+        id: title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 60),
+        source: 'declared',
+        title,
+        expectedBy: null,
+        memberIds: [],
+        declaredStatus: null,
+      };
+      continue;
+    }
+    if (!current) continue;
+
+    const eb = line.match(CLUSTER_EXPECTEDBY_RE);
+    if (eb) { current.expectedBy = eb[1].trim(); continue; }
+    const mem = line.match(CLUSTER_MEMBERS_RE);
+    if (mem) { current.memberIds = mem[1].split(',').map(s => s.trim()).filter(Boolean); continue; }
+    const st = line.match(CLUSTER_STATUS_RE);
+    if (st) { current.declaredStatus = st[1].trim().toLowerCase(); continue; }
+  }
+  flush();
+  return out;
+}
+
+import { createHash as _createHash } from 'node:crypto';
+
+export function deriveAutoClusters(ghosts, claimedIds) {
+  if (!Array.isArray(ghosts) || ghosts.length === 0) return [];
+
+  // Union-Find over the undirected dependsOn edges.
+  const parent = new Map();
+  const find = (x) => {
+    if (parent.get(x) === x) return x;
+    const root = find(parent.get(x));
+    parent.set(x, root);
+    return root;
+  };
+  const union = (a, b) => {
+    const ra = find(a), rb = find(b);
+    if (ra !== rb) parent.set(ra, rb);
+  };
+  for (const g of ghosts) parent.set(g.id, g.id);
+  for (const g of ghosts) {
+    for (const dep of g.dependsOn || []) {
+      if (parent.has(dep)) union(g.id, dep);
+    }
+  }
+
+  // Group by root.
+  const groups = new Map();
+  for (const g of ghosts) {
+    if (claimedIds.has(g.id)) continue;
+    const root = find(g.id);
+    if (!groups.has(root)) groups.set(root, []);
+    groups.get(root).push(g.id);
+  }
+
+  const out = [];
+  for (const memberIds of groups.values()) {
+    if (memberIds.length < 2) continue; // singletons not a cluster
+    const sorted = [...memberIds].sort();
+    const sha = _createHash('sha256').update(sorted.join(',')).digest('hex');
+    out.push({
+      id: `auto-cluster-${sha.slice(0, 8)}`,
+      source: 'auto',
+      title: `Auto cluster ${sha.slice(0, 8)}`,
+      expectedBy: null,
+      memberIds: sorted,
+      declaredStatus: null,
+    });
+  }
+  return out.sort((a, b) => a.id.localeCompare(b.id));
+}
+
+export function computeClusterStatus(cluster, members, opts = {}) {
+  const now = opts.now ? new Date(opts.now) : new Date();
+  const gracePeriodDays = opts.gracePeriodDays ?? 30;
+
+  const total = members.length;
+  let materialized = 0, planned = 0, expired = 0, cancelled = 0;
+  let minPlannedAt = null;
+  let maxMaterializedAt = null;
+  let maxCancelledAt = null;
+
+  for (const m of members) {
+    if (m.status === 'materialized') materialized++;
+    else if (m.status === 'cancelled') cancelled++;
+    else if (m.status === 'expired') expired++;
+    else planned++;
+
+    if (m.plannedAt?.date) {
+      if (!minPlannedAt || new Date(m.plannedAt.date) < new Date(minPlannedAt.date)) minPlannedAt = m.plannedAt;
+    }
+    if (m.materializedAt?.date) {
+      if (!maxMaterializedAt || new Date(m.materializedAt.date) > new Date(maxMaterializedAt.date)) maxMaterializedAt = m.materializedAt;
+    }
+    if (m.cancelledAt?.date) {
+      if (!maxCancelledAt || new Date(m.cancelledAt.date) > new Date(maxCancelledAt.date)) maxCancelledAt = m.cancelledAt;
+    }
+  }
+
+  const completionPct = total > 0 ? (materialized / total) * 100 : 0;
+  const allTerminal = (materialized + cancelled) === total;
+  const allCancelled = cancelled === total && total > 0;
+
+  let synthesizedStatus;
+  if (allCancelled) synthesizedStatus = 'cancelled';
+  else if (allTerminal && materialized > 0) synthesizedStatus = 'shipped';
+  else {
+    // check expired
+    if (cluster.expectedBy) {
+      const eb = parseTargetDate(cluster.expectedBy);
+      if (eb) {
+        const expiry = new Date(eb.getTime() + gracePeriodDays * 86_400_000);
+        if (now > expiry) synthesizedStatus = 'expired';
+      }
+    }
+    if (!synthesizedStatus) synthesizedStatus = 'planned';
+  }
+
+  // declaredStatus wins (override)
+  if (cluster.declaredStatus) synthesizedStatus = cluster.declaredStatus;
+
+  return {
+    aggregate: { total, materialized, planned, expired, cancelled, completionPct },
+    synthesizedStatus,
+    plannedAt: minPlannedAt,
+    materializedAt: (allTerminal && materialized > 0) ? maxMaterializedAt : null,
+    cancelledAt: allCancelled ? maxCancelledAt : null,
+  };
+}
diff --git a/docker-server-ghosts.mjs b/docker-server-ghosts.mjs
new file mode 100644
index 00000000..f315ea36
--- /dev/null
+++ b/docker-server-ghosts.mjs
@@ -0,0 +1,527 @@
+/**
+ * I/O wrapper + route handlers for the roadmap-predictive CORE.
+ * Imports pure fns from docker-server-ghosts-core.mjs.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-core-design.md
+ */
+import { readFile, writeFile, mkdir, access } from 'node:fs/promises';
+import { execFile } from 'node:child_process';
+import { promisify } from 'node:util';
+import { join } from 'node:path';
+import {
+  parseRoadmap,
+  renderRoadmapYml,
+  computeStatus,
+  parseClusters,
+  deriveAutoClusters,
+  computeClusterStatus,
+} from './docker-server-ghosts-core.mjs';
+import { findRepoByName, safeSnapshotKey, SNAPSHOTS_ROOT } from './docker-server-snapshots.mjs';
+
+const execFileP = promisify(execFile);
+
+// --- Plugin-aware ghost-source registry ---
+//
+// A ghost source is `{ name: string, fetchGhosts: async (repoPath) => GhostInput[] }`.
+// The builtin source (`roadmap-md`) parses ROADMAP.md at the repo root and is
+// always registered at module load. External sources can be added via
+// `registerGhostSource`; their ghosts get merged into `syncGhostsForRepo` /
+// `syncGhostsForSnapshot`, with the builtin winning on `id` conflicts.
+//
+// Spec : docs/superpowers/specs/2026-05-26-roadmap-predictive-core-design.md (Update delta b).
+
+const BUILTIN_GHOST_SOURCE_NAME = 'roadmap-md';
+
+/** @type {Map<string, { name: string, fetchGhosts: Function }>} */
+const ghostSources = new Map();
+
+function assertValidSource(source) {
+  if (!source || typeof source !== 'object') {
+    throw new TypeError('registerGhostSource: source must be an object');
+  }
+  if (typeof source.name !== 'string' || source.name.length === 0) {
+    throw new TypeError('registerGhostSource: source.name must be a non-empty string');
+  }
+  if (typeof source.fetchGhosts !== 'function') {
+    throw new TypeError('registerGhostSource: source.fetchGhosts must be a function returning a Promise');
+  }
+}
+
+/**
+ * Public : register an external ghost source. The builtin source `roadmap-md`
+ * cannot be replaced — calling with that name is a no-op + stderr warning.
+ *
+ * @param {{ name: string, fetchGhosts: (repoPath: string) => Promise<Array> }} source
+ */
+export function registerGhostSource(source) {
+  assertValidSource(source);
+  if (source.name === BUILTIN_GHOST_SOURCE_NAME) {
+    console.warn(
+      `[ghosts] registerGhostSource: cannot replace builtin source "${BUILTIN_GHOST_SOURCE_NAME}" — ignoring`,
+    );
+    return;
+  }
+  ghostSources.set(source.name, { name: source.name, fetchGhosts: source.fetchGhosts });
+}
+
+/**
+ * Public : list registered ghost source names (builtin first, then external
+ * in insertion order). Useful for tests and the future Audit/Plane connector.
+ */
+export function listGhostSources() {
+  return [...ghostSources.keys()];
+}
+
+/**
+ * Test-only : clear non-builtin sources. The builtin always persists.
+ * Use in `beforeEach` / `afterEach` to keep integration tests deterministic.
+ */
+export function _resetGhostSourcesForTests() {
+  for (const name of [...ghostSources.keys()]) {
+    if (name !== BUILTIN_GHOST_SOURCE_NAME) ghostSources.delete(name);
+  }
+  // Defensive : re-register builtin if for some reason it was wiped.
+  if (!ghostSources.has(BUILTIN_GHOST_SOURCE_NAME)) {
+    registerBuiltinGhostSource();
+  }
+}
+
+function registerBuiltinGhostSource() {
+  ghostSources.set(BUILTIN_GHOST_SOURCE_NAME, {
+    name: BUILTIN_GHOST_SOURCE_NAME,
+    fetchGhosts: async (repoPath) => parseRoadmap(await readRoadmapMd(repoPath)),
+  });
+}
+
+// Register the builtin at module load. Must come before any consumer can
+// import this module — that's why this block lives at the top of the file.
+// Idempotency guard : safe against future hot-reload / re-import scenarios.
+if (!ghostSources.has(BUILTIN_GHOST_SOURCE_NAME)) {
+  registerBuiltinGhostSource();
+}
+
+/**
+ * Internal : iterate all registered sources, fetch their declared ghosts and
+ * merge them by `id`. The builtin (`roadmap-md`) wins on id conflicts. Each
+ * surviving ghost gets a `source: <name>` field added so the runtime JSON
+ * can attribute it.
+ *
+ * Returns an array of GhostInput-like objects with an extra `source` field.
+ */
+async function fetchAndMergeDeclaredGhosts(repoPath) {
+  /** @type {Map<string, any>} */
+  const byId = new Map();
+  // Pull builtin first so it gets to claim its ids unconditionally.
+  const orderedSources = [
+    ghostSources.get(BUILTIN_GHOST_SOURCE_NAME),
+    ...[...ghostSources.values()].filter(s => s.name !== BUILTIN_GHOST_SOURCE_NAME),
+  ].filter(Boolean);
+
+  for (const src of orderedSources) {
+    let ghosts;
+    try {
+      ghosts = await src.fetchGhosts(repoPath);
+    } catch (err) {
+      console.warn(`[ghosts] source "${src.name}" threw — ignoring: ${err?.message || err}`);
+      continue;
+    }
+    if (!Array.isArray(ghosts)) continue;
+    for (const g of ghosts) {
+      if (!g || typeof g.id !== 'string') continue;
+      if (src.name === BUILTIN_GHOST_SOURCE_NAME) {
+        // Builtin always wins. Tag it for downstream consumers.
+        byId.set(g.id, { ...g, source: BUILTIN_GHOST_SOURCE_NAME });
+      } else if (!byId.has(g.id)) {
+        // External : add only if not shadowed by builtin (or an earlier external).
+        byId.set(g.id, { ...g, source: src.name });
+      }
+      // else: shadowed, drop silently.
+    }
+  }
+  return [...byId.values()];
+}
+
+// Test-only re-export of the internal merge helper. Lets the unit suite assert
+// the real "builtin-wins / first-non-builtin-wins" semantic without standing
+// up a git repo. Production code MUST NOT import this — call the public sync
+// functions instead.
+export { fetchAndMergeDeclaredGhosts as _fetchAndMergeDeclaredGhostsForTests };
+
+async function fileExists(p) {
+  try { await access(p); return true; } catch { return false; }
+}
+
+async function readRoadmapMd(repoPath) {
+  const path = join(repoPath, 'ROADMAP.md');
+  if (!(await fileExists(path))) return '';
+  return readFile(path, 'utf8');
+}
+
+async function getHeadSha(repoPath) {
+  const { stdout } = await execFileP('git', ['rev-parse', 'HEAD'], { cwd: repoPath });
+  return stdout.trim();
+}
+
+async function getHeadDate(repoPath) {
+  const { stdout } = await execFileP('git', ['log', '-1', '--format=%cI'], { cwd: repoPath });
+  return stdout.trim();
+}
+
+async function getChangedFilesSince(repoPath, fromSha) {
+  if (!fromSha) return [];
+  try {
+    const { stdout } = await execFileP(
+      'git',
+      ['log', '--name-only', '--pretty=format:', `${fromSha}..HEAD`],
+      { cwd: repoPath },
+    );
+    return [...new Set(stdout.split('\n').map(l => l.trim()).filter(Boolean))];
+  } catch {
+    return [];
+  }
+}
+
+/**
+ * Build the runtime ghost objects (declared + plannedAt + materializedAt + links).
+ * Idempotent : a second call with no changes produces the same JSON.
+ */
+async function buildGhosts(repoPath, declaredGhosts, previousRuntime) {
+  const sha = await getHeadSha(repoPath);
+  const date = await getHeadDate(repoPath);
+  const result = [];
+
+  const prevById = new Map((previousRuntime?.ghosts || []).map(g => [g.id, g]));
+
+  for (const declared of declaredGhosts) {
+    const prev = prevById.get(declared.id);
+    const plannedAt = prev?.plannedAt ?? { commit: sha, date };
+
+    let materializedAt = prev?.materializedAt ?? null;
+    let cancelledAt = prev?.cancelledAt ?? null;
+
+    // Declared status (from emoji in ROADMAP) wins.
+    if (declared.status === 'materialized' && !materializedAt) {
+      materializedAt = { commit: sha, date, confirmedBy: 'manual' };
+      cancelledAt = null;
+    }
+    if (declared.status === 'cancelled' && !cancelledAt) {
+      cancelledAt = { commit: sha, date };
+    }
+    if (declared.status === 'planned' && cancelledAt) {
+      cancelledAt = null; // ghost came back after cancellation
+    }
+
+    // Auto-match : if all paths match recently changed files, suggest materialization.
+    if (declared.status === 'planned' && !materializedAt) {
+      const changedFiles = await getChangedFilesSince(repoPath, plannedAt.commit);
+      const computed = computeStatus(declared, { changedFiles });
+      if (computed === 'materialized') {
+        materializedAt = { commit: sha, date, confirmedBy: 'auto' };
+      }
+    }
+
+    result.push({
+      id: declared.id,
+      // Carry the source attribution into the runtime JSON. Falls back to the
+      // builtin when an upstream caller passes a bare GhostInput[] without
+      // attribution (e.g. an older code path).
+      source: declared.source || BUILTIN_GHOST_SOURCE_NAME,
+      declared,
+      plannedAt,
+      materializedAt,
+      cancelledAt,
+      links: materializedAt ? (prev?.links || []) : [],
+    });
+  }
+
+  // Detect cancellations : ghosts in prev that are no longer declared.
+  for (const [id, prev] of prevById) {
+    if (!declaredGhosts.find(d => d.id === id)) {
+      result.push({
+        ...prev,
+        cancelledAt: prev.cancelledAt ?? { commit: sha, date },
+      });
+    }
+  }
+
+  return { syncedAt: date, syncedCommit: sha, ghosts: result };
+}
+
+/**
+ * Internal : build the runtime clusters payload for a sync.
+ *
+ * Combines declared clusters (parsed from ROADMAP.md) with auto-derived
+ * clusters (Union-Find on the dependsOn graph, excluding members already
+ * claimed by a declared cluster), then attaches `computeClusterStatus` output
+ * (aggregate counts + synthesizedStatus + plannedAt/materializedAt) for each.
+ *
+ * Returns `{ syncedAt, syncedCommit, clusters, declaredClusters }` — the last
+ * field is the raw declared list (without member-status enrichment) for the
+ * roadmap.yml renderer that needs only the declared shapes.
+ */
+function buildClusters(md, runtime) {
+  const declaredClusters = parseClusters(md);
+  const claimedIds = new Set(declaredClusters.flatMap(c => c.memberIds));
+  const autoClusters = deriveAutoClusters(runtime.ghosts, claimedIds);
+  const allClusters = [...declaredClusters, ...autoClusters];
+
+  const ghostsById = new Map(runtime.ghosts.map(g => [g.id, g]));
+
+  const clusters = allClusters.map(c => {
+    const members = c.memberIds.map(mid => {
+      const g = ghostsById.get(mid);
+      if (!g) return { id: mid, status: 'planned' };
+      return {
+        id: g.id,
+        status: g.declared.status,
+        plannedAt: g.plannedAt,
+        materializedAt: g.materializedAt,
+        cancelledAt: g.cancelledAt,
+      };
+    });
+    const computed = computeClusterStatus(c, members);
+    return { ...c, ...computed };
+  });
+
+  return {
+    syncedAt: runtime.syncedAt,
+    syncedCommit: runtime.syncedCommit,
+    clusters,
+    declaredClusters,
+  };
+}
+
+/**
+ * Public : sync at HEAD, write roadmap.yml + .gitnexus/ghosts.json +
+ * .gitnexus/clusters.json. Iterates every registered ghost source and merges
+ * them by id (builtin wins).
+ */
+export async function syncGhostsForRepo(repoPath) {
+  const declared = await fetchAndMergeDeclaredGhosts(repoPath);
+
+  let previous = null;
+  const runtimePath = join(repoPath, '.gitnexus', 'ghosts.json');
+  if (await fileExists(runtimePath)) {
+    try { previous = JSON.parse(await readFile(runtimePath, 'utf8')); } catch { /* corrupt = treat as none */ }
+  }
+
+  const runtime = await buildGhosts(repoPath, declared, previous);
+
+  // Parse the markdown once for cluster declarations; renderRoadmapYml then
+  // re-emits them inline in roadmap.yml. parseClusters tolerates missing files.
+  const md = await readRoadmapMd(repoPath);
+  const clusterPayload = buildClusters(md, runtime);
+  const yml = renderRoadmapYml(declared, { clusters: clusterPayload.declaredClusters });
+
+  await writeFile(join(repoPath, 'roadmap.yml'), yml);
+  await mkdir(join(repoPath, '.gitnexus'), { recursive: true });
+  await writeFile(runtimePath, JSON.stringify(runtime, null, 2) + '\n');
+
+  const clustersPath = join(repoPath, '.gitnexus', 'clusters.json');
+  const { declaredClusters: _omitDeclared, ...clustersJson } = clusterPayload;
+  await writeFile(clustersPath, JSON.stringify(clustersJson, null, 2) + '\n');
+
+  return runtime;
+}
+
+/**
+ * Public : sync inside a snapshot's directory. Does NOT touch the latest
+ * ghosts.json or clusters.json. Uses the same registry merge as
+ * `syncGhostsForRepo`.
+ */
+export async function syncGhostsForSnapshot(repoPath, snapshotDir, sha) {
+  const declared = await fetchAndMergeDeclaredGhosts(repoPath);
+
+  // For a historical snapshot, we re-derive from the markdown at this commit.
+  // plannedAt/materializedAt are sealed to this sha if declared-status is
+  // materialized/cancelled.
+  const runtime = await buildGhosts(repoPath, declared, null);
+
+  await mkdir(snapshotDir, { recursive: true });
+  await writeFile(join(snapshotDir, 'ghosts.json'), JSON.stringify(runtime, null, 2) + '\n');
+
+  // Snapshot clusters mirror the runtime ghosts at this commit. parseClusters
+  // tolerates a missing ROADMAP.md — auto-clusters still get derived from
+  // dependsOn edges in the snapshotted ghosts.
+  const md = await readRoadmapMd(repoPath);
+  const clusterPayload = buildClusters(md, runtime);
+  const { declaredClusters: _omitDeclared, ...clustersJson } = clusterPayload;
+  await writeFile(
+    join(snapshotDir, 'clusters.json'),
+    JSON.stringify(clustersJson, null, 2) + '\n',
+  );
+
+  return runtime;
+}
+
+/**
+ * Public : read latest ghosts.json, return parsed object or null if absent.
+ */
+export async function readLatestGhosts(repoPath) {
+  const path = join(repoPath, '.gitnexus', 'ghosts.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+/**
+ * Public : read a snapshot's ghosts.json.
+ *
+ * Takes the snapshot's storage directory (the same `snapshotDir` that
+ * `syncGhostsForSnapshot` writes to — typically
+ * `SNAPSHOTS_ROOT/<repoKey>/<shortHash>`) and reads `<snapshotDir>/ghosts.json`.
+ * Returns the parsed runtime object, or null if the file is absent.
+ */
+export async function readSnapshotGhosts(snapshotDir) {
+  const path = join(snapshotDir, 'ghosts.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+/**
+ * Public : read latest clusters.json (sibling of ghosts.json under `.gitnexus/`).
+ * Returns the parsed payload or null if absent. Section B Task 4 of the Ghost
+ * Cluster plan.
+ */
+export async function readLatestClusters(repoPath) {
+  const path = join(repoPath, '.gitnexus', 'clusters.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+/**
+ * Public : read a snapshot's clusters.json (sibling of the snapshot's
+ * ghosts.json). Returns the parsed payload or null if absent.
+ */
+export async function readSnapshotClusters(snapshotDir) {
+  const path = join(snapshotDir, 'clusters.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+// ---------------------------------------------------------------------------
+// HTTP route handlers (Task 7 of the roadmap-predictive CORE plan).
+//
+// Three routes, all dispatched by `handleGhostsRoute`:
+//   POST /ghosts/sync?repo=<name>           run syncGhostsForRepo
+//   GET  /ghosts?repo=<name>                read .gitnexus/ghosts.json
+//   GET  /ghosts/at?repo=<name>&commit=<sha> read a snapshot's ghosts.json
+//
+// Wired into `docker-server.mjs` by Task 8.
+// ---------------------------------------------------------------------------
+
+async function handleGhostsSync(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+      return;
+    }
+    const repoPath = repo.repoPath || repo.path;
+    const runtime = await syncGhostsForRepo(repoPath);
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ synced: true, ...runtime }));
+  } catch (err) {
+    console.error('[ghosts] sync failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+async function handleGhostsGet(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+      return;
+    }
+    const repoPath = repo.repoPath || repo.path;
+    const runtime = await readLatestGhosts(repoPath);
+    if (!runtime) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: 'No ghosts.json — run POST /ghosts/sync first.' }));
+      return;
+    }
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(runtime));
+  } catch (err) {
+    console.error('[ghosts] get failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+async function handleGhostsAt(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const commitKey = url.searchParams.get('commit');
+  if (!commitKey) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing commit' }));
+    return;
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+      return;
+    }
+    const snapshotDir = join(
+      SNAPSHOTS_ROOT,
+      safeSnapshotKey(repoName),
+      safeSnapshotKey(commitKey),
+    );
+    const runtime = await readSnapshotGhosts(snapshotDir);
+    if (!runtime) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `No ghosts.json for snapshot ${commitKey}.` }));
+      return;
+    }
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(runtime));
+  } catch (err) {
+    console.error('[ghosts] at failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+/**
+ * Public dispatcher : returns true if the request matches one of the
+ * three ghost routes (and is fully handled), false otherwise.
+ *
+ * Registered in `docker-server.mjs` next to the snapshot dispatcher.
+ */
+export async function handleGhostsRoute(req, url, res, opts) {
+  if (url.pathname === '/ghosts/sync' && req.method === 'POST') {
+    await handleGhostsSync(url, res, opts);
+    return true;
+  }
+  if (url.pathname === '/ghosts' && req.method === 'GET') {
+    await handleGhostsGet(url, res, opts);
+    return true;
+  }
+  if (url.pathname === '/ghosts/at' && req.method === 'GET') {
+    await handleGhostsAt(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-git-utils.mjs b/docker-server-git-utils.mjs
new file mode 100644
index 00000000..f30716c8
--- /dev/null
+++ b/docker-server-git-utils.mjs
@@ -0,0 +1,113 @@
+/**
+ * Shared git + snapshot helpers (extracted from docker-server-entropy-commits.mjs
+ * and docker-server-coupling.mjs for reuse by regression forensics Phase 2).
+ * Zero-dep. See docs/superpowers/specs/2026-05-28-regression-forensics-phase2-design.md
+ */
+import { spawn } from 'node:child_process';
+import { readdir, readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import { SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+
+export function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+// Parse `git log --pretty=format:%H%x09%aI%x09%an --name-only --no-merges`
+// → [{ sha, date (ISO), author, files: [path, ...] }]
+export function parseGitLog(stdout) {
+  const commits = [];
+  let header = null;
+  let files = [];
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      if (header) {
+        commits.push({ ...header, files });
+        header = null;
+        files = [];
+      }
+      continue;
+    }
+    if (header === null) {
+      const parts = line.split('\t');
+      if (parts.length < 3) continue;
+      header = { sha: parts[0], date: parts[1], author: parts[2] };
+      continue;
+    }
+    files.push(line);
+  }
+  if (header) commits.push({ ...header, files });
+  return commits;
+}
+
+// Resolve a window-end value: SHA → commit date, ISO → ISO, else null.
+export async function resolveWindowEnd(repoPath, value) {
+  if (!value) return null;
+  // ISO-ish? Any string that Date.parse accepts AND contains a '-' or 'T'.
+  if (/^\d{4}-/.test(value)) {
+    const t = Date.parse(value);
+    if (Number.isFinite(t)) return new Date(t).toISOString();
+  }
+  // SHA → commit date.
+  try {
+    const out = await runCmd('git', [
+      '-C', repoPath, 'show', '-s', '--format=%aI', value,
+    ]);
+    const iso = out.trim();
+    if (iso && Number.isFinite(Date.parse(iso))) return iso;
+  } catch {
+    // Fall through.
+  }
+  throw new Error(`could not resolve ${value} as a SHA or ISO date`);
+}
+
+export async function listSnapshotNamesAndDates(repoName) {
+  const repoSnapshotsDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(repoSnapshotsDir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(
+        await readFile(join(repoSnapshotsDir, e.name, 'commit.json'), 'utf8'),
+      );
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built snapshot; skip
+    }
+  }
+  return out;
+}
+
+// NEW: commits in a [fromIso, toIso] window with filesTouched counts.
+export async function commitsInWindow(repoPath, fromIso, toIso) {
+  const args = ['-C', repoPath, 'log', '--pretty=format:%H%x09%aI%x09%an', '--name-only', '--no-merges'];
+  if (fromIso) args.push(`--since=${fromIso}`);
+  if (toIso) args.push(`--until=${toIso}`);
+  let out;
+  try { out = await runCmd('git', args); } catch { return []; }
+  return parseGitLog(out).map((c) => ({
+    sha: c.sha,
+    shortSha: c.sha ? c.sha.slice(0, 7) : null,
+    author: c.author,
+    date: c.date,
+    filesTouched: Array.isArray(c.files) ? c.files.length : 0,
+  }));
+}
