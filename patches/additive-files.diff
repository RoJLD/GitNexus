+  const dim = vectors[0].length;
+  const c = new Array(dim).fill(0);
+  for (const v of vectors) {
+    if (v.length !== dim) return null;
+    for (let i = 0; i < dim; i++) c[i] += v[i];
+  }
+  for (let i = 0; i < dim; i++) c[i] /= vectors.length;
+  return c;
