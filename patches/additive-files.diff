+/**
+ * Graph-theory engine — pure JS, ZERO deps (matches every docker-server-*.mjs;
+ * graphology is a frontend-only dep). Operates on the universal render shape
+ * { nodes:[{id,...}], edges:[{source,target,...}] }. Degree + PageRank
+ * (power iteration) + Louvain (single-level modularity local-moving).
+ */
+
+function nodeIds(graph) {
+  const ids = [];
+  const seen = new Set();
+  for (const n of graph.nodes || []) {
+    if (n && n.id != null && !seen.has(n.id)) { seen.add(n.id); ids.push(n.id); }
+  }
+  return ids;
+}
+
+function cleanEdges(graph, idSet) {
+  const out = [];
+  for (const e of graph.edges || []) {
+    if (e && idSet.has(e.source) && idSet.has(e.target) && e.source !== e.target) out.push([e.source, e.target]);
+  }
+  return out;
+}
+
+export function degreeCentrality(graph) {
+  const ids = nodeIds(graph);
+  const idSet = new Set(ids);
+  const deg = {};
+  for (const id of ids) deg[id] = 0;
+  for (const [s, t] of cleanEdges(graph, idSet)) { deg[s]++; deg[t]++; }
+  return deg;
+}
+
+export function pageRank(graph, { damping = 0.85, maxIter = 200, tol = 1e-9 } = {}) {
+  const ids = nodeIds(graph);
+  const N = ids.length;
+  const pr = {};
+  if (N === 0) return pr;
+  const idSet = new Set(ids);
+  const outAdj = new Map(ids.map((id) => [id, []]));
+  for (const [s, t] of cleanEdges(graph, idSet)) outAdj.get(s).push(t);
+  let rank = new Map(ids.map((id) => [id, 1 / N]));
+  for (let iter = 0; iter < maxIter; iter++) {
+    const next = new Map(ids.map((id) => [id, (1 - damping) / N]));
+    let dangling = 0;
+    for (const id of ids) { if (outAdj.get(id).length === 0) dangling += rank.get(id); }
+    const danglingShare = (damping * dangling) / N;
+    for (const id of ids) next.set(id, next.get(id) + danglingShare);
+    for (const id of ids) {
+      const outs = outAdj.get(id);
+      if (outs.length === 0) continue;
+      const share = (damping * rank.get(id)) / outs.length;
+      for (const t of outs) next.set(t, next.get(t) + share);
+    }
+    let diff = 0;
+    for (const id of ids) diff += Math.abs(next.get(id) - rank.get(id));
+    rank = next;
+    if (diff < tol) break;
+  }
+  for (const id of ids) pr[id] = rank.get(id);
+  return pr;
+}
+
+function mulberry32(seed) {
+  let a = seed >>> 0;
+  return function () {
+    a |= 0; a = (a + 0x6d2b79f5) | 0;
+    let t = Math.imul(a ^ (a >>> 15), 1 | a);
+    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
+    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+  };
+}
+
+/**
+ * Louvain local-moving phase on a WEIGHTED adjacency. Returns Map<node, communityLabel>
+ * with labels renumbered 0..k-1 in adjW key-iteration order (so the caller's node order
+ * drives label assignment, matching the original single-level louvain output exactly).
+ *   adjW : Map<node, Map<nbr, weight>> — symmetric; a self-loop weight w on node u counts
+ *          as 2w in u's weighted degree (caller's responsibility to reflect that in kW).
+ *   kW   : Map<node, weightedDegree>
+ *   m2W  : 2 × total edge weight (Σ kW over all nodes). Must be > 0.
+ */
+function localMoving(adjW, kW, m2W, { seed = 1, resolution = 1 } = {}) {
+  const nodes = [...adjW.keys()];
+  const comm = new Map(nodes.map((id) => [id, id]));
+  const sigmaTot = new Map(nodes.map((id) => [id, kW.get(id)]));
+  const rng = mulberry32(seed);
+  const order = nodes.slice();
+  let improved = true;
+  let rounds = 0;
+  while (improved && rounds < 100) {
+    improved = false; rounds++;
+    for (let i = order.length - 1; i > 0; i--) { const j = Math.floor(rng() * (i + 1)); [order[i], order[j]] = [order[j], order[i]]; }
+    for (const id of order) {
+      const ki = kW.get(id);
+      const cur = comm.get(id);
+      sigmaTot.set(cur, sigmaTot.get(cur) - ki);
+      const kin = new Map();
+      for (const [nbr, w] of adjW.get(id)) {
+        if (nbr === id) continue;   // a self-loop never pulls a node toward (or away from) any community
+        const c = comm.get(nbr);
+        kin.set(c, (kin.get(c) || 0) + w);
+      }
+      let best = cur;
+      let bestGain = (kin.get(cur) || 0) - resolution * (sigmaTot.get(cur) * ki) / m2W;
+      for (const [c, kic] of kin) {
+        const gain = kic - resolution * (sigmaTot.get(c) * ki) / m2W;
+        if (gain > bestGain + 1e-12) { bestGain = gain; best = c; }
+      }
+      comm.set(id, best);
+      sigmaTot.set(best, sigmaTot.get(best) + ki);
+      if (best !== cur) improved = true;
+    }
+  }
+  const label = new Map();
+  let nextLabel = 0;
+  const out = new Map();
+  for (const id of nodes) {
+    const c = comm.get(id);
+    if (!label.has(c)) label.set(c, nextLabel++);
+    out.set(id, label.get(c));
+  }
+  return out;
+}
+
+/** Build the unit-weight weighted adjacency of `graph`: { adj, k, m2, ids }. */
+function unitWeightAdj(graph) {
+  const ids = nodeIds(graph);
+  const idSet = new Set(ids);
+  const adj = new Map(ids.map((id) => [id, new Map()]));
+  const k = new Map(ids.map((id) => [id, 0]));
+  let m2 = 0;
+  for (const [s, t] of cleanEdges(graph, idSet)) {
+    adj.get(s).set(t, (adj.get(s).get(t) || 0) + 1);
+    adj.get(t).set(s, (adj.get(t).get(s) || 0) + 1);
+    k.set(s, k.get(s) + 1); k.set(t, k.get(t) + 1);
+    m2 += 2;
+  }
+  return { adj, k, m2, ids };
+}
+
+export function louvain(graph, { seed = 1, resolution = 1 } = {}) {
+  const { adj, k, m2, ids } = unitWeightAdj(graph);
+  const communities = {};
+  if (m2 === 0) { ids.forEach((id, i) => { communities[id] = i; }); return { communities, modularity: 0 }; }
+
+  const labels = localMoving(adj, k, m2, { seed, resolution });
+  for (const id of ids) communities[id] = labels.get(id);
+  // Modularity Q = Σ_c [ Σin_c/m2 − (Σtot_c/m2)² ].
+  // adj is symmetric (each undirected edge stored both directions), so this loop
+  // counts each internal edge twice — intentional: the ×2 cancels with m2 (=2·total weight).
+  const sin = new Map();
+  const stot = new Map();
+  for (const id of ids) {
+    const c = communities[id];
+    stot.set(c, (stot.get(c) || 0) + k.get(id));
+    for (const [nbr, w] of adj.get(id)) { if (communities[nbr] === c) sin.set(c, (sin.get(c) || 0) + w); }
+  }
+  let modularity = 0;
+  for (const [c, st] of stot) modularity += (sin.get(c) || 0) / m2 - resolution * (st / m2) ** 2;
+  return { communities, modularity };
+}
+
+/**
+ * Aggregate a weighted graph into its community super-graph. `labels` maps each current
+ * node → community label; each label becomes a super-node. Every edge (u,v,w) — including
+ * intra-community edges, which fold into a super-node SELF-LOOP — is summed into the super
+ * adjacency. Because the input adjacency is symmetric (both (u,v) and (v,u) carry w), an
+ * intra-community edge accumulates onto adj.get(c).get(c) from both directions → a self-loop
+ * weight of 2·(internal weight), which is exactly its contribution to the super-node's
+ * weighted degree. Returns { adj, k, m2 }; m2 (= Σ weighted degree) is invariant under
+ * aggregation, so modularity is preserved across levels.
+ */
+function aggregate(adjW, labels) {
+  const superNodes = [...new Set([...labels.values()])];
+  const adj = new Map(superNodes.map((c) => [c, new Map()]));
+  const k = new Map(superNodes.map((c) => [c, 0]));
+  for (const [u, nbrs] of adjW) {
+    const cu = labels.get(u);
+    const row = adj.get(cu);
+    for (const [v, w] of nbrs) {
+      const cv = labels.get(v);
+      row.set(cv, (row.get(cv) || 0) + w);
+      k.set(cu, k.get(cu) + w);   // every (directed) endpoint adds w to its super-node's degree
+    }
+  }
+  let m2 = 0;
+  for (const v of k.values()) m2 += v;
+  return { adj, k, m2 };
+}
+
+/**
+ * Multi-level (hierarchical) Louvain. Returns { levels: [...] }, FINEST first (level 0 =
+ * the single-level local-moving partition, identical co-membership to `louvain`). Each
+ * subsequent level aggregates the previous partition into a super-graph and re-runs
+ * local-moving, composing the super-node labels back onto the ORIGINAL ids. Stops when a
+ * level no longer reduces the community count (no duplicate final level emitted).
+ *
+ * Each level entry: { communities: {origId→label}, modularity, communityCount }, where
+ * modularity is Q of that partition over the ORIGINAL graph (via modularityOf) and
+ * communityCount is the number of distinct labels.
+ *
+ * Edge cases: edgeless graph → exactly one level (each node its own community); empty graph
+ * → one empty level { communities:{}, modularity:0, communityCount:0 }.
+ */
+export function louvainMultiLevel(graph, { seed = 1, resolution = 1 } = {}) {
+  const { adj, k, m2, ids } = unitWeightAdj(graph);
+  if (ids.length === 0) return { levels: [{ communities: {}, modularity: 0, communityCount: 0 }] };
+  if (m2 === 0) {
+    // Edgeless: each node is its own community — a single level, no aggregation possible.
+    const communities = {};
+    ids.forEach((id, i) => { communities[id] = i; });
+    return { levels: [{ communities, modularity: 0, communityCount: ids.length }] };
+  }
+
+  // Helper: emit a level entry from a Map<origId, label>, renumbered 0..k-1 in ids order.
+  const makeLevel = (origLabels) => {
+    const remap = new Map();
+    let next = 0;
+    const communities = {};
+    for (const id of ids) { const c = origLabels.get(id); if (!remap.has(c)) remap.set(c, next++); communities[id] = remap.get(c); }
+    return { communities, modularity: modularityOf(graph, communities, resolution), communityCount: next };
+  };
+
+  const levels = [];
+  // Level 0: local-moving on the original unit-weight graph.
+  const baseLabels = localMoving(adj, k, m2, { seed, resolution });
+  // node→superNode for the CURRENT aggregation level, and origId→superNode composition.
+  let currentAdj = adj;
+  let nodeToSuper = baseLabels;                       // current-graph node → its super-node id
+  let origToSuper = new Map(ids.map((id) => [id, baseLabels.get(id)]));   // origId → current super-node
+  levels.push(makeLevel(origToSuper));
+
+  let prevCount = new Set(baseLabels.values()).size;
+  let level = 0;
+  while (level < 100) {
+    level++;
+    // Aggregate the current graph by its current partition, then re-run local-moving.
+    const { adj: superAdj, k: superK, m2: superM2 } = aggregate(currentAdj, nodeToSuper);
+    const superLabels = localMoving(superAdj, superK, superM2, { seed: seed + level, resolution });
+    const newCount = new Set(superLabels.values()).size;
+    if (newCount >= prevCount) break;                // no further merging → stop, don't emit a dup
+    // Compose: origId → (its super-node at the previous level) → (new coarser label).
+    const composed = new Map();
+    for (const id of ids) composed.set(id, superLabels.get(origToSuper.get(id)));
+    levels.push(makeLevel(composed));
+    // Advance: the new super-graph becomes "current" for the next round.
+    currentAdj = superAdj;
+    nodeToSuper = superLabels;                        // super-graph node → its coarser super-node
+    origToSuper = composed;
+    prevCount = newCount;
+  }
+  return { levels };
+}
+
+/** Undirected neighbor lists over the cleaned edge set. */
+function undirectedAdj(graph) {
+  const ids = nodeIds(graph);
+  const idSet = new Set(ids);
+  const adj = new Map(ids.map((id) => [id, []]));
+  for (const [s, t] of cleanEdges(graph, idSet)) { adj.get(s).push(t); adj.get(t).push(s); }
+  return { ids, adj };
+}
+
+/** Sample k distinct ids deterministically (partial Fisher–Yates with a seeded RNG). */
+function samplePivots(ids, k, seed) {
+  const rng = mulberry32(seed);
+  const arr = ids.slice();
+  const n = arr.length;
+  const m = Math.min(k, n);
+  for (let i = 0; i < m; i++) {
+    const j = i + Math.floor(rng() * (n - i));
+    [arr[i], arr[j]] = [arr[j], arr[i]];
+  }
+  return arr.slice(0, m);
+}
+
+/**
+ * Directed adjacency over the direction-preserving cleaned edge set.
+ * cleanEdges keeps [source,target] ordered (only the undirected path symmetrizes),
+ * so out = forward edges, in = reversed edges. Returns { ids, out, in } (both Maps).
+ */
+export function directedAdj(graph) {
+  const ids = nodeIds(graph);
+  const idSet = new Set(ids);
+  const out = new Map(ids.map((id) => [id, []]));
+  const inn = new Map(ids.map((id) => [id, []]));
+  for (const [s, t] of cleanEdges(graph, idSet)) { out.get(s).push(t); inn.get(t).push(s); }
+  return { ids, out, in: inn };
+}
+
+/** In/out degree split by direction. Plain objects, every id present (0 if no edges). */
+export function inOutDegree(graph) {
+  const { ids, out, in: inn } = directedAdj(graph);
+  const inDegree = {};
+  const outDegree = {};
+  for (const id of ids) { outDegree[id] = out.get(id).length; inDegree[id] = inn.get(id).length; }
+  return { inDegree, outDegree };
+}
+
+/**
+ * HITS (Kleinberg) hubs + authorities via power iteration with per-step L2 normalization.
+ * auth[v] = Σ_{u→v} hub[u] then normalize; hub[v] = Σ_{v→w} auth[w] then normalize.
+ * Zero-norm fallback to uniform 1/N mirrors eigenvector's edgeless guard. Empty → {}.
+ */
+export function hits(graph, { maxIter = 200, tol = 1e-9 } = {}) {
+  const { ids, out, in: inn } = directedAdj(graph);
+  const N = ids.length;
+  const hubsOut = {};
+  const authOut = {};
+  if (N === 0) return { hubs: hubsOut, authorities: authOut };
+  let hub = new Map(ids.map((id) => [id, 1]));
+  let auth = new Map(ids.map((id) => [id, 1]));
+  const l2norm = (m) => { let s = 0; for (const id of ids) s += m.get(id) * m.get(id); return Math.sqrt(s); };
+  for (let iter = 0; iter < maxIter; iter++) {
+    // authority update: sum of hub scores of in-neighbors, then L2-normalize
+    const nextAuth = new Map(ids.map((id) => [id, 0]));
+    for (const v of ids) { let a = 0; for (const u of inn.get(v)) a += hub.get(u); nextAuth.set(v, a); }
+    let na = l2norm(nextAuth);
+    if (na === 0) { for (const id of ids) nextAuth.set(id, 1 / N); } else { for (const id of ids) nextAuth.set(id, nextAuth.get(id) / na); }
+    // hub update: sum of (updated) authority scores of out-neighbors, then L2-normalize
+    const nextHub = new Map(ids.map((id) => [id, 0]));
+    for (const v of ids) { let h = 0; for (const w of out.get(v)) h += nextAuth.get(w); nextHub.set(v, h); }
+    let nh = l2norm(nextHub);
+    if (nh === 0) { for (const id of ids) nextHub.set(id, 1 / N); } else { for (const id of ids) nextHub.set(id, nextHub.get(id) / nh); }
+    let diff = 0;
+    for (const id of ids) diff += Math.abs(nextAuth.get(id) - auth.get(id)) + Math.abs(nextHub.get(id) - hub.get(id));
+    auth = nextAuth; hub = nextHub;
+    if (diff < tol) break;
+  }
+  for (const id of ids) { hubsOut[id] = hub.get(id); authOut[id] = auth.get(id); }
+  return { hubs: hubsOut, authorities: authOut };
+}
+
+/**
+ * Strongly connected components via iterative Tarjan (explicit work-stack of frames like
+ * articulationPointsAndBridges — NO recursion, so deep digraphs don't blow the call stack).
+ * Returns Map<id, sccId>; sccIds assigned 0..k-1 in the order SCCs are completed (popped).
+ */
+export function stronglyConnectedComponents(graph) {
+  const { ids, out } = directedAdj(graph);
+  const index = new Map();      // DFS discovery index
+  const low = new Map();        // lowlink
+  const onStack = new Set();    // membership of the Tarjan SCC stack
+  const sccStack = [];          // Tarjan SCC stack (nodes of the current open SCC)
+  const scc = new Map();        // id → sccId
+  let counter = 0;              // next DFS index
+  let sccId = 0;                // next SCC label
+
+  for (const root of ids) {
+    if (index.has(root)) continue;
+    const work = [{ u: root, idx: 0 }];     // explicit DFS frame stack
+    index.set(root, counter); low.set(root, counter); counter++;
+    sccStack.push(root); onStack.add(root);
+    while (work.length) {
+      const frame = work[work.length - 1];
+      const nbrs = out.get(frame.u);
+      if (frame.idx < nbrs.length) {
+        const w = nbrs[frame.idx++];
+        if (!index.has(w)) {                 // tree edge: descend
+          index.set(w, counter); low.set(w, counter); counter++;
+          sccStack.push(w); onStack.add(w);
+          work.push({ u: w, idx: 0 });
+        } else if (onStack.has(w)) {          // back/cross edge into the open stack
+          low.set(frame.u, Math.min(low.get(frame.u), index.get(w)));
+        }
+      } else {
+        work.pop();
+        // on the way up, fold this child's lowlink into its parent
+        if (work.length) { const p = work[work.length - 1].u; low.set(p, Math.min(low.get(p), low.get(frame.u))); }
+        if (low.get(frame.u) === index.get(frame.u)) {   // frame.u is an SCC root → pop the component
+          let x;
+          do { x = sccStack.pop(); onStack.delete(x); scc.set(x, sccId); } while (x !== frame.u);
+          sccId++;
+        }
+      }
+    }
+  }
+  return scc;
+}
+
+/**
+ * Directed reachability to terminals. `outputs`/`inputs` are id Sets (arrays accepted —
+ * normalized via new Set(...)); terminal ids not present in the graph are ignored.
+ *   reachesOutput[v] : v has a forward directed path (following OUT-edges) to SOME output.
+ *     Computed by ONE multi-source BFS over the REVERSED adjacency (walk `in`-edges) seeded
+ *     with ALL outputs at once — every node reached backward from an output forward-reaches it.
+ *   reachableFromInput[v] : v is reached by a forward BFS (OUT-edges) seeded with all inputs.
+ * Every graph id is present in both maps (default false). Empty graph → empty maps, no throw.
+ */
+export function reachability(graph, { outputs, inputs } = {}) {
+  const { ids, out, in: inn } = directedAdj(graph);
+  const idSet = new Set(ids);
+  const outSet = new Set(outputs || []);
+  const inSet = new Set(inputs || []);
+  // Multi-source BFS: seed with every terminal that is an actual node id, walk `adj`.
+  const multiBfs = (seeds, adj) => {
+    const reached = {};
+    for (const id of ids) reached[id] = false;
+    const queue = [];
+    for (const s of seeds) { if (idSet.has(s) && !reached[s]) { reached[s] = true; queue.push(s); } }
+    while (queue.length) {
+      const v = queue.shift();
+      for (const w of adj.get(v)) { if (!reached[w]) { reached[w] = true; queue.push(w); } }
+    }
+    return reached;
+  };
+  return {
+    reachesOutput: multiBfs(outSet, inn),         // reversed adjacency → forward-reaches an output
+    reachableFromInput: multiBfs(inSet, out),     // forward adjacency → reachable from an input
+  };
+}
+
+/**
+ * Structural observability of a digraph. Terminals are derived STRUCTURALLY from directedAdj:
+ *   outputs = genuine sinks  (out-degree 0 AND in-degree > 0 — receives something, emits nothing);
+ *   inputs  = genuine sources (in-degree 0 AND out-degree > 0 — emits something, receives nothing).
+ * deadWeight[v] = !reachesOutput[v] — a node contributing to NO output is prunable dead-weight.
+ * Empty/edgeless graph: every node is isolated (out==0 AND in==0 → neither sink nor source), so
+ * outputs/inputs are empty (degenerate), and every node is dead-weight. No throw.
+ * Note: directedAdj is built over cleanEdges (self-loops dropped), so a node whose only edge is a
+ * self-loop is isolated → not a genuine terminal → reachesOutput=false → dead-weight.
+ */
+export function staticObservability(graph) {
+  const { ids, out, in: inn } = directedAdj(graph);
+  const outputs = new Set();
+  const inputs = new Set();
+  for (const id of ids) {
+    const o = out.get(id).length;
+    const i = inn.get(id).length;
+    if (o === 0 && i > 0) outputs.add(id);
+    if (i === 0 && o > 0) inputs.add(id);
+  }
+  const { reachesOutput, reachableFromInput } = reachability(graph, { outputs, inputs });
+  const deadWeight = {};
+  for (const id of ids) deadWeight[id] = !reachesOutput[id];
+  return {
+    reachesOutput,
+    reachableFromInput,
+    deadWeight,
+    outputs,
+    inputs,
+    outputCount: outputs.size,
+    inputCount: inputs.size,
+    degenerateOutputs: outputs.size === 0,
+    degenerateInputs: inputs.size === 0,
+  };
+}
+
+/** Normalize raw directed Brandes scores in place: /((N-1)(N-2)) — directed is NOT halved. */
+function normalizeDirectedBetweenness(cb, ids, N) {
+  const norm = N > 2 ? (N - 1) * (N - 2) : 0;
+  if (norm > 0) for (const id of ids) cb[id] /= norm;
+  return cb;
+}
+
+/** Directed betweenness centrality (Brandes on the out-adjacency), normalized to [0,1]. */
+export function directedBetweenness(graph) {
+  const { ids, out } = directedAdj(graph);
+  const cb = {};
+  for (const id of ids) cb[id] = 0;
+  for (const s of ids) brandesAccumulate(out, ids, s, cb);
+  return normalizeDirectedBetweenness(cb, ids, ids.length);
+}
+
+/** One Brandes source pass: BFS from s + dependency back-accumulation into cb (mutates cb). */
+function brandesAccumulate(adj, ids, s, cb) {
+  const stack = [];
+  const pred = new Map(ids.map((id) => [id, []]));
+  const sigma = new Map(ids.map((id) => [id, 0]));
+  const dist = new Map(ids.map((id) => [id, -1]));
+  sigma.set(s, 1); dist.set(s, 0);
+  const queue = [s];
+  while (queue.length) {
+    const v = queue.shift();
+    stack.push(v);
+    for (const w of adj.get(v)) {
+      if (dist.get(w) < 0) { dist.set(w, dist.get(v) + 1); queue.push(w); }
+      if (dist.get(w) === dist.get(v) + 1) { sigma.set(w, sigma.get(w) + sigma.get(v)); pred.get(w).push(v); }
+    }
+  }
+  const delta = new Map(ids.map((id) => [id, 0]));
+  while (stack.length) {
+    const w = stack.pop();
+    for (const v of pred.get(w)) delta.set(v, delta.get(v) + (sigma.get(v) / sigma.get(w)) * (1 + delta.get(w)));
+    if (w !== s) cb[w] += delta.get(w);
+  }
+}
+
+/** Normalize raw Brandes scores in place: undirected /2 + /((N-1)(N-2)/2). */
+function normalizeBetweenness(cb, ids, N) {
+  for (const id of ids) cb[id] /= 2;
+  const norm = N > 2 ? ((N - 1) * (N - 2)) / 2 : 0;
+  if (norm > 0) for (const id of ids) cb[id] /= norm;
+  return cb;
+}
+
+/** Betweenness centrality (Brandes, undirected, unweighted), normalized to [0,1]. */
+export function betweenness(graph) {
+  const { ids, adj } = undirectedAdj(graph);
+  const cb = {};
+  for (const id of ids) cb[id] = 0;
+  for (const s of ids) brandesAccumulate(adj, ids, s, cb);
+  return normalizeBetweenness(cb, ids, ids.length);
+}
+
+/** Approximate betweenness via Brandes–Pich source sampling (scale by V/S); exact when samples≥V. */
+export function betweennessApprox(graph, { samples = 100, seed = 1 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  if (N === 0) return {};
+  if (samples >= N) return betweenness(graph);
+  const cb = {};
+  for (const id of ids) cb[id] = 0;
+  const sources = samplePivots(ids, samples, seed);
+  const S = sources.length;
+  if (S === 0) return cb;                          // samples<=0 → zeros (matches closeness/harmonicApprox), no 0·∞ NaN
+  for (const s of sources) brandesAccumulate(adj, ids, s, cb);
+  for (const id of ids) cb[id] *= N / S;          // unbiased scaling
+  return normalizeBetweenness(cb, ids, N);
+}
+
+/** Eigenvector centrality via power iteration on the undirected adjacency matrix; L2-normalized. */
+export function eigenvector(graph, { maxIter = 200, tol = 1e-9 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  const ev = {};
+  if (N === 0) return ev;
+  let x = new Map(ids.map((id) => [id, 1 / Math.sqrt(N)]));
+  for (let iter = 0; iter < maxIter; iter++) {
+    // (A + I)·x : seed with x (identity term) so the iteration converges on
+    // bipartite graphs — plain A·x oscillates because A's spectrum is ±λ.
+    const next = new Map(ids.map((id) => [id, x.get(id)]));
+    for (const id of ids) { for (const w of adj.get(id)) next.set(w, next.get(w) + x.get(id)); }
+    let norm = 0;
+    for (const id of ids) norm += next.get(id) * next.get(id);
+    norm = Math.sqrt(norm);
+    if (norm === 0) { for (const id of ids) ev[id] = 1 / N; return ev; } // edgeless → uniform, safe
+    let diff = 0;
+    for (const id of ids) { const v = next.get(id) / norm; diff += Math.abs(v - x.get(id)); next.set(id, v); }
+    x = next;
+    if (diff < tol) break;
+  }
+  for (const id of ids) ev[id] = x.get(id);
+  return ev;
+}
+
+/**
+ * Spectral node embeddings (Laplacian eigenmaps) over the undirected graph. Returns
+ * { id → number[] } where each vector has length = the effective embedding dimension.
+ *
+ * We embed via the top eigenvectors of the symmetric NORMALIZED adjacency
+ *   Â[v][w] = 1/√(deg(v)·deg(w))  for each undirected neighbour pair (deg = undirected
+ * degree from undirectedAdj; self-loops/dangling already dropped). Â is held implicitly as a
+ * matvec  y[v] = (1/√deg(v))·Σ_{w∈adj(v)} x[w]/√deg(w)  — an ISOLATED node (deg 0) has a
+ * zero row/col and so embeds to all-zeros. The eigenvectors of Â correspond to the smallest
+ * eigenvectors of the normalized Laplacian L = I − Â (same eigenvectors, flipped order), so
+ * its top non-trivial eigenvector is the Fiedler-like vector that separates clusters.
+ *
+ * Top K = k+1 eigenvectors are found by power iteration with Gram–Schmidt deflation (the
+ * single-vector form is `eigenvector`; here each vector subtracts its projection onto all
+ * previously-accepted vectors every iteration). Eigenvector #0 (≈ D^{1/2}·1, eigenvalue ~1,
+ * the trivial constant component) is DISCARDED; #1..#k form the coordinates. Effective k =
+ * clamp(dims, 2, min(32, N−1)) when N−1 ≥ 2, else max(0, N−1) (N=2 → length-1, N≤1 → empty).
+ * Never throws, never emits NaN/Infinity: a collapsed (zero-norm) deflated vector is re-seeded
+ * once and, failing that, left as a zero vector.
+ */
+export function spectralEmbedding(graph, { dims = 8, seed = 1, maxIter = 300, tol = 1e-9 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  const out = {};
+  // Effective embedding dimension k (number of NON-trivial eigenvectors kept).
+  const k = N - 1 >= 2 ? Math.min(Math.max(dims, 2), Math.min(32, N - 1)) : Math.max(0, N - 1);
+  if (N === 0) return out;
+  if (k === 0) { for (const id of ids) out[id] = []; return out; }
+
+  // Precompute undirected degree and its inverse sqrt (0 for isolated nodes → zero row/col).
+  const idx = new Map(ids.map((id, i) => [id, i]));
+  const invSqrtDeg = ids.map((id) => { const d = adj.get(id).length; return d > 0 ? 1 / Math.sqrt(d) : 0; });
+  const nbrIdx = ids.map((id) => adj.get(id).map((w) => idx.get(w)));
+
+  // y = Â·x (index-space vectors): y[v] = invSqrtDeg[v]·Σ_{w∈adj(v)} x[w]·invSqrtDeg[w].
+  const matvec = (x) => {
+    const y = new Array(N).fill(0);
+    for (let v = 0; v < N; v++) {
+      const fv = invSqrtDeg[v];
+      if (fv === 0) continue;                 // isolated → zero row
+      let s = 0;
+      const nb = nbrIdx[v];
+      for (let j = 0; j < nb.length; j++) s += x[nb[j]] * invSqrtDeg[nb[j]];
+      y[v] = fv * s;
+    }
+    return y;
+  };
+  const l2 = (x) => { let s = 0; for (let i = 0; i < N; i++) s += x[i] * x[i]; return Math.sqrt(s); };
+  const seedVec = (s) => { const r = mulberry32(s); const x = new Array(N); for (let i = 0; i < N; i++) x[i] = r() - 0.5; return x; };
+
+  // Find K = k+1 eigenvectors by power iteration + Gram–Schmidt deflation; discard #0.
+  const K = k + 1;
+  const evecs = [];                            // accepted eigenvectors (index-space), in order
+  for (let j = 0; j < K; j++) {
+    let x = seedVec(seed + j);
+    let reseeded = false;
+    let accepted = null;
+    for (let iter = 0; iter < maxIter; iter++) {
+      let y = matvec(x);
+      // Deflate: subtract projection onto every previously-accepted eigenvector.
+      for (const e of evecs) { let dot = 0; for (let i = 0; i < N; i++) dot += y[i] * e[i]; for (let i = 0; i < N; i++) y[i] -= dot * e[i]; }
+      let norm = l2(y);
+      if (norm === 0) {
+        // Collapsed (e.g. fully deflated on a tiny/symmetric graph): re-seed once, else give up → zero vector.
+        if (!reseeded) { reseeded = true; x = seedVec(seed + j + 1013 * (j + 1)); continue; }
+        accepted = new Array(N).fill(0);
+        break;
+      }
+      let diff = 0;
+      for (let i = 0; i < N; i++) { const v = y[i] / norm; diff += Math.abs(v - x[i]); y[i] = v; }
+      x = y;
+      if (diff < tol) break;
+    }
+    evecs.push(accepted || x);
+  }
+
+  // Drop eigenvector #0 (trivial); coordinates are eigenvectors #1..#k.
+  for (const id of ids) {
+    const i = idx.get(id);
+    const vec = new Array(k);
+    for (let d = 0; d < k; d++) { const c = evecs[d + 1][i]; vec[d] = Number.isFinite(c) ? c : 0; }
+    out[id] = vec;
+  }
+  return out;
+}
+
+/** Connected components (undirected). Returns Map<id, componentId>; ids assigned in node-iteration order. */
+export function connectedComponents(graph) {
+  const { ids, adj } = undirectedAdj(graph);
+  const comp = new Map();
+  let cid = 0;
+  for (const start of ids) {
+    if (comp.has(start)) continue;
+    comp.set(start, cid);
+    const queue = [start];
+    while (queue.length) {
+      const v = queue.shift();
+      for (const w of adj.get(v)) { if (!comp.has(w)) { comp.set(w, cid); queue.push(w); } }
+    }
+    cid++;
+  }
+  return comp;
+}
+
+/** Edge density of an undirected simple graph: 2E/(N(N-1)); 0 when N<2. */
+export function density(graph) {
+  const ids = nodeIds(graph);
+  const N = ids.length;
+  if (N < 2) return 0;
+  const E = cleanEdges(graph, new Set(ids)).length;
+  return (2 * E) / (N * (N - 1));
+}
+
+/**
+ * Articulation points + bridges (undirected, Tarjan low-link, iterative DFS so deep
+ * graphs don't blow the call stack; a DFS forest covers disconnected graphs).
+ * Returns { articulation:Set<id>, bridges:Array<[u,v]> }. Assumes a simple graph
+ * (the cleaned edge set drops self-loops; parallel edges are out of scope).
+ */
+export function articulationPointsAndBridges(graph) {
+  const { ids, adj } = undirectedAdj(graph);
+  const disc = new Map();
+  const low = new Map();
+  const articulation = new Set();
+  const bridges = [];
+  let timer = 0;
+
+  for (const root of ids) {
+    if (disc.has(root)) continue;
+    disc.set(root, timer); low.set(root, timer); timer++;
+    let rootChildren = 0;
+    const stack = [{ u: root, parent: null, idx: 0 }];
+    while (stack.length) {
+      const frame = stack[stack.length - 1];
+      const nbrs = adj.get(frame.u);
+      if (frame.idx < nbrs.length) {
+        const w = nbrs[frame.idx++];
+        if (w === frame.parent) continue;                 // skip the tree edge back to parent
+        if (!disc.has(w)) {
+          disc.set(w, timer); low.set(w, timer); timer++;
+          if (frame.u === root) rootChildren++;
+          stack.push({ u: w, parent: frame.u, idx: 0 });
+        } else {
+          low.set(frame.u, Math.min(low.get(frame.u), disc.get(w)));   // back edge
+        }
+      } else {
+        stack.pop();
+        const { u, parent } = frame;
+        if (parent !== null) {
+          low.set(parent, Math.min(low.get(parent), low.get(u)));
+          if (parent !== root && low.get(u) >= disc.get(parent)) articulation.add(parent);
+          if (low.get(u) > disc.get(parent)) bridges.push([parent, u]);
+        }
+      }
+    }
+    if (rootChildren >= 2) articulation.add(root);
+  }
+  return { articulation, bridges };
+}
+
+/** k-core decomposition (degeneracy ordering): Map<id, coreNumber>. O(V^2) peeling — graphs here are small. */
+export function kCore(graph) {
+  const { ids, adj } = undirectedAdj(graph);
+  const deg = new Map(ids.map((id) => [id, adj.get(id).length]));
+  const removed = new Set();
+  const core = new Map();
+  let k = 0;
+  while (removed.size < ids.length) {
+    let u = null, min = Infinity;
+    for (const id of ids) { if (removed.has(id)) continue; const d = deg.get(id); if (d < min) { min = d; u = id; } }
+    k = Math.max(k, min);
+    core.set(u, k);
+    removed.add(u);
+    for (const w of adj.get(u)) { if (!removed.has(w)) deg.set(w, deg.get(w) - 1); }
+  }
+  return core;
+}
+
+/** Local clustering coefficient per node + global transitivity (3·triangles / connected-triples). */
+export function clusteringCoefficient(graph) {
+  const { ids, adj } = undirectedAdj(graph);
+  const nbrSet = new Map(ids.map((id) => [id, new Set(adj.get(id))]));
+  const local = {};
+  let closedTriads = 0;   // Σ over v of (pairs of v's neighbors that are linked) = 3·triangles
+  let triads = 0;         // Σ over v of C(deg(v),2) = connected triples
+  for (const v of ids) {
+    const ns = [...nbrSet.get(v)];
+    const k = ns.length;
+    if (k < 2) { local[v] = 0; continue; }
+    let links = 0;
+    for (let i = 0; i < ns.length; i++) {
+      for (let j = i + 1; j < ns.length; j++) { if (nbrSet.get(ns[i]).has(ns[j])) links++; }
+    }
+    local[v] = (2 * links) / (k * (k - 1));
+    closedTriads += links;
+    triads += (k * (k - 1)) / 2;
+  }
+  const transitivity = triads > 0 ? closedTriads / triads : 0;
+  return { local, transitivity };
+}
+
+/** Single-source BFS distances over the undirected adjacency; unreached stay -1. */
+function bfsDistances(adj, ids, s) {
+  const dist = new Map(ids.map((id) => [id, -1]));
+  dist.set(s, 0);
+  const queue = [s];
+  while (queue.length) {
+    const v = queue.shift();
+    for (const w of adj.get(v)) { if (dist.get(w) < 0) { dist.set(w, dist.get(v) + 1); queue.push(w); } }
+  }
+  return dist;
+}
+
+/** Closeness centrality, component-aware (Wasserman–Faust): (reach/(N-1))·(reach/Σd); 0 if isolated. */
+export function closeness(graph) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  const out = {};
+  for (const s of ids) {
+    const dist = bfsDistances(adj, ids, s);
+    let sum = 0, reach = 0;
+    for (const id of ids) { if (id === s) continue; const d = dist.get(id); if (d > 0) { sum += d; reach++; } }
+    out[s] = (sum > 0 && N > 1) ? (reach / (N - 1)) * (reach / sum) : 0;
+  }
+  return out;
+}
+
+/** Harmonic centrality: Σ_{u≠v} 1/d(v,u) over reachable u, normalized by (N-1). Disconnection-safe. */
+export function harmonic(graph) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  const out = {};
+  for (const s of ids) {
+    const dist = bfsDistances(adj, ids, s);
+    let sum = 0;
+    for (const id of ids) { if (id === s) continue; const d = dist.get(id); if (d > 0) sum += 1 / d; }
+    out[s] = N > 1 ? sum / (N - 1) : 0;
+  }
+  return out;
+}
+
+/** Approximate closeness (Wasserman–Faust) via pivot sampling; exact when samples≥V. */
+export function closenessApprox(graph, { samples = 100, seed = 1 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  if (N === 0) return {};
+  if (samples >= N) return closeness(graph);
+  const pivots = samplePivots(ids, samples, seed);
+  const sumDist = new Map(ids.map((id) => [id, 0]));   // Σ d(v,pivot) over reachable pivots≠v
+  const reachP = new Map(ids.map((id) => [id, 0]));     // # reachable pivots ≠ v
+  const cntP = new Map(ids.map((id) => [id, 0]));       // # pivots ≠ v (sampled "others")
+  for (const p of pivots) {
+    const dist = bfsDistances(adj, ids, p);             // undirected: d(p,v)=d(v,p)
+    for (const v of ids) {
+      if (v === p) continue;
+      cntP.set(v, cntP.get(v) + 1);
+      const d = dist.get(v);
+      if (d > 0) { sumDist.set(v, sumDist.get(v) + d); reachP.set(v, reachP.get(v) + 1); }
+    }
+  }
+  const out = {};
+  for (const v of ids) {
+    const c = cntP.get(v), r = reachP.get(v), sd = sumDist.get(v);
+    if (r === 0 || sd === 0 || N <= 1) { out[v] = 0; continue; }
+    const reachEst = (r / c) * (N - 1);    // estimated reachable others
+    const sumDistEst = (sd / r) * reachEst; // mean dist × estimated reach
+    out[v] = (reachEst / (N - 1)) * (reachEst / sumDistEst);
+  }
+  return out;
+}
+
+/** Approximate harmonic centrality via pivot sampling (sample mean of 1/d); exact when samples≥V. */
+export function harmonicApprox(graph, { samples = 100, seed = 1 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  if (N === 0) return {};
+  if (samples >= N) return harmonic(graph);
+  const pivots = samplePivots(ids, samples, seed);
+  const sumRecip = new Map(ids.map((id) => [id, 0]));
+  const cnt = new Map(ids.map((id) => [id, 0]));
+  for (const p of pivots) {
+    const dist = bfsDistances(adj, ids, p);
+    for (const v of ids) {
+      if (v === p) continue;
+      cnt.set(v, cnt.get(v) + 1);
+      const d = dist.get(v);
+      if (d > 0) sumRecip.set(v, sumRecip.get(v) + 1 / d);
+    }
+  }
+  const out = {};
+  for (const v of ids) { const c = cnt.get(v); out[v] = c > 0 ? sumRecip.get(v) / c : 0; }
+  return out;
+}
+
+/**
+ * Katz centrality: x = β·Σ_{k≥0}(αA)^k·1, computed by iterating x ← α·A·x + β to
+ * convergence WITHOUT per-step normalization (normalizing each step changes the fixed
+ * point and corrupts the ranking). The result is L2-normalized once at the end for
+ * display (a single global scale preserves ranking). α is clamped to 0.85/Δ (Δ = max
+ * degree, an upper bound on the spectral radius λmax) so the Neumann series always
+ * converges (α·λmax < 1); the requested α (default 0.1) is used unchanged on low-degree
+ * graphs. A λmax-aware α was deferred in the spec, but per-step normalization made the
+ * fixed-α variant produce wrong rankings, so this minimal clamp ships now.
+ */
+export function katz(graph, { alpha = 0.1, beta = 1, maxIter = 1000, tol = 1e-12 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const N = ids.length;
+  const out = {};
+  if (N === 0) return out;
+  let maxDeg = 0;
+  for (const id of ids) maxDeg = Math.max(maxDeg, adj.get(id).length);
+  const aEff = maxDeg > 0 ? Math.min(alpha, 0.85 / maxDeg) : alpha;   // ensures aEff·λmax < 1
+  let x = new Map(ids.map((id) => [id, beta]));
+  for (let iter = 0; iter < maxIter; iter++) {
+    const next = new Map(ids.map((id) => [id, beta]));
+    for (const id of ids) { const xi = x.get(id); if (xi !== 0) for (const w of adj.get(id)) next.set(w, next.get(w) + aEff * xi); }
+    let diff = 0;
+    for (const id of ids) diff += Math.abs(next.get(id) - x.get(id));
+    x = next;
+    if (diff < tol) break;
+  }
+  let norm = 0;
+  for (const id of ids) norm += x.get(id) * x.get(id);
+  norm = Math.sqrt(norm) || 1;
+  for (const id of ids) out[id] = x.get(id) / norm;
+  return out;
+}
+
+/** Label propagation community detection (seeded, deterministic tie-break). Returns { communities }. */
+export function labelPropagation(graph, { seed = 1, maxIter = 100 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const communities = {};
+  if (ids.length === 0) return { communities };
+  const label = new Map(ids.map((id) => [id, id]));
+  const rng = mulberry32(seed);
+  const order = ids.slice();
+  for (let iter = 0; iter < maxIter; iter++) {
+    for (let i = order.length - 1; i > 0; i--) { const j = Math.floor(rng() * (i + 1)); [order[i], order[j]] = [order[j], order[i]]; }
+    let changed = false;
+    for (const v of order) {
+      const counts = new Map();
+      for (const w of adj.get(v)) { const l = label.get(w); counts.set(l, (counts.get(l) || 0) + 1); }
+      if (counts.size === 0) continue;                         // isolated node keeps its own label
+      let best = null, bestC = -1;
+      for (const [l, c] of counts) {
+        if (c > bestC || (c === bestC && String(l) < String(best))) { bestC = c; best = l; }   // deterministic tie-break
+      }
+      if (best !== label.get(v)) { label.set(v, best); changed = true; }
+    }
+    if (!changed) break;
+  }
+  const remap = new Map();
+  let next = 0;
+  for (const id of ids) { const l = label.get(id); if (!remap.has(l)) remap.set(l, next++); communities[id] = remap.get(l); }
+  return { communities };
+}
+
+/**
+ * Leiden community detection (single-level): Louvain local-moving, then a refinement
+ * phase that splits any internally-disconnected community into its connected
+ * sub-communities. The refinement is what distinguishes Leiden from Louvain — it
+ * GUARANTEES every output community is internally connected (Louvain can return a
+ * disconnected community; Leiden cannot). Single-level, matching this engine's Louvain;
+ * multi-level super-node aggregation is deferred. Returns { communities }.
+ */
+export function leiden(graph, { seed = 1, resolution = 1 } = {}) {
+  const { ids, adj } = undirectedAdj(graph);
+  const communities = {};
+  if (ids.length === 0) return { communities };
+  const base = louvain(graph, { seed, resolution }).communities;        // 1. local-moving partition
+  // 2. refinement: relabel each community by its connected components (intra-community edges only)
+  const byComm = new Map();
+  for (const id of ids) { const c = base[id]; if (!byComm.has(c)) byComm.set(c, []); byComm.get(c).push(id); }
+  const refined = new Map();
+  let nextSub = 0;
+  for (const [, members] of byComm) {
+    const memberSet = new Set(members);
+    const seen = new Set();
+    for (const start of members) {
+      if (seen.has(start)) continue;
+      seen.add(start); refined.set(start, nextSub);
+      const queue = [start];
+      while (queue.length) {
+        const v = queue.shift();
+        for (const w of adj.get(v)) { if (memberSet.has(w) && !seen.has(w)) { seen.add(w); refined.set(w, nextSub); queue.push(w); } }
+      }
+      nextSub++;
+    }
+  }
+  // 3. renumber 0..k-1 in first-seen order
+  const remap = new Map();
+  let next = 0;
+  for (const id of ids) { const c = refined.get(id); if (!remap.has(c)) remap.set(c, next++); communities[id] = remap.get(c); }
+  return { communities };
+}
+
+export function computeMetrics(graph, { community = 'louvain', resolution = 1, seed = 1, skipSuperLinear = false, approx = null, directed = false, hierarchy = false, embed = null, dims = 8, observability = false } = {}) {
+  // Observability IMPLIES directed: it needs the directed terminals/reachability, so it also
+  // emits the directed near-linear fields (inDegree/outDegree/hubs/authorities/sccId + directed betweenness).
+  const directedEff = directed || observability;
+  const ids = nodeIds(graph);
+  const deg = degreeCentrality(graph);
+  const pr = pageRank(graph);
+  const ev = eigenvector(graph);
+  const kz = katz(graph);
+  const useApprox = skipSuperLinear && Number.isInteger(approx) && approx > 0;
+  // Super-linear shortest-path centralities: full when not skipping; sampled when approx; else {}.
+  // Betweenness picks the DIRECTED Brandes variant only when directed AND not skipping (full pass);
+  // when skipping it follows the exact same approx/zero gating as the undirected case (no O(V·E)).
+  const bt = skipSuperLinear
+    ? (useApprox ? betweennessApprox(graph, { samples: approx, seed }) : {})
+    : (directedEff ? directedBetweenness(graph) : betweenness(graph));
+  const cl = skipSuperLinear ? (useApprox ? closenessApprox(graph, { samples: approx, seed }) : {}) : closeness(graph);
+  const hr = skipSuperLinear ? (useApprox ? harmonicApprox(graph, { samples: approx, seed }) : {}) : harmonic(graph);
+  // k-core + clustering are NOT approximated — skipped whenever skipSuperLinear.
+  const core = skipSuperLinear ? new Map() : kCore(graph);
+  const { local: clustering, transitivity } = skipSuperLinear ? { local: {}, transitivity: 0 } : clusteringCoefficient(graph);
+  const comp = connectedComponents(graph);
+  const { articulation, bridges } = articulationPointsAndBridges(graph);
+
+  // ── OPT-IN directed metrics (near-linear — computed even when capped). ──
+  let inDeg = null, outDeg = null, hubScore = null, authScore = null, scc = null;
+  if (directedEff) {
+    ({ inDegree: inDeg, outDegree: outDeg } = inOutDegree(graph));
+    ({ hubs: hubScore, authorities: authScore } = hits(graph));
+    scc = stronglyConnectedComponents(graph);
+  }
+  // ── OPT-IN structural observability (near-linear — computed even when capped). ──
+  let obs = null;
+  if (observability) obs = staticObservability(graph);
+  // ── OPT-IN hierarchical community (multi-level Louvain). ──
+  let hier = null;
+  if (hierarchy) hier = louvainMultiLevel(graph, { seed, resolution });
+  // ── OPT-IN spectral embedding (super-linear → skipped when capped). ──
+  let embedding = null;
+  if (embed === 'spectral' && !skipSuperLinear) embedding = spectralEmbedding(graph, { dims, seed });
+
+  // Community method dispatch — Louvain default (byte-identical to before).
+  let communities, modularity;
+  if (community === 'labelprop') {
+    ({ communities } = labelPropagation(graph, { seed }));
+    modularity = modularityOf(graph, communities, resolution);
+  } else if (community === 'leiden') {
+    ({ communities } = leiden(graph, { seed, resolution }));
+    modularity = modularityOf(graph, communities, resolution);
+  } else {
+    ({ communities, modularity } = louvain(graph, { seed, resolution }));
+  }
+
+  const nodes = ids.map((id) => {
+    const node = {
+      id,
+      degree: deg[id] ?? 0,
+      pagerank: pr[id] ?? 0,
+      betweenness: bt[id] ?? 0,
+      eigenvector: ev[id] ?? 0,
+      closeness: cl[id] ?? 0,
+      katz: kz[id] ?? 0,
+      harmonic: hr[id] ?? 0,
+      coreness: core.get(id) ?? 0,
+      clustering: clustering[id] ?? 0,
+      articulation: articulation.has(id),
+      componentId: comp.get(id) ?? 0,
+      community: communities[id] ?? 0,
+    };
+    // Additive opt-in fields — present ONLY when their feature was requested.
+    if (directedEff) {
+      node.inDegree = inDeg[id] ?? 0;
+      node.outDegree = outDeg[id] ?? 0;
+      node.hubs = hubScore[id] ?? 0;
+      node.authorities = authScore[id] ?? 0;
+      node.sccId = scc.get(id) ?? 0;
+    }
+    if (obs) {
+      node.reachesOutput = !!obs.reachesOutput[id];
+      node.reachableFromInput = !!obs.reachableFromInput[id];
+      node.deadWeight = !!obs.deadWeight[id];
+    }
+    if (hier) node.communityPath = hier.levels.map((l) => l.communities[id] ?? 0);
+    if (embedding) node.embedding = embedding[id] ?? [];
+    return node;
+  });
+  const idSet = new Set(ids);
+  const summary = {
+    nodeCount: ids.length,
+    edgeCount: cleanEdges(graph, idSet).length,
+    communityCount: new Set(Object.values(communities)).size,
+    modularity,
+    density: density(graph),
+    componentCount: new Set(comp.values()).size,
+    transitivity,
+    directed: !!directedEff,
+  };
+  if (directedEff) summary.stronglyConnectedComponentCount = new Set(scc.values()).size;
+  if (obs) {
+    summary.deadWeightCount = ids.reduce((acc, id) => acc + (obs.deadWeight[id] ? 1 : 0), 0);
+    summary.outputCount = obs.outputCount;
+    summary.inputCount = obs.inputCount;
+    summary.observabilityDegenerate = obs.degenerateOutputs || obs.degenerateInputs;
+  }
+  if (embedding) {
+    const first = nodes.find((n) => Array.isArray(n.embedding));
+    summary.embedding = { method: 'spectral', dims: first ? first.embedding.length : 0 };
+  }
+  const out = { nodes, bridges: bridges.map(([source, target]) => ({ source, target })), summary };
+  if (hier) out.hierarchy = { levelCount: hier.levels.length, levels: hier.levels.map((l) => ({ modularity: l.modularity, communityCount: l.communityCount })), method: 'louvain' };
+  return out;
+}
+
+/**
+ * computeMetrics with a node-count guard. On graphs larger than `cap` nodes, the
+ * super-linear metrics (betweenness O(V·E), closeness/harmonic O(V·(V+E)), k-core
+ * O(V²), clustering O(Σd²)) are skipped (set to 0) so the endpoint stays responsive;
+ * the near-linear metrics (degree, PageRank, eigenvector, Katz, community, density,
+ * components) are always computed. `summary.capped` + `summary.omittedMetrics` report it.
+ * (Real sampling/LoD/caching for the symbol-level case is deferred to P2.3.2c.)
+ */
+export function computeMetricsCapped(graph, { cap = 2000, approx = null, ...opts } = {}) {
+  const skip = nodeIds(graph).length > cap;
+  const useApprox = skip && Number.isInteger(approx) && approx > 0;
+  // directed/hierarchy/embed/dims flow through via ...opts. Directed/hierarchy are near-linear
+  // and still compute when capped; spectral embedding is super-linear so computeMetrics skips it
+  // under skipSuperLinear — we surface that omission below.
+  const r = computeMetrics(graph, { ...opts, skipSuperLinear: skip, approx: useApprox ? approx : null });
+  r.summary.capped = skip;
+  r.summary.approximate = useApprox;
+  r.summary.sampleSize = useApprox ? approx : null;
+  r.summary.omittedMetrics = !skip ? []
+    : useApprox ? ['coreness', 'clustering']
+    : ['betweenness', 'closeness', 'harmonic', 'coreness', 'clustering'];
+  // When capped, the requested spectral embedding was skipped — report it (additive).
+  if (skip && opts.embed === 'spectral') r.summary.omittedMetrics.push('embedding');
+  return r;
+}
+
+/** Modularity Q of an arbitrary partition (for label-prop / Leiden, which don't return it). */
+function modularityOf(graph, communities, resolution = 1) {
+  const ids = nodeIds(graph);
+  const idSet = new Set(ids);
+  const k = new Map(ids.map((id) => [id, 0]));
+  let m2 = 0;
+  const adj = new Map(ids.map((id) => [id, []]));
+  for (const [s, t] of cleanEdges(graph, idSet)) { adj.get(s).push(t); adj.get(t).push(s); k.set(s, k.get(s) + 1); k.set(t, k.get(t) + 1); m2 += 2; }
+  if (m2 === 0) return 0;
+  const sin = new Map(), stot = new Map();
+  for (const id of ids) {
+    const c = communities[id];
+    stot.set(c, (stot.get(c) || 0) + k.get(id));
+    for (const w of adj.get(id)) { if (communities[w] === c) sin.set(c, (sin.get(c) || 0) + 1); }
+  }
+  let q = 0;
+  for (const [c, st] of stot) q += (sin.get(c) || 0) / m2 - resolution * (st / m2) ** 2;
+  return q;
+}
diff --git a/docker-server-graph-theory.mjs b/docker-server-graph-theory.mjs
new file mode 100644
index 00000000..052fb2e5
--- /dev/null
+++ b/docker-server-graph-theory.mjs
@@ -0,0 +1,145 @@
+/**
+ * Graph-theory metrics routes (web container).
+ *   GET /graph/metrics/:name            → sidecar graph metrics
+ *   GET /graph/metrics/lens/:lensId?repo=<repo>  → code-graph (ASTKG) metrics via a lens
+ * Shared query params: ?community=louvain|leiden|labelprop &resolution= &cap= &approx=
+ *   and P2.3 opt-ins: &directed=1 (in/out degree, HITS hubs/authorities, sccId, directed
+ *   betweenness) &hierarchy=1 (multi-level Louvain) &embed=spectral&dims=<k> (Laplacian eigenmaps).
+ * Both → computeMetricsCapped (pure-JS engine). Response:
+ *   { nodes:[{id,degree,pagerank,betweenness,eigenvector,closeness,katz,harmonic,
+ *             coreness,clustering,articulation,componentId,community
+ *             [,inDegree,outDegree,hubs,authorities,sccId]    // when ?directed=1
+ *             [,communityPath]                                 // when ?hierarchy=1
+ *             [,embedding]]},                                  // when ?embed=spectral
+ *     bridges:[{source,target}],
+ *     [hierarchy:{levelCount,levels:[{modularity,communityCount}],method}],   // when ?hierarchy=1
+ *     summary:{nodeCount,edgeCount,communityCount,modularity,density,componentCount,transitivity,
+ *              capped,omittedMetrics,directed[,stronglyConnectedComponentCount][,embedding]} }
+ */
+import { sidecarRender } from './docker-server-graph-templates-core.mjs';
+import { computeMetricsCapped } from './docker-server-graph-theory-core.mjs';
+import { LENSES } from './docker-server-graph-lens-core.mjs';
+
+const COMMUNITY_METHODS = new Set(['louvain', 'leiden', 'labelprop']);
+const GITNEXUS_API = process.env.GITNEXUS_API || 'http://gitnexus:4747';
+const CAP_MAX = 50000;
+
+function sendJson(res, code, body) { res.writeHead(code, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(body)); }
+
+const METRICS_CACHE_TTL_MS = 300_000;
+const METRICS_CACHE_MAX = 64;
+
+/** Tiny TTL + insertion-order(LRU-ish) cache. Clock injected for testability. */
+export function makeMetricsCache({ ttlMs = METRICS_CACHE_TTL_MS, max = METRICS_CACHE_MAX, clock = Date.now } = {}) {
+  const m = new Map();   // key → { val, at }
+  return {
+    get(key) {
+      const e = m.get(key);
+      if (!e) return undefined;
+      if (clock() - e.at > ttlMs) { m.delete(key); return undefined; }
+      return e.val;
+    },
+    set(key, val) {
+      m.delete(key);
+      m.set(key, { val, at: clock() });
+      while (m.size > max) m.delete(m.keys().next().value);   // evict oldest
+    },
+  };
+}
+
+const metricsCache = makeMetricsCache();
+export function metricsCacheKey(kind, idOrName, lensId, params) {
+  return `${kind}|${idOrName}|${lensId || ''}|${params.community}|${params.resolution}|${params.cap}|${params.approx ?? ''}|${params.directed ? 1 : 0}|${params.hierarchy ? 1 : 0}|${params.embed ?? ''}|${params.dims}|${params.observability ? 1 : 0}`;
+}
+
+/** Parse a positive-integer query param. Returns `def` when absent/empty; throws on ≤0/non-int; clamps to clampMax. */
+function parsePosInt(searchParams, key, { def = null, clampMax = null } = {}) {
+  const raw = searchParams.get(key);
+  if (raw == null || raw === '') return def;
+  const n = Number(raw);
+  if (!Number.isInteger(n) || n <= 0) throw new Error(`${key} must be a positive integer, got "${raw}"`);
+  return clampMax != null ? Math.min(n, clampMax) : n;
+}
+
+/** Parse + validate the metrics query params. Throws Error (→ 400) on bad input. */
+export function parseMetricsParams(searchParams) {
+  const community = searchParams.get('community') || 'louvain';
+  if (!COMMUNITY_METHODS.has(community)) throw new Error(`unknown community method "${community}" (use louvain|leiden|labelprop)`);
+  let resolution = 1;
+  const raw = searchParams.get('resolution');
+  if (raw != null && raw !== '') {
+    resolution = Number(raw);
+    if (!Number.isFinite(resolution) || resolution <= 0) throw new Error(`resolution must be a positive finite number, got "${raw}"`);
+  }
+  const cap = parsePosInt(searchParams, 'cap', { def: 2000, clampMax: CAP_MAX });
+  const approx = parsePosInt(searchParams, 'approx', { def: null });
+  const directed = ['1', 'true'].includes((searchParams.get('directed') || '').toLowerCase());
+  const hierarchy = ['1', 'true'].includes((searchParams.get('hierarchy') || '').toLowerCase());
+  const embedRaw = searchParams.get('embed');
+  if (embedRaw != null && embedRaw !== '' && embedRaw !== 'spectral') throw new Error(`unknown embed "${embedRaw}" (use spectral)`);
+  const embed = embedRaw === 'spectral' ? 'spectral' : null;
+  const dims = parsePosInt(searchParams, 'dims', { def: 8, clampMax: 64 });
+  const observability = ['1', 'true'].includes((searchParams.get('observability') || '').toLowerCase());
+  return { community, resolution, cap, approx, directed, hierarchy, embed, dims, observability };
+}
+
+/** Pure: project an /api/graph JSON via a lens, then compute capped metrics. Throws on unknown lens.
+ * `cap` is a FALLBACK — `params.cap` (from parseMetricsParams) wins when present. */
+export function lensMetrics(apiGraph, lensId, params, cap = 2000) {
+  const project = LENSES[lensId];
+  if (!project) throw new Error(`unknown lens: ${lensId}`);
+  return computeMetricsCapped(project(apiGraph), { ...params, cap: params.cap ?? cap });
+}
+
+export async function handleGraphMetricsRoute(req, url, res) {
+  if (!url.pathname.startsWith('/graph/metrics/') || req.method !== 'GET') return false;
+  if (url.pathname.startsWith('/graph/metrics/lens/')) return false;   // owned by handleGraphLensMetricsRoute
+  const name = decodeURIComponent(url.pathname.slice('/graph/metrics/'.length));
+  let params;
+  try { params = parseMetricsParams(url.searchParams); }
+  catch (e) { sendJson(res, 400, { error: e.message }); return true; }
+  const fresh = url.searchParams.get('fresh') === '1';
+  const cacheKey = metricsCacheKey('sidecar', name, '', params);
+  if (!fresh) {
+    const cached = metricsCache.get(cacheKey);
+    if (cached !== undefined) { sendJson(res, 200, cached); return true; }
+  }
+  let graph;
+  try { graph = await sidecarRender(name); }
+  catch (e) { sendJson(res, 404, { error: `graph "${name}" not available: ${e.message}` }); return true; }
+  let payload;
+  try { payload = computeMetricsCapped(graph, params); }
+  catch (e) { sendJson(res, 500, { error: `metrics failed: ${e.message}` }); return true; }
+  metricsCache.set(cacheKey, payload);
+  sendJson(res, 200, payload);
+  return true;
+}
+
+export async function handleGraphLensMetricsRoute(req, url, res) {
+  if (!url.pathname.startsWith('/graph/metrics/lens/') || req.method !== 'GET') return false;
+  const lensId = decodeURIComponent(url.pathname.slice('/graph/metrics/lens/'.length));
+  if (!LENSES[lensId]) { sendJson(res, 404, { error: `unknown lens: ${lensId}` }); return true; }
+  const repo = url.searchParams.get('repo');
+  if (!repo) { sendJson(res, 400, { error: 'missing repo' }); return true; }
+  let params;
+  try { params = parseMetricsParams(url.searchParams); }
+  catch (e) { sendJson(res, 400, { error: e.message }); return true; }
+  const fresh = url.searchParams.get('fresh') === '1';
+  const cacheKey = metricsCacheKey('lens', repo, lensId, params);
+  if (!fresh) {
+    const cached = metricsCache.get(cacheKey);
+    if (cached !== undefined) { sendJson(res, 200, cached); return true; }
+  }
+  let apiGraph;
+  try {
+    const r = await fetch(`${GITNEXUS_API}/api/graph?repo=${encodeURIComponent(repo)}`);
+    if (!r.ok) { sendJson(res, 502, { error: `upstream /api/graph ${r.status}` }); return true; }
+    apiGraph = await r.json();
+  } catch (e) { sendJson(res, 502, { error: `upstream /api/graph failed: ${e.message}` }); return true; }
+  let payload;
+  try { payload = lensMetrics(apiGraph, lensId, params); }
+  catch (e) { sendJson(res, 500, { error: `lens metrics failed: ${e.message}` }); return true; }
+  metricsCache.set(cacheKey, payload);
+  sendJson(res, 200, payload);
+  return true;
+}
diff --git a/docker-server-group-graph-core.mjs b/docker-server-group-graph-core.mjs
new file mode 100644
index 00000000..a532f08d
--- /dev/null
+++ b/docker-server-group-graph-core.mjs
@@ -0,0 +1,55 @@
+/**
+ * Multi-repo merged graph — pure core. No I/O. See spec:
+ * docs/superpowers/specs/2026-05-29-multi-repo-unified-graph-design.md
+ */
+
+// Collapse a single-repo /api/graph result to file-level. Node ids are
+// namespaced `<repo>::<filePath>`. Symbol→symbol edges roll up to file→file
+// (dedup, self-loops dropped). Returns { nodes:[{id,label,repo,kind,filePath}], edges:[{source,target}] }.
+export function collapseToFileLevel(graph, repo) {
+  const nodes = Array.isArray(graph?.nodes) ? graph.nodes : [];
+  const rels = Array.isArray(graph?.relationships) ? graph.relationships : [];
+  const fileOf = new Map();    // nodeId → fileId
+  const fileNodes = new Map(); // fileId → node
+  for (const n of nodes) {
+    const fp = n?.properties?.filePath;
+    if (typeof fp !== 'string' || !fp) continue;
+    const fileId = `${repo}::${fp}`;
+    fileOf.set(n.id, fileId);
+    if (!fileNodes.has(fileId)) {
+      fileNodes.set(fileId, { id: fileId, label: fp.split('/').pop() || fp, repo, kind: 'file', filePath: fp });
+    }
+  }
+  const edgeSet = new Set();
+  const edges = [];
+  for (const r of rels) {
+    const s = fileOf.get(r.sourceId);
+    const t = fileOf.get(r.targetId);
+    if (!s || !t || s === t) continue;
+    const key = `${s} ${t}`;
+    if (edgeSet.has(key)) continue;
+    edgeSet.add(key);
+    edges.push({ source: s, target: t });
+  }
+  return { nodes: [...fileNodes.values()], edges };
+}
+
+// Merge collapsed repo graphs + add cross-repo edges from group crossLinks.
+// crossLinks: [{ from:{repo, symbolRef:{filePath}}, to:{repo, symbolRef:{filePath}}, type, matchType }].
+// A cross edge is added only if both file nodes exist in the merged set.
+export function mergeRepoGraphs(collapsed, crossLinks = []) {
+  const nodes = [];
+  const edges = [];
+  const nodeIds = new Set();
+  for (const g of collapsed) {
+    for (const n of g.nodes) { if (!nodeIds.has(n.id)) { nodeIds.add(n.id); nodes.push(n); } }
+    for (const e of g.edges) edges.push(e);
+  }
+  for (const cl of crossLinks) {
+    const s = `${cl?.from?.repo}::${cl?.from?.symbolRef?.filePath}`;
+    const t = `${cl?.to?.repo}::${cl?.to?.symbolRef?.filePath}`;
+    if (!nodeIds.has(s) || !nodeIds.has(t) || s === t) continue;
+    edges.push({ source: s, target: t, crossRepo: true, matchType: cl.matchType || null, contractType: cl.type || null });
+  }
+  return { nodes, edges };
+}
diff --git a/docker-server-group-graph.mjs b/docker-server-group-graph.mjs
new file mode 100644
index 00000000..ec2d92e0
--- /dev/null
+++ b/docker-server-group-graph.mjs
@@ -0,0 +1,90 @@
+/**
+ * Merged multi-repo graph (web container). Reads the group's member repos +
+ * contracts from the shared gitnexus-data volume, fetches each repo's graph
+ * from the API server, collapses to file-level, and stitches cross-repo edges.
+ * See spec § 4.4.
+ */
+import { readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import { collapseToFileLevel, mergeRepoGraphs } from './docker-server-group-graph-core.mjs';
+
+const GITNEXUS_API = process.env.GITNEXUS_API || 'http://gitnexus:4747';
+const GROUPS_DIR = join(process.env.GITNEXUS_HOME || '/data/gitnexus', 'groups');
+const NODE_CAP = Number(process.env.GROUP_GRAPH_NODE_CAP) || 8000;
+const PALETTE = ['#60a5fa', '#f59e0b', '#34d399', '#f472b6', '#a78bfa', '#fb7185', '#22d3ee', '#facc15'];
+
+function sendJson(res, code, body) { res.writeHead(code, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(body)); }
+
+async function readGroupRepos(name) {
+  const raw = await readFile(join(GROUPS_DIR, name, 'group.yaml'), 'utf8'); // throws if absent
+  const repos = [];
+  let inRepos = false;
+  for (const line of raw.split('\n')) {
+    if (/^repos:\s*$/.test(line)) { inRepos = true; continue; }
+    if (inRepos) {
+      if (/^\S/.test(line)) break;
+      const m = /^\s+[^:]+:\s*(.+?)\s*$/.exec(line);
+      if (m) repos.push(m[1].replace(/^["']|["']$/g, ''));
+    }
+  }
+  return repos;
+}
+
+async function readCrossLinks(name) {
+  try {
+    const raw = await readFile(join(GROUPS_DIR, name, 'contracts.json'), 'utf8');
+    const reg = JSON.parse(raw);
+    return Array.isArray(reg?.crossLinks) ? reg.crossLinks : [];
+  } catch { return []; }
+}
+
+export async function handleGroupGraphRoute(req, url, res) {
+  if (url.pathname !== '/graph/merged' || req.method !== 'GET') return false;
+  const group = url.searchParams.get('group');
+  if (!group) { sendJson(res, 400, { error: 'missing group' }); return true; }
+
+  let repoNames;
+  try { repoNames = await readGroupRepos(group); }
+  catch { sendJson(res, 404, { error: 'group not synced (no group.yaml)' }); return true; }
+  if (!repoNames.length) { sendJson(res, 404, { error: 'group has no repos' }); return true; }
+
+  const collapsed = [];
+  const repos = [];
+  let i = 0;
+  for (const repo of repoNames) {
+    const color = PALETTE[i % PALETTE.length];
+    repos.push({ name: repo, color });
+    i++;
+    try {
+      const r = await fetch(`${GITNEXUS_API}/api/graph?repo=${encodeURIComponent(repo)}`);
+      if (!r.ok) { collapsed.push({ nodes: [], edges: [] }); continue; }
+      const graph = await r.json();
+      collapsed.push(collapseToFileLevel(graph, repo));
+    } catch { collapsed.push({ nodes: [], edges: [] }); }
+  }
+
+  const crossLinks = await readCrossLinks(group);
+  const merged = mergeRepoGraphs(collapsed, crossLinks);
+
+  const colorByRepo = Object.fromEntries(repos.map((r) => [r.name, r.color]));
+  for (const n of merged.nodes) n.color = colorByRepo[n.repo] || '#94a3b8';
+  let capped = false;
+  let nodes = merged.nodes;
+  let edges = merged.edges;
+  if (nodes.length > NODE_CAP) {
+    capped = true;
+    const crossIds = new Set();
+    for (const e of edges) if (e.crossRepo) { crossIds.add(e.source); crossIds.add(e.target); }
+    const prioritized = [...nodes].sort((a, b) => (crossIds.has(b.id) ? 1 : 0) - (crossIds.has(a.id) ? 1 : 0));
+    nodes = prioritized.slice(0, NODE_CAP);
+    const keep = new Set(nodes.map((n) => n.id));
+    edges = edges.filter((e) => keep.has(e.source) && keep.has(e.target));
+  }
+
+  sendJson(res, 200, {
+    group, repos, nodes, edges,
+    crossRepoEdgeCount: edges.filter((e) => e.crossRepo).length,
+    capped,
+  });
+  return true;
+}
