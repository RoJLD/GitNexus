@@ -0,0 +1,34 @@
+import { nodeInspectorData, type InspectorData } from '../lib/node-inspector';
+import type { ResearchGraph } from '../lib/research-graph-adapter';
+
+const METRIC_KEYS = ['degree', 'pagerank', 'betweenness', 'eigenvector', 'closeness', 'katz', 'harmonic', 'coreness', 'clustering', 'community'];
+
+interface NodeInspectorProps {
+  researchData: ResearchGraph | null;
+  metricsById?: Map<string, Record<string, number>>;
+  selectedId: string | null;
+}
+
+export function NodeInspector({ researchData, metricsById, selectedId }: NodeInspectorProps) {
+  const d: InspectorData | null = nodeInspectorData(researchData, metricsById, selectedId);
+  if (!d) return null;
+  return (
+    <div className="absolute left-4 top-16 z-20 w-64 rounded-lg border border-border-subtle bg-elevated/95 p-3 font-mono text-xs text-text-secondary shadow-lg" data-testid="node-inspector">
+      <div className="mb-2 truncate font-semibold text-text-primary" title={d.id}>{d.label || d.id}</div>
+      <div className="space-y-0.5">
+        <div><span className="text-text-muted">type</span> {d.type}</div>
+        {d.path && <div className="truncate" title={d.path}><span className="text-text-muted">path</span> {d.path}</div>}
+      </div>
+      {d.metrics && (
+        <div className="mt-2 border-t border-border-subtle pt-2">
+          {METRIC_KEYS.filter((k) => d.metrics![k] !== undefined).map((k) => (
+            <div key={k} className="flex justify-between gap-2">
+              <span className="text-text-muted">{k}</span>
+              <span className="text-indigo-300">{k === 'community' || k === 'degree' || k === 'coreness' ? d.metrics![k] : (d.metrics![k] as number).toFixed(4)}</span>
+            </div>
+          ))}
+        </div>
+      )}
+    </div>
+  );
+}
diff --git a/gitnexus-web/src/components/OwnershipPanel.tsx b/gitnexus-web/src/components/OwnershipPanel.tsx
new file mode 100644
index 00000000..cf9a4669
--- /dev/null
+++ b/gitnexus-web/src/components/OwnershipPanel.tsx
@@ -0,0 +1,237 @@
+import { useMemo, useState } from 'react';
+import {
+  X,
+  Users,
+  Loader2,
+  AlertCircle,
+  Download,
+  AlertTriangle,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Ownership / bus-factor panel — ROADMAP Tier 1.1.
+ *
+ * Lists files sorted by *fragility*: the lowest bus factor (=1 means one
+ * person has touched 80%+ of the file's history) first. Within the same
+ * bus factor, busier files (more commits) rank higher because they
+ * matter more.
+ *
+ * Filter by path/author. Click a row to highlight the file in the live
+ * graph (skipped if the file no longer exists). A header strip shows
+ * the *repo-level* bus factor — your "how many people could leave
+ * before the codebase is in trouble" number.
+ *
+ * Position: top-right (same slot as CouplingPanel — they're mutually
+ * exclusive, since both are "list of things by metric" panels and
+ * stacking would be noisy).
+ */
+
+const PANEL_WIDTH_PX = 380;
+
+function busFactorColor(bf: number): string {
+  // 1 author owns 80%+ = red flag.
+  // 2 = amber: still fragile, vacation risk.
+  // 3+ = green: healthy.
+  if (bf <= 1) return 'text-red-300 bg-red-500/15 border-red-500/30';
+  if (bf === 2) return 'text-amber-300 bg-amber-500/15 border-amber-500/30';
+  return 'text-emerald-300 bg-emerald-500/15 border-emerald-500/30';
+}
+
+export const OwnershipPanel = () => {
+  const {
+    projectName,
+    ownershipActive,
+    ownershipLoading,
+    ownershipError,
+    ownershipData,
+    graph,
+    setHighlightedNodeIds,
+    exitOwnershipMode,
+  } = useAppState();
+  const baseRepo = (projectName || '').split('@')[0];
+  const [search, setSearch] = useState('');
+  const [maxBusFactor, setMaxBusFactor] = useState(99);
+
+  // Build a path → File-node-id index so a row click can highlight in
+  // the graph. Same trick CouplingPanel uses.
+  const fileIdByPath = useMemo(() => {
+    const m = new Map<string, string>();
+    if (!graph) return m;
+    for (const n of graph.nodes) {
+      if (n.label === 'File' && n.properties.filePath) {
+        m.set(n.properties.filePath, n.id);
+      }
+    }
+    return m;
+  }, [graph]);
+
+  const filtered = useMemo(() => {
+    if (!ownershipData) return [];
+    const q = search.trim().toLowerCase();
+    return ownershipData.files.filter((f) => {
+      if (f.busFactor > maxBusFactor) return false;
+      if (!q) return true;
+      if (f.path.toLowerCase().includes(q)) return true;
+      return f.authors.some((a) => a.name.toLowerCase().includes(q));
+    });
+  }, [ownershipData, search, maxBusFactor]);
+
+  if (!ownershipActive && !ownershipLoading && !ownershipError) return null;
+
+  return (
+    <div
+      className="pointer-events-auto absolute top-3 right-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width: PANEL_WIDTH_PX, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <Users className="h-3.5 w-3.5 text-rose-300" />
+        <span className="text-xs font-semibold text-text-primary">Ownership · Bus factor</span>
+        {ownershipData && (
+          <a
+            href={`/ownership?repo=${encodeURIComponent(baseRepo)}&format=csv`}
+            download
+            className="ml-auto shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+            title="Download per-file ownership as CSV"
+          >
+            <Download className="h-3.5 w-3.5" />
+          </a>
+        )}
+        <button
+          type="button"
+          onClick={() => exitOwnershipMode()}
+          className={`${ownershipData ? '' : 'ml-auto'} shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary`}
+          title="Close panel"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+
+      {ownershipLoading && (
+        <div className="flex items-center justify-center gap-2 py-6 text-xs text-text-muted">
+          <Loader2 className="h-3.5 w-3.5 animate-spin" />
+          Running git log…
+        </div>
+      )}
+      {ownershipError && (
+        <div className="flex items-start gap-2 px-3 py-3 text-xs text-red-400">
+          <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+          <span>{ownershipError}</span>
+        </div>
+      )}
+
+      {ownershipData && !ownershipLoading && (
+        <>
+          {/* Repo-level summary strip */}
+          <div className="space-y-1 border-b border-border-subtle bg-elevated px-3 py-2">
+            <div className="flex items-center gap-2 text-[11px]">
+              <span className="text-text-muted">Repo bus factor:</span>
+              <span
+                className={`rounded border px-1.5 py-0.5 font-mono font-semibold ${busFactorColor(ownershipData.repoBusFactor)}`}
+                title={`Smallest set of authors covering ≥${Math.round(ownershipData.busFactorThreshold * 100)}% of commits`}
+              >
+                {ownershipData.repoBusFactor}
+              </span>
+              <span className="text-text-muted">
+                · {ownershipData.authorsCount} authors total · {ownershipData.totalFiles} files
+              </span>
+            </div>
+            <div className="text-[10px] text-text-muted">
+              Top:{' '}
+              {ownershipData.repoAuthors
+                .slice(0, 3)
+                .map((a) => `${a.name} (${Math.round(a.share * 100)}%)`)
+                .join(', ')}
+            </div>
+          </div>
+
+          {/* Filters */}
+          <div className="space-y-2 border-b border-border-subtle px-3 py-2">
+            <input
+              type="text"
+              value={search}
+              onChange={(e) => setSearch(e.target.value)}
+              placeholder="Filter by path or author…"
+              className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+              spellCheck={false}
+              autoComplete="off"
+            />
+            <div className="flex items-center gap-2 text-[10px] text-text-muted">
+              <span className="shrink-0">Max bus factor:</span>
+              <input
+                type="range"
+                min={1}
+                max={10}
+                value={maxBusFactor === 99 ? 10 : maxBusFactor}
+                onChange={(e) => {
+                  const v = parseInt(e.target.value, 10);
+                  setMaxBusFactor(v === 10 ? 99 : v);
+                }}
+                className="flex-1 accent-accent"
+              />
+              <span className="shrink-0 font-mono">
+                {maxBusFactor === 99 ? '∞' : `≤${maxBusFactor}`}
+              </span>
+            </div>
+          </div>
+
+          <div className="flex-1 overflow-y-auto">
+            {filtered.length === 0 ? (
+              <div className="px-3 py-4 text-center text-[11px] text-text-muted italic">
+                No files match the filters.
+              </div>
+            ) : (
+              filtered.map((f) => {
+                const fileId = fileIdByPath.get(f.path);
+                const canHighlight = !!fileId;
+                return (
+                  <button
+                    key={f.path}
+                    type="button"
+                    onClick={() => {
+                      if (!canHighlight) return;
+                      setHighlightedNodeIds(new Set([fileId!]));
+                    }}
+                    disabled={!canHighlight}
+                    className="group flex w-full flex-col gap-0.5 border-b border-border-subtle px-3 py-2 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+                    title={canHighlight ? `Highlight in graph (${f.totalCommits} commits)` : 'Not in live graph any more'}
+                  >
+                    <div className="flex min-w-0 items-center gap-2 font-mono text-[11px]">
+                      <span
+                        className={`shrink-0 rounded border px-1.5 py-0 font-semibold ${busFactorColor(f.busFactor)}`}
+                      >
+                        BF {f.busFactor}
+                      </span>
+                      <span className="truncate text-text-primary">{f.path}</span>
+                      {f.busFactor === 1 && (
+                        <AlertTriangle
+                          className="h-3 w-3 shrink-0 text-red-400"
+                          aria-label="Single owner — fragile"
+                        />
+                      )}
+                    </div>
+                    <div className="flex min-w-0 items-center gap-2 truncate text-[10px] text-text-muted">
+                      <span className="font-mono">{f.totalCommits} commits</span>
+                      <span>·</span>
+                      <span className="truncate">
+                        {f.authors
+                          .slice(0, 3)
+                          .map((a) => `${a.name} ${Math.round(a.share * 100)}%`)
+                          .join(', ')}
+                      </span>
+                    </div>
+                  </button>
+                );
+              })
+            )}
+            {ownershipData.truncated && (
+              <div className="px-3 py-2 text-[10px] text-text-muted italic">
+                Showing first {ownershipData.files.length} of {ownershipData.truncated} files (capped server-side).
+              </div>
+            )}
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
diff --git a/gitnexus-web/src/components/SimilarityPanel.tsx b/gitnexus-web/src/components/SimilarityPanel.tsx
new file mode 100644
index 00000000..6b329d74
--- /dev/null
+++ b/gitnexus-web/src/components/SimilarityPanel.tsx
@@ -0,0 +1,957 @@
+import { useEffect, useMemo, useState } from 'react';
+import {
+  X,
+  AlertCircle,
+  Loader2,
+  Network,
+  ShieldAlert,
+  Info,
+  Sparkles,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Cross-repo similarity panel — ROADMAP Tier 2.5.
+ *
+ * Aggregates the per-repo analytics (entropy, ownership, lifespan,
+ * git activity) into a 5-dim identity vector per repo and shows the
+ * pairwise diagnostic in a small matrix.
+ *
+ * v1 ships the structural × temporal plane (4 quadrants). The semantic
+ * axis is documented in the response (`semanticAxisAvailable: false`)
+ * but not computed — same rationale as /semantic-labels: the LLM
+ * credentials live client-side and embedding the labels needs a
+ * separate embeddings client, deferred to v1.1.
+ *
+ * Position: top-right slot, mutex with Coupling/Ownership/Dissonance/
+ * What-If. The panel auto-fetches when toggled on, using every
+ * non-snapshot repo in `availableRepos` (capped at 8 by the backend).
+ */
+
+const PANEL_WIDTH_PX = 460;
+
+type SimilarityRepo = {
+  name: string;
+  identityVector: Record<string, number>;
+  stats: {
+    nodes: number;
+    edges: number;
+    communities: number;
+    authorsCount: number;
+    busFactor: number;
+  };
+  hasGit: boolean;
+  gitError: string | null;
+  licensePresent: boolean;
+  policy: { isolation_required: boolean; reason: string | null; allow_merge_with: string[] } | null;
+  lastCommitDate: string | null;
+  semanticLabelsCount: number;
+  semanticEmbeddingsCount: number;
+  hasLabelCentroid: boolean;
+  galaxyXY: [number, number] | null;
+};
+
+type SimilarityPair = {
+  a: string;
+  b: string;
+  structuralScore: number;
+  semanticScore: number | null;
+  semanticMode: 'embeddings' | 'lexical' | 'none';
+  temporalCoupling: number;
+  quadrant: string;
+  recommendation: string | null;
+  warnings: string[];
+  dominantFeatures: string[];
+  policyApplied: { isolationRequired?: boolean; reasons?: string[]; whitelisted?: boolean } | null;
+};
+
+type SimilarityData = {
+  repos: SimilarityRepo[];
+  pairs: SimilarityPair[];
+  thresholds: { structural: number; semantic: number; temporal: number };
+  windowDays: number;
+  identityVersion: number;
+  identityDims: string[];
+  semanticAxisAvailable: boolean;
+  semanticAxisMode: 'lexical' | 'embeddings' | 'disabled';
+  reposWithLabels: number;
+  reposWithCentroid: number;
+  semanticAxisNote: string;
+  galaxyProjection: { method: 'pca'; dim: 2 } | null;
+};
+
+// Quadrant → tailwind color tokens. The 4 v1 quadrants get distinct
+// hues so the matrix reads at a glance; the others (semantic-axis
+// dependent) are listed for future use.
+const QUADRANT_COLORS: Record<string, string> = {
+  'Jumeaux actifs': 'bg-emerald-500/40 hover:bg-emerald-500/60 border-emerald-500/60',
+  'Jumeaux isolés': 'bg-amber-500/40 hover:bg-amber-500/60 border-amber-500/60',
+  'Jumeaux (isolation intentionnelle)': 'bg-slate-500/30 hover:bg-slate-500/50 border-slate-500/50',
+  'Patterns + collision': 'bg-orange-500/40 hover:bg-orange-500/60 border-orange-500/60',
+  'Patterns partagés': 'bg-sky-500/40 hover:bg-sky-500/60 border-sky-500/60',
+  'Collision réelle': 'bg-red-500/40 hover:bg-red-500/60 border-red-500/60',
+  'Domaines parallèles': 'bg-indigo-500/30 hover:bg-indigo-500/50 border-indigo-500/50',
+  'Couplage caché': 'bg-fuchsia-500/40 hover:bg-fuchsia-500/60 border-fuchsia-500/60',
+  'Indépendants': 'bg-elevated hover:bg-hover border-border-default',
+};
+
+function quadrantColor(q: string): string {
+  return QUADRANT_COLORS[q] || 'bg-elevated hover:bg-hover border-border-default';
+}
+
+function fmtScore(n: number | null): string {
+  if (n === null) return '—';
+  return n.toFixed(2);
+}
+
+// ── Galaxy view (Tier 2.6) ──────────────────────────────────────────
+//
+// PCA-projected 2D scatter of repos. Points colored by their dominant
+// pairwise quadrant (most-frequent quadrant they appear in). Edges
+// drawn for pairs with strong total similarity (struct + sem + temp
+// average above a threshold) so the user sees "constellation".
+//
+// SVG over Canvas: <=8 repos fit happily, SVG is more accessible
+// (hover titles, no manual hit-testing) and re-renders without state.
+
+const GALAXY_WIDTH = 420;
+const GALAXY_HEIGHT = 280;
+const GALAXY_PADDING = 24;
+const GALAXY_EDGE_THRESHOLD = 0.6; // avg of 3 normalized axes
+const GALAXY_DOT_RADIUS = 6;
+
+type GalaxyProps = {
+  repos: SimilarityRepo[];
+  pairs: SimilarityPair[];
+  selectedPair: SimilarityPair | null;
+  baseRepo: string;
+  onSelectRepo: (name: string) => void;
+};
+
+function quadrantHex(q: string): string {
+  // Stand-alone hex colors matching the Tailwind classes used in the
+  // matrix. SVG fill doesn't pick up class-based vars cleanly.
+  if (q.startsWith('Jumeaux actifs')) return '#34d399';        // emerald-400
+  if (q.startsWith('Jumeaux isolés')) return '#fbbf24';        // amber-400
+  if (q.startsWith('Jumeaux (isolation')) return '#94a3b8';    // slate-400
+  if (q === 'Patterns + collision') return '#fb923c';          // orange-400
+  if (q === 'Patterns partagés') return '#38bdf8';             // sky-400
+  if (q === 'Collision réelle') return '#f87171';              // red-400
+  if (q === 'Domaines parallèles') return '#a5b4fc';           // indigo-300
+  if (q === 'Couplage caché') return '#e879f9';                // fuchsia-400
+  return '#6b7280';                                            // gray-500 fallback
+}
+
+function GalaxyView({ repos, pairs, selectedPair, baseRepo, onSelectRepo }: GalaxyProps) {
+  // Projection method toggle (Tier 2.6 = PCA from backend, 2.6.bis =
+  // UMAP computed client-side via umap-js). UMAP gives better
+  // neighborhood preservation but degenerates < ~5 points; PCA is
+  // smoother for the small-N case (2-4 repos) but doesn't pick up
+  // nonlinear cluster shape. We default to PCA because it ships
+  // already-computed in the backend response (no extra import cost).
+  const [method, setMethod] = useState<'pca' | 'umap'>('pca');
+  const [umapCoords, setUmapCoords] = useState<Map<string, [number, number]> | null>(null);
+  const [umapError, setUmapError] = useState<string | null>(null);
+
+  // Compute UMAP lazily on first switch to 'umap' for the active repo
+  // set. Re-runs when repos change (new index, refetch). Dynamic
+  // import keeps umap-js out of the bundle for users who never open
+  // the galaxy.
+  const reposKey = repos.map((r) => r.name).join('|');
+  useEffect(() => {
+    if (method !== 'umap') return;
+    let cancelled = false;
+    void (async () => {
+      try {
+        // Build the raw identity matrix from each repo's identityVector
+        // — same dims the backend used for PCA, but we re-project from
+        // scratch via UMAP for fairness (UMAP needs the original space
+        // to find neighborhoods).
+        const labeled = repos.filter((r) => Object.keys(r.identityVector).length > 0);
+        if (labeled.length < 2) {
+          setUmapError('UMAP needs ≥2 repos.');
+          return;
+        }
+        const dims = Object.keys(labeled[0].identityVector);
+        const data = labeled.map((r) => dims.map((d) => r.identityVector[d] ?? 0));
+        // umap-js requires nNeighbors ≤ N-1. For tiny N the result is
+        // basically scaled PCA, but it doesn't error out.
+        const nNeighbors = Math.max(2, Math.min(15, labeled.length - 1));
+        const { UMAP } = await import('umap-js');
+        // Seeded RNG so the projection is stable across refetches —
+        // umap-js takes a `random` function returning [0, 1). A simple
+        // mulberry32 keyed on the repo-set hash gives deterministic
+        // output without rotating on every page reload.
+        let seed = 0;
+        for (let i = 0; i < reposKey.length; i++) seed = (seed * 31 + reposKey.charCodeAt(i)) >>> 0;
+        const rng = () => {
+          seed = (seed + 0x6d2b79f5) >>> 0;
+          let t = seed;
+          t = Math.imul(t ^ (t >>> 15), t | 1);
+          t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
+          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+        };
+        const umap = new UMAP({
+          nNeighbors,
+          minDist: 0.1,
+          nComponents: 2,
+          random: rng,
+        });
+        const embedding = umap.fit(data);
+        if (cancelled) return;
+        const coords = new Map<string, [number, number]>();
+        for (let i = 0; i < labeled.length; i++) {
+          coords.set(labeled[i].name, [embedding[i][0], embedding[i][1]]);
+        }
+        setUmapCoords(coords);
+        setUmapError(null);
+      } catch (err) {
+        if (!cancelled) setUmapError(err instanceof Error ? err.message : 'UMAP failed');
+      }
+    })();
+    return () => {
+      cancelled = true;
+    };
+  }, [method, reposKey, repos]);
+
+  // Source of truth for [x, y] depends on the active method.
+  const coordsFor = (r: SimilarityRepo): [number, number] | null => {
+    if (method === 'umap') {
+      return umapCoords?.get(r.name) ?? null;
+    }
+    return r.galaxyXY;
+  };
+
+  const pts = repos
+    .map((r) => {
+      const xy = coordsFor(r);
+      if (!xy) return null;
+      return { name: r.name, x: xy[0], y: xy[1], repo: r };
+    })
+    .filter(Boolean) as { name: string; x: number; y: number; repo: SimilarityRepo }[];
+  if (pts.length === 0 && method === 'umap' && !umapError) {
+    // UMAP still loading — show a placeholder. PCA path always has data.
+  }
+  const xs = pts.map((p) => p.x);
+  const ys = pts.map((p) => p.y);
+  const xMin = Math.min(...xs);
+  const xMax = Math.max(...xs);
+  const yMin = Math.min(...ys);
+  const yMax = Math.max(...ys);
+  // Pad ranges by 5% on each side; avoid division-by-zero by giving
+  // degenerate axes a tiny synthetic range.
+  const xRange = Math.max(xMax - xMin, 1e-6);
+  const yRange = Math.max(yMax - yMin, 1e-6);
+  const project = (x: number, y: number) => ({
+    cx: GALAXY_PADDING + ((x - xMin) / xRange) * (GALAXY_WIDTH - 2 * GALAXY_PADDING),
+    // SVG y is inverted; flip so up = positive PC2.
+    cy: GALAXY_HEIGHT - GALAXY_PADDING - ((y - yMin) / yRange) * (GALAXY_HEIGHT - 2 * GALAXY_PADDING),
+  });
+
+  // Per-repo dominant quadrant — what quadrant does this repo MOST
+  // frequently appear in across its pairs. Colors the point.
+  const dominantQuadrant = new Map<string, string>();
+  for (const p of pts) {
+    const counts = new Map<string, number>();
+    for (const pair of pairs) {
+      if (pair.a !== p.name && pair.b !== p.name) continue;
+      counts.set(pair.quadrant, (counts.get(pair.quadrant) || 0) + 1);
+    }
+    const top = [...counts.entries()].sort((a, b) => b[1] - a[1])[0];
+    dominantQuadrant.set(p.name, top ? top[0] : 'Indépendants');
+  }
+
+  // Edges for "strong" pairs (avg of normalized scores above threshold).
+  const edges = pairs
+    .map((pair) => {
+      const a = pts.find((p) => p.name === pair.a);
+      const b = pts.find((p) => p.name === pair.b);
+      if (!a || !b) return null;
+      const sem = pair.semanticScore ?? 0;
+      const strength = (pair.structuralScore + sem + pair.temporalCoupling) / 3;
+      if (strength < GALAXY_EDGE_THRESHOLD) return null;
+      return { a, b, strength, pair };
+    })
+    .filter(Boolean) as { a: typeof pts[0]; b: typeof pts[0]; strength: number; pair: SimilarityPair }[];
+
+  return (
+    <div className="px-3 py-2">
+      {/* PCA / UMAP method toggle (Tier 2.6 + 2.6.bis). PCA is the
+          default because it ships pre-computed in the response; UMAP
+          is dynamic-imported on first switch. */}
+      <div className="mb-2 flex items-center gap-1.5">
+        <span className="text-[9px] text-text-muted">projection:</span>
+        <button
+          type="button"
+          onClick={() => setMethod('pca')}
+          className={`cursor-pointer rounded px-1.5 py-0 text-[9px] font-medium transition-all ${
+            method === 'pca'
+              ? 'bg-cyan-500/20 text-cyan-200'
+              : 'text-text-muted hover:text-text-primary'
+          }`}
+          title="Principal Component Analysis — linear projection, deterministic, smooth for small N"
+        >
+          PCA
+        </button>
+        <button
+          type="button"
+          onClick={() => setMethod('umap')}
+          className={`cursor-pointer rounded px-1.5 py-0 text-[9px] font-medium transition-all ${
+            method === 'umap'
+              ? 'bg-cyan-500/20 text-cyan-200'
+              : 'text-text-muted hover:text-text-primary'
+          }`}
+          title="Uniform Manifold Approximation — nonlinear, preserves local neighborhoods (best for 5+ repos)"
+        >
+          UMAP
+        </button>
+        {method === 'umap' && pts.length === 0 && !umapError && (
+          <span className="text-[9px] text-violet-300">computing…</span>
+        )}
+        {umapError && (
+          <span className="text-[9px] text-red-400" title={umapError}>
+            UMAP error (hover)
+          </span>
+        )}
+      </div>
+      <svg
+        width="100%"
+        height={GALAXY_HEIGHT}
+        viewBox={`0 0 ${GALAXY_WIDTH} ${GALAXY_HEIGHT}`}
+        className="rounded border border-border-subtle bg-void"
+      >
+        {/* Edges below dots so dots draw on top. */}
+        {edges.map(({ a, b, strength, pair }, idx) => {
+          const { cx: ax, cy: ay } = project(a.x, a.y);
+          const { cx: bx, cy: by } = project(b.x, b.y);
+          const isSelected =
+            selectedPair &&
+            ((selectedPair.a === a.name && selectedPair.b === b.name) ||
+              (selectedPair.a === b.name && selectedPair.b === a.name));
+          return (
+            <line
+              key={`edge-${idx}`}
+              x1={ax}
+              y1={ay}
+              x2={bx}
+              y2={by}
+              stroke={isSelected ? '#22d3ee' : '#475569'}
+              strokeWidth={isSelected ? 2 : 0.5 + (strength - GALAXY_EDGE_THRESHOLD) * 4}
+              strokeOpacity={isSelected ? 0.9 : 0.4}
+            >
+              <title>
+                {a.name} ↔ {b.name}: {pair.quadrant} (avg strength {strength.toFixed(2)})
+              </title>
+            </line>
+          );
+        })}
+        {/* Dots + labels */}
+        {pts.map((p) => {
+          const { cx, cy } = project(p.x, p.y);
+          const color = quadrantHex(dominantQuadrant.get(p.name) || '');
+          const isBase = p.name === baseRepo;
+          const isSelected =
+            selectedPair && (selectedPair.a === p.name || selectedPair.b === p.name);
+          return (
+            <g
+              key={p.name}
+              onClick={() => onSelectRepo(p.name)}
+              style={{ cursor: 'pointer' }}
+            >
+              <circle
+                cx={cx}
+                cy={cy}
+                r={isSelected ? GALAXY_DOT_RADIUS + 2 : GALAXY_DOT_RADIUS}
+                fill={color}
+                stroke={isBase ? '#ffffff' : isSelected ? '#22d3ee' : '#1e293b'}
+                strokeWidth={isBase ? 2 : isSelected ? 2 : 1}
+                opacity={0.9}
+              >
+                <title>
+                  {p.name}
+                  {isBase ? ' ★' : ''}: {dominantQuadrant.get(p.name) || ''}
+                </title>
+              </circle>
+              <text
+                x={cx + GALAXY_DOT_RADIUS + 4}
+                y={cy + 3}
+                fontSize={9}
+                fill="#cbd5e1"
+                className="pointer-events-none"
+              >
+                {p.name.length > 16 ? p.name.slice(0, 14) + '…' : p.name}
+              </text>
+            </g>
+          );
+        })}
+      </svg>
+      <div className="mt-2 text-[9px] text-text-muted">
+        {method === 'pca'
+          ? 'PCA 2D · linear projection · distance ≈ structural similarity'
+          : 'UMAP 2D · nonlinear · preserves local neighborhoods'}{' '}
+        · edges shown when avg(struct, sem, temp) ≥ {GALAXY_EDGE_THRESHOLD.toFixed(1)} · ★ = current
+        repo · click a point to select its nearest pair.
+      </div>
+    </div>
+  );
+}
+
+function dimLabel(dim: string): string {
+  switch (dim) {
+    case 'density': return 'graph density';
+    case 'modularity': return 'modularity';
+    case 'busFactorNorm': return 'bus factor (norm)';
+    case 'topAuthorShare': return 'top-author share';
+    case 'foundationalRatio': return 'foundational ratio';
+    case 'growthRate': return 'growth rate';
+    case 'churnConcentration': return 'churn concentration (Gini)';
+    case 'fileSizePareto': return 'file-size Pareto (Gini)';
+    case 'languageDiversity': return 'language diversity (Shannon)';
+    case 'treeDepth': return 'tree depth (median)';
+    default: return dim;
+  }
