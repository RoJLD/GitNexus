@@ -0,0 +1,203 @@
+import { useEffect, useState } from 'react';
+import AuditSummary from './audit/AuditSummary';
+import LeadTimeHistogram from './audit/LeadTimeHistogram';
+import SlippageBar from './audit/SlippageBar';
+import VelocitySparkline from './audit/VelocitySparkline';
+import PlanChurnList from './audit/PlanChurnList';
+import GhostTable from './audit/GhostTable';
+import CleanupModal from './audit/CleanupModal';
+import ClusterDrillModal from './audit/ClusterDrillModal';
+import { fetchClusters, type ClusterRuntime } from '../services/clusters-client';
+
+/**
+ * Roadmap-predictive Audit container.
+ *
+ * Fetches `/ghost-audit` (analytics) and `/ghosts` (raw list for the
+ * sortable table) in parallel. Renders one of three states:
+ *   - loading (spinner-ish placeholder)
+ *   - error (either 404 → "Run sync now" banner, or generic error)
+ *   - success (header + summary + 4 visualizations + churners list + table)
+ *
+ * Spec : docs/superpowers/specs/2026-05-26-roadmap-predictive-audit-design.md
+ */
+
+export interface AuditData {
+  computedAt: string;
+  cached: boolean;
+  summary: {
+    total: number;
+    materialized: number;
+    planned: number;
+    cancelled: number;
+    cancellationRate: number;
+  };
+  leadTime: {
+    medianDays: number | null;
+    p25Days: number | null;
+    p75Days: number | null;
+    maxDays: number | null;
+    distribution: { bucket: string; count: number }[];
+  };
+  slippage: {
+    early: number;
+    onTime: number;
+    late: number;
+    noTarget: number;
+    onTimePct: number | null;
+  };
+  planChurn: {
+    totalGhostsWithChurn: number;
+    avgChurnPerGhost: number;
+    topChurners: { id: string; churn: number; deltas: string[] }[];
+  };
+  velocity: {
+    windowDays: number;
+    currentCount: number;
+    history: { weekStarting: string; count: number }[];
+  };
+  // Update 1 (computeExpired, shipped earlier) — the audit response now
+  // carries an `expired` block too. Optional in the type for backwards
+  // compatibility with older snapshots cached before the field landed.
+  expired?: {
+    total: number;
+    critical: number;
+    expiredButRecent: number;
+    list: { id: string; expectedBy: string; daysPastExpiry: number; alertLevel: string }[];
+  };
+}
+
+export default function AuditPanel({
+  repo,
+  onGhostSelect,
+}: {
+  repo: string;
+  onGhostSelect?: (id: string) => void;
+}) {
+  const [audit, setAudit] = useState<AuditData | null>(null);
+  const [ghosts, setGhosts] = useState<any[] | null>(null);
+  const [error, setError] = useState<string | null>(null);
+  const [highlightedId, setHighlightedId] = useState<string | null>(null);
+  const [cleanupOpen, setCleanupOpen] = useState(false);
+  // Section H / Task 13 — clusters + drill modal. Fetch is best-effort
+  // (a repo with no /clusters route or no clusters.json sidecar simply
+  // leaves the 7th card hidden — `ClustersCard` returns null when the
+  // array is empty).
+  const [clusters, setClusters] = useState<ClusterRuntime[] | null>(null);
+  const [clustersOpen, setClustersOpen] = useState(false);
+
+  async function loadAll() {
+    setError(null);
+    const [auditRes, ghostsRes] = await Promise.all([
+      fetch(`/ghost-audit?repo=${encodeURIComponent(repo)}`),
+      fetch(`/ghosts?repo=${encodeURIComponent(repo)}`),
+    ]);
+    if (auditRes.status === 404 || ghostsRes.status === 404) {
+      setError('not-synced');
+      return;
+    }
+    if (!auditRes.ok || !ghostsRes.ok) {
+      setError('Failed to load audit data');
+      return;
+    }
+    setAudit(await auditRes.json());
+    setGhosts((await ghostsRes.json()).ghosts ?? []);
+  }
+
+  useEffect(() => {
+    loadAll();
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [repo]);
+
+  // Clusters live in their own sidecar (clusters.json) so the audit
+  // payload doesn't carry them — we fetch in parallel with /ghosts.
+  // 404 (cache miss / no roadmap synced) silently leaves the 7th
+  // card hidden.
+  useEffect(() => {
+    let cancelled = false;
+    fetchClusters(repo)
+      .then((data) => {
+        if (cancelled) return;
+        setClusters(data?.clusters ?? null);
+      })
+      .catch(() => {
+        if (cancelled) return;
+        setClusters(null);
+      });
+    return () => {
+      cancelled = true;
+    };
+  }, [repo]);
+
+  async function handleSync() {
+    await fetch(`/ghosts/sync?repo=${encodeURIComponent(repo)}`, { method: 'POST' });
+    await loadAll();
+  }
+
+  if (error === 'not-synced') {
+    return (
+      <div className="audit-panel" data-testid="audit-panel">
+        <p>Roadmap not synced yet.</p>
+        <button onClick={handleSync}>Run sync now</button>
+      </div>
+    );
+  }
+  if (error) {
+    return (
+      <div className="audit-panel">
+        <p>Error: {error}</p>
+      </div>
+    );
+  }
+  if (!audit || !ghosts) {
+    return <div className="audit-panel">Loading audit…</div>;
+  }
+
+  return (
+    <div className="audit-panel" data-testid="audit-panel">
+      <header>
+        <h3>Audit roadmap</h3>
+        <span className="ghost-count">{audit.summary.total} ghosts</span>
+        {audit.cached && (
+          <span className="badge" title={`Computed at ${audit.computedAt}`}>
+            cached
+          </span>
+        )}
+      </header>
+      <AuditSummary
+        data={audit.summary}
+        expired={audit.expired}
+        onExpiredClick={() => setCleanupOpen(true)}
+        clusters={clusters ?? undefined}
+        onClustersClick={() => setClustersOpen(true)}
+      />
+      <SlippageBar data={audit.slippage} />
+      <LeadTimeHistogram data={audit.leadTime} />
+      <VelocitySparkline data={audit.velocity} />
+      <PlanChurnList
+        topChurners={audit.planChurn.topChurners}
+        onSelectChurner={(id) => setHighlightedId(id)}
+      />
+      <GhostTable
+        ghosts={ghosts}
+        highlightedId={highlightedId}
+        onGhostSelect={(id) => {
+          setHighlightedId(id);
+          onGhostSelect?.(id);
+        }}
+      />
+      <CleanupModal repo={repo} open={cleanupOpen} onClose={() => setCleanupOpen(false)} />
+      {clusters && (
+        <ClusterDrillModal
+          clusters={clusters}
+          ghosts={ghosts ?? []}
+          open={clustersOpen}
+          onClose={() => setClustersOpen(false)}
+          onGhostClick={(id) => {
+            setHighlightedId(id);
+            onGhostSelect?.(id);
+          }}
+        />
+      )}
+    </div>
+  );
+}
