+// Per-type colors for research-artifacts graphs (node.type -> hex).
+// Mirrors the template's visual.nodeColors in docker-server-graph-templates-core.mjs.
+export const RESEARCH_COLORS: Record<string, string> = {
+  notebook: '#3b82f6',
+  experiment: '#f59e0b',
+  hypothesis: '#a855f7',
+  result: '#10b981',
+  dataset: '#14b8a6',
+  note: '#64748b',
+  // model-graph node types (mirror visual.nodeColors of the model-graph template
+  // in docker-server-graph-templates-core.mjs) so model nodes render distinctly.
+  state: '#60a5fa',
+  observation: '#f59e0b',
+  op: '#34d399',
+  layer: '#a78bfa',
+  'param-group': '#f472b6',
+};
+
+export const RESEARCH_FALLBACK_COLOR = '#9ca3af';
+
+// Community palette for metrics overlays (node.community % len). Lives here (dep-free)
+// so both research-graph-adapter (2D) and research-to-3d (3D) share ONE source — and
+// so the 3D mapper can import it without pulling graphology (which the unit runner
+// can't resolve from web src). 2D ↔ 3D community colors stay in lockstep.
+export const COMMUNITY_PALETTE = ['#60a5fa', '#f59e0b', '#34d399', '#f472b6', '#a78bfa', '#fb7185', '#22d3ee', '#facc15', '#4ade80', '#c084fc'];
diff --git a/gitnexus-web/src/lib/research-graph-adapter.ts b/gitnexus-web/src/lib/research-graph-adapter.ts
new file mode 100644
index 00000000..a6174460
--- /dev/null
+++ b/gitnexus-web/src/lib/research-graph-adapter.ts
@@ -0,0 +1,118 @@
+import Graph from 'graphology';
+import type { SigmaNodeAttributes, SigmaEdgeAttributes } from './graph-adapter';
+import { RESEARCH_COLORS, RESEARCH_FALLBACK_COLOR, COMMUNITY_PALETTE } from './research-colors';
+import { heatColor } from './metrics-view';
+import { layeredLayout } from './layered-layout';
+
+// Re-exported so existing consumers (e.g. AdjacencyMatrix) keep importing it from here;
+// the single source of truth now lives in research-colors.ts (dep-free).
+export { COMMUNITY_PALETTE };
+
+export interface ResearchNode {
+  id: string;
+  type: string;
+  label: string;
+  path: string;
+  stage: string;
+}
+export interface ResearchEdge {
+  id: string;
+  source: string;
+  target: string;
+  kind: string;
+}
+export interface ResearchGraph {
+  schema_type?: string;
+  template?: string;
+  name?: string | null;
+  source?: string | null;
+  generated?: string;
+  nodes: ResearchNode[];
+  edges: ResearchEdge[];
+  report?: unknown;
+}
+
+const EDGE_COLOR = '#475569';
+
+/**
+ * Convert a ResearchGraph JSON into a graphology graph ready for useSigma().setGraph.
+ * Positions are seeded on a circle (deterministic); ForceAtlas2 in setGraph converges them.
+ * Mirrors group-graph-adapter.ts.
+ */
+export function researchGraphToGraphology(
+  rg: ResearchGraph,
+  metricsById?: Map<string, { degree: number; pagerank: number; betweenness: number; eigenvector: number; closeness: number; katz: number; harmonic: number; coreness: number; clustering: number; community: number }>,
+  sizeBy: 'degree' | 'pagerank' | 'betweenness' | 'eigenvector' | 'closeness' | 'katz' | 'harmonic' | 'coreness' | 'clustering' = 'pagerank',
+  opts: {
+    colorMode?: 'community' | 'heatmap';
+    highlightStructure?: boolean;
+    isolateCommunity?: number | null;
+    articulationIds?: Set<string>;
+    bridgeKeys?: Set<string>;
+    layoutMode?: 'force' | 'hierarchical' | 'circular';
+    deadNodeIds?: Set<string>;
+  } = {},
+): Graph<SigmaNodeAttributes, SigmaEdgeAttributes> {
+  const { colorMode = 'community', highlightStructure = false, isolateCommunity = null, articulationIds, bridgeKeys, layoutMode = 'force', deadNodeIds = undefined } = opts;
+  const graph = new Graph<SigmaNodeAttributes, SigmaEdgeAttributes>();
+  const nodes = rg.nodes || [];
+  const total = Math.max(1, nodes.length);
+  const radius = Math.sqrt(total) * 30;
+
+  const maxV = metricsById
+    ? Math.max(...[...metricsById.values()].map((v) => v[sizeBy]), 1e-9)
+    : 1;
+
+  const layered = layoutMode === 'hierarchical'
+    ? layeredLayout({ nodes: nodes.map((n) => ({ id: n.id })), edges: (rg.edges || []).map((e) => ({ source: e.source, target: e.target })) })
+    : null;
+
+  let i = 0;
+  for (const node of nodes) {
+    if (graph.hasNode(node.id)) continue;
+    const angle = (i / total) * 2 * Math.PI;
+    const r = radius * (0.5 + ((i % 50) / 50) * 0.5);
+    const m = metricsById?.get(node.id);
+    const dimmed = isolateCommunity != null && m != null && m.community !== isolateCommunity;
+    let color = m
+      ? (colorMode === 'heatmap' ? heatColor((m[sizeBy] ?? 0) / maxV) : COMMUNITY_PALETTE[m.community % COMMUNITY_PALETTE.length])
+      : (RESEARCH_COLORS[node.type] || RESEARCH_FALLBACK_COLOR);
+    let size = m ? 4 + 16 * Math.sqrt((m[sizeBy] ?? 0) / maxV) : 5;
+    const isArticulation = !!(highlightStructure && articulationIds?.has(node.id));
+    if (dimmed) { color = '#374151'; size = 2; }   // dim non-isolated (no opacity attr → gray+small)
+    // Observability — a dead-weight node (no directed path to any output) pops in red,
+    // taking precedence over the community/heatmap color but respecting `dimmed`.
+    const isDead = !!(deadNodeIds?.has(node.id) && !dimmed);
+    if (isDead) color = '#ef4444';   // dead-weight red
+    graph.addNode(node.id, {
+      x: layered?.get(node.id)?.x ?? Math.cos(angle) * r,
+      y: layered?.get(node.id)?.y ?? Math.sin(angle) * r,
+      size,
+      color,
+      label: node.label,
+      nodeType: 'CodeElement',
+      filePath: node.path,
+      mass: 3,
+      ...((isArticulation && !dimmed) || isDead ? { highlighted: true, zIndex: 2 } : {}),
+    });
+    i++;
+  }
+
+  for (const e of rg.edges || []) {
+    if (!graph.hasNode(e.source) || !graph.hasNode(e.target)) continue;
+    if (e.source === e.target) continue;
+    if (graph.hasEdge(e.source, e.target)) continue;
+    const isBridge = !!(highlightStructure && bridgeKeys?.has(`${e.source}\0${e.target}`));
+    const sm = metricsById?.get(e.source);
+    const tm = metricsById?.get(e.target);
+    const edgeDimmed = isolateCommunity != null && sm != null && tm != null && sm.community !== isolateCommunity && tm.community !== isolateCommunity;
+    graph.addEdge(e.source, e.target, {
+      size: isBridge ? 3 : 1,
+      color: edgeDimmed ? '#1f2937' : (isBridge ? '#ef4444' : EDGE_COLOR),
+      relationType: e.kind,
+      type: 'curved',
+      zIndex: isBridge ? 2 : 1,
+    });
+  }
+  return graph;
+}
diff --git a/gitnexus-web/src/lib/research-to-3d.ts b/gitnexus-web/src/lib/research-to-3d.ts
