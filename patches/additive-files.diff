+/**
+ * ClusterTooltip — popup rendered when a cluster halo is clicked on the
+ * augmented graph canvas. Shows the cluster's title, source badge
+ * (declared vs auto), `expectedBy` hint when present, the synthesized
+ * status pill, the aggregate completion %, and the list of member
+ * ghosts (each clickable so the parent can re-open the GhostTooltip on
+ * that specific ghost).
+ *
+ * Section F / Task 10 of
+ * docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ */
+
+export type ClusterMember = {
+  id: string;
+  title?: string;
+  status?: 'planned' | 'materialized' | 'cancelled';
+};
+
+export type ClusterTooltipData = {
+  id: string;
+  source: 'declared' | 'auto';
+  title: string;
+  expectedBy?: string | null;
+  synthesizedStatus: 'planned' | 'shipped' | 'cancelled' | 'expired';
+  memberIds: string[];
+  aggregate: {
+    total: number;
+    materialized: number;
+    planned: number;
+    expired: number;
+    cancelled: number;
+    completionPct: number;
+  };
+};
+
+type Props = {
+  cluster: ClusterTooltipData;
+  /** Optional resolver: cluster carries memberIds; if the caller can
+   *  resolve them to { title, status } it provides this map so the
+   *  list renders with friendly titles instead of opaque ids. */
+  members?: Record<string, ClusterMember>;
+  onClose: () => void;
+  onMemberClick?: (ghostId: string) => void;
+};
+
+const STATUS_PALETTE: Record<ClusterTooltipData['synthesizedStatus'], string> = {
+  shipped: 'bg-emerald-500/20 text-emerald-300',
+  planned: 'bg-sky-500/20 text-sky-300',
+  cancelled: 'bg-zinc-500/20 text-zinc-300',
+  expired: 'bg-rose-500/20 text-rose-300',
+};
+
+export default function ClusterTooltip({
+  cluster,
+  members,
+  onClose,
+  onMemberClick,
+}: Props) {
+  const sourceBadgeClass =
+    cluster.source === 'declared'
+      ? 'bg-accent/20 text-accent'
+      : 'bg-amber-500/20 text-amber-300';
+  const statusClass = STATUS_PALETTE[cluster.synthesizedStatus] ?? STATUS_PALETTE.planned;
+  const completion = cluster.aggregate.completionPct;
+
+  return (
+    <div
+      className="cluster-tooltip pointer-events-auto absolute top-16 left-4 z-30 w-96 animate-fade-in rounded-lg border border-border-subtle bg-elevated/95 p-4 shadow-lg backdrop-blur-sm"
+      data-testid="cluster-tooltip"
+    >
+      <header className="mb-2 flex items-start gap-2">
+        <span
+          className={`badge source rounded px-2 py-0.5 text-[11px] font-mono ${sourceBadgeClass}`}
+          data-testid="cluster-source-badge"
+        >
+          {cluster.source}
+        </span>
+        <h3 className="flex-1 text-sm font-semibold text-text-primary">{cluster.title}</h3>
+        <button
+          onClick={onClose}
+          aria-label="close"
+          className="rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+        >
+          ×
+        </button>
+      </header>
+
+      <div className="mb-3 flex flex-wrap items-center gap-2">
+        <span
+          className={`badge status rounded px-2 py-0.5 text-[11px] font-mono ${statusClass}`}
+          data-testid="cluster-status-badge"
+        >
+          {cluster.synthesizedStatus}
+        </span>
+        {cluster.expectedBy && (
+          <span
+            className="text-[11px] text-text-secondary"
+            data-testid="cluster-expected-by"
+            title="Declared target date"
+          >
+            expectedBy {cluster.expectedBy}
+          </span>
+        )}
+        <span
+          className="ml-auto text-[11px] font-mono text-text-secondary"
+          data-testid="cluster-completion"
+        >
+          {completion.toFixed(0)}% complete
+        </span>
+      </div>
+
+      <div className="mb-2 h-1.5 w-full overflow-hidden rounded bg-border-subtle/40">
+        <div
+          className="h-full bg-emerald-400/70"
+          style={{ width: `${Math.max(0, Math.min(100, completion))}%` }}
+          data-testid="cluster-completion-bar"
+        />
+      </div>
+
+      <p className="mb-2 text-[11px] text-text-muted">
+        {cluster.aggregate.materialized}/{cluster.aggregate.total} matérialisés
+        {cluster.aggregate.expired > 0 ? ` · ${cluster.aggregate.expired} expired` : ''}
+        {cluster.aggregate.cancelled > 0 ? ` · ${cluster.aggregate.cancelled} cancelled` : ''}
+      </p>
+
+      <h4 className="mb-1 text-[11px] font-medium tracking-wide text-text-muted uppercase">
+        Members ({cluster.memberIds.length})
+      </h4>
+      <ul className="space-y-1" data-testid="cluster-member-list">
+        {cluster.memberIds.map((mid) => {
+          const m = members?.[mid];
+          const label = m?.title ?? mid;
+          const status = m?.status;
+          const statusGlyph =
+            status === 'materialized' ? '✓' : status === 'cancelled' ? '✕' : '·';
+          const statusColor =
+            status === 'materialized'
+              ? 'text-emerald-400'
+              : status === 'cancelled'
+                ? 'text-zinc-500'
+                : 'text-sky-300';
+          return (
+            <li key={mid}>
+              <button
+                type="button"
+                onClick={() => onMemberClick?.(mid)}
+                className="flex w-full items-center gap-2 rounded px-1 py-0.5 text-left text-xs text-text-secondary transition-colors hover:bg-hover hover:text-text-primary"
+                data-testid={`cluster-member-${mid}`}
+              >
+                <span className={`font-mono ${statusColor}`}>{statusGlyph}</span>
+                <span className="truncate">{label}</span>
+              </button>
+            </li>
+          );
+        })}
+      </ul>
+    </div>
+  );
+}
diff --git a/gitnexus-web/src/components/CouplingPanel.tsx b/gitnexus-web/src/components/CouplingPanel.tsx
