@@ -0,0 +1,78 @@
+/**
+ * TimelineScrubber — Task 10.5.
+ *
+ * A horizontal range slider that lets the user scrub through the snapshot
+ * timeline for a given graph. Fetches the available timestamps from
+ * TimelineReplay and calls onTimestampChange whenever the slider moves.
+ *
+ * Props:
+ *   graph              — name of the graph to load timestamps for
+ *   onTimestampChange  — called with the selected timestamp string
+ */
+
+import { useEffect, useState } from 'react';
+import { TimelineReplay } from '@/services/TimelineReplay';
+
+interface TimelineScrubberProps {
+  graph: string;
+  onTimestampChange: (ts: string) => void;
+}
+
+export function TimelineScrubber({ graph, onTimestampChange }: TimelineScrubberProps) {
+  const [timestamps, setTimestamps] = useState<string[]>([]);
+  const [idx, setIdx] = useState(0);
+  const [error, setError] = useState<string | null>(null);
+
+  useEffect(() => {
+    setTimestamps([]);
+    setIdx(0);
+    setError(null);
+    new TimelineReplay()
+      .listSnapshots(graph)
+      .then((snaps) => {
+        setTimestamps(snaps);
+        if (snaps.length > 0) onTimestampChange(snaps[0]);
+      })
+      .catch((err: unknown) => {
+        const msg = err instanceof Error ? err.message : String(err);
+        setError(msg);
+      });
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [graph]);
+
+  if (error) {
+    return (
+      <div className="p-2 text-xs text-red-400" title={error}>
+        Timeline unavailable
+      </div>
+    );
+  }
+
+  if (timestamps.length === 0) {
+    return <div className="p-2 text-xs text-slate-400">No timeline data</div>;
+  }
+
+  return (
+    <div className="flex items-center gap-3 p-2 bg-slate-800" data-testid="timeline-scrubber">
+      <span className="text-xs text-slate-400 shrink-0">
+        {timestamps[0]?.slice(0, 10) ?? ''}
+      </span>
+      <input
+        type="range"
+        min={0}
+        max={timestamps.length - 1}
+        value={idx}
+        onChange={(e) => {
+          const i = parseInt(e.target.value, 10);
+          setIdx(i);
+          onTimestampChange(timestamps[i]);
+        }}
+        className="flex-1 accent-indigo-400"
+        aria-label="Timeline scrubber"
+      />
+      <span className="text-xs font-mono text-slate-200 shrink-0 w-40 text-right">
+        {timestamps[idx]}
+      </span>
+    </div>
+  );
+}
