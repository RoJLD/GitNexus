+
+// Foundational ratio: fraction of node ids present in every snapshot
+// from start to live. We use snapshot meta.json node counts as a proxy
+// when we don't have the full id list — that's a much cheaper signal
+// than running /lifespan and good enough for a 5-dim identity vector.
+// If only 1 timeline point exists, returns null (caller fills with 0).
+async function foundationalRatioCheap(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return null;
+    return null;
+  }
