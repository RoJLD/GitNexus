+/**
+ * MultigraphLoader — fetches gitnexus.config.json and exposes the N graph entries
+ * to the rest of the UI (sidebar, canvas, scrubber).
+ *
+ * Config schema produced by ELYSIUM sigma_gitnexus_config_generator.py.
+ * Spec source : docs/governance/sigils/SIGIL-GITNEXUS-MULTIGRAPH.md (commit 8b5574ba).
+ */
+
+export type PrivacyClass = 'SHARED' | 'PRIVATE-IDENTITY' | 'REGENERABLE';
+
+export interface GraphConfigEntry {
+  name: string;
+  path: string;
+  schema_type: string;
+  parent_schema?: string | null;
+  ttl_snapshot_hours: number;
+  privacy_class: PrivacyClass;
+}
+
+export interface MultigraphConfig {
+  version: string;
+  generated_by?: string;
+  workspace_root?: string;
+  graphs: GraphConfigEntry[];
+}
+
+export interface MultigraphLoaderOptions {
+  configFetcher?: () => Promise<MultigraphConfig>;
+  configPath?: string;
+}
+
+const DEFAULT_CONFIG_PATH = '/gitnexus.config.json';
+
+export class MultigraphLoader {
+  private readonly fetcher: () => Promise<MultigraphConfig>;
+
+  constructor(opts: MultigraphLoaderOptions = {}) {
+    if (opts.configFetcher) {
+      this.fetcher = opts.configFetcher;
+    } else {
+      const path = opts.configPath ?? DEFAULT_CONFIG_PATH;
+      this.fetcher = async () => {
+        const res = await fetch(path);
+        if (!res.ok) {
+          throw new Error(`Config fetch failed: ${res.status}`);
+        }
+        return res.json() as Promise<MultigraphConfig>;
+      };
+    }
+  }
+
+  async listGraphs(): Promise<GraphConfigEntry[]> {
+    const config = await this.fetcher();
+    if (!Array.isArray(config.graphs)) {
+      throw new Error('Invalid config: graphs[] missing or not an array');
+    }
+    return config.graphs;
+  }
+}
