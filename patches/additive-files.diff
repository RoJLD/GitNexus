@@ -0,0 +1,56 @@
+/**
+ * GanttRow — one ghost line in the Gantt chart.
+ *
+ * Left column : truncated title (max 28 chars, ellipsis).
+ * Right column : bar area, translated by `labelWidth`.
+ *
+ * Whole group is clickable — forwards the ghostId to onClick so the
+ * parent panel can drive selection / detail-panel opening.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-gantt-design.md
+ */
+
+import type { GanttRow as GanttRowData } from '../../lib/gantt-layout';
+import GanttBar from './GanttBar';
+
+type Props = {
+  row: GanttRowData;
+  scale: (d: Date) => number;
+  y: number;
+  height: number;
+  labelWidth: number;
+  onClick: (ghostId: string) => void;
+};
+
+const MAX_LABEL_CHARS = 28;
+
+function truncate(s: string): string {
+  return s.length > MAX_LABEL_CHARS ? s.slice(0, MAX_LABEL_CHARS - 2) + '…' : s;
+}
+
+export default function GanttRow({ row, scale, y, height, labelWidth, onClick }: Props) {
+  return (
+    <g
+      className="gantt-row"
+      data-ghost-id={row.ghostId}
+      onClick={() => onClick(row.ghostId)}
+      style={{ cursor: 'pointer' }}
+    >
+      <text x={4} y={y + height / 2 + 4} fontSize={11} fill="#ddd">
+        {truncate(row.title)}
+      </text>
+      <g transform={`translate(${labelWidth}, 0)`}>
+        {row.bars.map((bar, i) => (
+          <GanttBar
+            key={i}
+            bar={bar}
+            scale={scale}
+            y={y + 3}
+            height={height - 6}
+            title={`${row.title} (${row.status})`}
+          />
+        ))}
+      </g>
+    </g>
+  );
+}
diff --git a/gitnexus-web/src/hooks/useTimelineUrlSync.ts b/gitnexus-web/src/hooks/useTimelineUrlSync.ts
new file mode 100644
index 00000000..f405dfe6
--- /dev/null
+++ b/gitnexus-web/src/hooks/useTimelineUrlSync.ts
@@ -0,0 +1,113 @@
+import { useEffect, useRef } from 'react';
+import { useAppState } from './useAppState';
+import { serializeTimelineToParams, parseTimelineParams } from '../lib/timeline-url';
+
+/**
+ * Two-way sync between Timeline state and the URL query string :
+ *   - WRITE : on any change to cursorA/B/zoomWindow/graphMode/temporalFilterMode,
+ *     replaceState the 5 tl* params (resolving cursor dates -> shortHash).
+ *   - READ : one-shot on mount once snapshots are available, parse the URL
+ *     params (resolving shortHash -> date) and apply to state.
+ *
+ * Mounted once in App.tsx. Self-subscribes to useAppState. Produces no UI.
+ * See docs/superpowers/specs/2026-05-28-timeline-url-persistence-design.md
+ */
+export function useTimelineUrlSync(): void {
+  const {
+    projectName,
+    availableRepos,
+    cursorA,
+    cursorB,
+    zoomWindow,
+    graphMode,
+    temporalFilterMode,
+    setCursorA,
+    setCursorB,
+    enterZoom,
+    setGraphMode,
+    setTemporalFilterMode,
+  } = useAppState();
+
+  const baseRepo = projectName ? projectName.split('@')[0] : '';
+  // One-shot: deliberately NOT reset on repo switch. After a switch the URL may
+  // hold stale shortHashes from the previous repo; re-reading them would be
+  // wrong, so we let the WRITE effect overwrite with the new repo's state.
+  const readDone = useRef(false);
+  // enterZoom() reads cursorA/B from state, which the READ effect has only just
+  // scheduled via setCursorA/B (not flushed yet). Defer the zoom until a later
+  // render where both cursors are populated.
+  const pendingZoom = useRef(false);
+
+  const dateToShortHash = (date: string | null): string | null => {
+    if (!date) return null;
+    const repo = availableRepos.find((r) => r.name === baseRepo);
+    const snap = repo?.snapshots?.find((s) => s.commit?.date === date);
+    if (snap) return snap.commit?.shortHash || null;
+    if (repo?.indexedAt === date) return 'live';
+    return null;
+  };
+
+  const shortHashToDate = (sh: string | null): string | null => {
+    if (!sh) return null;
+    const repo = availableRepos.find((r) => r.name === baseRepo);
+    if (sh === 'live') return repo?.indexedAt || null;
+    const snap = repo?.snapshots?.find((s) => s.commit?.shortHash === sh);
+    return snap?.commit?.date || null;
+  };
+
+  // READ (one-shot, after snapshots load)
+  useEffect(() => {
+    if (readDone.current) return;
+    const repo = availableRepos.find((r) => r.name === baseRepo);
+    if (!repo || !repo.snapshots?.length) return; // wait for snapshots
+
+    const params = new URLSearchParams(window.location.search);
+    const hasAny =
+      params.has('tlA') ||
+      params.has('tlB') ||
+      params.has('tlZoom') ||
+      params.has('tlMode') ||
+      params.has('tlFilter');
+    if (!hasAny) {
+      readDone.current = true; // nothing to restore, unblock the write effect
+      return;
+    }
+
+    const parsed = parseTimelineParams(params);
+    const dateA = shortHashToDate(parsed.cursorAShortHash);
+    const dateB = shortHashToDate(parsed.cursorBShortHash);
+    if (dateA) setCursorA(dateA);
+    if (dateB) setCursorB(dateB);
+    if (parsed.filterMode !== 'off') setTemporalFilterMode(parsed.filterMode);
+    if (parsed.graphMode === 'diff') setGraphMode('diff');
+    if (parsed.zoom && dateA && dateB) pendingZoom.current = true;
+    readDone.current = true;
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [availableRepos, baseRepo]);
+
+  // Deferred zoom restore: fire enterZoom once both cursors have actually
+  // landed in state (the READ effect only schedules them).
+  useEffect(() => {
+    if (pendingZoom.current && cursorA !== null && cursorB !== null) {
+      pendingZoom.current = false;
+      enterZoom();
+    }
+  }, [cursorA, cursorB, enterZoom]);
+
+  // WRITE (on any state change, only after read is done)
+  useEffect(() => {
+    if (!readDone.current) return; // don't clobber a shared link before reading it
+    const { set, remove } = serializeTimelineToParams({
+      cursorAShortHash: dateToShortHash(cursorA),
+      cursorBShortHash: dateToShortHash(cursorB),
+      zoom: zoomWindow !== null,
+      graphMode,
+      filterMode: temporalFilterMode,
+    });
+    const urlObj = new URL(window.location.href);
+    for (const [k, v] of Object.entries(set)) urlObj.searchParams.set(k, v);
+    for (const k of remove) urlObj.searchParams.delete(k);
+    window.history.replaceState(null, '', urlObj.toString());
+    // eslint-disable-next-line react-hooks/exhaustive-deps
+  }, [cursorA, cursorB, zoomWindow, graphMode, temporalFilterMode, availableRepos, baseRepo]);
+}
diff --git a/gitnexus-web/src/lib/adjacency-matrix.ts b/gitnexus-web/src/lib/adjacency-matrix.ts
new file mode 100644
index 00000000..16dd509f
--- /dev/null
+++ b/gitnexus-web/src/lib/adjacency-matrix.ts
@@ -0,0 +1,31 @@
+export type MatrixOrder = 'community' | 'degree' | 'input';
+export interface MatrixNodeMetric { community: number; degree: number }
+
+const byId = (a: string, b: string) => (a < b ? -1 : a > b ? 1 : 0);
+
+/** Order node ids for the matrix. community → grouped by community asc then id; degree → desc then id;
+ *  input (or no metrics) → as given. Deterministic, non-mutating. */
+export function orderNodes(ids: string[], metricsById: Map<string, MatrixNodeMetric> | undefined, mode: MatrixOrder): string[] {
+  const arr = [...ids];
+  if (!metricsById || mode === 'input') return arr;
+  if (mode === 'community') {
+    return arr.sort((a, b) => ((metricsById.get(a)?.community ?? -1) - (metricsById.get(b)?.community ?? -1)) || byId(a, b));
+  }
+  return arr.sort((a, b) => ((metricsById.get(b)?.degree ?? 0) - (metricsById.get(a)?.degree ?? 0)) || byId(a, b));
+}
+
+/** Occupancy set of "row,col" index strings (UNDIRECTED — both (i,j) and (j,i); self-loops + danglers dropped). */
+export function matrixCells(orderedIds: string[], edges: { source: string; target: string }[]): Set<string> {
+  const idx = new Map<string, number>();
+  orderedIds.forEach((id, i) => idx.set(id, i));
+  const cells = new Set<string>();
+  for (const e of edges || []) {
+    if (!e) continue;
+    const i = idx.get(e.source);
+    const j = idx.get(e.target);
+    if (i === undefined || j === undefined || i === j) continue;
+    cells.add(`${i},${j}`);
+    cells.add(`${j},${i}`);
+  }
+  return cells;
+}
diff --git a/gitnexus-web/src/lib/augmented-timeline.ts b/gitnexus-web/src/lib/augmented-timeline.ts
new file mode 100644
index 00000000..e05156f0
--- /dev/null
+++ b/gitnexus-web/src/lib/augmented-timeline.ts
@@ -0,0 +1,122 @@
+/**
+ * Pure functions for the Augmented Timeline (Roadmap-predictive Tier 3.x).
+ * Reused across `GraphCanvas` (cursor → effective ghost set) and the
+ * Play animation cross-fade loop. No I/O, no Sigma deps.
+ *
+ * See docs/superpowers/specs/2026-05-27-roadmap-predictive-augmented-timeline-design.md
+ */
+
+import type { GhostInput } from './ghost-layout';
+
+/**
+ * One slot of the per-snapshot ghost cache: the snapshot's commit
+ * shortHash, its ISO commit date, and the ghosts that existed at that
+ * point in time. Built by `services/snapshot-ghosts-cache.ts`.
+ */
+export type SnapshotGhosts = {
+  sha: string;
+  date: string;
+  ghosts: GhostInput[];
+};
+
+/**
+ * Closest-prior lookup. Given a cursor time and the per-snapshot cache,
+ * returns the ghost set of the snapshot whose commit date is the
+ * greatest date ≤ cursorTime. In `lock-to-head` mode returns the
+ * `liveGhosts` argument unchanged — that's the "today" view, no
+ * time-aware behavior.
+ *
+ * Returns `[]` when the cache is empty or the cursor predates every
+ * snapshot (no closest-prior to land on).
+ */
+export function selectGhostsAt(
+  cache: Map<string, SnapshotGhosts>,
+  cursorTime: Date,
+  mode: 'time-aware' | 'lock-to-head',
+  liveGhosts: GhostInput[],
+): GhostInput[] {
+  if (mode === 'lock-to-head') return liveGhosts;
+  if (cache.size === 0) return [];
+  const cursorMs = cursorTime.getTime();
+  let best: SnapshotGhosts | null = null;
+  let bestMs = -Infinity;
+  for (const snap of cache.values()) {
+    const d = Date.parse(snap.date);
+    if (!Number.isFinite(d)) continue;
+    if (d > cursorMs) continue;
+    if (d > bestMs) {
+      best = snap;
+      bestMs = d;
+    }
+  }
+  return best?.ghosts ?? [];
+}
+
+/**
+ * Window-of-time transition detector. For the Play animation: returns
+ * the ghosts that crossed the `materialized` or `cancelled` threshold
+ * between `prevTime` and `nextTime` (i.e. their event date is in the
+ * half-open window `(prev, next]`). Used to trigger cross-fade
+ * transitions in `useSigma.startGhostCrossFade`.
+ *
+ * Walks the union of every ghost ever seen across all cached
+ * snapshots, deduped by id — a ghost that's materialized in snapshot
+ * 12 still appears in the cache (as `status: 'materialized'`), we
+ * detect the transition by inspecting its `materializedAt.date`.
+ */
+export function computeTransitions(
+  cache: Map<string, SnapshotGhosts>,
+  prevTime: Date,
+  nextTime: Date,
+): { materializing: string[]; cancelling: string[] } {
+  const materializing: string[] = [];
+  const cancelling: string[] = [];
+  const prev = prevTime.getTime();
+  const next = nextTime.getTime();
+  const seen = new Set<string>();
+  for (const snap of cache.values()) {
+    for (const g of snap.ghosts) {
+      if (seen.has(g.id)) continue;
+      seen.add(g.id);
+      // `materializedAt` and `cancelledAt` live on the `GhostRuntime`
+      // shape (`services/ghosts-client.ts`); `GhostInput` is the
+      // narrow flavor consumed by `ghost-layout`, but the snapshot
+      // ghosts cache hands us the full runtime payload merged in.
+      // We read defensively via `any` because the runtime shape is
+      // optional on `GhostInput`.
+      const matAt =
+        (g as unknown as { materializedAt?: { date?: string } | null }).materializedAt?.date;
+      const canAt =
+        (g as unknown as { cancelledAt?: { date?: string } | null }).cancelledAt?.date;
+      if (matAt) {
+        const t = Date.parse(matAt);
+        if (Number.isFinite(t) && t > prev && t <= next) materializing.push(g.id);
+      }
+      if (canAt) {
+        const t = Date.parse(canAt);
+        if (Number.isFinite(t) && t > prev && t <= next) cancelling.push(g.id);
+      }
+    }
+  }
+  return { materializing, cancelling };
+}
+
+/**
+ * Resolve the active "Augmented Timeline" mode for a given cursor /
+ * head pair. Three rules :
+ *  1. If the user pinned `lockGhostsToHead`, stay live (today's ghosts).
+ *  2. Else if the cursor is within `skewToleranceMs` (default 60 s) of
+ *     HEAD, treat as live — sub-minute drift is noise, not "history".
+ *  3. Else time-aware (cursor is genuinely in the past).
+ */
+export function resolveAugmentedTimelineMode(opts: {
+  cursor: Date;
+  head: Date;
+  lockGhostsToHead: boolean;
+  skewToleranceMs?: number;
+}): 'live' | 'time-aware' {
+  if (opts.lockGhostsToHead) return 'live';
+  const skew = opts.skewToleranceMs ?? 60_000;
+  if (Math.abs(opts.cursor.getTime() - opts.head.getTime()) < skew) return 'live';
+  return 'time-aware';
+}
diff --git a/gitnexus-web/src/lib/cluster-layout.ts b/gitnexus-web/src/lib/cluster-layout.ts
new file mode 100644
index 00000000..9a7bffb3
--- /dev/null
+++ b/gitnexus-web/src/lib/cluster-layout.ts
@@ -0,0 +1,242 @@
+/**
+ * Pure layout helpers for the Ghost Cluster surfaces.
+ *
+ * - Augmented graph overlay: convex-hull polygon halos around cluster
+ *   members, drawn as an SVG layer on top of the Sigma canvas.
+ * - Gantt panel: swimlane assignment (one row per cluster, sorted by
+ *   earliest plannedAt; an "Unclustered" lane at the bottom for ghosts
+ *   that belong to no cluster).
+ *
+ * All functions are pure: no DOM, no fetch, no module-level state.
+ * Tested in tests/unit/cluster-layout.test.mjs.
+ *
+ * See docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ * and docs/superpowers/plans/2026-05-27-roadmap-predictive-ghost-cluster.md
+ * (Tasks 8-9, Sections D-E).
+ */
+
+export type Point = { x: number; y: number };
+
+/**
+ * Andrew's monotone chain convex hull (O(n log n)).
+ *
+ * Returns the hull vertices in counter-clockwise order, with no
+ * duplicated start/end point. Returns a shallow clone of the input
+ * when there are 0 or 1 points (degenerate hull). Duplicate input
+ * points are collapsed implicitly by the cross-product check.
+ */
+export function convexHull(points: Point[]): Point[] {
+  if (!Array.isArray(points)) return [];
+  if (points.length <= 1) return points.map((p) => ({ x: p.x, y: p.y }));
+  // Sort lexicographically (x asc, then y asc).
+  const sorted = [...points].sort((a, b) => a.x - b.x || a.y - b.y);
+  const cross = (O: Point, A: Point, B: Point) =>
+    (A.x - O.x) * (B.y - O.y) - (A.y - O.y) * (B.x - O.x);
+
+  // Lower hull
+  const lower: Point[] = [];
+  for (const p of sorted) {
+    while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) {
+      lower.pop();
+    }
+    lower.push(p);
+  }
+  // Upper hull
+  const upper: Point[] = [];
+  for (let i = sorted.length - 1; i >= 0; i--) {
+    const p = sorted[i];
+    while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) {
+      upper.pop();
+    }
+    upper.push(p);
+  }
+  // Concatenate lower + upper, dropping the duplicated endpoints.
+  upper.pop();
+  lower.pop();
+  return [...lower, ...upper];
+}
+
+/**
+ * Returns the polygon to draw for a cluster halo.
+ *
+ * - `null` when there are 0 or 1 member positions (caller represents
+ *   the cluster as a circle around the single member, or skips render
+ *   if empty).
+ * - 2-point line when there are exactly 2 members (caller can render
+ *   as a thin pill / capsule).
+ * - Convex hull (>= 3 vertices) otherwise.
+ */
+export function clusterHullPolygon(memberPositions: Point[]): Point[] | null {
+  if (!Array.isArray(memberPositions) || memberPositions.length === 0) return null;
+  if (memberPositions.length === 1) return null;
+  if (memberPositions.length === 2) {
+    return [
+      { x: memberPositions[0].x, y: memberPositions[0].y },
+      { x: memberPositions[1].x, y: memberPositions[1].y },
+    ];
+  }
+  const hull = convexHull(memberPositions);
+  // After de-duplication, the hull may collapse to <3 vertices when
+  // all input points are collinear or coincident — fall back to the
+  // 2-point pill (or null for a singleton).
+  if (hull.length <= 1) return null;
+  if (hull.length === 2) return hull;
+  return hull;
+}
+
+/**
+ * Polygon centroid via the standard signed-area formula. Best suited
+ * to label placement on a convex hull. Degrades gracefully:
+ *
+ * - Empty polygon → `{ x: 0, y: 0 }` (caller should not render).
+ * - Single point → that point.
+ * - Two-point segment → midpoint.
+ * - Polygon with zero signed area (collinear) → arithmetic mean of
+ *   the vertices, which is still a sensible label anchor.
+ */
+export function polygonCentroid(polygon: Point[]): Point {
+  if (!Array.isArray(polygon) || polygon.length === 0) return { x: 0, y: 0 };
+  if (polygon.length === 1) return { x: polygon[0].x, y: polygon[0].y };
+  if (polygon.length === 2) {
+    return {
+      x: (polygon[0].x + polygon[1].x) / 2,
+      y: (polygon[0].y + polygon[1].y) / 2,
+    };
+  }
+  let area = 0;
+  let cx = 0;
+  let cy = 0;
+  const n = polygon.length;
+  for (let i = 0; i < n; i++) {
+    const p1 = polygon[i];
+    const p2 = polygon[(i + 1) % n];
+    const cross = p1.x * p2.y - p2.x * p1.y;
+    area += cross;
+    cx += (p1.x + p2.x) * cross;
+    cy += (p1.y + p2.y) * cross;
+  }
+  area /= 2;
+  if (area === 0) {
+    // Degenerate / collinear polygon — arithmetic mean of vertices.
+    let mx = 0;
+    let my = 0;
+    for (const p of polygon) {
+      mx += p.x;
+      my += p.y;
+    }
+    return { x: mx / n, y: my / n };
+  }
+  return { x: cx / (6 * area), y: cy / (6 * area) };
+}
+
+/**
+ * Gantt swimlane assignment.
+ *
+ * Inputs:
+ * - `rows`: pre-computed Gantt rows, each carrying at least an `id`
+ *   (the ghost id) and a `plannedAt` timestamp (string ISO or null).
+ *   Other fields are passed through untouched.
+ * - `clusters`: cluster objects with `{ id, title, memberIds[] }`.
+ *
+ * Output: ordered `{ lane, rows }` list. Clusters are sorted by the
+ * smallest `plannedAt` among their members (ascending). Ghosts that
+ * belong to no cluster land in a final "Unclustered" lane. A ghost
+ * present in N clusters is duplicated N times (one row per lane); a
+ * ghost simultaneously declared and auto-clustered will still appear
+ * in both lanes — the UI deduplicates labels, not data.
+ */
+export function assignSwimlanes(
+  rows: any[],
+  clusters: any[],
+): { lane: string; rows: any[] }[] {
+  if (!Array.isArray(rows)) rows = [];
+  if (!Array.isArray(clusters)) clusters = [];
+  const rowById = new Map<string, any>();
+  for (const r of rows) {
+    if (r && typeof r.id === 'string') rowById.set(r.id, r);
+  }
+
+  const memberSet = new Set<string>();
+  const clusterLanes: { lane: string; rows: any[]; sortKey: number }[] = [];
+
+  for (const c of clusters) {
+    if (!c || !Array.isArray(c.memberIds)) continue;
+    const laneRows: any[] = [];
+    let minPlanned = Number.POSITIVE_INFINITY;
+    for (const mid of c.memberIds) {
+      const r = rowById.get(mid);
+      if (!r) continue;
+      laneRows.push(r);
+      memberSet.add(mid);
+      const t = parsePlannedAt(r);
+      if (t !== null && t < minPlanned) minPlanned = t;
+    }
+    if (laneRows.length === 0) continue;
+    clusterLanes.push({
+      lane: c.title || c.id || 'cluster',
+      rows: laneRows,
+      // Clusters whose members have no plannedAt sort last among
+      // declared clusters, before the Unclustered lane.
+      sortKey: Number.isFinite(minPlanned) ? minPlanned : Number.POSITIVE_INFINITY,
+    });
+  }
+
+  // Stable sort: clusters by earliest plannedAt ascending; ties keep
+  // insertion order, which matches the declared-then-auto ordering
+  // produced upstream.
+  clusterLanes.sort((a, b) => a.sortKey - b.sortKey);
+
+  const unclustered: any[] = [];
+  for (const r of rows) {
+    if (!r || typeof r.id !== 'string') continue;
+    if (!memberSet.has(r.id)) unclustered.push(r);
+  }
+
+  const out: { lane: string; rows: any[] }[] = clusterLanes.map(({ lane, rows }) => ({ lane, rows }));
+  if (unclustered.length > 0) out.push({ lane: 'Unclustered', rows: unclustered });
+  return out;
+}
+
+function parsePlannedAt(row: any): number | null {
+  if (!row) return null;
+  const raw = row.plannedAt;
+  if (raw == null) return null;
+  if (typeof raw === 'number') return Number.isFinite(raw) ? raw : null;
+  if (typeof raw === 'string') {
+    const t = Date.parse(raw);
+    return Number.isFinite(t) ? t : null;
+  }
+  if (typeof raw === 'object' && typeof raw.date === 'string') {
+    const t = Date.parse(raw.date);
+    return Number.isFinite(t) ? t : null;
+  }
+  return null;
+}
+
+/**
+ * Point-in-polygon test via ray casting.
+ *
+ * Used by GraphCanvas to detect clicks on a cluster halo: project the
+ * pointer to canvas coordinates, then test against each cluster's
+ * polygon. Edge cases:
+ * - Polygons with < 3 vertices return `false` (a 1- or 2-vertex shape
+ *   has no interior — caller does hit-testing on the bounding circle
+ *   / pill, not on this polygon).
+ * - Vertices on the boundary may flip-flop; the caller is expected to
+ *   tolerate a 1-pixel epsilon in canvas space.
+ */
+export function pointInPolygon(p: Point, polygon: Point[]): boolean {
+  if (!p || !Array.isArray(polygon) || polygon.length < 3) return false;
+  let inside = false;
+  for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
+    const xi = polygon[i].x;
+    const yi = polygon[i].y;
+    const xj = polygon[j].x;
+    const yj = polygon[j].y;
+    const intersect =
+      yi > p.y !== yj > p.y &&
+      p.x < ((xj - xi) * (p.y - yi)) / (yj - yi + 0) + xi;
+    if (intersect) inside = !inside;
+  }
+  return inside;
+}
diff --git a/gitnexus-web/src/lib/gantt-layout.ts b/gitnexus-web/src/lib/gantt-layout.ts
new file mode 100644
index 00000000..325a5c48
--- /dev/null
+++ b/gitnexus-web/src/lib/gantt-layout.ts
@@ -0,0 +1,156 @@
+/**
+ * Pure functions for the Gantt panel.
+ * Reads ghost runtime objects (from /ghosts), emits SVG-ready layout data.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-gantt-design.md
+ *
+ * Reuses tierColor / parseTargetDate / computeGhostVisualState from the
+ * Augmented graph module (`./ghost-layout`) — Update 1 wires time-decaying
+ * bar coloring through that shared engine.
+ */
+
+import { parseTargetDate, tierColor, computeGhostVisualState } from './ghost-layout';
+
+export { parseTargetDate, tierColor };
+
+const DAY = 86_400_000;
+
+export type GhostInput = {
+  plannedAt: { date: string } | null;
+  materializedAt: { date: string } | null;
+  cancelledAt: { date: string } | null;
+  declared: { plannedFor: string | null; tier?: string | null; title?: string; expectedBy?: string | null };
+  id?: string;
+};
+
+export function computeTimeWindow(ghosts: GhostInput[], opts: { now?: Date } = {}): { start: Date; end: Date } {
+  const now = opts.now ?? new Date();
+  const times: number[] = [];
+  for (const g of ghosts) {
+    if (g.plannedAt) times.push(new Date(g.plannedAt.date).getTime());
+    if (g.materializedAt) times.push(new Date(g.materializedAt.date).getTime());
+    if (g.cancelledAt) times.push(new Date(g.cancelledAt.date).getTime());
+    if (g.declared?.plannedFor) {
+      const t = parseTargetDate(g.declared.plannedFor);
+      if (t) times.push(t.getTime());
+    }
+  }
+  if (times.length === 0) {
+    return { start: new Date(now.getTime() - 30 * DAY), end: new Date(now.getTime() + 30 * DAY) };
+  }
+  const minT = Math.min(...times);
+  const maxT = Math.max(...times, now.getTime() + 90 * DAY);
+  return { start: new Date(minT - 7 * DAY), end: new Date(maxT) };
+}
+
+export type GanttBar = {
+  kind: 'solid' | 'dashed' | 'dot' | 'grey';
+  startDate: string;
+  endDate: string | null;
+  color: string;
+};
+
+export type GanttRow = {
+  ghostId: string;
+  title: string;
+  tier: string | null;
+  status: 'planned' | 'materialized' | 'cancelled';
+  bars: GanttBar[];
+};
+
+function derivedStatus(g: GhostInput): 'planned' | 'materialized' | 'cancelled' {
+  if (g.cancelledAt) return 'cancelled';
+  if (g.materializedAt) return 'materialized';
+  return 'planned';
+}
+
+/**
+ * Update 1 — time-decaying bar color.
+ *
+ * Reuses the visual-state engine shipped by the Augmented graph
+ * (`computeGhostVisualState` in `./ghost-layout`). For the Gantt the
+ * dashed bar's "expectation date" is the ghost's `plannedFor` (the
+ * planning-horizon target), so we synthesise a `GhostVisualInput` where
+ * `expectedBy = plannedFor ?? expectedBy` and forward to the engine.
+ *
+ * Returns:
+ *   - '#e67e22' (orange) when the engine reports `late`,
+ *   - '#c0392b' (red)    when it reports `critical`,
+ *   - tier color otherwise (fresh / mature / fallback).
+ *
+ * Cancelled ghosts never hit this path (handled by the grey-bar branch
+ * in `computeGanttRows`), but the engine still short-circuits to grey
+ * if it ever does.
+ */
+export function pickBarColor(ghost: GhostInput, now: Date): string {
+  const tier = ghost.declared?.tier ?? null;
+  const expectedBy = ghost.declared?.plannedFor ?? ghost.declared?.expectedBy ?? null;
+  const state = computeGhostVisualState(
+    {
+      tier,
+      status: 'planned',
+      plannedAt: ghost.plannedAt ?? null,
+      declared: { expectedBy },
+    },
+    now,
+  );
+  if (state.alertLevel === 'late') return '#e67e22';
+  if (state.alertLevel === 'critical') return '#c0392b';
+  return tierColor(tier);
+}
+
+export function computeGanttRows(ghosts: GhostInput[], opts: { now?: Date } = {}): GanttRow[] {
+  const now = opts.now ?? new Date();
+  const rows: GanttRow[] = [];
+
+  for (const g of ghosts) {
+    const status = derivedStatus(g);
+    const tier = g.declared?.tier ?? null;
+    const color = tierColor(tier);
+    const startDate = g.plannedAt?.date ?? null;
+    const bars: GanttBar[] = [];
+
+    if (status === 'materialized' && startDate) {
+      bars.push({ kind: 'solid', startDate, endDate: g.materializedAt!.date, color });
+    } else if (status === 'cancelled' && startDate) {
+      bars.push({ kind: 'grey', startDate, endDate: g.cancelledAt!.date, color: '#888' });
+    } else if (status === 'planned' && startDate) {
+      const target = parseTargetDate(g.declared?.plannedFor ?? null);
+      if (target) {
+        const startD = new Date(startDate);
+        const startMs = Math.max(startD.getTime(), now.getTime());
+        // Update 1 — time-decaying bar color : reuse computeGhostVisualState.
+        const dashColor = pickBarColor(g, now);
+        bars.push({ kind: 'dashed', startDate: new Date(startMs).toISOString(), endDate: target.toISOString(), color: dashColor });
+      } else {
+        bars.push({ kind: 'dot', startDate, endDate: null, color });
+      }
+    }
+
+    if (bars.length === 0) continue; // skip ghosts without plannedAt - pas representables
+
+    rows.push({
+      ghostId: g.id ?? g.declared?.title ?? 'unknown',
+      title: g.declared?.title ?? g.id ?? '(no title)',
+      tier,
+      status,
+      bars,
+    });
+  }
+
+  // Sort by plannedAt ASC, then by id for tie-break.
+  rows.sort((a, b) => {
+    const aDate = a.bars[0].startDate.localeCompare(b.bars[0].startDate);
+    if (aDate !== 0) return aDate;
+    return a.ghostId.localeCompare(b.ghostId);
+  });
+
+  return rows;
+}
+
+export function dateScale(window: { start: Date; end: Date }, width: number): (d: Date) => number {
+  const startMs = window.start.getTime();
+  const span = window.end.getTime() - startMs;
+  if (span <= 0) return () => 0;
+  return (d: Date) => ((d.getTime() - startMs) / span) * width;
+}
diff --git a/gitnexus-web/src/lib/ghost-layout.ts b/gitnexus-web/src/lib/ghost-layout.ts
new file mode 100644
index 00000000..f6158f93
--- /dev/null
+++ b/gitnexus-web/src/lib/ghost-layout.ts
@@ -0,0 +1,252 @@
+/**
+ * Pure functions for placing ghost nodes on the Sigma canvas.
+ * Reused from frontend only — no I/O, no Sigma deps.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-augmented-graph-design.md
+ */
+
+export type ExpectedLink = { kind: 'path' | 'label'; value: string };
+
+export type GhostInput = {
+  id: string;
+  title: string;
+  tier: string | null;
+  status: 'planned' | 'materialized' | 'cancelled';
+  expectedLinks: ExpectedLink[];
+};
+
+export type ExistingNode = { id: string; x: number; y: number };
+
+export type GhostLayoutNode = {
+  id: string;             // prefixed with "ghost:" to avoid collision
+  ghostId: string;        // original ghost id
+  x: number;
+  y: number;
+  tier: string | null;
+  status: GhostInput['status'];
+  title: string;
+  anchored: boolean;
+};
+
+export type GhostLayoutEdge = {
+  source: string;
+  target: string;
+  tier: string | null;
+};
+
+function pathToRegex(pattern: string): RegExp {
+  let re = '';
+  for (let i = 0; i < pattern.length; i++) {
+    const c = pattern[i];
+    if (c === '*' && pattern[i + 1] === '*') { re += '.*'; i++; }
+    else if (c === '*') { re += '[^/]*'; }
+    else if (c === '?') { re += '[^/]'; }
+    else if (/[.+^${}()|[\]\\]/.test(c)) { re += '\\' + c; }
+    else { re += c; }
+  }
+  return new RegExp(re + '$');
+}
+
+export function matchExistingNodes(links: ExpectedLink[], nodeIds: string[]): string[] {
+  const out = new Set<string>();
+  for (const link of links) {
+    if (link.kind !== 'path') continue;
+    const hasWildcard = /[*?]/.test(link.value);
+    if (hasWildcard) {
+      const re = pathToRegex(link.value);
+      for (const id of nodeIds) if (re.test(id)) out.add(id);
+    } else {
+      for (const id of nodeIds) {
+        if (id.endsWith(link.value) || id.includes('/' + link.value)) out.add(id);
+      }
+    }
+  }
+  return [...out];
+}
+
+export function computeGhostLayout(
+  ghosts: GhostInput[],
+  existing: ExistingNode[],
+  options: { canvasBounds?: { xMax: number; yMin: number }; satelliteCols?: number } = {},
+): { ghostNodes: GhostLayoutNode[]; ghostEdges: GhostLayoutEdge[] } {
+  const xMax = options.canvasBounds?.xMax ?? 100;
+  const yMin = options.canvasBounds?.yMin ?? -50;
+  const cols = options.satelliteCols ?? 5;
+  const colWidth = 5;
+  const rowHeight = 5;
+
+  const ghostNodes: GhostLayoutNode[] = [];
+  const ghostEdges: GhostLayoutEdge[] = [];
+  const nodeById = new Map(existing.map(n => [n.id, n]));
+  let satelliteIndex = 0;
+
+  for (const g of ghosts) {
+    if (g.status === 'materialized') continue; // doublon avec real node
+    const matched = matchExistingNodes(g.expectedLinks, existing.map(n => n.id));
+    const ghostNodeId = `ghost:${g.id}`;
+    if (matched.length > 0) {
+      const xs = matched.map(id => nodeById.get(id)!.x);
+      const ys = matched.map(id => nodeById.get(id)!.y);
+      const x = xs.reduce((a, b) => a + b, 0) / xs.length;
+      const y = ys.reduce((a, b) => a + b, 0) / ys.length;
+      ghostNodes.push({ id: ghostNodeId, ghostId: g.id, x, y, tier: g.tier, status: g.status, title: g.title, anchored: true });
+      for (const matchedId of matched) {
+        ghostEdges.push({ source: ghostNodeId, target: matchedId, tier: g.tier });
+      }
+    } else {
+      const col = satelliteIndex % cols;
+      const row = Math.floor(satelliteIndex / cols);
+      ghostNodes.push({
+        id: ghostNodeId,
+        ghostId: g.id,
+        x: xMax - (cols - col) * colWidth,
+        y: yMin + row * rowHeight,
+        tier: g.tier,
+        status: g.status,
+        title: g.title,
+        anchored: false,
+      });
+      satelliteIndex += 1;
+    }
+  }
+  return { ghostNodes, ghostEdges };
+}
+
+const TIER_COLORS: Record<string, string> = {
+  '1': '#5b9bd5',  // bleu
+  '2': '#e1aa55',  // ambre
+  '3': '#9b59b6',  // violet
+};
+
+export function tierColor(tier: string | null): string {
+  if (!tier) return '#6d6d6d';
+  const major = String(tier).split('.')[0];
+  return TIER_COLORS[major] ?? '#6d6d6d';
+}
+
+/**
+ * Update 1 — time-decaying opacity for ghost nodes.
+ *
+ * Parses an ISO date (YYYY-MM-DD or full ISO timestamp), a quarter
+ * (YYYY-Qx where x ∈ 1..4), or a year-month (YYYY-MM).
+ * Returns null if the input is missing or unrecognised.
+ */
+export function parseTargetDate(value: string | null | undefined): Date | null {
+  if (!value || typeof value !== 'string') return null;
+  const s = value.trim();
+  if (!s) return null;
+  // YYYY-Qx form
+  const quarterMatch = s.match(/^(\d{4})-Q([1-4])$/i);
+  if (quarterMatch) {
+    const year = Number(quarterMatch[1]);
+    const q = Number(quarterMatch[2]);
+    // End of quarter: month = q*3 (1..12), day = last day of that month.
+    const endMonth = q * 3; // 3, 6, 9, 12
+    // Date constructor month is 0-indexed; day 0 of next month = last day of current month.
+    return new Date(Date.UTC(year, endMonth, 0, 23, 59, 59));
+  }
+  // YYYY-MM form
+  const monthMatch = s.match(/^(\d{4})-(\d{2})$/);
+  if (monthMatch) {
+    const year = Number(monthMatch[1]);
+    const month = Number(monthMatch[2]);
+    if (month < 1 || month > 12) return null;
+    return new Date(Date.UTC(year, month, 0, 23, 59, 59));
+  }
+  // Fallback: native Date parsing (ISO date / timestamp).
+  const t = Date.parse(s);
+  if (Number.isNaN(t)) return null;
+  return new Date(t);
+}
+
+export type GhostAlertLevel = 'fresh' | 'mature' | 'late' | 'critical' | 'cancelled';
+
+export type GhostVisualState = {
+  opacity: number;
+  outlineColor: string;
+  alertLevel: GhostAlertLevel;
+};
+
+export type GhostVisualInput = {
+  tier?: string | null;
+  status?: 'planned' | 'materialized' | 'cancelled' | string | null;
+  plannedAt?: { date?: string | null } | null;
+  declared?: { expectedBy?: string | null } | null;
+};
+
+/**
+ * Computes the visual state of a ghost node based on how much of its
+ * planned->expectedBy window has elapsed at `now`. The further past the
+ * expected date, the more opaque and alarming the outline.
+ *
+ * See spec : docs/superpowers/specs/2026-05-26-roadmap-predictive-augmented-graph-design.md
+ * (Update 1 — time-decaying opacity).
+ */
+export function computeGhostVisualState(ghost: GhostVisualInput, now: Date): GhostVisualState {
+  if (ghost.status === 'cancelled') {
+    return { opacity: 0.3, outlineColor: '#6d6d6d', alertLevel: 'cancelled' };
+  }
+  const tc = tierColor(ghost.tier ?? null);
+  const planned = ghost.plannedAt?.date ? new Date(ghost.plannedAt.date) : null;
+  const expectedBy = parseTargetDate(ghost.declared?.expectedBy);
+  if (!planned || Number.isNaN(planned.getTime()) || !expectedBy) {
+    return { opacity: 0.4, outlineColor: tc, alertLevel: 'fresh' };
+  }
+  const totalMs = expectedBy.getTime() - planned.getTime();
+  const elapsedMs = now.getTime() - planned.getTime();
+  const ratio = totalMs > 0 ? elapsedMs / totalMs : 1;
+  if (ratio < 0.5) return { opacity: 0.5, outlineColor: tc, alertLevel: 'fresh' };
+  if (ratio < 1.0) return { opacity: 0.4, outlineColor: tc, alertLevel: 'mature' };
+  if (ratio < 1.5) return { opacity: 0.3, outlineColor: '#e67e22', alertLevel: 'late' };
+  return { opacity: 0.2, outlineColor: '#c0392b', alertLevel: 'critical' };
+}
+
+/* ═══════════════════════════════════════════════════════════════
+ * Filter + status helpers (Section C / Task 7)
+ *
+ * These mirror the CORE's derivedStatus rule so the frontend never
+ * has to round-trip to the backend just to know whether a ghost is
+ * "planned", "materialized" or "cancelled". `passesFilter` is the
+ * single gate consumed by `applyGhostLayer` in useSigma.
+ * ═══════════════════════════════════════════════════════════════ */
+
+export type GhostFilters = {
+  showGhosts: boolean;
+  /** Which major tiers ("1", "2", "3") are visible. Tier "1.4" matches "1". */
+  tiers: string[];
+  showCancelled: boolean;
+};
+
+export const DEFAULT_GHOST_FILTERS: GhostFilters = {
+  showGhosts: false,
+  tiers: ['1', '2', '3'],
+  showCancelled: false,
+};
+
+/**
+ * Mirrors the CORE's derivedStatus rule : cancelled > materialized > planned.
+ * Accepts the runtime shape (the full ghost) or a minimal object with the
+ * two timestamps. Returns `'planned'` when neither has fired.
+ */
+export function derivedStatus(g: {
+  materializedAt?: unknown;
+  cancelledAt?: unknown;
+}): 'planned' | 'materialized' | 'cancelled' {
+  if (g.cancelledAt) return 'cancelled';
+  if (g.materializedAt) return 'materialized';
+  return 'planned';
+}
+
+/**
+ * Returns true when the ghost should be drawn on the canvas under
+ * the current filter state. Used by `applyGhostLayer` to gate
+ * insertion into the graph.
+ */
+export function passesFilter(ghost: GhostInput, f: GhostFilters): boolean {
+  if (!f.showGhosts) return false;
+  // Materialized ghosts are doublons of real nodes — never draw them.
+  if (ghost.status === 'materialized') return false;
+  if (ghost.status === 'cancelled' && !f.showCancelled) return false;
+  if (ghost.tier && !f.tiers.includes(String(ghost.tier).split('.')[0])) return false;
+  return true;
+}
diff --git a/gitnexus-web/src/lib/ghost-node-program.ts b/gitnexus-web/src/lib/ghost-node-program.ts
new file mode 100644
index 00000000..9301c0bd
--- /dev/null
+++ b/gitnexus-web/src/lib/ghost-node-program.ts
@@ -0,0 +1,99 @@
+/**
+ * Custom Sigma node program for ghost nodes : dashed circular outline.
+ *
+ * Sigma 3.x ships `NodeCircleProgram` from `sigma/rendering`. Its WebGL
+ * fragment-shader override mechanism has shifted between minor versions
+ * and is not stable across the 3.0.x line we depend on (see plan note in
+ * docs/superpowers/plans/2026-05-26-roadmap-predictive-augmented-graph.md
+ * — "If the shader path is risky, use the fallback CSS approach").
+ *
+ * The chosen approach therefore is the documented fallback:
+ *
+ *   1. Register `GhostNodeProgram` as a thin extension of
+ *      `NodeCircleProgram` so Sigma routes ghost nodes through our class
+ *      — this gives us a stable type-discriminator (`type: 'ghost'`).
+ *   2. The dashed outline + alpha decay is then expressed via the
+ *      node attributes (`color` with embedded RGBA, `size`) and a
+ *      canvas-side overlay drawn in the parent component (see useSigma's
+ *      `applyGhostLayer` + `defaultDrawNodeHover`-style helper).
+ *
+ * If Sigma upstream stabilises a fragment-shader override hook in 3.1+
+ * we can switch back to the GLSL approach (see plan Task 5 step 2 for
+ * the original shader source).
+ */
+
+// Sigma 3.x exposes the canvas circle program at this stable public path.
+// Both the WebGL and the canvas variants accept the same constructor
+// signature; we extend the canvas one because (a) the ghost layer is
+// rendered with low frequency (refresh on filter change, not per-frame)
+// and (b) the WebGL fragment-shader override is not stable across 3.0.x
+// (see header).
+import { NodeCircleProgram } from 'sigma/rendering';
+import type { NodeDisplayData } from 'sigma/types';
+
+/**
+ * Visual constants — kept here so they can be tweaked without touching
+ * the consumer (`useSigma`). These mirror the design spec defaults.
+ */
+export const GHOST_DASH_SEGMENTS = 8;
+export const GHOST_DEFAULT_OUTLINE = '#7f8c8d';
+export const GHOST_FILL_ALPHA = 0.4;
+
+/**
+ * Extension of Sigma's `NodeCircleProgram` that flags ghost nodes for
+ * the renderer. The dashed look is achieved by the consumer drawing a
+ * dashed `arc` overlay on top of the base circle — keeping the program
+ * itself a no-op makes us robust to Sigma 3.x minor-version drift.
+ *
+ * Consumers register it via:
+ *
+ *   nodeProgramClasses: { ghost: GhostNodeProgram }
+ */
+export class GhostNodeProgram extends NodeCircleProgram {
+  // Tag the class so we can sanity-check at runtime if needed.
+  static readonly NODE_TYPE = 'ghost';
+}
+
+/**
+ * Helper invoked by the consumer (`useSigma`) to draw the dashed
+ * outline + reduced-opacity fill of a ghost node on the 2D overlay
+ * canvas. Pure function — no Sigma deps — so it stays test-friendly.
+ *
+ * `data` is the node-display data Sigma already projected to screen
+ * coordinates. `outlineColor` and `opacity` come from
+ * `computeGhostVisualState` in `ghost-layout.ts` (Update 1 — time
+ * decay).
+ */
+export function drawGhostNode(
+  ctx: CanvasRenderingContext2D,
+  data: NodeDisplayData & { ghostStatus?: string; ghostOutline?: string; ghostOpacity?: number },
+): void {
+  const radius = data.size ?? 6;
+  const x = data.x;
+  const y = data.y;
+  const outlineColor = data.ghostOutline ?? GHOST_DEFAULT_OUTLINE;
+  const fillAlpha = data.ghostOpacity ?? GHOST_FILL_ALPHA;
+
+  // Fill (semi-transparent disk in the node's base color).
+  ctx.save();
+  ctx.globalAlpha = fillAlpha;
+  ctx.fillStyle = data.color || outlineColor;
+  ctx.beginPath();
+  ctx.arc(x, y, radius, 0, Math.PI * 2);
+  ctx.fill();
+  ctx.restore();
+
+  // Dashed outline (8-segment stipple around the circle).
+  ctx.save();
+  ctx.strokeStyle = outlineColor;
+  ctx.lineWidth = 1.5;
+  // Compute dash length so we get GHOST_DASH_SEGMENTS dashes around
+  // the circumference, with equal gaps between them.
+  const circumference = 2 * Math.PI * radius;
+  const dashLen = circumference / (GHOST_DASH_SEGMENTS * 2);
+  ctx.setLineDash([dashLen, dashLen]);
+  ctx.beginPath();
+  ctx.arc(x, y, radius, 0, Math.PI * 2);
+  ctx.stroke();
+  ctx.restore();
+}
