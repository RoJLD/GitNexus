+  let authorsRepo = new Map();
+  let busFactorRepo = 0;
+  let topAuthorShare = 0;
+  let lastCommitMs = null;
+  let perBucketActivity = new Set();
+  let filesTouched = 0;
+  let perFileTouches = new Map();
+  let gitError = null;
+
+  if (hasGit) {
+    try {
+      const log = await runCmd('git', [
+        '-C',
+        repoPath,
+        'log',
+        '--pretty=format:%an%x09%aI',
+        '--name-only',
+        '--no-merges',
+      ]);
+      const parsed = parseLogForRepo(log, COUPLING_BUCKET_HOURS * 3600 * 1000);
+      authorsRepo = parsed.authors;
+      perBucketActivity = parsed.perBucketActivity;
+      lastCommitMs = parsed.lastCommitDate;
+      filesTouched = parsed.filesTouched;
+      perFileTouches = parsed.perFileTouches;
+      const bf = busFactor(authorsRepo);
+      busFactorRepo = bf.bf;
+      topAuthorShare = bf.topShare;
+    } catch (err) {
+      gitError = err.message;
+    }
+  }
+
+  const authorsCount = authorsRepo.size;
+  const busFactorNorm = authorsCount > 0 ? busFactorRepo / authorsCount : 0;
+
+  const foundationalRatio = (await foundationalRatioCheap(repoName)) ?? 0;
+
+  // v2 dims (Tier 2.5c) — computed in parallel where independent.
+  const [growthRate, fileWalk] = await Promise.all([
+    growthRateFromSnapshots(repoName),
+    walkRepoFiles(repoPath),
+  ]);
+  const churnConcentration = perFileTouches.size > 0 ? gini([...perFileTouches.values()]) : 0;
+  const fileSizePareto = fileWalk.length > 0 ? gini(fileWalk.map((f) => f.size)) : 0;
+  // languageDiversity: Shannon entropy over file extensions (only files
+  // that have an extension — extensionless ones like Makefile / LICENSE
+  // are noise here).
+  const extCounts = new Map();
+  for (const f of fileWalk) {
+    if (!f.ext) continue;
+    extCounts.set(f.ext, (extCounts.get(f.ext) || 0) + 1);
+  }
+  const languageDiversity = normalizedShannon([...extCounts.values()]);
+  // treeDepth: normalized median depth. We squash median into [0, 1]
+  // via 1 - exp(-d/4) so depth 0 = 0, depth 4 ≈ 0.63, depth 10 ≈ 0.92.
+  // Captures "deep nested" vs "flat" without exploding the dim.
+  const medDepth = median(fileWalk.map((f) => f.depth));
+  const treeDepth = 1 - Math.exp(-medDepth / 4);
+
+  const identityVector = {
+    density,
+    modularity,
+    busFactorNorm,
+    topAuthorShare,
+    foundationalRatio,
+    growthRate,
+    churnConcentration,
+    fileSizePareto,
+    languageDiversity,
+    treeDepth,
+  };
+
+  const policy = await readPolicy(repoPath);
+  const license = await readLicense(repoPath);
+  const semanticData = await readSemanticLabels(repoPath);
+  const labelBow = bowVectorFromLabels(semanticData.labels);
+  // Per-repo: do we trust embeddings? Yes if ≥80% of labels are
+  // embedded. Below that, we'd be averaging a non-representative
+  // sample; lexical BoW is the safer choice for that pair.
+  const embeddingCoverage = semanticData.labels.length > 0
+    ? semanticData.embeddings.length / semanticData.labels.length
+    : 0;
+  const labelCentroid = embeddingCoverage >= 0.8 ? centroid(semanticData.embeddings) : null;
+
+  return {
+    name: repoName,
+    repoPath,
+    hasGit: !!hasGit,
+    gitError,
+    identityVector,
+    rawStats: {
+      nodes: Number(stats?.nodes) || 0,
+      edges: Number(stats?.edges) || 0,
+      communities: Number(stats?.communities) || 0,
+      authorsCount,
+      busFactor: busFactorRepo,
+    },
+    authorsSet: new Set(authorsRepo.keys()),
+    perBucketActivity,
+    lastCommitMs,
+    license,
+    policy,
+    semanticLabelsCount: semanticData.labels.length,
+    semanticEmbeddingsCount: semanticData.embeddings.length,
+    labelBow,
+    labelCentroid,
+  };
+}
+
+function cosineSimilarity(va, vb, dims) {
+  let dot = 0;
+  let na = 0;
+  let nb = 0;
+  for (const k of dims) {
+    const x = Number(va[k]) || 0;
+    const y = Number(vb[k]) || 0;
+    dot += x * y;
+    na += x * x;
+    nb += y * y;
+  }
+  if (na === 0 || nb === 0) return 0;
+  return dot / (Math.sqrt(na) * Math.sqrt(nb));
+}
+
+function dominantFeatures(va, vb, dims) {
+  const diffs = dims.map((k) => ({
+    dim: k,
+    delta: Math.abs((Number(va[k]) || 0) - (Number(vb[k]) || 0)),
+  }));
+  diffs.sort((x, y) => y.delta - x.delta);
+  return diffs.slice(0, 2).map((d) => d.dim);
+}
+
+function temporalJaccard(bucketsA, bucketsB, windowMs, sinceMs) {
+  // Restrict to recent window. sinceMs = epoch ms cutoff.
+  const sinceBucket = Math.floor(sinceMs / windowMs);
+  const a = new Set([...bucketsA].filter((b) => b >= sinceBucket));
+  const b = new Set([...bucketsB].filter((bk) => bk >= sinceBucket));
+  if (a.size === 0 && b.size === 0) return 0;
+  let inter = 0;
+  for (const bk of a) if (b.has(bk)) inter++;
+  const union = a.size + b.size - inter;
+  return union > 0 ? inter / union : 0;
+}
+
+function quadrantLabel(highS, highSem, highT, semanticAxisPresent) {
+  if (!semanticAxisPresent) {
+    // Collapse to 2D plane.
+    if (highS && highT) return 'Patterns + collision';
+    if (highS && !highT) return 'Patterns partagés';
+    if (!highS && highT) return 'Couplage caché';
+    return 'Indépendants';
+  }
+  if (highS && highSem && highT) return 'Jumeaux actifs';
+  if (highS && highSem && !highT) return 'Jumeaux isolés';
+  if (highS && !highSem && highT) return 'Patterns + collision';
+  if (highS && !highSem && !highT) return 'Patterns partagés';
+  if (!highS && highSem && highT) return 'Collision réelle';
+  if (!highS && highSem && !highT) return 'Domaines parallèles';
+  if (!highS && !highSem && highT) return 'Couplage caché';
+  return 'Indépendants';
+}
+
+function recommendationFor(quadrant) {
+  switch (quadrant) {
+    case 'Jumeaux actifs': return 'Extraire en lib partagée';
+    case 'Jumeaux isolés': return 'Suspect — vérifier .gitnexus-policy.json';
+    case 'Jumeaux (isolation intentionnelle)': return 'OK — isolation requise par policy';
+    case 'Patterns + collision': return 'Standardiser outillage';
+    case 'Patterns partagés': return 'Standardiser (sans urgence)';
+    case 'Collision réelle': return 'Orchestrer via API Gateway';
+    case 'Domaines parallèles': return 'Surveiller, pas d\'action';
+    case 'Couplage caché': return 'Découpler';
+    case 'Indépendants': return 'Aucune action';
+    default: return null;
+  }
+}
+
+function pairWarnings(repoA, repoB) {
+  const warnings = [];
+  // LICENSE divergence: both present and different.
+  if (repoA.license && repoB.license && repoA.license !== repoB.license) {
+    warnings.push('LICENSE files diverge');
+  }
+  // Stale repo: > 6mo since last commit.
+  const now = Date.now();
+  const stale = (r) => r.lastCommitMs && (now - r.lastCommitMs) / (24 * 3600 * 1000) > STALE_REPO_DAYS;
+  if (stale(repoA)) warnings.push(`Last commit on ${repoA.name} > ${STALE_REPO_DAYS}d`);
+  if (stale(repoB)) warnings.push(`Last commit on ${repoB.name} > ${STALE_REPO_DAYS}d`);
+  // Distinct author sets: zero overlap.
+  if (repoA.authorsSet.size > 0 && repoB.authorsSet.size > 0) {
+    let overlap = 0;
+    for (const a of repoA.authorsSet) if (repoB.authorsSet.has(a)) { overlap++; break; }
+    if (overlap === 0) warnings.push('Distinct author sets');
+  }
+  return warnings;
+}
+
+function applyPolicy(repoA, repoB, quadrant) {
+  const isolationA = repoA.policy?.isolation_required;
+  const isolationB = repoB.policy?.isolation_required;
+  if (!isolationA && !isolationB) return { quadrant, policyApplied: null };
+  // Check whitelist: does either side explicitly allow merging with the other?
+  const allowsAB = isolationA && repoA.policy.allow_merge_with?.includes(repoB.name);
+  const allowsBA = isolationB && repoB.policy.allow_merge_with?.includes(repoA.name);
+  if (allowsAB && allowsBA) return { quadrant, policyApplied: { whitelisted: true } };
+  // For "Jumeaux" quadrants, rewrite to the intentional-isolation variant.
+  if (quadrant === 'Jumeaux actifs' || quadrant === 'Jumeaux isolés') {
+    const reasons = [];
+    if (isolationA) reasons.push(`${repoA.name}: ${repoA.policy.reason || 'isolation_required'}`);
+    if (isolationB) reasons.push(`${repoB.name}: ${repoB.policy.reason || 'isolation_required'}`);
+    return {
+      quadrant: 'Jumeaux (isolation intentionnelle)',
+      policyApplied: { isolationRequired: true, reasons },
+    };
+  }
+  // For other quadrants, just attach the policy info without rewriting.
+  return {
+    quadrant,
+    policyApplied: {
+      isolationRequired: true,
+      reasons: [
+        ...(isolationA ? [`${repoA.name}: ${repoA.policy.reason || 'isolation_required'}`] : []),
+        ...(isolationB ? [`${repoB.name}: ${repoB.policy.reason || 'isolation_required'}`] : []),
+      ],
+    },
+  };
+}
+
+async function handleSimilarity(url, res, opts) {
+  const reposParam = url.searchParams.get('repos');
+  if (!reposParam) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repos (comma-separated)' }));
+    return;
+  }
+  const repoNames = reposParam
+    .split(',')
+    .map((s) => s.trim())
+    .filter(Boolean)
+    .filter((s) => !s.includes('@'))
+    .slice(0, MAX_REPOS);
+  if (repoNames.length < 2) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'need at least 2 distinct repos' }));
+    return;
+  }
+
+  const windowDays = Math.max(1, Math.min(3650, Number(url.searchParams.get('windowDays')) || DEFAULT_WINDOW_DAYS));
+  const structuralThreshold = clampUnit(Number(url.searchParams.get('structuralThreshold')) || DEFAULT_STRUCTURAL);
+  const semanticThreshold = clampUnit(Number(url.searchParams.get('semanticThreshold')) || DEFAULT_SEMANTIC);
+  const temporalThreshold = clampUnit(Number(url.searchParams.get('temporalThreshold')) || DEFAULT_TEMPORAL);
+  const lexicalSemantic = (url.searchParams.get('lexicalSemantic') ?? 'true').toLowerCase() !== 'false';
+  const identityVersion = (() => {
+    const v = Number(url.searchParams.get('identityVersion'));
+    return v === 1 || v === 2 ? v : DEFAULT_IDENTITY_VERSION;
+  })();
+  const dims = identityVersion === 2 ? IDENTITY_DIMS_V2 : IDENTITY_DIMS_V1;
+
+  // Build per-repo snapshots in parallel — git log is the slowest step
+  // and they're independent.
+  const snapshots = await Promise.all(repoNames.map((name) => buildRepoSnapshot(name, opts.api)));
+  for (let i = 0; i < snapshots.length; i++) {
+    if (snapshots[i].error) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: snapshots[i].error }));
+      return;
+    }
+  }
+
+  const windowMs = COUPLING_BUCKET_HOURS * 3600 * 1000;
+  const sinceMs = Date.now() - windowDays * 24 * 3600 * 1000;
+
+  const pairs = [];
+  for (let i = 0; i < snapshots.length; i++) {
+    for (let j = i + 1; j < snapshots.length; j++) {
+      const a = snapshots[i];
+      const b = snapshots[j];
+      const structural = cosineSimilarity(a.identityVector, b.identityVector, dims);
+      const temporal = temporalJaccard(a.perBucketActivity, b.perBucketActivity, windowMs, sinceMs);
+      // Semantic axis priority (Tier 2.5b.bis):
+      //   1. If both repos have a label centroid (≥80% of labels
+      //      embedded) → dense cosine on the centroids = true
+      //      embedding-based semantic similarity.
+      //   2. Else if both have BoW labels → lexical cosine fallback
+      //      (Tier 2.5b).
+      //   3. Else null (4-quadrant collapse for this pair).
+      // The ?lexicalSemantic=false flag disables both options.
+      let semantic = null;
+      let pairSemanticMode = 'none';
+      if (lexicalSemantic) {
+        if (a.labelCentroid && b.labelCentroid &&
+            a.labelCentroid.length === b.labelCentroid.length) {
+          semantic = cosineDense(a.labelCentroid, b.labelCentroid);
+          pairSemanticMode = 'embeddings';
+        } else if (a.labelBow.size > 0 && b.labelBow.size > 0) {
+          semantic = cosineBow(a.labelBow, b.labelBow);
+          pairSemanticMode = 'lexical';
+        }
+      }
+      const semanticAxisPresent = semantic !== null;
+
+      const highS = structural >= structuralThreshold;
+      const highSem = semantic !== null && semantic >= semanticThreshold;
+      const highT = temporal >= temporalThreshold;
+
+      let quadrant = quadrantLabel(highS, highSem, highT, semanticAxisPresent);
+      const policyOutcome = applyPolicy(a, b, quadrant);
+      quadrant = policyOutcome.quadrant;
+
+      const recommendation = recommendationFor(quadrant);
+      const warnings = pairWarnings(a, b);
+      const dominant = dominantFeatures(a.identityVector, b.identityVector, dims);
+
+      pairs.push({
+        a: a.name,
+        b: b.name,
+        structuralScore: roundN(structural, 4),
+        semanticScore: semantic === null ? null : roundN(semantic, 4),
+        semanticMode: pairSemanticMode,
+        temporalCoupling: roundN(temporal, 4),
+        quadrant,
+        recommendation,
+        warnings,
+        dominantFeatures: dominant,
+        policyApplied: policyOutcome.policyApplied,
+      });
+    }
+  }
+
+  // Slice the identity vector to the selected version's dims. v1
+  // callers should not see the v2 dims even if they're computed.
+  const sliceVec = (v) => Object.fromEntries(dims.map((k) => [k, Number(v[k]) || 0]));
+  const repos = snapshots.map((s) => ({
+    name: s.name,
+    identityVector: roundVector(sliceVec(s.identityVector), 4),
+    stats: s.rawStats,
+    hasGit: s.hasGit,
+    gitError: s.gitError,
+    licensePresent: !!s.license,
+    policy: s.policy,
+    lastCommitDate: s.lastCommitMs ? new Date(s.lastCommitMs).toISOString() : null,
+    semanticLabelsCount: s.semanticLabelsCount,
+    semanticEmbeddingsCount: s.semanticEmbeddingsCount,
+    hasLabelCentroid: !!s.labelCentroid,
+  }));
+
+  // Semantic axis is "available" if at least one pair could use it.
+  // The frontend uses this to decide whether to render the pending
+  // banner (no labels anywhere) vs the partial-coverage hint (some
+  // pairs have it, others don't).
+  const reposWithLabels = repos.filter((r) => r.semanticLabelsCount > 0).length;
+  const reposWithCentroid = repos.filter((r) => r.hasLabelCentroid).length;
+  const semanticAxisAvailable = lexicalSemantic && reposWithLabels >= 2;
+  // Overall mode: 'embeddings' if every pair uses embeddings, 'lexical'
+  // if at least one pair uses BoW, 'disabled' otherwise. The per-pair
+  // mode (pair.semanticMode) is the source of truth for mixed cases.
+  const pairModes = new Set(pairs.map((p) => p.semanticMode));
+  const semanticAxisMode = !lexicalSemantic
+    ? 'disabled'
+    : pairModes.has('embeddings') && !pairModes.has('lexical')
+      ? 'embeddings'
+      : pairModes.has('lexical') || pairModes.has('embeddings')
+        ? 'lexical' // mixed counts as lexical for the headline label
+        : 'disabled';
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      repos,
+      pairs,
+      thresholds: {
+        structural: structuralThreshold,
+        semantic: semanticThreshold,
+        temporal: temporalThreshold,
+      },
+      windowDays,
+      identityVersion,
+      identityDims: dims,
+      semanticAxisAvailable,
+      semanticAxisMode,
+      reposWithLabels,
+      reposWithCentroid,
+      semanticAxisNote: !lexicalSemantic
+        ? 'Semantic axis disabled via ?lexicalSemantic=false.'
+        : semanticAxisMode === 'embeddings'
+          ? `Semantic axis: dense cosine on label embedding centroids (Tier 2.5b.bis). ${reposWithCentroid}/${repos.length} repos embedded.`
+          : `Semantic axis: lexical cosine on cached LLM labels (Tier 2.5b). ${reposWithLabels}/${repos.length} repos labeled, ${reposWithCentroid}/${repos.length} embedded — click "Embed labels" in the panel to upgrade pairs to dense embedding cosine.`,
+    }),
+  );
+}
+
+function clampUnit(n) {
+  if (!Number.isFinite(n)) return 0;
+  if (n < 0) return 0;
+  if (n > 1) return 1;
+  return n;
+}
+
+function roundN(n, digits) {
+  if (!Number.isFinite(n)) return 0;
+  const f = Math.pow(10, digits);
+  return Math.round(n * f) / f;
+}
+
+function roundVector(v, digits) {
+  const out = {};
+  for (const k of Object.keys(v)) out[k] = roundN(v[k], digits);
+  return out;
+}
+
+export async function handleSimilarityRoute(req, url, res, opts) {
+  if (url.pathname === '/similarity' && req.method === 'GET') {
+    await handleSimilarity(url, res, opts);
+    return true;
+  }
+  return false;
+}
