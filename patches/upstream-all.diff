+  // Source of truth for [x, y] depends on the active method.
+  const coordsFor = (r: SimilarityRepo): [number, number] | null => {
+    if (method === 'umap') {
+      return umapCoords?.get(r.name) ?? null;
+    }
+    return r.galaxyXY;
+  };
+
+  const pts = repos
+    .map((r) => {
+      const xy = coordsFor(r);
+      if (!xy) return null;
+      return { name: r.name, x: xy[0], y: xy[1], repo: r };
+    })
+    .filter(Boolean) as { name: string; x: number; y: number; repo: SimilarityRepo }[];
+  if (pts.length === 0 && method === 'umap' && !umapError) {
+    // UMAP still loading — show a placeholder. PCA path always has data.
+  }
+  const xs = pts.map((p) => p.x);
+  const ys = pts.map((p) => p.y);
+  const xMin = Math.min(...xs);
+  const xMax = Math.max(...xs);
+  const yMin = Math.min(...ys);
+  const yMax = Math.max(...ys);
+  // Pad ranges by 5% on each side; avoid division-by-zero by giving
+  // degenerate axes a tiny synthetic range.
+  const xRange = Math.max(xMax - xMin, 1e-6);
+  const yRange = Math.max(yMax - yMin, 1e-6);
