--- /dev/null
+++ b/gitnexus-web/src/lib/layout-cache.ts
@@ -0,0 +1,108 @@
+/**
+ * Layout persistence cache (FA2 positions per snapshot).
+ *
+ * Stores `graphology` node positions in `localStorage` keyed by a stable
+ * `cacheKey` (typically `<repoName>` or `<repoName>@<sha>` for snapshots).
+ *
+ * Used by `useSigma.setGraph` to skip the expensive FA2 + noverlap pass on
+ * revisited snapshots, and by `lib/layout-worker.ts` to pre-compute layouts
+ * in the background during `preloadAllSnapshots`.
+ *
+ * Schema versioned (`gitnexus:layout:v1:<cacheKey>`) so an entry written by
+ * a previous version is silently ignored, not crash-loaded.
+ */
+
+const STORAGE_PREFIX = 'gitnexus:layout:v1:';
+const SCHEMA_VERSION = 1 as const;
+
+export type CachedLayout = {
+  version: typeof SCHEMA_VERSION;
+  cacheKey: string;
+  computedAt: string;
+  nodeCount: number;
+  positions: Record<string, { x: number; y: number }>;
+};
+
+export function saveLayoutPositions(
+  cacheKey: string,
+  positions: Record<string, { x: number; y: number }>,
+): void {
+  if (!cacheKey || typeof window === 'undefined' || !window.localStorage) return;
+  const payload: CachedLayout = {
+    version: SCHEMA_VERSION,
+    cacheKey,
+    computedAt: new Date().toISOString(),
+    nodeCount: Object.keys(positions).length,
+    positions,
+  };
+  try {
+    window.localStorage.setItem(STORAGE_PREFIX + cacheKey, JSON.stringify(payload));
+  } catch (e) {
+    // QuotaExceededError or similar — best-effort, don't crash UI.
+    console.warn('[layout-cache] save failed for', cacheKey, e);
+  }
+}
+
+export function saveLayoutFromGraph(
+  cacheKey: string,
+  // See applyLayoutToGraph — same reason for `any`.
+  graph: any,
+): void {
+  const positions: Record<string, { x: number; y: number }> = {};
+  graph.forEachNode((id: string, attrs: { x?: number; y?: number }) => {
+    if (typeof attrs.x === 'number' && typeof attrs.y === 'number') {
+      positions[id] = { x: attrs.x, y: attrs.y };
+    }
+  });
+  saveLayoutPositions(cacheKey, positions);
+}
+
+export function loadLayout(cacheKey: string): CachedLayout | null {
+  if (!cacheKey || typeof window === 'undefined' || !window.localStorage) return null;
+  const raw = window.localStorage.getItem(STORAGE_PREFIX + cacheKey);
+  if (!raw) return null;
+  try {
+    const parsed = JSON.parse(raw);
+    if (parsed?.version !== SCHEMA_VERSION) return null;
+    if (typeof parsed.cacheKey !== 'string' || !parsed.positions) return null;
+    return parsed as CachedLayout;
+  } catch {
+    return null;
+  }
+}
+
+export function applyLayoutToGraph(
+  cached: CachedLayout,
+  // Structural typing kept loose so a typed Graphology `Graph<X, Y, Z>` passes
+  // without coercion. TS would reject narrower callback signatures otherwise.
+  graph: any,
+): { applied: number; missing: number } {
+  let applied = 0;
+  let missing = 0;
+  graph.forEachNode((id: string) => {
+    const p = cached.positions[id];
+    if (p) {
+      graph.setNodeAttribute(id, 'x', p.x);
+      graph.setNodeAttribute(id, 'y', p.y);
+      applied++;
+    } else {
+      missing++;
+    }
+  });
+  return { applied, missing };
+}
+
+export function clearLayout(cacheKey: string): void {
+  if (typeof window === 'undefined' || !window.localStorage) return;
+  window.localStorage.removeItem(STORAGE_PREFIX + cacheKey);
+}
+
+export function clearAllLayouts(): void {
+  if (typeof window === 'undefined' || !window.localStorage) return;
+  const keys: string[] = [];
+  for (let i = 0; i < window.localStorage.length; i++) {
+    const k = window.localStorage.key(i);
+    if (k?.startsWith(STORAGE_PREFIX)) keys.push(k);
+  }
+  for (const k of keys) window.localStorage.removeItem(k);
+}
diff --git a/gitnexus-web/src/lib/layout-worker-pool.ts b/gitnexus-web/src/lib/layout-worker-pool.ts
new file mode 100644
index 0000000..ceaccda
--- /dev/null
+++ b/gitnexus-web/src/lib/layout-worker-pool.ts
@@ -0,0 +1,114 @@
+/**
+ * Small fixed-size worker pool driving `layout-worker.ts` to pre-compute
+ * FA2 positions for every snapshot during `preloadAllSnapshots`. Results
+ * are persisted to localStorage via `saveLayoutPositions` so subsequent
+ * `useSigma.setGraph(g, { cacheKey })` calls hit the fast path.
+ *
+ * Pool size 2 (CPU-bound, leaves a core for the main thread + the
+ * preload network pool).
+ */
+import Graph from 'graphology';
+import { saveLayoutPositions, loadLayout } from './layout-cache';
+import type { WorkerOutput } from './layout-worker';
+
+export type LayoutPoolJob = {
+  cacheKey: string;
+  graphData: any; // graph.export()
+  iterations?: number;
+};
+
+/**
+ * Build a minimal serialized graph (nodes + edges) suitable for the
+ * worker. FA2 only needs the topology — we strip styling to keep the
+ * postMessage clone small.
+ */
+export function buildWorkerInputFromNodesEdges(
+  nodes: Array<{ id: string }>,
+  edges: Array<{ sourceId: string; targetId: string }>,
+): any {
+  const g = new Graph({ multi: true, allowSelfLoops: true });
+  for (const n of nodes) {
+    if (!g.hasNode(n.id)) g.addNode(n.id);
+  }
+  for (const e of edges) {
+    if (!g.hasNode(e.sourceId) || !g.hasNode(e.targetId)) continue;
+    try {
+      g.addEdge(e.sourceId, e.targetId);
+    } catch {
+      // duplicate / forbidden — skip
+    }
+  }
+  return g.export();
+}
+
+export type LayoutPool = {
+  enqueue: (job: LayoutPoolJob) => void;
+  terminate: () => void;
+};
+
+export function createLayoutWorkerPool(size = 2): LayoutPool {
+  const queue: LayoutPoolJob[] = [];
+  const workers: Worker[] = [];
+  const busy: boolean[] = [];
+  let terminated = false;
+
+  function spawnWorker(idx: number) {
+    const w = new Worker(new URL('./layout-worker.ts', import.meta.url), {
+      type: 'module',
+    });
+    w.onmessage = (e: MessageEvent<WorkerOutput>) => {
+      const { cacheKey, positions, nodeCount } = e.data;
+      if (cacheKey && nodeCount > 0) {
+        saveLayoutPositions(cacheKey, positions);
+      }
+      busy[idx] = false;
+      pump();
+    };
+    w.onerror = (err) => {
+      // eslint-disable-next-line no-console
+      console.warn('[layout-worker-pool] worker error', err);
+      busy[idx] = false;
+      pump();
+    };
+    workers[idx] = w;
+    busy[idx] = false;
+  }
+
+  function pump() {
+    if (terminated) return;
+    for (let i = 0; i < size; i++) {
+      if (!busy[i] && queue.length > 0) {
+        const job = queue.shift();
+        if (!job) break;
+        // Skip if already cached — saves a worker round-trip when the
+        // user re-runs Preload after a partial cancel.
+        if (loadLayout(job.cacheKey)) continue;
+        if (!workers[i]) spawnWorker(i);
+        busy[i] = true;
+        workers[i].postMessage(job);
+      }
+    }
+  }
+
+  function enqueue(job: LayoutPoolJob) {
+    if (terminated) return;
+    queue.push(job);
+    pump();
+  }
+
+  function terminate() {
+    terminated = true;
+    queue.length = 0;
+    for (const w of workers) {
+      try {
+        w?.terminate();
+      } catch {
+        // ignore
+      }
+    }
+    workers.length = 0;
+    busy.length = 0;
+  }
+
+  return { enqueue, terminate };
+}
diff --git a/gitnexus-web/src/lib/layout-worker.ts b/gitnexus-web/src/lib/layout-worker.ts
new file mode 100644
index 0000000..9fb3e02
--- /dev/null
+++ b/gitnexus-web/src/lib/layout-worker.ts
@@ -0,0 +1,65 @@
+/**
+ * Web Worker that runs ForceAtlas2 + light noverlap on a serialized
+ * graphology graph and posts back the converged positions. Driven by
+ * `useAppState.preloadAllSnapshots` so the first Play roadmap after a
+ * preload is near-instant (positions are already in localStorage).
+ *
+ * Imported via Vite as a module Worker:
+ *   new Worker(new URL('../lib/layout-worker.ts', import.meta.url),
+ *     { type: 'module' })
+ */
+import Graph from 'graphology';
+import forceAtlas2 from 'graphology-layout-forceatlas2';
+
+export type WorkerInput = {
+  cacheKey: string;
+  graphData: any; // result of graph.export() — JSON-clonable
+  iterations?: number; // default 200
+};
+
+export type WorkerOutput = {
+  cacheKey: string;
+  positions: Record<string, { x: number; y: number }>;
+  nodeCount: number;
+  durationMs: number;
+};
+
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+(self as any).onmessage = (e: MessageEvent<WorkerInput>) => {
+  const { cacheKey, graphData, iterations = 200 } = e.data;
+  const start =
+    typeof performance !== 'undefined' && typeof performance.now === 'function'
+      ? performance.now()
+      : Date.now();
+  const graph = Graph.from(graphData);
+  if (graph.order === 0) {
+    (self as any).postMessage({
+      cacheKey,
+      positions: {},
+      nodeCount: 0,
+      durationMs: 0,
+    } satisfies WorkerOutput);
+    return;
+  }
+  const settings = forceAtlas2.inferSettings(graph);
+  forceAtlas2.assign(graph, { iterations, settings });
+  // Note: noverlap.assign skipped here (TS overload friction with the generic
+  // Graph.from result). FA2 alone is sufficient for the pre-compute path;
+  // useSigma's runLayout applies noverlap when running in the foreground.
+  const positions: Record<string, { x: number; y: number }> = {};
+  graph.forEachNode((id, attrs) => {
+    if (typeof attrs.x === 'number' && typeof attrs.y === 'number') {
+      positions[id] = { x: attrs.x, y: attrs.y };
+    }
+  });
+  const end =
+    typeof performance !== 'undefined' && typeof performance.now === 'function'
+      ? performance.now()
+      : Date.now();
+  (self as any).postMessage({
+    cacheKey,
+    positions,
+    nodeCount: graph.order,
+    durationMs: end - start,
+  } satisfies WorkerOutput);
+};
