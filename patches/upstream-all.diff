+/**
+ * I/O wrapper + route handlers for the roadmap-predictive CORE.
+ * Imports pure fns from docker-server-ghosts-core.mjs.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-core-design.md
+ */
+import { readFile, writeFile, mkdir, access } from 'node:fs/promises';
+import { execFile } from 'node:child_process';
+import { promisify } from 'node:util';
+import { join } from 'node:path';
+import {
+  parseRoadmap,
+  renderRoadmapYml,
+  computeStatus,
+  parseClusters,
+  deriveAutoClusters,
+  computeClusterStatus,
+} from './docker-server-ghosts-core.mjs';
+import { findRepoByName, safeSnapshotKey, SNAPSHOTS_ROOT } from './docker-server-snapshots.mjs';
+
+const execFileP = promisify(execFile);
+
+// --- Plugin-aware ghost-source registry ---
+//
+// A ghost source is `{ name: string, fetchGhosts: async (repoPath) => GhostInput[] }`.
+// The builtin source (`roadmap-md`) parses ROADMAP.md at the repo root and is
+// always registered at module load. External sources can be added via
+// `registerGhostSource`; their ghosts get merged into `syncGhostsForRepo` /
+// `syncGhostsForSnapshot`, with the builtin winning on `id` conflicts.
+//
+// Spec : docs/superpowers/specs/2026-05-26-roadmap-predictive-core-design.md (Update delta b).
+
+const BUILTIN_GHOST_SOURCE_NAME = 'roadmap-md';
+
+/** @type {Map<string, { name: string, fetchGhosts: Function }>} */
+const ghostSources = new Map();
+
+function assertValidSource(source) {
+  if (!source || typeof source !== 'object') {
+    throw new TypeError('registerGhostSource: source must be an object');
+  }
+  if (typeof source.name !== 'string' || source.name.length === 0) {
+    throw new TypeError('registerGhostSource: source.name must be a non-empty string');
+  }
+  if (typeof source.fetchGhosts !== 'function') {
+    throw new TypeError('registerGhostSource: source.fetchGhosts must be a function returning a Promise');
+  }
+}
+
+/**
+ * Public : register an external ghost source. The builtin source `roadmap-md`
+ * cannot be replaced — calling with that name is a no-op + stderr warning.
+ *
+ * @param {{ name: string, fetchGhosts: (repoPath: string) => Promise<Array> }} source
+ */
+export function registerGhostSource(source) {
+  assertValidSource(source);
+  if (source.name === BUILTIN_GHOST_SOURCE_NAME) {
+    console.warn(
+      `[ghosts] registerGhostSource: cannot replace builtin source "${BUILTIN_GHOST_SOURCE_NAME}" — ignoring`,
+    );
+    return;
+  }
+  ghostSources.set(source.name, { name: source.name, fetchGhosts: source.fetchGhosts });
+}
+
+/**
+ * Public : list registered ghost source names (builtin first, then external
+ * in insertion order). Useful for tests and the future Audit/Plane connector.
+ */
+export function listGhostSources() {
+  return [...ghostSources.keys()];
+}
+
+/**
+ * Test-only : clear non-builtin sources. The builtin always persists.
+ * Use in `beforeEach` / `afterEach` to keep integration tests deterministic.
+ */
+export function _resetGhostSourcesForTests() {
+  for (const name of [...ghostSources.keys()]) {
+    if (name !== BUILTIN_GHOST_SOURCE_NAME) ghostSources.delete(name);
+  }
+  // Defensive : re-register builtin if for some reason it was wiped.
+  if (!ghostSources.has(BUILTIN_GHOST_SOURCE_NAME)) {
+    registerBuiltinGhostSource();
+  }
+}
+
+function registerBuiltinGhostSource() {
+  ghostSources.set(BUILTIN_GHOST_SOURCE_NAME, {
+    name: BUILTIN_GHOST_SOURCE_NAME,
+    fetchGhosts: async (repoPath) => parseRoadmap(await readRoadmapMd(repoPath)),
+  });
+}
+
+// Register the builtin at module load. Must come before any consumer can
+// import this module — that's why this block lives at the top of the file.
+// Idempotency guard : safe against future hot-reload / re-import scenarios.
+if (!ghostSources.has(BUILTIN_GHOST_SOURCE_NAME)) {
+  registerBuiltinGhostSource();
+}
+
+/**
+ * Internal : iterate all registered sources, fetch their declared ghosts and
+ * merge them by `id`. The builtin (`roadmap-md`) wins on id conflicts. Each
+ * surviving ghost gets a `source: <name>` field added so the runtime JSON
+ * can attribute it.
+ *
+ * Returns an array of GhostInput-like objects with an extra `source` field.
+ */
+async function fetchAndMergeDeclaredGhosts(repoPath) {
+  /** @type {Map<string, any>} */
+  const byId = new Map();
+  // Pull builtin first so it gets to claim its ids unconditionally.
+  const orderedSources = [
+    ghostSources.get(BUILTIN_GHOST_SOURCE_NAME),
+    ...[...ghostSources.values()].filter(s => s.name !== BUILTIN_GHOST_SOURCE_NAME),
+  ].filter(Boolean);
+
+  for (const src of orderedSources) {
+    let ghosts;
+    try {
+      ghosts = await src.fetchGhosts(repoPath);
+    } catch (err) {
+      console.warn(`[ghosts] source "${src.name}" threw — ignoring: ${err?.message || err}`);
+      continue;
+    }
+    if (!Array.isArray(ghosts)) continue;
+    for (const g of ghosts) {
+      if (!g || typeof g.id !== 'string') continue;
+      if (src.name === BUILTIN_GHOST_SOURCE_NAME) {
+        // Builtin always wins. Tag it for downstream consumers.
+        byId.set(g.id, { ...g, source: BUILTIN_GHOST_SOURCE_NAME });
+      } else if (!byId.has(g.id)) {
+        // External : add only if not shadowed by builtin (or an earlier external).
+        byId.set(g.id, { ...g, source: src.name });
+      }
+      // else: shadowed, drop silently.
+    }
+  }
+  return [...byId.values()];
+}
+
+// Test-only re-export of the internal merge helper. Lets the unit suite assert
+// the real "builtin-wins / first-non-builtin-wins" semantic without standing
+// up a git repo. Production code MUST NOT import this — call the public sync
+// functions instead.
+export { fetchAndMergeDeclaredGhosts as _fetchAndMergeDeclaredGhostsForTests };
+
+async function fileExists(p) {
+  try { await access(p); return true; } catch { return false; }
+}
+
+async function readRoadmapMd(repoPath) {
+  const path = join(repoPath, 'ROADMAP.md');
+  if (!(await fileExists(path))) return '';
+  return readFile(path, 'utf8');
+}
+
+async function getHeadSha(repoPath) {
+  const { stdout } = await execFileP('git', ['rev-parse', 'HEAD'], { cwd: repoPath });
+  return stdout.trim();
+}
+
+async function getHeadDate(repoPath) {
+  const { stdout } = await execFileP('git', ['log', '-1', '--format=%cI'], { cwd: repoPath });
+  return stdout.trim();
+}
+
+async function getChangedFilesSince(repoPath, fromSha) {
+  if (!fromSha) return [];
+  try {
+    const { stdout } = await execFileP(
+      'git',
+      ['log', '--name-only', '--pretty=format:', `${fromSha}..HEAD`],
+      { cwd: repoPath },
+    );
+    return [...new Set(stdout.split('\n').map(l => l.trim()).filter(Boolean))];
+  } catch {
+    return [];
+  }
+}
+
+/**
+ * Build the runtime ghost objects (declared + plannedAt + materializedAt + links).
+ * Idempotent : a second call with no changes produces the same JSON.
+ */
+async function buildGhosts(repoPath, declaredGhosts, previousRuntime) {
+  const sha = await getHeadSha(repoPath);
+  const date = await getHeadDate(repoPath);
+  const result = [];
+
+  const prevById = new Map((previousRuntime?.ghosts || []).map(g => [g.id, g]));
+
+  for (const declared of declaredGhosts) {
+    const prev = prevById.get(declared.id);
+    const plannedAt = prev?.plannedAt ?? { commit: sha, date };
+
+    let materializedAt = prev?.materializedAt ?? null;
+    let cancelledAt = prev?.cancelledAt ?? null;
+
+    // Declared status (from emoji in ROADMAP) wins.
+    if (declared.status === 'materialized' && !materializedAt) {
+      materializedAt = { commit: sha, date, confirmedBy: 'manual' };
+      cancelledAt = null;
+    }
+    if (declared.status === 'cancelled' && !cancelledAt) {
+      cancelledAt = { commit: sha, date };
+    }
+    if (declared.status === 'planned' && cancelledAt) {
+      cancelledAt = null; // ghost came back after cancellation
+    }
+
+    // Auto-match : if all paths match recently changed files, suggest materialization.
+    if (declared.status === 'planned' && !materializedAt) {
+      const changedFiles = await getChangedFilesSince(repoPath, plannedAt.commit);
+      const computed = computeStatus(declared, { changedFiles });
+      if (computed === 'materialized') {
+        materializedAt = { commit: sha, date, confirmedBy: 'auto' };
+      }
+    }
+
+    result.push({
+      id: declared.id,
+      // Carry the source attribution into the runtime JSON. Falls back to the
+      // builtin when an upstream caller passes a bare GhostInput[] without
+      // attribution (e.g. an older code path).
+      source: declared.source || BUILTIN_GHOST_SOURCE_NAME,
+      declared,
+      plannedAt,
+      materializedAt,
+      cancelledAt,
+      links: materializedAt ? (prev?.links || []) : [],
+    });
+  }
+
+  // Detect cancellations : ghosts in prev that are no longer declared.
+  for (const [id, prev] of prevById) {
+    if (!declaredGhosts.find(d => d.id === id)) {
+      result.push({
+        ...prev,
+        cancelledAt: prev.cancelledAt ?? { commit: sha, date },
+      });
+    }
+  }
+
+  return { syncedAt: date, syncedCommit: sha, ghosts: result };
+}
+
+/**
+ * Internal : build the runtime clusters payload for a sync.
+ *
+ * Combines declared clusters (parsed from ROADMAP.md) with auto-derived
+ * clusters (Union-Find on the dependsOn graph, excluding members already
+ * claimed by a declared cluster), then attaches `computeClusterStatus` output
+ * (aggregate counts + synthesizedStatus + plannedAt/materializedAt) for each.
+ *
+ * Returns `{ syncedAt, syncedCommit, clusters, declaredClusters }` — the last
+ * field is the raw declared list (without member-status enrichment) for the
+ * roadmap.yml renderer that needs only the declared shapes.
+ */
+function buildClusters(md, runtime) {
+  const declaredClusters = parseClusters(md);
+  const claimedIds = new Set(declaredClusters.flatMap(c => c.memberIds));
+  const autoClusters = deriveAutoClusters(runtime.ghosts, claimedIds);
+  const allClusters = [...declaredClusters, ...autoClusters];
+
+  const ghostsById = new Map(runtime.ghosts.map(g => [g.id, g]));
+
+  const clusters = allClusters.map(c => {
+    const members = c.memberIds.map(mid => {
+      const g = ghostsById.get(mid);
+      if (!g) return { id: mid, status: 'planned' };
+      return {
+        id: g.id,
+        status: g.declared.status,
+        plannedAt: g.plannedAt,
+        materializedAt: g.materializedAt,
+        cancelledAt: g.cancelledAt,
+      };
+    });
+    const computed = computeClusterStatus(c, members);
+    return { ...c, ...computed };
+  });
+
+  return {
+    syncedAt: runtime.syncedAt,
+    syncedCommit: runtime.syncedCommit,
+    clusters,
+    declaredClusters,
+  };
+}
+
+/**
+ * Public : sync at HEAD, write roadmap.yml + .gitnexus/ghosts.json +
+ * .gitnexus/clusters.json. Iterates every registered ghost source and merges
+ * them by id (builtin wins).
+ */
+export async function syncGhostsForRepo(repoPath) {
+  const declared = await fetchAndMergeDeclaredGhosts(repoPath);
+
+  let previous = null;
+  const runtimePath = join(repoPath, '.gitnexus', 'ghosts.json');
+  if (await fileExists(runtimePath)) {
+    try { previous = JSON.parse(await readFile(runtimePath, 'utf8')); } catch { /* corrupt = treat as none */ }
+  }
+
+  const runtime = await buildGhosts(repoPath, declared, previous);
+
+  // Parse the markdown once for cluster declarations; renderRoadmapYml then
+  // re-emits them inline in roadmap.yml. parseClusters tolerates missing files.
+  const md = await readRoadmapMd(repoPath);
+  const clusterPayload = buildClusters(md, runtime);
+  const yml = renderRoadmapYml(declared, { clusters: clusterPayload.declaredClusters });
+
+  await writeFile(join(repoPath, 'roadmap.yml'), yml);
+  await mkdir(join(repoPath, '.gitnexus'), { recursive: true });
+  await writeFile(runtimePath, JSON.stringify(runtime, null, 2) + '\n');
+
+  const clustersPath = join(repoPath, '.gitnexus', 'clusters.json');
+  const { declaredClusters: _omitDeclared, ...clustersJson } = clusterPayload;
+  await writeFile(clustersPath, JSON.stringify(clustersJson, null, 2) + '\n');
+
+  return runtime;
+}
+
+/**
+ * Public : sync inside a snapshot's directory. Does NOT touch the latest
+ * ghosts.json or clusters.json. Uses the same registry merge as
+ * `syncGhostsForRepo`.
+ */
+export async function syncGhostsForSnapshot(repoPath, snapshotDir, sha) {
+  const declared = await fetchAndMergeDeclaredGhosts(repoPath);
+
+  // For a historical snapshot, we re-derive from the markdown at this commit.
+  // plannedAt/materializedAt are sealed to this sha if declared-status is
+  // materialized/cancelled.
+  const runtime = await buildGhosts(repoPath, declared, null);
+
+  await mkdir(snapshotDir, { recursive: true });
+  await writeFile(join(snapshotDir, 'ghosts.json'), JSON.stringify(runtime, null, 2) + '\n');
+
+  // Snapshot clusters mirror the runtime ghosts at this commit. parseClusters
+  // tolerates a missing ROADMAP.md — auto-clusters still get derived from
+  // dependsOn edges in the snapshotted ghosts.
+  const md = await readRoadmapMd(repoPath);
+  const clusterPayload = buildClusters(md, runtime);
+  const { declaredClusters: _omitDeclared, ...clustersJson } = clusterPayload;
+  await writeFile(
+    join(snapshotDir, 'clusters.json'),
+    JSON.stringify(clustersJson, null, 2) + '\n',
+  );
+
+  return runtime;
+}
+
+/**
+ * Public : read latest ghosts.json, return parsed object or null if absent.
+ */
+export async function readLatestGhosts(repoPath) {
+  const path = join(repoPath, '.gitnexus', 'ghosts.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+/**
+ * Public : read a snapshot's ghosts.json.
+ *
+ * Takes the snapshot's storage directory (the same `snapshotDir` that
+ * `syncGhostsForSnapshot` writes to — typically
+ * `SNAPSHOTS_ROOT/<repoKey>/<shortHash>`) and reads `<snapshotDir>/ghosts.json`.
+ * Returns the parsed runtime object, or null if the file is absent.
+ */
+export async function readSnapshotGhosts(snapshotDir) {
+  const path = join(snapshotDir, 'ghosts.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+/**
+ * Public : read latest clusters.json (sibling of ghosts.json under `.gitnexus/`).
+ * Returns the parsed payload or null if absent. Section B Task 4 of the Ghost
+ * Cluster plan.
+ */
+export async function readLatestClusters(repoPath) {
+  const path = join(repoPath, '.gitnexus', 'clusters.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+/**
+ * Public : read a snapshot's clusters.json (sibling of the snapshot's
+ * ghosts.json). Returns the parsed payload or null if absent.
+ */
+export async function readSnapshotClusters(snapshotDir) {
+  const path = join(snapshotDir, 'clusters.json');
+  if (!(await fileExists(path))) return null;
+  return JSON.parse(await readFile(path, 'utf8'));
+}
+
+// ---------------------------------------------------------------------------
+// HTTP route handlers (Task 7 of the roadmap-predictive CORE plan).
+//
+// Three routes, all dispatched by `handleGhostsRoute`:
+//   POST /ghosts/sync?repo=<name>           run syncGhostsForRepo
+//   GET  /ghosts?repo=<name>                read .gitnexus/ghosts.json
+//   GET  /ghosts/at?repo=<name>&commit=<sha> read a snapshot's ghosts.json
+//
+// Wired into `docker-server.mjs` by Task 8.
+// ---------------------------------------------------------------------------
+
+async function handleGhostsSync(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+      return;
+    }
+    const repoPath = repo.repoPath || repo.path;
+    const runtime = await syncGhostsForRepo(repoPath);
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ synced: true, ...runtime }));
+  } catch (err) {
+    console.error('[ghosts] sync failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+async function handleGhostsGet(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+      return;
+    }
+    const repoPath = repo.repoPath || repo.path;
+    const runtime = await readLatestGhosts(repoPath);
+    if (!runtime) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: 'No ghosts.json — run POST /ghosts/sync first.' }));
+      return;
+    }
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(runtime));
+  } catch (err) {
+    console.error('[ghosts] get failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+async function handleGhostsAt(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const commitKey = url.searchParams.get('commit');
+  if (!commitKey) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing commit' }));
+    return;
+  }
+  try {
+    const repo = await findRepoByName(repoName, opts.api);
+    if (!repo) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+      return;
+    }
+    const snapshotDir = join(
+      SNAPSHOTS_ROOT,
+      safeSnapshotKey(repoName),
+      safeSnapshotKey(commitKey),
+    );
+    const runtime = await readSnapshotGhosts(snapshotDir);
+    if (!runtime) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `No ghosts.json for snapshot ${commitKey}.` }));
+      return;
+    }
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(runtime));
+  } catch (err) {
+    console.error('[ghosts] at failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+/**
+ * Public dispatcher : returns true if the request matches one of the
+ * three ghost routes (and is fully handled), false otherwise.
+ *
+ * Registered in `docker-server.mjs` next to the snapshot dispatcher.
+ */
+export async function handleGhostsRoute(req, url, res, opts) {
+  if (url.pathname === '/ghosts/sync' && req.method === 'POST') {
+    await handleGhostsSync(url, res, opts);
+    return true;
+  }
+  if (url.pathname === '/ghosts' && req.method === 'GET') {
+    await handleGhostsGet(url, res, opts);
+    return true;
+  }
+  if (url.pathname === '/ghosts/at' && req.method === 'GET') {
+    await handleGhostsAt(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-git-utils.mjs b/docker-server-git-utils.mjs
new file mode 100644
index 0000000..f30716c
--- /dev/null
+++ b/docker-server-git-utils.mjs
@@ -0,0 +1,113 @@
+/**
+ * Shared git + snapshot helpers (extracted from docker-server-entropy-commits.mjs
+ * and docker-server-coupling.mjs for reuse by regression forensics Phase 2).
+ * Zero-dep. See docs/superpowers/specs/2026-05-28-regression-forensics-phase2-design.md
+ */
+import { spawn } from 'node:child_process';
+import { readdir, readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import { SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+
+export function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+// Parse `git log --pretty=format:%H%x09%aI%x09%an --name-only --no-merges`
+// → [{ sha, date (ISO), author, files: [path, ...] }]
+export function parseGitLog(stdout) {
+  const commits = [];
+  let header = null;
+  let files = [];
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      if (header) {
+        commits.push({ ...header, files });
+        header = null;
+        files = [];
+      }
+      continue;
+    }
+    if (header === null) {
+      const parts = line.split('\t');
+      if (parts.length < 3) continue;
+      header = { sha: parts[0], date: parts[1], author: parts[2] };
+      continue;
+    }
+    files.push(line);
+  }
+  if (header) commits.push({ ...header, files });
+  return commits;
+}
+
+// Resolve a window-end value: SHA → commit date, ISO → ISO, else null.
+export async function resolveWindowEnd(repoPath, value) {
+  if (!value) return null;
+  // ISO-ish? Any string that Date.parse accepts AND contains a '-' or 'T'.
+  if (/^\d{4}-/.test(value)) {
+    const t = Date.parse(value);
+    if (Number.isFinite(t)) return new Date(t).toISOString();
+  }
+  // SHA → commit date.
+  try {
+    const out = await runCmd('git', [
+      '-C', repoPath, 'show', '-s', '--format=%aI', value,
+    ]);
+    const iso = out.trim();
+    if (iso && Number.isFinite(Date.parse(iso))) return iso;
+  } catch {
+    // Fall through.
+  }
+  throw new Error(`could not resolve ${value} as a SHA or ISO date`);
+}
+
+export async function listSnapshotNamesAndDates(repoName) {
+  const repoSnapshotsDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(repoSnapshotsDir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(
+        await readFile(join(repoSnapshotsDir, e.name, 'commit.json'), 'utf8'),
+      );
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built snapshot; skip
+    }
+  }
+  return out;
+}
+
+// NEW: commits in a [fromIso, toIso] window with filesTouched counts.
+export async function commitsInWindow(repoPath, fromIso, toIso) {
+  const args = ['-C', repoPath, 'log', '--pretty=format:%H%x09%aI%x09%an', '--name-only', '--no-merges'];
+  if (fromIso) args.push(`--since=${fromIso}`);
+  if (toIso) args.push(`--until=${toIso}`);
+  let out;
+  try { out = await runCmd('git', args); } catch { return []; }
+  return parseGitLog(out).map((c) => ({
+    sha: c.sha,
+    shortSha: c.sha ? c.sha.slice(0, 7) : null,
+    author: c.author,
+    date: c.date,
+    filesTouched: Array.isArray(c.files) ? c.files.length : 0,
+  }));
+}
diff --git a/docker-server-growth-cross.mjs b/docker-server-growth-cross.mjs
new file mode 100644
index 0000000..7db9b38
--- /dev/null
+++ b/docker-server-growth-cross.mjs
@@ -0,0 +1,243 @@
+/**
+ * Cross-repo growth — ROADMAP Tier 1.3.
+ *
+ * Endpoint:
+ *   GET /growth/cross?repos=A,B[,C][&format=csv]
+ *
+ * For each input repo, gather the same per-snapshot counts the
+ * single-repo /growth endpoint produces, then merge them onto a *union
+ * timeline* sorted by date. For each timeline point, every repo
+ * contributes the counts of its most-recent snapshot at or before that
+ * point — so the chart shows a step function per repo, and the user
+ * can see code mass shift between repos over time.
+ *
+ * Use cases:
+ *   - Monolith → microservices migration: total counts in monolith
+ *     plateau or decrease while new-service counts climb.
+ *   - Cross-team workload: which repo carried the most new code in
+ *     the last quarter.
+ *   - Documentation drift: docs-repo growth vs source-repo growth.
+ *
+ * Implementation notes:
+ *   - Per-repo counts come from each snapshot's `meta.json` (cheap, no
+ *     lbug touch) — same pattern as /entropy. This means we never
+ *     contend for the lbug cache, so multi-repo scans stay parallel-safe.
+ *   - Union-timeline interpolation uses a stable "use the most recent
+ *     known counts" rule. Before a repo's first snapshot it contributes
+ *     zeros across every label. The frontend stacks those into a chart
+ *     that naturally tells the migration story.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const MAX_REPOS = 8;
+
+async function readMeta(storagePath) {
+  try {
+    return JSON.parse(await readFile(join(storagePath, 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+async function listSnapshotMetas(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    const snapshotDir = join(dir, e.name);
+    let commit = null;
+    try {
+      commit = JSON.parse(await readFile(join(snapshotDir, 'commit.json'), 'utf8'));
+    } catch {
+      continue;
+    }
+    const meta = await readMeta(join(snapshotDir, 'source', '.gitnexus'));
+    out.push({
+      name: `${repoName}@${e.name}`,
+      date: commit.date,
+      isLive: false,
+      stats: meta?.stats || {},
+    });
+  }
+  return out;
+}
+
+async function gatherRepoTimeline(repoName, api) {
+  const liveEntry = await findRepoByName(repoName, api);
+  if (!liveEntry) return null;
+  const liveStats = liveEntry.stats || {};
+  const liveMeta = await readMeta(
+    join('/data/projects', repoName, '.gitnexus'),
+  ).catch(() => null);
+  const livePoint = {
+    name: repoName,
+    date: liveEntry.indexedAt,
+    isLive: true,
+    stats: liveMeta?.stats || liveStats,
+  };
+  const snapshots = await listSnapshotMetas(repoName);
+  return [...snapshots, livePoint].sort((a, b) =>
+    (a.date || '').localeCompare(b.date || ''),
+  );
+}
+
+// Convert one snapshot's raw `meta.stats` into a counts-by-category map
+// shaped like the single-repo /growth endpoint. The mapping mirrors
+// gitnexus stat keys → label names so frontends can share the same
+// color palette across both endpoints.
+function statsToCounts(stats) {
+  const counts = {};
+  if (!stats || typeof stats !== 'object') return counts;
+  for (const [k, v] of Object.entries(stats)) {
+    if (typeof v !== 'number') continue;
+    // Keep gitnexus naming: "nodes", "edges", "files", "communities",
+    // "processes", "embeddings" stay as-is so the frontend's existing
+    // labels-vs-counts logic still works.
+    counts[k] = v;
+  }
+  return counts;
+}
+
+async function handleGrowthCross(url, res, opts) {
+  const reposParam = url.searchParams.get('repos');
+  if (!reposParam) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repos (comma-separated)' }));
+    return;
+  }
+  const repoNames = reposParam
+    .split(',')
+    .map((s) => s.trim())
+    .filter(Boolean)
+    .filter((s) => !s.includes('@'))
+    .slice(0, MAX_REPOS);
+  if (repoNames.length < 2) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'need at least 2 distinct repos' }));
+    return;
+  }
+
+  const perRepoTimelines = {};
+  for (const name of repoNames) {
+    const tl = await gatherRepoTimeline(name, opts.api);
+    if (!tl) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${name}` }));
+      return;
+    }
+    perRepoTimelines[name] = tl;
+  }
+
+  // Union timeline: every distinct date from any repo, sorted ascending.
+  // Using a Set keyed by ISO string is enough — collisions are rare and
+  // would only deduplicate truly-simultaneous events.
+  const dateSet = new Set();
+  for (const tl of Object.values(perRepoTimelines)) {
+    for (const p of tl) dateSet.add(p.date || '');
+  }
+  const dates = [...dateSet].filter(Boolean).sort();
+  if (dates.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        repos: repoNames,
+        timeline: [],
+        labels: [],
+        warning: 'Need at least 2 timeline points across the selected repos.',
+      }),
+    );
+    return;
+  }
+
+  // Per-repo cursor walk: for each timeline date, take each repo's most
+  // recent snapshot at-or-before that date. Linear in (dates × repos).
+  const cursors = Object.fromEntries(repoNames.map((n) => [n, 0]));
+  const lastKnown = Object.fromEntries(repoNames.map((n) => [n, null]));
+  const labelsSet = new Set();
+  const enriched = [];
+
+  for (const date of dates) {
+    for (const name of repoNames) {
+      const tl = perRepoTimelines[name];
+      while (cursors[name] < tl.length && (tl[cursors[name]].date || '') <= date) {
+        lastKnown[name] = tl[cursors[name]];
+        cursors[name]++;
+      }
+    }
+    const byRepo = {};
+    for (const name of repoNames) {
+      const point = lastKnown[name];
+      const counts = point ? statsToCounts(point.stats) : {};
+      for (const k of Object.keys(counts)) labelsSet.add(k);
+      byRepo[name] = counts;
+    }
+    enriched.push({ date, byRepo });
+  }
+
+  // Sort labels by max count across all repos, all points — same
+  // convention as /growth so the color palette is stable.
+  const maxPerLabel = {};
+  for (const point of enriched) {
+    for (const name of repoNames) {
+      const counts = point.byRepo[name];
+      for (const [lbl, c] of Object.entries(counts)) {
+        if (!maxPerLabel[lbl] || c > maxPerLabel[lbl]) maxPerLabel[lbl] = c;
+      }
+    }
+  }
+  const labels = Object.keys(maxPerLabel).sort((a, b) => maxPerLabel[b] - maxPerLabel[a]);
+
+  if (url.searchParams.get('format') === 'csv') {
+    // Long-format: (date, repo, label, count) — easier to pivot in
+    // pandas than a wide table per repo.
+    const rows = [];
+    for (const point of enriched) {
+      for (const name of repoNames) {
+        const counts = point.byRepo[name];
+        for (const lbl of labels) {
+          rows.push({ date: point.date, repo: name, label: lbl, count: counts[lbl] || 0 });
+        }
+      }
+    }
+    const csv = toCsv(rows, [
+      { key: 'date' },
+      { key: 'repo' },
+      { key: 'label' },
+      { key: 'count' },
+    ]);
+    writeCsv(res, `${safeFilename(repoNames.join('-vs-'))}-growth-cross.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      repos: repoNames,
+      timeline: enriched,
+      labels,
+    }),
+  );
+}
+
+export async function handleGrowthCrossRoute(req, url, res, opts) {
+  if (url.pathname === '/growth/cross' && req.method === 'GET') {
+    await handleGrowthCross(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-growth.mjs b/docker-server-growth.mjs
new file mode 100644
index 0000000..4e22daa
--- /dev/null
+++ b/docker-server-growth.mjs
@@ -0,0 +1,185 @@
+/**
+ * Growth-by-category analytics — Phase 4D.
+ *
+ * Endpoint:
+ *   GET /growth?repo=<baseRepoName>
+ *
+ * For each snapshot of <baseRepoName> (plus the live entry), counts nodes
+ * by their label (File, Function, Class, Method, Section, Variable, …).
+ * The label is extracted from the node id's first segment — gitnexus ids
+ * follow `<Label>:<rest>`, so a single Cypher `MATCH (n) RETURN n.id`
+ * round-trip per snapshot is enough; we never need to enumerate labels
+ * upfront.
+ *
+ * Response:
+ *   {
+ *     timeline: [
+ *       { name, date, isLive, counts: { File: 123, Function: 456, ... } },
+ *       ...
+ *     ],
+ *     labels: ['File', 'Function', ...]   // sorted desc by max count, so
+ *                                          // the most-impactful categories
+ *                                          // get the brightest colors in
+ *                                          // the chart legend by default
+ *   }
+ *
+ * Sequential snapshot iteration (same lbug-cache reasoning as /churn and
+ * /coupling): parallel access would thrash gitnexus's per-path connection
+ * pool.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+async function listSnapshotNamesAndDates(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built snapshot; skip
+    }
+  }
+  return out;
+}
+
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+function labelOf(id) {
+  // <Label>:<...> for nearly all ids; the few synthetic ones without a
+  // colon ("comm_5", "proc_1") get bucketed under "Other" so they don't
+  // disappear from the chart.
+  if (!id.includes(':')) return 'Other';
+  return id.slice(0, id.indexOf(':')) || 'Other';
+}
+
+async function handleGrowth(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ].sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  if (timeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        timeline: timeline.map((t) => ({ ...t, counts: {} })),
+        labels: [],
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) for a meaningful growth view.',
+      }),
+    );
+    return;
+  }
+
+  // Walk timeline, accumulate per-label counts and a global max-per-label
+  // (used to sort the label list so the most prominent categories drive
+  // the chart's color palette ordering).
+  const errors = [];
+  const maxPerLabel = Object.create(null);
+  const enriched = [];
+  for (const point of timeline) {
+    let counts = {};
+    try {
+      const ids = await fetchNodeIds(point.name, opts.api);
+      for (const id of ids) {
+        const lbl = labelOf(id);
+        counts[lbl] = (counts[lbl] || 0) + 1;
+      }
+    } catch (err) {
+      errors.push({ snapshot: point.name, error: err?.message || 'fetch failed' });
+    }
+    for (const [lbl, c] of Object.entries(counts)) {
+      if (!maxPerLabel[lbl] || c > maxPerLabel[lbl]) maxPerLabel[lbl] = c;
+    }
+    enriched.push({ ...point, counts });
+  }
+
+  const labels = Object.keys(maxPerLabel).sort((a, b) => maxPerLabel[b] - maxPerLabel[a]);
+
+  // CSV emits long-format rows: (snapshot, label, count) — easier to
+  // pivot in pandas/Excel than a wide table with one column per label.
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = [];
+    for (const point of enriched) {
+      for (const lbl of labels) {
+        rows.push({
+          snapshotName: point.name,
+          date: point.date,
+          isLive: point.isLive,
+          label: lbl,
+          count: point.counts[lbl] || 0,
+        });
+      }
+    }
+    const csv = toCsv(rows, [
+      { key: 'snapshotName' },
+      { key: 'date' },
+      { key: 'isLive' },
+      { key: 'label' },
+      { key: 'count' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-growth.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      timeline: enriched,
+      labels,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+export async function handleGrowthRoute(req, url, res, opts) {
+  if (url.pathname === '/growth' && req.method === 'GET') {
+    await handleGrowth(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-lifespan-windowed-core.mjs b/docker-server-lifespan-windowed-core.mjs
new file mode 100644
index 0000000..907d355
--- /dev/null
+++ b/docker-server-lifespan-windowed-core.mjs
@@ -0,0 +1,50 @@
+/**
+ * Pure compute for the windowed Lifespan buckets (Phase 2 Item #3 of
+ * Timeline series). Takes sets of node IDs for snapshots A, B, and the
+ * intermediates, returns the 4 buckets.
+ *
+ * Semantics (windowed) :
+ *   - foundational : in A AND in B (survives the window)
+ *   - recent       : not in A, in B (appeared during the window)
+ *   - discontinued : in A, not in B (disappeared during the window)
+ *   - ephemeral    : not in A, present in intermediates, not in B
+ *                    (created+deleted within the window — only visible
+ *                    via /nodes/alive-between or windowed snapshot scan)
+ *
+ * See spec :
+ * docs/superpowers/specs/2026-05-27-timeline-lifespan-windowed-design.md
+ */
+
+/**
+ * @param {Set<string>} idsA  Node IDs in snapshot at cursor A.
+ * @param {Set<string>} idsB  Node IDs in snapshot at cursor B.
+ * @param {Set<string>} ephemeralIds  Node IDs found in intermediate
+ *   snapshots that are neither in A nor in B (caller should filter
+ *   before passing, but we re-filter defensively here).
+ * @returns {{ foundational: Set<string>, recent: Set<string>,
+ *   discontinued: Set<string>, ephemeral: Set<string> }}
+ */
+export function computeWindowedBuckets(idsA, idsB, ephemeralIds) {
+  const foundational = new Set();
+  for (const id of idsA) {
+    if (idsB.has(id)) foundational.add(id);
+  }
+
+  const recent = new Set();
+  for (const id of idsB) {
+    if (!idsA.has(id)) recent.add(id);
+  }
+
+  const discontinued = new Set();
+  for (const id of idsA) {
+    if (!idsB.has(id)) discontinued.add(id);
+  }
+
+  // Defensive : ephemeral = strictly NOT in A and NOT in B
+  const ephemeral = new Set();
+  for (const id of ephemeralIds) {
+    if (!idsA.has(id) && !idsB.has(id)) ephemeral.add(id);
+  }
+
+  return { foundational, recent, discontinued, ephemeral };
+}
diff --git a/docker-server-lifespan.mjs b/docker-server-lifespan.mjs
new file mode 100644
index 0000000..c998bf9
--- /dev/null
+++ b/docker-server-lifespan.mjs
@@ -0,0 +1,386 @@
+/**
+ * Lifespan analytics — Phase 4C.
+ *
+ * Endpoint:
+ *   GET /lifespan?repo=<baseRepoName>
+ *
+ * For every node id ever seen across the snapshot timeline (+ live), we
+ * compute the index of its first and last appearance, then bucket it:
+ *
+ *   - foundational : present in the very first snapshot AND in live (it's
+ *                    the load-bearing skeleton that survived all changes).
+ *   - recent       : appeared after the first snapshot, still in live
+ *                    (innovations that stuck).
+ *   - discontinued : present at some point, but gone in live (deleted /
+ *                    refactored away).
+ *   - ephemeral    : appeared after the first snapshot AND gone before
+ *                    live (tried, didn't survive).
+ *
+ * For the user's "reverse-engineering / find patterns that worked" use
+ * case, `foundational` and `recent` are the survivors (= proven), while
+ * `discontinued` and `ephemeral` are the cautionary tales (= patterns
+ * that were tried but didn't stick).
+ *
+ * Response:
+ *   {
+ *     totalPoints: number,
+ *     timeline: [{ name, date, isLive }],
+ *     counts: { foundational, recent, discontinued, ephemeral },
+ *     nodes: {
+ *       foundational: [{ id, label, name, path }],
+ *       recent:       [{ id, label, name, path, firstSeen, firstSeenDate }],
+ *       discontinued: [{ id, label, name, path, lastSeen, lastSeenDate }],
+ *       ephemeral:    [{ id, label, name, path, firstSeen, lastSeen, firstSeenDate, lastSeenDate }],
+ *     }
+ *   }
+ *
+ * Each bucket is capped at 1000 entries (sorted by file path) so a giant
+ * repo doesn't ship a 50 MB JSON to the browser. The frontend already
+ * shows counts so the user knows the bucket may be truncated.
+ *
+ * Same sequential snapshot iteration as the other analytics endpoints —
+ * avoids thrashing gitnexus's per-path lbug cache.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+import { filterSnapshotsInWindow, unionSnapshotNodeIds } from './docker-server-nodes-alive-between.mjs';
+import { computeWindowedBuckets } from './docker-server-lifespan-windowed-core.mjs';
+
+const MAX_NODES_PER_BUCKET = 1000;
+
+async function listSnapshotNamesAndDates(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built; skip
+    }
+  }
+  return out;
+}
+
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+// Parse the display fields out of a node id. gitnexus ids follow a few
+// shapes; we extract:
+//   label  → the leading segment ("File", "Function", "Section", ...)
+//   path   → the file path that owns the node, if there is one
+//   name   → the symbol's display name (function/class/section name)
+// Returns minimal info even when the id is non-standard (e.g. "comm_5").
+function parseId(id) {
+  if (!id.includes(':')) return { label: 'Other', path: '', name: id };
+  const parts = id.split(':');
+  const label = parts[0];
+  if (parts.length === 1) return { label, path: '', name: '' };
+  // For File / Folder nodes, the whole rest is the path.
+  if (label === 'File' || label === 'Folder' || label === 'Repository') {
+    return { label, path: parts.slice(1).join(':'), name: parts[parts.length - 1] };
+  }
+  // For everything else (Function, Class, Method, Section, Variable…),
+  // index 1 is the file path and the rest is the symbol identifier.
+  const path = parts[1];
+  const name = parts.slice(2).join(':') || parts[1];
+  return { label, path, name };
+}
+
+async function handleLifespan(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+
+  const from = url.searchParams.get('from');
+  const to = url.searchParams.get('to');
+
+  // Validate windowed mode preconditions
+  if ((from && !to) || (!from && to)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'windowed mode requires both from and to params (or neither)' }));
+    return;
+  }
+
+  if (from && to) {
+    // Windowed mode — branches off the global code path entirely.
+    await handleWindowedLifespan(url, res, { api: opts.api, repoName, from, to });
+    return;
+  }
+
+  const baseRepo = repoName.split('@')[0];
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ].sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  if (timeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        totalPoints: timeline.length,
+        timeline,
+        counts: { foundational: 0, recent: 0, discontinued: 0, ephemeral: 0 },
+        nodes: { foundational: [], recent: [], discontinued: [], ephemeral: [] },
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) to compute lifespan.',
+      }),
+    );
+    return;
+  }
+
+  // Walk timeline once, recording per-id (first, last) indices.
+  const perId = new Map(); // id → { first, last }
+  const errors = [];
+  for (let i = 0; i < timeline.length; i++) {
+    let ids;
+    try {
+      ids = await fetchNodeIds(timeline[i].name, opts.api);
+    } catch (err) {
+      errors.push({ snapshot: timeline[i].name, error: err?.message || 'fetch failed' });
+      continue;
+    }
+    for (const id of ids) {
+      const cur = perId.get(id);
+      if (cur === undefined) perId.set(id, { first: i, last: i });
+      else cur.last = i;
+    }
+  }
+
+  const lastIdx = timeline.length - 1;
+  const buckets = { foundational: [], recent: [], discontinued: [], ephemeral: [] };
+
+  for (const [id, span] of perId) {
+    const parsed = parseId(id);
+    const presentInLive = span.last === lastIdx;
+    const presentAtStart = span.first === 0;
+    let bucket;
+    if (presentAtStart && presentInLive) bucket = 'foundational';
+    else if (!presentAtStart && presentInLive) bucket = 'recent';
+    else if (presentAtStart && !presentInLive) bucket = 'discontinued';
+    else bucket = 'ephemeral';
+
+    const entry = { id, ...parsed };
+    if (bucket === 'recent' || bucket === 'ephemeral') {
+      entry.firstSeen = span.first;
+      entry.firstSeenDate = timeline[span.first]?.date;
+    }
+    if (bucket === 'discontinued' || bucket === 'ephemeral') {
+      entry.lastSeen = span.last;
+      entry.lastSeenDate = timeline[span.last]?.date;
+    }
+    buckets[bucket].push(entry);
+  }
+
+  // Sort each bucket by path then name for a stable, scannable order.
+  // Then truncate to the per-bucket cap.
+  const counts = { foundational: 0, recent: 0, discontinued: 0, ephemeral: 0 };
+  for (const k of Object.keys(buckets)) {
+    counts[k] = buckets[k].length;
+    buckets[k].sort((a, b) => {
+      const p = (a.path || '').localeCompare(b.path || '');
+      if (p !== 0) return p;
+      return (a.name || '').localeCompare(b.name || '');
+    });
+    if (buckets[k].length > MAX_NODES_PER_BUCKET) {
+      buckets[k] = buckets[k].slice(0, MAX_NODES_PER_BUCKET);
+    }
+  }
+
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = [];
+    for (const bucket of Object.keys(buckets)) {
+      for (const n of buckets[bucket]) {
+        rows.push({
+          bucket,
+          id: n.id,
+          label: n.label,
+          name: n.name,
+          path: n.path,
+          firstSeen: n.firstSeen ?? '',
+          firstSeenDate: n.firstSeenDate ?? '',
+          lastSeen: n.lastSeen ?? '',
+          lastSeenDate: n.lastSeenDate ?? '',
+        });
+      }
+    }
+    const csv = toCsv(rows, [
+      { key: 'bucket' },
+      { key: 'id' },
+      { key: 'label' },
+      { key: 'name' },
+      { key: 'path' },
+      { key: 'firstSeen' },
+      { key: 'firstSeenDate' },
+      { key: 'lastSeen' },
+      { key: 'lastSeenDate' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-lifespan.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalPoints: timeline.length,
+      timeline,
+      counts,
+      nodes: buckets,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+async function handleWindowedLifespan(url, res, opts) {
+  const { api, repoName, from, to } = opts;
+
+  try {
+    // Resolve repo
+    const reposResp = await fetch(`${api}/api/repos`);
+    const reposBody = await reposResp.json();
+    const reposList = Array.isArray(reposBody) ? reposBody : reposBody.repos;
+    const repo = reposList?.find((r) => r.name === repoName);
+    if (!repo) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found : ${repoName}` }));
+      return;
+    }
+
+    // Resolve snapshots — normalize to have shortHash at top level for
+    // filterSnapshotsInWindow (which accesses s.shortHash, not s.commit.shortHash).
+    const snapshotsResp = await fetch(`${api}/snapshots?repo=${encodeURIComponent(repoName)}`);
+    const snapshotsBody = await snapshotsResp.json();
+    const snapshots = (snapshotsBody.snapshots || [])
+      .slice()
+      .sort((a, b) => (a.commit?.date || '').localeCompare(b.commit?.date || ''))
+      .map((s) => ({ ...s, shortHash: s.shortHash ?? s.commit?.shortHash }));
+
+    // Resolve aliases (same pattern as /nodes/alive-between)
+    let resolvedFrom = from;
+    let resolvedTo = to;
+    if (snapshots.length > 0) {
+      if (from === 'oldest') resolvedFrom = snapshots[0].commit.shortHash;
+      if (to === 'live' || to === 'newest') resolvedTo = snapshots[snapshots.length - 1].commit.shortHash;
+    }
+
+    const windowed = filterSnapshotsInWindow(snapshots, resolvedFrom, resolvedTo);
+    if (windowed.length === 0) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `invalid window : from=${resolvedFrom} to=${resolvedTo} not in repo snapshots, or from > to` }));
+      return;
+    }
+
+    const snapA = windowed[0];
+    const snapB = windowed[windowed.length - 1];
+
+    // Fetch graphs for A and B
+    const [graphA, graphB] = await Promise.all([
+      fetch(`${api}/api/graph?repo=${encodeURIComponent(snapA.name)}&stream=false`).then((r) => r.json()),
+      fetch(`${api}/api/graph?repo=${encodeURIComponent(snapB.name)}&stream=false`).then((r) => r.json()),
+    ]);
+    const idsA = new Set((graphA.nodes || []).map((n) => n.id));
+    const idsB = new Set((graphB.nodes || []).map((n) => n.id));
+
+    // Ephemeral : compute union over STRICTLY intermediate snapshots, then
+    // filter to those not in A or B.
+    let ephemeralIds = new Set();
+    const intermediates = windowed.slice(1, -1);
+    if (intermediates.length > 0) {
+      const interGraphs = await Promise.all(
+        intermediates.map((s) =>
+          fetch(`${api}/api/graph?repo=${encodeURIComponent(s.name)}&stream=false`).then((r) => r.json()),
+        ),
+      );
+      const interUnion = unionSnapshotNodeIds(interGraphs.map((g) => ({ nodes: g.nodes || [] })));
+      for (const id of interUnion) {
+        if (!idsA.has(id) && !idsB.has(id)) ephemeralIds.add(id);
+      }
+    }
+
+    const buckets = computeWindowedBuckets(idsA, idsB, ephemeralIds);
+
+    // Enrich nodes for response (look up label from graphA / graphB)
+    const nodeMap = new Map();
+    for (const n of graphA.nodes || []) nodeMap.set(n.id, n);
+    for (const n of graphB.nodes || []) if (!nodeMap.has(n.id)) nodeMap.set(n.id, n);
+
+    const enrich = (idSet) =>
+      [...idSet].map((id) => {
+        const n = nodeMap.get(id);
+        return n
+          ? { id, label: n.label || id, name: n.name || n.label || id, path: n.path || n.name || id }
+          : { id, label: id, name: id, path: id };
+      });
+
+    const response = {
+      counts: {
+        foundational: buckets.foundational.size,
+        recent: buckets.recent.size,
+        discontinued: buckets.discontinued.size,
+        ephemeral: buckets.ephemeral.size,
+      },
+      nodes: {
+        foundational: enrich(buckets.foundational),
+        recent: enrich(buckets.recent),
+        discontinued: enrich(buckets.discontinued),
+        ephemeral: enrich(buckets.ephemeral),
+      },
+      windowed: {
+        from: resolvedFrom,
+        to: resolvedTo,
+        snapshotCount: windowed.length,
+      },
+    };
+
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(response));
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err?.message || 'windowed lifespan failed' }));
+  }
+}
+
+export async function handleLifespanRoute(req, url, res, opts) {
+  if (url.pathname === '/lifespan' && req.method === 'GET') {
+    await handleLifespan(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-nodes-alive-between.mjs b/docker-server-nodes-alive-between.mjs
new file mode 100644
index 0000000..67c2bef
--- /dev/null
+++ b/docker-server-nodes-alive-between.mjs
@@ -0,0 +1,161 @@
+/**
+ * Backend endpoint /nodes/alive-between?repo=&from=&to= for the Timeline
+ * Temporal Filter Phase 2 Item #1 (permissive mode).
+ *
+ * Returns the union of node IDs across all snapshots in window [from, to]
+ * inclusive. Caches per (repo, from, to) — windowed results are stable
+ * until a new snapshot lands in the range.
+ *
+ * Pure fns first, HTTP wrapper at the bottom. See spec:
+ * docs/superpowers/specs/2026-05-27-timeline-temporal-filter-design.md
+ */
+
+/**
+ * Filter the snapshot list to those whose shortHash is in window [from, to].
+ * Snapshots are assumed pre-sorted by commit date ascending. Returns the
+ * sublist between the from-snapshot and to-snapshot inclusive. Returns
+ * [] if from or to is not in the list, or if from > to.
+ */
+export function filterSnapshotsInWindow(snapshots, fromShortHash, toShortHash) {
+  const fromIdx = snapshots.findIndex((s) => s.shortHash === fromShortHash);
+  const toIdx = snapshots.findIndex((s) => s.shortHash === toShortHash);
+  if (fromIdx === -1 || toIdx === -1) return [];
+  if (fromIdx > toIdx) return [];
+  return snapshots.slice(fromIdx, toIdx + 1);
+}
+
+/**
+ * Take a list of snapshot graphs ({ nodes: [{id}] }) and return the union
+ * of all node IDs across them.
+ */
+export function unionSnapshotNodeIds(graphs) {
+  const result = new Set();
+  for (const g of graphs) {
+    for (const n of g.nodes) result.add(n.id);
+  }
+  return result;
+}
+
+/**
+ * Path to the alive-between cache file inside the repo's .gitnexus/ dir.
+ * Cache key : (fromShortHash, toShortHash) — windowed results stable
+ * until a new snapshot lands in the range.
+ */
+function aliveBetweenCachePath(repoPath) {
+  return `${repoPath}/.gitnexus/alive-between-cache.json`;
+}
+
+async function readCache(repoPath) {
+  try {
+    const fs = await import('node:fs/promises');
+    const raw = await fs.readFile(aliveBetweenCachePath(repoPath), 'utf8');
+    return JSON.parse(raw);
+  } catch {
+    return {};
+  }
+}
+
+async function writeCache(repoPath, cache) {
+  const fs = await import('node:fs/promises');
+  await fs.writeFile(aliveBetweenCachePath(repoPath), JSON.stringify(cache, null, 2), 'utf8');
+}
+
+/**
+ * HTTP handler for GET /nodes/alive-between?repo=&from=&to=
+ * - Resolves repo via API (/api/repos)
+ * - Lists snapshots, filters to window
+ * - Caches by (from, to) — invalidate when snapshotCount changes
+ * - Fetches each snapshot's graph (via /api/graph)
+ * - Returns union of node IDs
+ *
+ * Returns false if this route doesn't match (so the caller can try the
+ * next route in the dispatch chain) — matches the pattern of all other
+ * docker-server-*.mjs handlers.
+ */
+export async function handleNodesAliveBetweenRoute(req, url, res, opts = {}) {
+  if (url.pathname !== '/nodes/alive-between' || req.method !== 'GET') {
+    return false;
+  }
+  const api = opts.api || 'http://gitnexus:4747';
+  const repoName = url.searchParams.get('repo');
+  const from = url.searchParams.get('from');
+  const to = url.searchParams.get('to');
+
+  if (!repoName || !from || !to) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing required params : repo, from, to' }));
+    return true;
+  }
+
+  try {
+    // Resolve repo to get its path + snapshot list
+    const reposResp = await fetch(`${api}/api/repos`);
+    const reposBody = await reposResp.json();
+    const reposList = Array.isArray(reposBody) ? reposBody : reposBody.repos;
+    const repo = reposList?.find((r) => r.name === repoName);
+    if (!repo) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found : ${repoName}` }));
+      return true;
+    }
+
+    const snapshotsResp = await fetch(`${api}/snapshots?repo=${encodeURIComponent(repoName)}`);
+    const snapshotsBody = await snapshotsResp.json();
+    const snapshots = (snapshotsBody.snapshots || [])
+      .slice()
+      .sort((a, b) => (a.commit?.date || '').localeCompare(b.commit?.date || ''));
+
+    // Resolve aliases : "oldest" → first snapshot's shortHash, "live"/"newest" → last
+    let resolvedFrom = from;
+    let resolvedTo = to;
+    if (snapshots.length > 0) {
+      if (from === 'oldest') resolvedFrom = snapshots[0].shortHash;
+      if (to === 'live' || to === 'newest') resolvedTo = snapshots[snapshots.length - 1].shortHash;
+    }
+
+    const windowed = filterSnapshotsInWindow(snapshots, resolvedFrom, resolvedTo);
+    if (windowed.length === 0) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `invalid window : from=${resolvedFrom} to=${resolvedTo} not in repo snapshots (original: from=${from} to=${to})` }));
+      return true;
+    }
+
+    // Check cache
+    const cacheKey = `${resolvedFrom}__${resolvedTo}__${windowed.length}`;
+    const cache = await readCache(repo.path || repo.repoPath || '/tmp');
+    if (cache[cacheKey]) {
+      res.writeHead(200, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ ...cache[cacheKey], cached: true }));
+      return true;
+    }
+
+    // Fetch each snapshot's graph and union the node IDs
+    const graphs = await Promise.all(
+      windowed.map((s) =>
+        fetch(`${api}/api/graph?repo=${encodeURIComponent(s.name)}&stream=false`)
+          .then((r) => r.json())
+          .then((data) => ({ nodes: data.nodes || [] })),
+      ),
+    );
+    const nodeIdsSet = unionSnapshotNodeIds(graphs);
+    const result = {
+      nodeIds: [...nodeIdsSet].sort(),
+      snapshotCount: windowed.length,
+      fromSnapshot: resolvedFrom,
+      toSnapshot: resolvedTo,
+      computedAt: new Date().toISOString(),
+    };
+
+    // Cache result
+    cache[cacheKey] = result;
+    await writeCache(repo.path || repo.repoPath || '/tmp', cache).catch(() => {});
+
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(result));
+    return true;
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err?.message || 'alive-between failed' }));
+    return true;
+  }
+}
diff --git a/docker-server-ownership.mjs b/docker-server-ownership.mjs
new file mode 100644
index 0000000..4e8a5d3
--- /dev/null
+++ b/docker-server-ownership.mjs
@@ -0,0 +1,222 @@
+/**
+ * Ownership / bus-factor analytics — ROADMAP Tier 1.1.
+ *
+ * Endpoint:
+ *   GET /ownership?repo=<baseRepoName>[&format=csv]
+ *
+ * Walks the *live* git history (a single `git log --name-only` call —
+ * O(commits), much cheaper than running `git blame` per file) and
+ * aggregates, per file:
+ *
+ *   - totalCommits  number of non-merge commits that touched the file
+ *   - authors       top contributors by commit share (max 5)
+ *   - busFactor     smallest N authors whose commits cover ≥ BUS_FACTOR_PCT
+ *                   of the file's history. busFactor=1 means one person
+ *                   owns the file's history — fragile.
+ *
+ * We use commit counts (not blame'd line counts) for cost reasons:
+ * blame is per-file, per-line, on a working-tree clone, while
+ * `git log --name-only` returns everything in one pass. The semantic
+ * difference matters at the edges (someone who wrote a lot but
+ * disappeared shows up in blame but not in recent log activity), but
+ * for the "who owns this code today" question the log-based view is
+ * usually the right one.
+ *
+ * Response (JSON):
+ *   {
+ *     totalFiles: number,
+ *     authorsCount: number,           // distinct authors across the repo
+ *     busFactorThreshold: number,     // the % used to compute busFactor
+ *     files: [{ path, totalCommits, busFactor, authors: [...] }],   // sorted
+ *                                                                    // by busFactor asc, then totalCommits desc
+ *                                                                    // (most fragile + most active first)
+ *     repoBusFactor: number,          // bus factor of the repo as a whole
+ *     repoAuthors: [{ name, commits, share }]
+ *   }
+ */
+
+import { join } from 'node:path';
+import { stat } from 'node:fs/promises';
+import { spawn } from 'node:child_process';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const BUS_FACTOR_PCT = 0.8;
+const TOP_AUTHORS_PER_FILE = 5;
+const MAX_FILES = 2000; // cap response size
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+/**
+ * Parse `git log --pretty=format:%an --name-only --no-merges` output.
+ * Format alternates:
+ *   <author>\n
+ *   <file1>\n
+ *   <file2>\n
+ *   \n  (blank between commits)
+ * Returns Map<filePath, Map<author, commitCount>>.
+ */
+function parseLog(stdout) {
+  const filesByAuthor = new Map();
+  let currentAuthor = null;
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      currentAuthor = null;
+      continue;
+    }
+    if (currentAuthor === null) {
+      currentAuthor = line;
+      continue;
+    }
+    const filePath = line;
+    let m = filesByAuthor.get(filePath);
+    if (!m) {
+      m = new Map();
+      filesByAuthor.set(filePath, m);
+    }
+    m.set(currentAuthor, (m.get(currentAuthor) || 0) + 1);
+  }
+  return filesByAuthor;
+}
+
+function busFactorFromAuthors(authorMap) {
+  const sorted = [...authorMap.entries()].sort((a, b) => b[1] - a[1]);
+  const total = sorted.reduce((sum, [, c]) => sum + c, 0);
+  if (total === 0) return { busFactor: 0, authors: [], totalCommits: 0 };
+  let cum = 0;
+  let bf = 0;
+  for (const [, count] of sorted) {
+    bf++;
+    cum += count;
+    if (cum / total >= BUS_FACTOR_PCT) break;
+  }
+  return {
+    busFactor: bf,
+    totalCommits: total,
+    authors: sorted.slice(0, TOP_AUTHORS_PER_FILE).map(([name, commits]) => ({
+      name,
+      commits,
+      share: commits / total,
+    })),
+  };
+}
+
+async function handleOwnership(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const until = url.searchParams.get('until');
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+  if (!(await stat(join(repoPath, '.git')).catch(() => null))) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        error: `repo at ${repoPath} is not a git repository — ownership requires git history`,
+      }),
+    );
+    return;
+  }
+
+  let logOut;
+  try {
+    const logArgs = ['-C', repoPath, 'log', '--pretty=format:%an', '--name-only', '--no-merges'];
+    if (until) logArgs.push(`--until=${until}`);
+    logOut = await runCmd('git', logArgs);
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `git log failed: ${err.message}` }));
+    return;
+  }
+
+  const filesByAuthor = parseLog(logOut);
+
+  // Per-file bus factor.
+  const fileRows = [];
+  const overallAuthors = new Map();
+  for (const [path, authorMap] of filesByAuthor) {
+    const summary = busFactorFromAuthors(authorMap);
+    fileRows.push({ path, ...summary });
+    for (const [name, count] of authorMap) {
+      overallAuthors.set(name, (overallAuthors.get(name) || 0) + count);
+    }
+  }
+  // Sort: most fragile (low bus factor) first, then most active (commits desc).
+  // That puts "you only have one expert on a hot file" at the top of the list,
+  // which is the exact thing the user wants to see.
+  fileRows.sort((a, b) => a.busFactor - b.busFactor || b.totalCommits - a.totalCommits);
+
+  // Repo-level bus factor: smallest N authors covering 80% of all commits.
+  const repoSummary = busFactorFromAuthors(overallAuthors);
+
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = fileRows.slice(0, MAX_FILES).map((f) => ({
+      path: f.path,
+      busFactor: f.busFactor,
+      totalCommits: f.totalCommits,
+      topAuthor: f.authors[0]?.name || '',
+      topAuthorShare: f.authors[0]?.share ?? 0,
+      secondAuthor: f.authors[1]?.name || '',
+      secondAuthorShare: f.authors[1]?.share ?? 0,
+      thirdAuthor: f.authors[2]?.name || '',
+      thirdAuthorShare: f.authors[2]?.share ?? 0,
+    }));
+    const csv = toCsv(rows, [
+      { key: 'path' },
+      { key: 'busFactor' },
+      { key: 'totalCommits' },
+      { key: 'topAuthor' },
+      { key: 'topAuthorShare' },
+      { key: 'secondAuthor' },
+      { key: 'secondAuthorShare' },
+      { key: 'thirdAuthor' },
+      { key: 'thirdAuthorShare' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-ownership.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalFiles: fileRows.length,
+      authorsCount: overallAuthors.size,
+      busFactorThreshold: BUS_FACTOR_PCT,
+      files: fileRows.slice(0, MAX_FILES),
+      repoBusFactor: repoSummary.busFactor,
+      repoAuthors: repoSummary.authors,
+      truncated: fileRows.length > MAX_FILES ? fileRows.length : undefined,
+    }),
+  );
+}
+
+export async function handleOwnershipRoute(req, url, res, opts) {
+  if (url.pathname === '/ownership' && req.method === 'GET') {
+    await handleOwnership(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-prewarm.mjs b/docker-server-prewarm.mjs
new file mode 100644
index 0000000..d2619ee
--- /dev/null
+++ b/docker-server-prewarm.mjs
@@ -0,0 +1,162 @@
+/**
+ * Diff pre-warming (commit-level time-travel section 3.4).
+ *
+ * Génère en fond les diffs incrémentaux manquants pour que la nav par-commit
+ * (/graph/at-commit) soit instantanée au lieu de payer ~50s de génération lazy
+ * au 1er clic. Deux déclencheurs, même logique :
+ *   - on-push : la cron watches appelle maybePrewarmRepo (opt-in .gitnexus.json
+ *     > incremental.preWarm), pré-chauffe les N derniers commits.
+ *   - on-era  : POST /snapshot/prewarm?repo=&max= (à l'entrée du mode Commits).
+ *   - GET /snapshot/prewarm?repo=&max= -> { total, warm, cold } (état, read-only).
+ *
+ * Génère via POST /snapshot/incremental sur soi-même (même chemin que le lazy
+ * de /graph/at-commit). Cap par passage + garde anti-overlap par repo pour ne
+ * pas lancer plusieurs analyses concurrentes.
+ */
+import { execFile } from 'node:child_process';
+import { stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { promisify } from 'node:util';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+const execFileP = promisify(execFile);
+const SELF = `http://127.0.0.1:${process.env.PORT || '4173'}`;
+const PER_TICK_CAP = Number(process.env.PREWARM_PER_TICK) || 5;
+const _inflight = new Set(); // baseRepo en cours de pré-chauffe (anti-overlap)
+
+async function diffExists(repoPath, sha) {
+  const base = join(repoPath, '.gitnexus', 'incremental', sha);
+  for (const ext of ['json.gz', 'json.br', 'json']) {
+    if (await stat(`${base}.${ext}`).catch(() => null)) return true;
+  }
+  return false;
+}
+
+async function lastCommits(repoPath, n) {
+  try {
+    const { stdout } = await execFileP('git', ['-C', repoPath, 'log', '--format=%H', '-n', String(n), 'HEAD'], { timeout: 10000 });
+    return stdout.split('\n').map((s) => s.trim()).filter(Boolean);
+  } catch {
+    return [];
+  }
+}
+
+// Génère les diffs manquants pour `shas` (best-effort, séquentiel). Au plus
+// `cap` générations par appel (les suivants restent "cold" pour un prochain
+// passage). Skip ceux déjà présents (stat — pas de re-analyze).
+async function prewarmShas(baseRepo, repoPath, shas, cap) {
+  if (_inflight.has(baseRepo)) return { busy: true, warmed: 0, skipped: 0, cold: shas.length };
+  _inflight.add(baseRepo);
+  let warmed = 0;
+  let skipped = 0;
+  let cold = 0;
+  try {
+    for (const sha of shas) {
+      if (await diffExists(repoPath, sha)) {
+        skipped++;
+        continue;
+      }
+      if (warmed >= cap) {
+        cold++;
+        continue;
+      }
+      try {
+        const r = await fetch(`${SELF}/snapshot/incremental?repo=${encodeURIComponent(baseRepo)}&commit=${sha}`, {
+          method: 'POST',
+          headers: { 'Content-Type': 'application/json' },
+          body: '{}',
+        });
+        if (r.ok) warmed++;
+        else cold++;
+      } catch {
+        cold++;
+      }
+    }
+  } finally {
+    _inflight.delete(baseRepo);
+  }
+  return { warmed, skipped, cold };
+}
+
+// Cron tick (appelé par docker-server-watches.mjs). Opt-in par repo.
+export async function maybePrewarmRepo(repo) {
+  const repoPath = repo && (repo.repoPath || repo.path);
+  if (!repoPath || !repo.name || repo.name.includes('@')) return;
+  let cfg;
+  try {
+    const { getConfig } = await import('./docker-server-config.mjs');
+    cfg = await getConfig(repoPath);
+  } catch {
+    return;
+  }
+  if (!cfg?.incremental?.preWarm) return;
+  const shas = await lastCommits(repoPath, cfg.incremental.preWarmCommits || 50);
+  if (shas.length === 0) return;
+  const res = await prewarmShas(repo.name, repoPath, shas, PER_TICK_CAP);
+  if (res.warmed > 0) {
+    process.stderr.write(`[prewarm] ${repo.name}: warmed ${res.warmed}, skipped ${res.skipped}, cold ${res.cold}\n`);
+  }
+}
+
+async function handlePost(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  let max = Number(url.searchParams.get('max'));
+  if (!Number.isFinite(max) || max <= 0) max = 200;
+  max = Math.min(max, 500);
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+  const shas = await lastCommits(repoPath, max);
+  // Fire-and-forget : on chauffe en fond (cap = max pour l'on-era), le client
+  // n'attend pas. Les clics qui arrivent avant la fin tombent en lazy.
+  prewarmShas(baseRepo, repoPath, shas, max).catch(() => {});
+  res.writeHead(202, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ queued: shas.length }));
+}
+
+async function handleGet(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  let max = Number(url.searchParams.get('max'));
+  if (!Number.isFinite(max) || max <= 0) max = 200;
+  max = Math.min(max, 500);
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+  const shas = await lastCommits(repoPath, max);
+  let warm = 0;
+  for (const sha of shas) if (await diffExists(repoPath, sha)) warm++;
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ repo: baseRepo, total: shas.length, warm, cold: shas.length - warm }));
+}
+
+export async function handlePrewarmRoute(req, url, res, opts) {
+  if (url.pathname === '/snapshot/prewarm' && req.method === 'POST') {
+    await handlePost(url, res, opts);
+    return true;
+  }
+  if (url.pathname === '/snapshot/prewarm' && req.method === 'GET') {
+    await handleGet(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-regression-core.mjs b/docker-server-regression-core.mjs
new file mode 100644
index 0000000..31cf7aa
--- /dev/null
+++ b/docker-server-regression-core.mjs
@@ -0,0 +1,79 @@
+/**
+ * Regression forensics — pure core. No I/O. See spec:
+ * docs/superpowers/specs/2026-05-28-regression-forensics-mvp-design.md
+ *
+ * worseDirection convention matches EntropyCommitTimeline.tsx (density up = bad,
+ * modularity down = bad). Phase 2 adds registry rows; the fns never change.
+ */
+
+export const METRIC_REGISTRY = {
+  density:    { worseDirection: 'up',   series: 'entropy:density',    attribution: 'entropy-commits', attrField: 'attributedDensityDelta' },
+  modularity: { worseDirection: 'down', series: 'entropy:modularity', attribution: 'entropy-commits', attrField: 'attributedModularityDelta' },
+  'ownership.busFactor':      { worseDirection: 'down', series: 'ownership:repoBusFactor',      attribution: 'window-suspects' },
+  'ownership.topAuthorShare': { worseDirection: 'up',   series: 'ownership:topAuthorShare',     attribution: 'window-suspects' },
+  'dissonance.purity':        { worseDirection: 'down', series: 'dissonance:purity',            attribution: 'window-suspects' },
+  coupling:                   { worseDirection: 'up',   series: 'coupling:pairsAboveThreshold', attribution: 'window-suspects' },
+};
+
+// Adverse delta normalizes direction so "bigger = worse" regardless of metric.
+function adverse(delta, worseDirection) {
+  return worseDirection === 'up' ? delta : -delta;
+}
+
+/**
+ * series : [{ name?, sha?, date?, value: number|null }, ...] oldest→newest.
+ * Returns { worstPair: [a,b]|null, stepDelta, netDelta, regressed, first, last }.
+ */
+export function locateRegression(series, worseDirection, eps = 1e-9) {
+  const pts = (Array.isArray(series) ? series : []).filter(
+    (p) => p && typeof p.value === 'number' && Number.isFinite(p.value),
+  );
+  if (pts.length < 2) {
+    return { worstPair: null, stepDelta: 0, netDelta: 0, regressed: false, first: pts[0] || null, last: pts[0] || null };
+  }
+  const first = pts[0];
+  const last = pts[pts.length - 1];
+  const netDelta = last.value - first.value;
+  let worstPair = null;
+  let stepDelta = 0;
+  for (let i = 1; i < pts.length; i++) {
+    const adv = adverse(pts[i].value - pts[i - 1].value, worseDirection);
+    if (adv > stepDelta) {
+      stepDelta = adv;
+      worstPair = [pts[i - 1], pts[i]];
+    }
+  }
+  const regressed = adverse(netDelta, worseDirection) > eps;
+  return { worstPair, stepDelta, netDelta, regressed, first, last };
+}
+
+/**
+ * attributedCommits : the `commits` array from /entropy/commits.
+ * Returns a copy sorted worst-first by adverse attributed delta. Commits whose
+ * attr field is missing/non-numeric sort last (treated as 0).
+ */
+export function rankCulprits(attributedCommits, attrField, worseDirection) {
+  const list = Array.isArray(attributedCommits) ? attributedCommits.slice() : [];
+  const advOf = (c) => {
+    const v = c && typeof c[attrField] === 'number' && Number.isFinite(c[attrField]) ? c[attrField] : 0;
+    return adverse(v, worseDirection);
+  };
+  return list.sort((a, b) => advOf(b) - advOf(a));
+}
+
+/**
+ * Rank commits in the regression window as "suspects" by filesTouched (desc),
+ * tie-broken by most-recent date first. Used when no per-commit attribution
+ * exists (ownership/dissonance/coupling). Returns a sorted copy.
+ */
+export function rankSuspects(commitsInWindow) {
+  const list = Array.isArray(commitsInWindow) ? commitsInWindow.slice() : [];
+  return list.sort((a, b) => {
+    const fa = typeof a.filesTouched === 'number' ? a.filesTouched : 0;
+    const fb = typeof b.filesTouched === 'number' ? b.filesTouched : 0;
+    if (fb !== fa) return fb - fa;
+    const da = Date.parse(a.date || '') || 0;
+    const db = Date.parse(b.date || '') || 0;
+    return db - da;
+  });
+}
diff --git a/docker-server-regression.mjs b/docker-server-regression.mjs
new file mode 100644
index 0000000..09be928
--- /dev/null
+++ b/docker-server-regression.mjs
@@ -0,0 +1,135 @@
+/**
+ * Regression forensics — I/O + route (Phase 2 generalized). Dispatches series
+ * fetching by the registry `series` tag and attribution by `attribution` mode.
+ * Calls OUR existing web-server endpoints. Handler returns true if it owned the
+ * route. See docs/superpowers/specs/2026-05-28-regression-forensics-phase2-design.md
+ */
+import { METRIC_REGISTRY, locateRegression, rankCulprits, rankSuspects } from './docker-server-regression-core.mjs';
+import { commitsInWindow, listSnapshotNamesAndDates } from './docker-server-git-utils.mjs';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+const WEB_BASE = () => `http://127.0.0.1:${process.env.PORT || '4173'}`;
+const GITNEXUS_API = process.env.GITNEXUS_API || 'http://gitnexus:4747';
+
+async function getJson(url) {
+  try { const r = await fetch(url); if (!r.ok) return null; return await r.json(); } catch { return null; }
+}
+function sendJson(res, code, body) { res.writeHead(code, { 'Content-Type': 'application/json' }); res.end(JSON.stringify(body)); }
+
+// Build a [{ name, sha, date, value }] series for a metric's series tag.
+// Providers for ownership/coupling/dissonance are added in Tasks 4/5/6.
+async function getSeries(seriesTag, repo, base) {
+  const [source, field] = seriesTag.split(':');
+  if (source === 'entropy') {
+    const entropy = await getJson(`${base}/entropy?repo=${encodeURIComponent(repo)}`);
+    const timeline = entropy && Array.isArray(entropy.timeline) ? entropy.timeline : [];
+    return timeline.map((t) => ({ name: t.name, sha: t.sha, date: t.date, value: t[field] }));
+  }
+  if (source === 'ownership') {
+    const baseRepo = repo.split('@')[0];
+    const snaps = await listSnapshotNamesAndDates(baseRepo);
+    const live = { name: baseRepo, sha: 'live', date: new Date().toISOString(), isLive: true };
+    const points = [...snaps, live];
+    const out = [];
+    for (const p of points) {
+      const o = await getJson(`${base}/ownership?repo=${encodeURIComponent(baseRepo)}&until=${encodeURIComponent(p.date)}`);
+      if (!o) continue;
+      const value = field === 'repoBusFactor'
+        ? (typeof o.repoBusFactor === 'number' ? o.repoBusFactor : null)
+        : (Array.isArray(o.repoAuthors) && o.repoAuthors[0] ? o.repoAuthors[0].share : null);
+      out.push({ name: p.name, sha: p.sha, date: p.date, value });
+    }
+    return out;
+  }
+  if (source === 'coupling') {
+    const baseRepo = repo.split('@')[0];
+    const snaps = await listSnapshotNamesAndDates(baseRepo);
+    const live = { name: baseRepo, sha: 'live', date: new Date().toISOString(), isLive: true };
+    const points = [...snaps, live];
+    const out = [];
+    for (const p of points) {
+      const c = await getJson(`${base}/coupling?repo=${encodeURIComponent(baseRepo)}&asOf=${encodeURIComponent(p.date)}`);
+      const value = c && typeof c.pairsAboveThreshold === 'number' ? c.pairsAboveThreshold : null;
+      out.push({ name: p.name, sha: p.sha, date: p.date, value });
+    }
+    return out;
+  }
+  if (source === 'dissonance') {
+    const baseRepo = repo.split('@')[0];
+    const snaps = await listSnapshotNamesAndDates(baseRepo); // name = '<base>@<sha>'
+    const live = { name: baseRepo, sha: 'live', date: new Date().toISOString(), isLive: true };
+    const points = [...snaps, live];
+    const out = [];
+    for (const p of points) {
+      const d = await getJson(`${base}/dissonance?repo=${encodeURIComponent(p.name)}`);
+      const value = d && typeof d.purity === 'number' ? d.purity : null;
+      out.push({ name: p.name, sha: p.sha, date: p.date, value });
+    }
+    return out;
+  }
+  return [];
+}
+
+export async function handleRegressionRoute(req, url, res) {
+  if (url.pathname !== '/regression' || req.method !== 'GET') return false;
+  const repo = url.searchParams.get('repo');
+  const metric = url.searchParams.get('metric') || 'density';
+  const from = url.searchParams.get('from') || '';
+  const to = url.searchParams.get('to') || '';
+  if (!repo) { sendJson(res, 400, { error: 'missing repo' }); return true; }
+  const cfg = METRIC_REGISTRY[metric];
+  if (!cfg) { sendJson(res, 400, { error: `unknown metric '${metric}' (supported: ${Object.keys(METRIC_REGISTRY).join(', ')})` }); return true; }
+
+  const base = WEB_BASE();
+  const series = await getSeries(cfg.series, repo, base);
+  const loc = locateRegression(series, cfg.worseDirection);
+  const attributionMode = cfg.attribution === 'entropy-commits' ? 'attributed' : 'suspects';
+
+  if (series.length < 2) {
+    sendJson(res, 200, { repo, metric, regressed: false, window: { from, to }, note: 'Need at least 2 snapshots to detect a regression.', worstCommit: null, runnersUp: [], attribution: attributionMode });
+    return true;
+  }
+
+  let worstCommit = null;
+  let runnersUp = [];
+
+  if (cfg.attribution === 'entropy-commits') {
+    const qs = [`repo=${encodeURIComponent(repo)}`];
+    if (from) qs.push(`from=${encodeURIComponent(from)}`);
+    if (to) qs.push(`to=${encodeURIComponent(to)}`);
+    const attrib = await getJson(`${base}/entropy/commits?${qs.join('&')}`);
+    const commits = attrib && Array.isArray(attrib.commits) ? attrib.commits : [];
+    const ranked = rankCulprits(commits, cfg.attrField, cfg.worseDirection);
+    const worstRaw = ranked[0] || null;
+    const adv = worstRaw && typeof worstRaw[cfg.attrField] === 'number' ? (cfg.worseDirection === 'up' ? worstRaw[cfg.attrField] : -worstRaw[cfg.attrField]) : 0;
+    if (worstRaw && adv > 0) {
+      const fp = await getJson(`${base}/commit/footprint?repo=${encodeURIComponent(repo)}&sha=${encodeURIComponent(worstRaw.sha)}`);
+      worstCommit = { sha: worstRaw.sha, shortSha: worstRaw.shortSha || (worstRaw.sha ? worstRaw.sha.slice(0, 7) : null), author: worstRaw.author || (fp && fp.author) || null, date: worstRaw.date || (fp && fp.date) || null, message: (fp && fp.message) || null, attributedDelta: worstRaw[cfg.attrField], files: fp && Array.isArray(fp.filesTouched) ? fp.filesTouched : [] };
+      runnersUp = ranked.slice(1, 4).filter((c) => (cfg.worseDirection === 'up' ? c[cfg.attrField] : -c[cfg.attrField]) > 0).map((c) => ({ sha: c.sha, shortSha: c.shortSha || (c.sha ? c.sha.slice(0, 7) : null), author: c.author || null, attributedDelta: c[cfg.attrField] }));
+    }
+  } else {
+    // window-suspects: commits in the regression window ranked by filesTouched.
+    const repoObj = await findRepoByName(repo.split('@')[0], GITNEXUS_API);
+    const repoPath = repoObj && (repoObj.repoPath || repoObj.path);
+    if (repoPath) {
+      const fromIso = loc.worstPair ? loc.worstPair[0].date : (loc.first ? loc.first.date : null);
+      const toIso = loc.worstPair ? loc.worstPair[1].date : (loc.last ? loc.last.date : null);
+      const suspects = await commitsInWindow(repoPath, fromIso, toIso);
+      const ranked = rankSuspects(suspects);
+      const top = ranked[0] || null;
+      if (top) {
+        const fp = await getJson(`${base}/commit/footprint?repo=${encodeURIComponent(repo)}&sha=${encodeURIComponent(top.sha)}`);
+        worstCommit = { sha: top.sha, shortSha: top.shortSha, author: top.author || (fp && fp.author) || null, date: top.date || null, message: (fp && fp.message) || null, attributedDelta: null, filesTouched: top.filesTouched, files: fp && Array.isArray(fp.filesTouched) ? fp.filesTouched : [] };
+        runnersUp = ranked.slice(1, 4).map((c) => ({ sha: c.sha, shortSha: c.shortSha, author: c.author || null, attributedDelta: null, filesTouched: c.filesTouched }));
+      }
+    }
+  }
+
+  sendJson(res, 200, {
+    repo, metric, regressed: loc.regressed, window: { from, to },
+    before: loc.first ? loc.first.value : null, after: loc.last ? loc.last.value : null, netDelta: loc.netDelta,
+    steepestDrop: loc.worstPair ? { between: [loc.worstPair[0].date, loc.worstPair[1].date], delta: loc.stepDelta } : null,
+    attribution: attributionMode, worstCommit, runnersUp,
+  });
+  return true;
+}
diff --git a/docker-server-repo-id.mjs b/docker-server-repo-id.mjs
new file mode 100644
index 0000000..ae8e0f6
--- /dev/null
+++ b/docker-server-repo-id.mjs
@@ -0,0 +1,290 @@
+/**
+ * Repo ID stable — ROADMAP Tier 2bis.5.
+ *
+ * Every git repo gets a stable identifier independent of:
+ *   - the folder name it was cloned into
+ *   - the absolute path on this machine
+ *   - re-clones with a different layout
+ *
+ * Formula:
+ *   repoId = sha256(firstCommitSha + '\n' + normalizedRemote)[:16]
+ *
+ * 16 hex chars = 64 bits of entropy. Collision probability negligible
+ * for the scale we care about (typically <50 repos per deployment, in
+ * the worst case <10k for an enterprise OSS dataset). 16 chars is short
+ * enough to be readable in URLs and panels, long enough to never
+ * collide in practice.
+ *
+ * --- Why these two inputs and not others ---
+ *
+ *   - **firstCommitSha**: invariant by definition. A repo's first
+ *     commit is the only commit that exists in every fork, every
+ *     re-clone, every mirror. Renaming or rebasing later commits
+ *     doesn't change it. Genuinely-different repos that happen to be
+ *     forks of the same source ARE the same repo by this measure —
+ *     which is what we want for the cross-repo similarity FN-2
+ *     "legacy + rewrite" case.
+ *   - **normalizedRemote**: lower-cased, scheme-stripped, .git-suffix-
+ *     stripped form of `git config --get remote.origin.url`. Two
+ *     mirrors of the same logical project (github + gitlab) get
+ *     different IDs — we treat them as different deployments. Repos
+ *     with no remote (purely local) get an empty-string remote, so
+ *     they're identified purely by their first commit (acceptable for
+ *     local exploration).
+ *
+ * --- Storage ---
+ *
+ * The id is cached per repo at `<repoPath>/.gitnexus/repo-id.json`
+ * with the inputs alongside, so the computation never repeats on the
+ * same repo and the user can verify what's been hashed.
+ *
+ * Stored shape:
+ *   {
+ *     "schemaVersion": 1,
+ *     "repoId": "a1b2c3d4e5f60718",
+ *     "firstCommitSha": "abc123...",
+ *     "normalizedRemote": "github.com/owner/repo",
+ *     "computedAt": "2026-05-26T11:30:00.000Z"
+ *   }
+ *
+ * The first-time computation invokes `git` twice (rev-list +
+ * config get); subsequent calls just read the JSON.
+ *
+ * --- Endpoint ---
+ *
+ *   GET /repos/by-id/:repoId
+ *     →  { repoId, matches: [{ name, repoPath, lastIndexedAt }, ...] }
+ *
+ * Iterates all repos via `/api/repos`, computes (or reads cache for)
+ * each, returns the ones whose repoId equals the requested one. Used
+ * by the cross-repo features when a `<base>` no longer matches because
+ * the repo was re-cloned, and as a sanity check that `<base>` and
+ * `repoId` refer to the same thing.
+ *
+ * --- What 2bis.5 does NOT do (deliberately) ---
+ *
+ * Cross-repo endpoints (`/coupling/cross`, `/growth/cross`,
+ * `/similarity`) still take `?repos=<base>,<base>,…`. Switching them
+ * to accept `<repoId>` interchangeably is a separate follow-up — the
+ * MVP here is "compute + expose the ID" so downstream features can
+ * start consuming it without a big refactor.
+ */
+
+import { createHash } from 'node:crypto';
+import { spawn } from 'node:child_process';
+import { readFile, writeFile, mkdir, stat } from 'node:fs/promises';
+import { join, dirname } from 'node:path';
+
+const CACHE_PATH_PARTS = ['.gitnexus', 'repo-id.json'];
+const SCHEMA_VERSION = 1;
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout.trim());
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim() || stdout.trim()}`));
+    });
+  });
+}
+
+/**
+ * Strip the noisy parts off a git remote URL so two equivalent URLs
+ * yield the same string:
+ *   git@github.com:owner/repo.git       → github.com/owner/repo
+ *   https://github.com/owner/repo.git   → github.com/owner/repo
+ *   ssh://git@github.com/owner/repo     → github.com/owner/repo
+ *   https://github.com/owner/repo/      → github.com/owner/repo
+ * Empty string in / out is fine (local-only repo with no remote).
+ */
+export function normalizeRemote(rawUrl) {
+  if (!rawUrl || typeof rawUrl !== 'string') return '';
+  let s = rawUrl.trim();
+  if (!s) return '';
+  // git@host:owner/repo → ssh-like
+  const scpMatch = s.match(/^([\w-]+)@([\w.-]+):(.+)$/);
+  if (scpMatch) {
+    s = `${scpMatch[2]}/${scpMatch[3]}`;
+  } else {
+    // Drop scheme.
+    s = s.replace(/^[a-z]+:\/\//i, '');
+    // Drop user@ inside the URL.
+    s = s.replace(/^[\w-]+@/, '');
+  }
+  // Drop trailing .git, then query/fragment, then trailing slashes.
+  // (Previous version had a bug stripping the path too — `[/?#]` should
+  // be `[?#]`.)
+  s = s.replace(/\.git$/i, '').replace(/[?#].*$/, '').replace(/\/+$/g, '');
+  // Re-canonicalize the case for the host part (everything before the
+  // first slash). The path part (owner/repo) is case-sensitive on
+  // GitHub-like hosts so we leave it alone.
+  const slash = s.indexOf('/');
+  if (slash > 0) {
+    s = s.slice(0, slash).toLowerCase() + s.slice(slash);
+  } else {
+    s = s.toLowerCase();
+  }
+  return s;
+}
+
+/**
+ * Compute the repoId from its two inputs. Pure function, no I/O.
+ * Exposed so callers (tests, the resolve endpoint) can verify against
+ * a known input pair without going through the cache.
+ */
+export function computeRepoId(firstCommitSha, normalizedRemoteStr) {
+  const h = createHash('sha256');
+  h.update(String(firstCommitSha || '') + '\n' + String(normalizedRemoteStr || ''));
+  return h.digest('hex').slice(0, 16);
+}
+
+async function loadCache(cachePath) {
+  try {
+    const raw = await readFile(cachePath, 'utf8');
+    const parsed = JSON.parse(raw);
+    if (parsed?.schemaVersion === SCHEMA_VERSION && typeof parsed.repoId === 'string') {
+      return parsed;
+    }
+    return null;
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return null;
+    return null;
+  }
+}
+
+async function saveCache(cachePath, payload) {
+  await mkdir(dirname(cachePath), { recursive: true });
+  await writeFile(cachePath, JSON.stringify(payload, null, 2), 'utf8');
+}
+
+/**
+ * Get the cached repoId for a repo path, computing + persisting it
+ * if the cache is missing. Returns null when the repo isn't a git
+ * working tree (no `.git/`), since we can't compute the ID then.
+ *
+ *   const info = await getOrComputeRepoId('/data/projects/hmm_studio');
+ *   // info = {
+ *   //   repoId: 'a1b2c3d4e5f60718',
+ *   //   firstCommitSha: 'abc...',
+ *   //   normalizedRemote: 'github.com/owner/repo',
+ *   //   computedAt: '2026-...'
+ *   // } | null
+ */
+export async function getOrComputeRepoId(repoPath) {
+  if (!repoPath) return null;
+  const cachePath = join(repoPath, ...CACHE_PATH_PARTS);
+  const cached = await loadCache(cachePath);
+  if (cached) return cached;
+
+  const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
+  if (!hasGit) return null;
+
+  let firstCommitSha = '';
+  let remoteUrl = '';
+  try {
+    firstCommitSha = await runCmd('git', ['-C', repoPath, 'rev-list', '--max-parents=0', 'HEAD']);
+    // A repo can have multiple root commits (merged unrelated histories).
+    // Take the first line; deterministic because git sorts by commit order.
+    firstCommitSha = firstCommitSha.split('\n')[0].trim();
+  } catch {
+    // No commits yet → no repoId possible.
+    return null;
+  }
+  try {
+    remoteUrl = await runCmd('git', ['-C', repoPath, 'config', '--get', 'remote.origin.url']);
+  } catch {
+    // No origin remote — fine, identify purely by first commit.
+    remoteUrl = '';
+  }
+  const normalizedRemote = normalizeRemote(remoteUrl);
+  const repoId = computeRepoId(firstCommitSha, normalizedRemote);
+  const payload = {
+    schemaVersion: SCHEMA_VERSION,
+    repoId,
+    firstCommitSha,
+    normalizedRemote,
+    computedAt: new Date().toISOString(),
+  };
+  try {
+    await saveCache(cachePath, payload);
+  } catch {
+    // Best-effort cache; if we can't write (perms, read-only mount),
+    // we still return the computed value. Next request will recompute.
+  }
+  return payload;
+}
+
+/**
+ * Resolve a repoId back to one or more registered `<base>` names by
+ * iterating /api/repos and computing the id for each.
+ *
+ * Cache-friendly: each repo's id read is cheap (one file read after
+ * the first computation), so resolving 10 repos is ~10 small reads.
+ *
+ * Returns the resolution payload for the route handler.
+ */
+async function resolveRepoId(targetId, opts) {
+  const resp = await fetch(`${opts.api}/api/repos`);
+  if (!resp.ok) throw new Error(`/api/repos failed: HTTP ${resp.status}`);
+  const data = await resp.json();
+  const list = Array.isArray(data) ? data : data?.repos;
+  if (!Array.isArray(list)) return { repoId: targetId, matches: [] };
+
+  const matches = [];
+  for (const repo of list) {
+    const repoPath = repo.repoPath || repo.path;
+    if (!repoPath) continue;
+    const info = await getOrComputeRepoId(repoPath);
+    if (info && info.repoId === targetId) {
+      matches.push({
+        name: repo.name,
+        repoPath,
+        lastIndexedAt: repo.indexedAt || null,
+        firstCommitSha: info.firstCommitSha,
+        normalizedRemote: info.normalizedRemote,
+      });
+    }
+  }
+  return { repoId: targetId, matches };
+}
+
+// ── Route handler ────────────────────────────────────────────────────
+
+async function handleRepoById(url, res, opts) {
+  // Path looks like /repos/by-id/<hex16>. Extract the id and validate.
+  const parts = url.pathname.split('/').filter(Boolean);
+  const repoId = parts[parts.length - 1];
+  if (!/^[a-f0-9]{16}$/.test(repoId)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repoId must be 16 lowercase hex chars, got: ${repoId}` }));
+    return;
+  }
+  let result;
+  try {
+    result = await resolveRepoId(repoId, opts);
+  } catch (err) {
+    res.writeHead(502, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `resolve failed: ${err.message}` }));
+    return;
+  }
+  if (result.matches.length === 0) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ repoId, matches: [], error: 'no indexed repo with this id' }));
+    return;
+  }
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify(result));
+}
+
+export async function handleRepoByIdRoute(req, url, res, opts) {
+  if (req.method === 'GET' && url.pathname.startsWith('/repos/by-id/')) {
+    await handleRepoById(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-routes.mjs b/docker-server-routes.mjs
new file mode 100644
index 0000000..7a3d2d3
--- /dev/null
+++ b/docker-server-routes.mjs
@@ -0,0 +1,77 @@
+import { handleSnapshotRoute } from './docker-server-snapshots.mjs';
+import { handleSnapshotBulkRoute } from './docker-server-snapshots-bulk.mjs';
+import { handleChurnRoute } from './docker-server-churn.mjs';
+import { handleCouplingRoute } from './docker-server-coupling.mjs';
+import { handleGrowthRoute } from './docker-server-growth.mjs';
+import { handleLifespanRoute } from './docker-server-lifespan.mjs';
+import { handleEntropyRoute } from './docker-server-entropy.mjs';
+import { handleOwnershipRoute } from './docker-server-ownership.mjs';
+import { handleDissonanceRoute } from './docker-server-dissonance.mjs';
+import { handleSemanticLabelsRoute } from './docker-server-semantic-labels.mjs';
+import { handleCouplingCrossRoute } from './docker-server-coupling-cross.mjs';
+import { handleGrowthCrossRoute } from './docker-server-growth-cross.mjs';
+import { handleSimilarityRoute } from './docker-server-similarity.mjs';
+import { handleNodesAliveBetweenRoute } from './docker-server-nodes-alive-between.mjs';
+import { handleRepoByIdRoute } from './docker-server-repo-id.mjs';
+import { handleEntropyCommitsRoute } from './docker-server-entropy-commits.mjs';
+import { handleWatchesRoute, startWatchesCron } from './docker-server-watches.mjs';
+import { handleCommitFootprintRoute } from './docker-server-commit-footprint.mjs';
+import { handleSnapshotAutoRoute } from './docker-server-snapshot-auto.mjs';
+import { handleSnapshotFromPrRoute } from './docker-server-snapshot-from-pr.mjs';
+import { handleSnapshotIncrementalRoute, handleGraphAtCommitRoute } from './docker-server-snapshot-incremental.mjs';
+import { handleGhostsRoute } from './docker-server-ghosts.mjs';
+import { handleGhostAuditRoute } from './docker-server-ghost-audit.mjs';
+import { handleGhostsCleanupRoute } from './docker-server-ghost-cleanup.mjs';
+import { handleConnectorsRoute } from './docker-server-connectors.mjs';
+import { handleSysmlExportRoute } from './docker-server-sysml-export.mjs';
+import { handleClustersRoute } from './docker-server-cluster-audit.mjs';
+import { handleWikiRoute } from './docker-server-wiki.mjs';
+import { handleAutoReindexRoute } from './docker-server-auto-reindex.mjs';
+import { handleRegressionRoute } from './docker-server-regression.mjs';
+import { handleCommitsRoute } from './docker-server-commits.mjs';
+import { handleBaselineSeedRoute } from './docker-server-baseline-seed.mjs';
+import { handlePrewarmRoute } from './docker-server-prewarm.mjs';
+
+// Returns true once a handler claims (responds to) the request; false if no route matched.
+export async function registerGitnexusRoutes(req, reqUrl, res, ctx) {
+  if (await handleSnapshotRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleSnapshotBulkRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleChurnRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleCouplingRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleGrowthRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleLifespanRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleEntropyRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleOwnershipRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleDissonanceRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleSemanticLabelsRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleCouplingCrossRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleGrowthCrossRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleSimilarityRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleNodesAliveBetweenRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleRepoByIdRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleEntropyCommitsRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleWatchesRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleCommitFootprintRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleSnapshotAutoRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleSnapshotFromPrRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleSnapshotIncrementalRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleGraphAtCommitRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleGhostsRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleGhostAuditRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleGhostsCleanupRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleConnectorsRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleSysmlExportRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleClustersRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleWikiRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleAutoReindexRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleRegressionRoute(req, reqUrl, res)) return true; // NB: no ctx — handler resolves its own API base, unlike the others
+  if (await handleCommitsRoute(req, reqUrl, res, ctx)) return true;
+  if (await handleBaselineSeedRoute(req, reqUrl, res, ctx)) return true;
+  if (await handlePrewarmRoute(req, reqUrl, res, ctx)) return true;
+  return false;
+}
+
+// Grouping point: add future crons here so docker-server.mjs stays untouched.
+export function startGitnexusCron(api) {
+  startWatchesCron(api);
+}
diff --git a/docker-server-semantic-labels.mjs b/docker-server-semantic-labels.mjs
new file mode 100644
index 0000000..254682a
--- /dev/null
+++ b/docker-server-semantic-labels.mjs
@@ -0,0 +1,191 @@
+/**
+ * Semantic-labels cache — ROADMAP Tier 2.1, server side.
+ *
+ * Endpoints:
+ *   GET  /semantic-labels?repo=<base>
+ *        Reads the on-disk cache and returns it, or an empty payload
+ *        if no labels have been generated yet. Cheap and idempotent.
+ *
+ *   POST /semantic-labels?repo=<base>   body: { labels: {…}, provider?, model? }
+ *        Merges the incoming labels into the cache, last-write-wins
+ *        per communityId. We persist a tiny audit trail (when, with
+ *        which provider/model) so a future "regenerate stale labels"
+ *        feature can decide what's old.
+ *
+ * The LLM call itself is done by the *frontend* (`semantic-labeler.ts`),
+ * because the user already has provider credentials configured for the
+ * chat panel — no point asking them to re-enter API keys server-side
+ * or wiring per-provider clients here. This module just owns the cache.
+ *
+ * Cache file: <repoPath>/.gitnexus/semantic-labels.json
+ *
+ *   {
+ *     "schemaVersion": 1,
+ *     "labels": {
+ *       "community-id-1": {
+ *         "label": "Authentication",
+ *         "confidence": 0.85,
+ *         "evidenceNodes": ["src/auth/login.py:login", ...],
+ *         "labeledAt": "2026-05-22T10:00:00.000Z",
+ *         "provider": "anthropic",
+ *         "model": "claude-sonnet-4-20250514"
+ *       },
+ *       ...
+ *     }
+ *   }
+ */
+
+import { readFile, writeFile, mkdir } from 'node:fs/promises';
+import { join, dirname } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+const CACHE_FILENAME = 'semantic-labels.json';
+const SCHEMA_VERSION = 1;
+
+async function loadCache(cachePath) {
+  try {
+    const raw = await readFile(cachePath, 'utf8');
+    const parsed = JSON.parse(raw);
+    if (parsed?.schemaVersion === SCHEMA_VERSION && parsed?.labels && typeof parsed.labels === 'object') {
+      return parsed;
+    }
+    // Future-proofing: if the schema bumps, we won't error — we'll just
+    // start fresh rather than serve incompatible data.
+    return { schemaVersion: SCHEMA_VERSION, labels: {} };
+  } catch (err) {
+    if (err && err.code === 'ENOENT') {
+      return { schemaVersion: SCHEMA_VERSION, labels: {} };
+    }
+    throw err;
+  }
+}
+
+async function saveCache(cachePath, cache) {
+  await mkdir(dirname(cachePath), { recursive: true });
+  await writeFile(cachePath, JSON.stringify(cache, null, 2), 'utf8');
+}
+
+async function handleGet(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+  const cachePath = join(repoPath, '.gitnexus', CACHE_FILENAME);
+  const cache = await loadCache(cachePath);
+  res.writeHead(200, { 'Content-Type': 'application/json', 'Cache-Control': 'no-store' });
+  res.end(JSON.stringify({ repo: baseRepo, ...cache }));
+}
+
+async function handlePost(url, req, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  // Read JSON body (small — at most a few KB per repo's worth of labels).
+  let body = '';
+  for await (const chunk of req) body += chunk;
+  let payload;
+  try {
+    payload = body ? JSON.parse(body) : {};
+  } catch (err) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `invalid JSON: ${err.message}` }));
+    return;
+  }
+  const incoming = payload?.labels;
+  if (!incoming || typeof incoming !== 'object' || Array.isArray(incoming)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'body.labels must be an object {communityId: {...}}' }));
+    return;
+  }
+  const provider = typeof payload.provider === 'string' ? payload.provider : 'unknown';
+  const model = typeof payload.model === 'string' ? payload.model : 'unknown';
+  const now = new Date().toISOString();
+
+  const repoPath = repo.repoPath || repo.path;
+  const cachePath = join(repoPath, '.gitnexus', CACHE_FILENAME);
+  const cache = await loadCache(cachePath);
+
+  // Validate each entry, drop garbage rather than corrupting the cache.
+  let merged = 0;
+  for (const [communityId, entry] of Object.entries(incoming)) {
+    if (typeof communityId !== 'string' || communityId.length > 200) continue;
+    if (!entry || typeof entry !== 'object') continue;
+    const label = typeof entry.label === 'string' && entry.label.trim().length > 0
+      ? entry.label.trim().slice(0, 80)
+      : null;
+    if (!label) continue;
+    const confidence = typeof entry.confidence === 'number' && entry.confidence >= 0 && entry.confidence <= 1
+      ? entry.confidence
+      : 0.5;
+    const evidenceNodes = Array.isArray(entry.evidenceNodes)
+      ? entry.evidenceNodes.filter((s) => typeof s === 'string').slice(0, 20)
+      : [];
+    // Tier 2.5b.bis: accept optional embedding vector + provenance.
+    // We tolerate the absence of these (cache entries without embeddings
+    // are still valid — they just won't contribute to centroid cosine
+    // in /similarity). When present we sanity-check it's a numeric array
+    // of reasonable length (truncate at 4096 dims — current largest
+    // commodity model is 3072).
+    let embedding;
+    let embeddingProvider;
+    let embeddingModel;
+    if (Array.isArray(entry.embedding)) {
+      const cleaned = entry.embedding
+        .filter((n) => typeof n === 'number' && Number.isFinite(n))
+        .slice(0, 4096);
+      if (cleaned.length > 0) {
+        embedding = cleaned;
+        embeddingProvider = typeof entry.embeddingProvider === 'string' ? entry.embeddingProvider : provider;
+        embeddingModel = typeof entry.embeddingModel === 'string' ? entry.embeddingModel : model;
+      }
+    }
+    cache.labels[communityId] = {
+      label,
+      confidence,
+      evidenceNodes,
+      labeledAt: now,
+      provider,
+      model,
+      ...(embedding ? { embedding, embeddingProvider, embeddingModel } : {}),
+    };
+    merged++;
+  }
+
+  await saveCache(cachePath, cache);
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ok: true, merged, total: Object.keys(cache.labels).length }));
+}
+
+export async function handleSemanticLabelsRoute(req, url, res, opts) {
+  if (url.pathname !== '/semantic-labels') return false;
+  if (req.method === 'GET') {
+    await handleGet(url, res, opts);
+    return true;
+  }
+  if (req.method === 'POST') {
+    await handlePost(url, req, res, opts);
+    return true;
+  }
+  return false;
+}
