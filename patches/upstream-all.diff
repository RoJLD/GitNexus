+    return;
+  }
+
+  const repoPath = resolveBrowsePath(repo.repoPath || repo.path);
+  if (!repoPath) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'repo path is outside the mounted projects root' }));
+    return;
