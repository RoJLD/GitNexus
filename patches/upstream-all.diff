diff --git a/gitnexus-web/src/components/GanttPanel.tsx b/gitnexus-web/src/components/GanttPanel.tsx
new file mode 100644
index 0000000..614d86c
--- /dev/null
+++ b/gitnexus-web/src/components/GanttPanel.tsx
@@ -0,0 +1,461 @@
+/**
+ * GanttPanel — fetch /ghosts, compute Gantt layout, render SVG + CSV export.
+ *
+ * Container component. Wraps :
+ *   - data fetch via ghosts-client.fetchGhosts(repo) (30s cache)
+ *   - layout via computeTimeWindow + computeGanttRows + dateScale
+ *   - render via GanttAxis + GanttRow (one <g> per row)
+ *   - CSV export button (download "ghosts-{repo}.csv")
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-gantt-design.md
+ */
+
+import { useEffect, useMemo, useState } from 'react';
+import {
+  computeTimeWindow,
+  computeGanttRows,
+  dateScale,
+  type GanttRow as GanttRowData,
+  type GhostInput,
+} from '../lib/gantt-layout';
+import { fetchGhosts, type GhostRuntime } from '../services/ghosts-client';
+import {
+  passesFilter,
+  derivedStatus,
+  DEFAULT_GHOST_FILTERS,
+  type GhostFilters,
+} from '../lib/ghost-layout';
+import { assignSwimlanes } from '../lib/cluster-layout';
+import {
+  fetchClusters,
+  type ClusterRuntime,
+} from '../services/clusters-client';
+import GanttAxis from './gantt/GanttAxis';
+import GanttRow from './gantt/GanttRow';
+
+type Props = {
+  repo: string;
+  onGhostSelect?: (id: string) => void;
+  /**
+   * Optional filter state — shared with the Augmented graph layer so a
+   * single Tier / status toggle drives both views. When omitted, we
+   * fall back to DEFAULT_GHOST_FILTERS with `showGhosts: true` so the
+   * Gantt is visible by default (the Augmented graph default is hidden
+   * because it's an overlay; the Gantt is its own panel).
+   */
+  ghostFilters?: GhostFilters;
+};
+
+const GANTT_DEFAULT_FILTERS: GhostFilters = {
+  ...DEFAULT_GHOST_FILTERS,
+  showGhosts: true,
+  showCancelled: true,
+};
+
+const LABEL_WIDTH = 200;
+const ROW_HEIGHT = 24;
+const AXIS_HEIGHT = 30;
+const BAR_AREA_WIDTH = 900;
+
+function ghostsToInputs(ghosts: GhostRuntime[]): GhostInput[] {
+  return ghosts.map((g) => ({
+    id: g.id,
+    plannedAt: g.plannedAt ? { date: g.plannedAt.date } : null,
+    materializedAt: g.materializedAt ? { date: g.materializedAt.date } : null,
+    cancelledAt: g.cancelledAt ? { date: g.cancelledAt.date } : null,
+    declared: {
+      plannedFor: (g.declared as { plannedFor?: string | null })?.plannedFor ?? null,
+      tier: g.declared?.tier ?? null,
+      title: g.declared?.title,
+      expectedBy: g.declared?.expectedBy ?? null,
+    },
+  }));
+}
+
+type SwimlaneGroup = { tier: string; rows: GanttRowData[] };
+
+function groupByTier(rows: GanttRowData[]): SwimlaneGroup[] {
+  const groups = new Map<string, GanttRowData[]>();
+  for (const r of rows) {
+    const major = r.tier ? String(r.tier).split('.')[0] : 'none';
+    if (!groups.has(major)) groups.set(major, []);
+    groups.get(major)!.push(r);
+  }
+  // Sort groups by major-tier label so "1" < "2" < "3" < "none".
+  return [...groups.entries()]
+    .sort((a, b) => {
+      if (a[0] === 'none') return 1;
+      if (b[0] === 'none') return -1;
+      return a[0].localeCompare(b[0]);
+    })
+    .map(([tier, groupRows]) => ({ tier, rows: groupRows }));
+}
+
+function tierGroupLabel(tier: string): string {
+  if (tier === 'none') return 'No tier';
+  return `Tier ${tier}`;
+}
+
+/**
+ * Collapse the rows of a cluster lane into a single synthetic Gantt
+ * row. Start = min(plannedAt) across members; end = the latest
+ * materializedAt fallback to the latest expectedBy / cancelledAt the
+ * member rows already carry. Used when `showOnlyClusterBars` is on.
+ */
+function collapseClusterRows(
+  cluster: ClusterRuntime,
+  rows: GanttRowData[],
+): GanttRowData {
+  let minStart: string | undefined;
+  let maxEnd: string | undefined;
+  for (const r of rows) {
+    for (const b of r.bars) {
+      if (b.startDate && (!minStart || b.startDate < minStart)) minStart = b.startDate;
+      if (b.endDate && (!maxEnd || b.endDate > maxEnd)) maxEnd = b.endDate;
+    }
+  }
+  // Pick a bar kind that GanttBar already knows how to render. Shipped
+  // clusters land on `solid`; expired/planned use `dashed` (a forecast
+  // band); cancelled uses `grey`. This avoids teaching GanttBar a new
+  // shape just for the synthetic cluster bar — Tier 3 follow-up.
+  let kind: 'solid' | 'dashed' | 'grey' = 'dashed';
+  if (cluster.synthesizedStatus === 'shipped') kind = 'solid';
+  else if (cluster.synthesizedStatus === 'cancelled') kind = 'grey';
+  const color =
+    cluster.source === 'declared' ? '#7c3aed' /* violet */ : '#f59e0b' /* amber */;
+  return {
+    ghostId: `cluster:${cluster.id}`,
+    title: cluster.title,
+    tier: null,
+    status: cluster.synthesizedStatus === 'shipped' ? 'materialized' : cluster.synthesizedStatus,
+    bars: [
+      {
+        kind,
+        color,
+        startDate: minStart ?? null,
+        endDate: maxEnd ?? null,
+      },
+    ],
+  } as unknown as GanttRowData;
+}
+
+function rowsToCsv(rows: GanttRowData[]): string {
+  const header = 'ghostId,title,tier,status,bar_kind,bar_start,bar_end';
+  const lines: string[] = [header];
+  for (const r of rows) {
+    for (const b of r.bars) {
+      const safe = (s: string) => `"${s.replace(/"/g, '""')}"`;
+      lines.push(
+        [
+          safe(r.ghostId),
+          safe(r.title),
+          safe(r.tier ?? ''),
+          safe(r.status),
+          safe(b.kind),
+          safe(b.startDate ?? ''),
+          safe(b.endDate ?? ''),
+        ].join(','),
+      );
+    }
+  }
+  return lines.join('\n');
+}
+
+function triggerCsvDownload(csv: string, filename: string) {
+  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
+  const url = URL.createObjectURL(blob);
+  const a = document.createElement('a');
+  a.href = url;
+  a.download = filename;
+  document.body.appendChild(a);
+  a.click();
+  document.body.removeChild(a);
+  URL.revokeObjectURL(url);
+}
+
+const GROUP_HEADER_HEIGHT = 22;
+
+/** Swimlane modes are 3-state since Task 12 (Ghost Cluster Section G).
+ *  - `flat`    : default, one row per ghost, no group headers.
+ *  - `tier`    : group by major tier (1/2/3/none), historical behavior.
+ *  - `cluster` : group by declared / auto cluster (uses `assignSwimlanes`
+ *                from cluster-layout.ts). Ghosts that belong to no
+ *                cluster fall into the "Unclustered" lane at the bottom.
+ */
+export type GanttSwimlaneMode = 'flat' | 'tier' | 'cluster';
+
+export default function GanttPanel({ repo, onGhostSelect, ghostFilters }: Props) {
+  const [ghosts, setGhosts] = useState<GhostRuntime[] | null>(null);
+  const [error, setError] = useState<string | null>(null);
+  const [swimlaneMode, setSwimlaneMode] = useState<GanttSwimlaneMode>('flat');
+  const [showOnlyClusterBars, setShowOnlyClusterBars] = useState(false);
+  const [clusters, setClusters] = useState<ClusterRuntime[] | null>(null);
+
+  // Use the caller's filters when provided, otherwise the Gantt-local
+  // default (showGhosts: true, showCancelled: true) so the panel is
+  // usable as a standalone view.
+  const effectiveFilters = ghostFilters ?? GANTT_DEFAULT_FILTERS;
+
+  useEffect(() => {
+    let cancelled = false;
+    setError(null);
+    setGhosts(null);
+    fetchGhosts(repo)
+      .then((data) => {
+        if (cancelled) return;
+        if (data === null) {
+          setError('not-synced');
+          return;
+        }
+        setGhosts(data.ghosts ?? []);
+      })
+      .catch((err: Error) => {
+        if (!cancelled) setError(err.message);
+      });
+    return () => {
+      cancelled = true;
+    };
+  }, [repo]);
+
+  // Clusters — fetched lazily; only consumed when the swimlane mode
+  // is `cluster`. The shared 30 s cache means switching back and forth
+  // between modes is free after the first hit.
+  useEffect(() => {
+    if (swimlaneMode !== 'cluster') return;
+    let cancelled = false;
+    fetchClusters(repo)
+      .then((data) => {
+        if (cancelled) return;
+        setClusters(data?.clusters ?? []);
+      })
+      .catch(() => {
+        if (cancelled) return;
+        setClusters([]);
+      });
+    return () => {
+      cancelled = true;
+    };
+  }, [repo, swimlaneMode]);
+
+  // Filter the runtime ghosts BEFORE projecting into layout inputs.
+  // Reuses `passesFilter` from ghost-layout so the Gantt agrees with
+  // the Augmented graph on what's visible (Tier/status gating).
+  const filteredRuntime = useMemo<GhostRuntime[]>(() => {
+    if (!ghosts) return [];
+    return ghosts.filter((g) =>
+      passesFilter(
+        {
+          id: g.id ?? '',
+          title: g.declared?.title ?? '',
+          tier: g.declared?.tier ?? null,
+          status: derivedStatus(g),
+          expectedLinks: g.declared?.expectedLinks ?? [],
+        },
+        effectiveFilters,
+      ),
+    );
+  }, [ghosts, effectiveFilters]);
+
+  const inputs = useMemo<GhostInput[]>(
+    () => ghostsToInputs(filteredRuntime),
+    [filteredRuntime],
+  );
+
+  if (error === 'not-synced') {
+    return <div className="gantt-panel">Roadmap not synced. Run sync first.</div>;
+  }
+  if (error) {
+    return <div className="gantt-panel">Error: {error}</div>;
+  }
+  if (!ghosts) {
+    return <div className="gantt-panel">Loading gantt…</div>;
+  }
+  if (inputs.length === 0) {
+    // Distinguish "no ghosts at all" from "all filtered out" so the user
+    // knows whether to sync the roadmap or relax their filters.
+    const message =
+      ghosts.length === 0
+        ? 'No ghosts found.'
+        : 'No ghosts match the current filters.';
+    return <div className="gantt-panel">{message}</div>;
+  }
+
+  const now = new Date();
+  const timeWindow = computeTimeWindow(inputs, { now });
+  const rows = computeGanttRows(inputs, { now });
+  const scale = dateScale(timeWindow, BAR_AREA_WIDTH);
+
+  if (rows.length === 0) {
+    return <div className="gantt-panel">No ghosts found.</div>;
+  }
+
+  const onExportCsv = () => {
+    const csv = rowsToCsv(rows);
+    triggerCsvDownload(csv, `ghosts-${repo}.csv`);
+  };
+
+  // Build either a flat row list or grouped swimlanes for rendering.
+  // We compute pre-positioned items so the SVG render loop is a single
+  // pass — much easier to scan than nested loops with running offsets.
+  type RenderItem =
+    | { kind: 'row'; row: GanttRowData; y: number }
+    | { kind: 'header'; label: string; y: number };
+
+  const items: RenderItem[] = [];
+  let cursorY = AXIS_HEIGHT;
+  if (swimlaneMode === 'tier') {
+    const groups = groupByTier(rows);
+    for (const group of groups) {
+      items.push({ kind: 'header', label: tierGroupLabel(group.tier), y: cursorY });
+      cursorY += GROUP_HEADER_HEIGHT;
+      for (const row of group.rows) {
+        items.push({ kind: 'row', row, y: cursorY });
+        cursorY += ROW_HEIGHT;
+      }
+    }
+  } else if (swimlaneMode === 'cluster') {
+    // Cluster lanes via the pure `assignSwimlanes` helper, which sorts
+    // clusters by min(plannedAt) ASC and folds the unclustered ghosts
+    // into a final "Unclustered" lane.
+    const lanes = assignSwimlanes(rows, clusters ?? []);
+    for (const lane of lanes) {
+      // Look up the matching cluster object so the header can carry
+      // the synthesizedStatus + completion %. `Unclustered` has no
+      // match in `clusters` — we just render the title.
+      const cluster =
+        clusters?.find((c) => c.title === lane.lane || c.id === lane.lane) ?? null;
+      const headerLabel = cluster
+        ? `${cluster.title} · ${cluster.aggregate.completionPct.toFixed(0)}% · ${cluster.synthesizedStatus}`
+        : lane.lane;
+      items.push({ kind: 'header', label: headerLabel, y: cursorY });
+      cursorY += GROUP_HEADER_HEIGHT;
+      if (showOnlyClusterBars && cluster && lane.rows.length > 0) {
+        const collapsed = collapseClusterRows(cluster, lane.rows);
+        items.push({ kind: 'row', row: collapsed, y: cursorY });
+        cursorY += ROW_HEIGHT;
+      } else {
+        for (const row of lane.rows) {
+          items.push({ kind: 'row', row, y: cursorY });
+          cursorY += ROW_HEIGHT;
+        }
+      }
+    }
+  } else {
+    for (const row of rows) {
+      items.push({ kind: 'row', row, y: cursorY });
+      cursorY += ROW_HEIGHT;
+    }
+  }
+  const svgHeight = cursorY;
+
+  return (
+    <div className="gantt-panel" data-testid="gantt-panel">
+      <header style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
+        <h3 style={{ margin: 0 }}>Gantt roadmap</h3>
+        <div
+          role="radiogroup"
+          aria-label="Swimlane mode"
+          style={{ display: 'flex', alignItems: 'center', gap: 8 }}
+          data-testid="gantt-swimlanes-radio"
+        >
+          <label style={{ display: 'flex', alignItems: 'center', gap: 4 }}>
+            <input
+              type="radio"
+              name="gantt-swimlanes"
+              value="flat"
+              checked={swimlaneMode === 'flat'}
+              onChange={() => setSwimlaneMode('flat')}
+              data-testid="gantt-swimlanes-flat"
+            />
+            Flat
+          </label>
+          <label style={{ display: 'flex', alignItems: 'center', gap: 4 }}>
+            <input
+              type="radio"
+              name="gantt-swimlanes"
+              value="tier"
+              checked={swimlaneMode === 'tier'}
+              onChange={() => setSwimlaneMode('tier')}
+              data-testid="gantt-swimlanes-tier"
+            />
+            By Tier
+          </label>
+          <label style={{ display: 'flex', alignItems: 'center', gap: 4 }}>
+            <input
+              type="radio"
+              name="gantt-swimlanes"
+              value="cluster"
+              checked={swimlaneMode === 'cluster'}
+              onChange={() => setSwimlaneMode('cluster')}
+              data-testid="gantt-swimlanes-cluster"
+            />
+            By Cluster
+          </label>
+        </div>
+        {swimlaneMode === 'cluster' && (
+          <label style={{ display: 'flex', alignItems: 'center', gap: 4 }}>
+            <input
+              type="checkbox"
+              checked={showOnlyClusterBars}
+              onChange={(e) => setShowOnlyClusterBars(e.target.checked)}
+              data-testid="gantt-show-only-cluster-bars"
+            />
+            Cluster bars only
+          </label>
+        )}
+        <button
+          type="button"
+          onClick={onExportCsv}
+          data-testid="gantt-export-csv"
+        >
+          Export CSV
+        </button>
+      </header>
+      <svg width={LABEL_WIDTH + BAR_AREA_WIDTH} height={svgHeight}>
+        <g transform={`translate(${LABEL_WIDTH}, 0)`}>
+          <GanttAxis
+            window={timeWindow}
+            width={BAR_AREA_WIDTH}
+            height={AXIS_HEIGHT}
+            now={now}
+          />
+        </g>
+        {items.map((item, i) => {
+          if (item.kind === 'header') {
+            return (
+              <g key={`hdr-${i}`} className="gantt-swimlane-header">
+                <rect
+                  x={0}
+                  y={item.y}
+                  width={LABEL_WIDTH + BAR_AREA_WIDTH}
+                  height={GROUP_HEADER_HEIGHT}
+                  fill="#1f1f1f"
+                />
+                <text
+                  x={6}
+                  y={item.y + GROUP_HEADER_HEIGHT / 2 + 4}
+                  fontSize={12}
+                  fill="#bbb"
+                  fontWeight={600}
+                >
+                  {item.label}
+                </text>
+              </g>
+            );
+          }
+          return (
+            <GanttRow
+              key={item.row.ghostId}
+              row={item.row}
+              scale={scale}
+              y={item.y}
+              height={ROW_HEIGHT}
+              labelWidth={LABEL_WIDTH}
+              onClick={(id) => onGhostSelect?.(id)}
+            />
+          );
+        })}
+      </svg>
+    </div>
+  );
+}
diff --git a/gitnexus-web/src/components/GhostFiltersSection.tsx b/gitnexus-web/src/components/GhostFiltersSection.tsx
new file mode 100644
index 0000000..303835f
--- /dev/null
+++ b/gitnexus-web/src/components/GhostFiltersSection.tsx
@@ -0,0 +1,194 @@
+/**
+ * GhostFiltersSection — the "Roadmap predictive" filter block embedded
+ * in the FileTreePanel's Filters tab. Lives as its own component so
+ * Task 10's test can render it in isolation without dragging the whole
+ * AppStateProvider into the test environment.
+ *
+ * Hierarchical UX :
+ *   - master toggle "Show ghosts"
+ *   - when on, 3 tier checkboxes ("1", "2", "3")
+ *   - plus a "Show cancelled ghosts" toggle
+ *
+ * Section I / Task 14 of the Ghost Cluster plan adds an independent
+ * sub-block for cluster halos with three knobs : master toggle
+ * "Show cluster halos", an "include auto-clusters" boolean, and a
+ * 3-way radio source filter (both / declared only / auto only). All
+ * three cluster props are optional so existing render sites that only
+ * care about ghosts still type-check.
+ *
+ * Section E / Task 10 of
+ * docs/superpowers/specs/2026-05-26-roadmap-predictive-augmented-graph-design.md
+ * Section I / Task 14 of
+ * docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ */
+
+import type { GhostFilters } from '../lib/ghost-layout';
+
+export type ClusterSourceFilter = 'both' | 'declared' | 'auto';
+
+type Props = {
+  ghostFilters: GhostFilters;
+  setGhostFilters: (next: GhostFilters) => void;
+  showClusterHalos?: boolean;
+  setShowClusterHalos?: (next: boolean) => void;
+  includeAutoClusters?: boolean;
+  setIncludeAutoClusters?: (next: boolean) => void;
+  clusterSourceFilter?: ClusterSourceFilter;
+  setClusterSourceFilter?: (next: ClusterSourceFilter) => void;
+  /** Augmented Timeline (Tier 3.x). When set, renders the "Lock ghosts
+   *  to today's view" sub-toggle below the per-Tier filters. Hidden
+   *  whenever the master "Show ghosts" toggle is off — locking
+   *  something invisible makes no sense. */
+  lockGhostsToHead?: boolean;
+  setLockGhostsToHead?: (next: boolean) => void;
+};
+
+const TIERS = ['1', '2', '3'] as const;
+const CLUSTER_SOURCES: ClusterSourceFilter[] = ['both', 'declared', 'auto'];
+
+export default function GhostFiltersSection({
+  ghostFilters,
+  setGhostFilters,
+  showClusterHalos,
+  setShowClusterHalos,
+  includeAutoClusters,
+  setIncludeAutoClusters,
+  clusterSourceFilter,
+  setClusterSourceFilter,
+  lockGhostsToHead,
+  setLockGhostsToHead,
+}: Props) {
+  const lockToggleEnabled = typeof setLockGhostsToHead === 'function';
+  // Sub-block is rendered when the parent wires the cluster props
+  // through — otherwise we degrade gracefully (e.g. early callers that
+  // only pre-date Task 14).
+  const clusterBlockEnabled =
+    typeof setShowClusterHalos === 'function' && typeof showClusterHalos === 'boolean';
+  return (
+    <section className="filter-section mt-6 border-t border-border-subtle pt-4">
+      <h3 className="mb-2 text-xs font-medium tracking-wide text-text-secondary uppercase">
+        Roadmap predictive
+      </h3>
+      <p className="mb-3 text-[11px] text-text-muted">
+        Overlay planned-but-unbuilt features on the graph
+      </p>
+
+      <label className="flex items-center gap-2 text-xs text-text-primary">
+        <input
+          type="checkbox"
+          checked={ghostFilters.showGhosts}
+          onChange={(e) =>
+            setGhostFilters({ ...ghostFilters, showGhosts: e.target.checked })
+          }
+        />
+        Show ghosts
+      </label>
+
+      {ghostFilters.showGhosts && (
+        <div className="mt-2 flex flex-col gap-1 pl-4">
+          {TIERS.map((t) => (
+            <label key={t} className="flex items-center gap-2 text-xs text-text-secondary">
+              <input
+                type="checkbox"
+                checked={ghostFilters.tiers.includes(t)}
+                onChange={(e) =>
+                  setGhostFilters({
+                    ...ghostFilters,
+                    tiers: e.target.checked
+                      ? [...ghostFilters.tiers, t].sort()
+                      : ghostFilters.tiers.filter((x) => x !== t),
+                  })
+                }
+              />
+              Tier {t}
+            </label>
+          ))}
+          <label className="mt-2 flex items-center gap-2 text-xs text-text-secondary">
+            <input
+              type="checkbox"
+              checked={ghostFilters.showCancelled}
+              onChange={(e) =>
+                setGhostFilters({ ...ghostFilters, showCancelled: e.target.checked })
+              }
+            />
+            Show cancelled ghosts
+          </label>
+
+          {/* Augmented Timeline — lock ghost layer to today's view.
+              When ON, the predictive layer ignores the cursor and
+              renders the live ghost set even when the user scrubs
+              into the past. Off by default; auto-detect takes over. */}
+          {lockToggleEnabled && (
+            <label
+              className="mt-2 flex items-center gap-2 text-xs text-text-secondary"
+              data-testid="lock-ghosts-to-head-label"
+            >
+              <input
+                type="checkbox"
+                checked={!!lockGhostsToHead}
+                onChange={(e) => setLockGhostsToHead?.(e.target.checked)}
+                data-testid="toggle-lock-ghosts-to-head"
+              />
+              Lock ghosts to today's view
+            </label>
+          )}
+        </div>
+      )}
+
+      {clusterBlockEnabled && (
+        <div className="mt-4 border-t border-border-subtle pt-3" data-testid="cluster-filters">
+          <label className="flex items-center gap-2 text-xs text-text-primary">
+            <input
+              type="checkbox"
+              checked={!!showClusterHalos}
+              onChange={(e) => setShowClusterHalos?.(e.target.checked)}
+              data-testid="toggle-show-cluster-halos"
+            />
+            Show cluster halos
+          </label>
+
+          {showClusterHalos && (
+            <div className="mt-2 flex flex-col gap-1 pl-4">
+              <label className="flex items-center gap-2 text-xs text-text-secondary">
+                <input
+                  type="checkbox"
+                  checked={!!includeAutoClusters}
+                  onChange={(e) => setIncludeAutoClusters?.(e.target.checked)}
+                  data-testid="toggle-include-auto-clusters"
+                />
+                Include auto-clusters
+              </label>
+              <div
+                role="radiogroup"
+                aria-label="Cluster source filter"
+                data-testid="cluster-source-radio"
+                className="mt-1 flex flex-col gap-1"
+              >
+                {CLUSTER_SOURCES.map((src) => (
+                  <label
+                    key={src}
+                    className="flex items-center gap-2 text-xs text-text-secondary"
+                  >
+                    <input
+                      type="radio"
+                      name="cluster-source-filter"
+                      value={src}
+                      checked={(clusterSourceFilter ?? 'both') === src}
+                      onChange={() => setClusterSourceFilter?.(src)}
+                      data-testid={`cluster-source-${src}`}
+                    />
+                    {src === 'both'
+                      ? 'Both (declared + auto)'
+                      : src === 'declared'
+                        ? 'Declared only'
+                        : 'Auto only'}
+                  </label>
+                ))}
+              </div>
+            </div>
+          )}
+        </div>
+      )}
+    </section>
+  );
+}
diff --git a/gitnexus-web/src/components/GhostTooltip.tsx b/gitnexus-web/src/components/GhostTooltip.tsx
