+import { describe, it, expect } from 'vitest';
+import { render, screen } from '@testing-library/react';
+import { CanvasMultigraph } from '@/components/CanvasMultigraph';
+
+describe('CanvasMultigraph', () => {
+  it('shows placeholder when no graph selected', () => {
+    render(<CanvasMultigraph selectedGraph={null} zoomLevel="meta" />);
+    expect(screen.getByText(/select a graph/i)).toBeInTheDocument();
+  });
+
+  it('renders graph name when selected', () => {
+    render(<CanvasMultigraph selectedGraph={{
+      name: 'ASTKG', path: '/x', schema_type: 'code-cognition', ttl_snapshot_hours: 1, privacy_class: 'SHARED'
+    }} zoomLevel="graph" />);
+    expect(screen.getByText(/ASTKG/)).toBeInTheDocument();
+  });
+
+  it('zoom level controls rendering mode', () => {
+    const { rerender } = render(<CanvasMultigraph selectedGraph={null} zoomLevel="meta" />);
+    expect(screen.getByTestId('canvas-mode')).toHaveTextContent('meta');
+    rerender(<CanvasMultigraph selectedGraph={null} zoomLevel="graph" />);
+    expect(screen.getByTestId('canvas-mode')).toHaveTextContent('graph');
+  });
+});
