+        <div className="mt-1 rounded border border-amber-500/30 bg-amber-500/5 px-2 py-1 text-[9px] text-amber-200">
+          <span className="font-semibold">{commitFootprint.unresolvedFiles.length} unresolved:</span>{' '}
+          files touched by the commit but not present in the current snapshot's graph (likely
+          deletions, renames the graph didn't follow, or files gitnexus doesn't track).
+        </div>
+      )}
+      {commitFootprintError && (
+        <div className="mt-1 flex items-start gap-1.5 px-1 py-1 text-[10px] text-red-400">
+          <AlertCircle className="mt-0.5 h-3 w-3 shrink-0" />
+          <span className="break-all font-mono">{commitFootprintError}</span>
+        </div>
+      )}
+
+      {/* Reconstructed-graph banner (Phase C). The canvas is showing the
+          graph rebuilt at atCommitSha — make that unmissable and offer a
+          one-click return to the live graph. */}
+      {atCommitActive && atCommitSha && (
+        <div className="mt-1 flex items-center gap-2 rounded border border-violet-500/40 bg-violet-500/10 px-2 py-1 text-[10px] text-violet-200">
+          <History className="h-3 w-3 shrink-0" />
+          <span className="min-w-0 flex-1 break-all">
+            <span className="font-semibold">Reconstructed graph @ {atCommitSha.slice(0, 7)}</span>
+            {atCommitMeta && (
+              <>
+                {' '}— {atCommitMeta.reconstructedCounts.nodes.toLocaleString()} nodes ·{' '}
+                {atCommitMeta.reconstructedCounts.relationships.toLocaleString()} rels · baseline{' '}
+                {atCommitMeta.baselineShortSha}
+                {atCommitMeta.distance > 0 ? ` +${atCommitMeta.distance} diffs` : ' (exact)'}
+                {atCommitMeta.filterConsistency !== 'consistent' && (
+                  <span className="ml-1 text-amber-300" title="The replayed diffs were captured under different filter chains; structural fidelity holds but counts may vary.">
+                    · mixed filters
+                  </span>
+                )}
+              </>
+            )}
+          </span>
+          <button
+            type="button"
+            onClick={() => exitGraphAtCommit()}
+            className="shrink-0 cursor-pointer rounded border border-violet-500/40 bg-violet-500/15 px-1.5 py-0.5 font-medium text-violet-200 transition-all hover:bg-violet-500/25"
+            title="Restore the live graph"
+          >
+            Back to live
+          </button>
+        </div>
+      )}
+
+      {/* Missing diffs in the replay chain → offer lazy generation. */}
+      {atCommitMissingDiffs > 0 && (selected || atCommitSha) && (
+        <div className="mt-1 flex items-center gap-2 rounded border border-amber-500/30 bg-amber-500/5 px-2 py-1 text-[9px] text-amber-200">
+          <span className="min-w-0 flex-1">
+            <span className="font-semibold">{atCommitMissingDiffs} diff(s) missing</span> from the
+            replay chain — generate them on demand to reconstruct this commit (slower; runs analyze
+            per missing step).
+          </span>
+          <button
+            type="button"
+            disabled={atCommitLoading}
+            onClick={() => {
+              const sha = atCommitSha || selected?.sha;
+              if (sha) void loadGraphAtCommit(sha, { lazy: true });
+            }}
+            className="shrink-0 cursor-pointer rounded border border-amber-500/40 bg-amber-500/15 px-1.5 py-0.5 font-medium text-amber-100 transition-all hover:bg-amber-500/25 disabled:cursor-not-allowed disabled:opacity-40"
+          >
+            {atCommitLoading ? 'Generating…' : 'Generate & retry'}
+          </button>
+        </div>
+      )}
+
+      {atCommitError && atCommitMissingDiffs === 0 && (
+        <div className="mt-1 flex items-start gap-1.5 px-1 py-1 text-[10px] text-red-400">
+          <AlertCircle className="mt-0.5 h-3 w-3 shrink-0" />
+          <span className="break-all font-mono">{atCommitError}</span>
+        </div>
+      )}
+    </div>
+  );
+};
