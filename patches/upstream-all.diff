+
+type SimilarityRepo = {
+  name: string;
+  identityVector: Record<string, number>;
+  stats: {
+    nodes: number;
+    edges: number;
+    communities: number;
+    authorsCount: number;
+    busFactor: number;
+  };
+  hasGit: boolean;
+  gitError: string | null;
+  licensePresent: boolean;
+  policy: { isolation_required: boolean; reason: string | null; allow_merge_with: string[] } | null;
+  lastCommitDate: string | null;
+  semanticLabelsCount: number;
+  semanticEmbeddingsCount: number;
+  hasLabelCentroid: boolean;
+  galaxyXY: [number, number] | null;
+};
+
+type SimilarityPair = {
+  a: string;
+  b: string;
+  structuralScore: number;
+  semanticScore: number | null;
+  semanticMode: 'embeddings' | 'lexical' | 'none';
+  temporalCoupling: number;
+  quadrant: string;
+  recommendation: string | null;
+  warnings: string[];
+  dominantFeatures: string[];
+  policyApplied: { isolationRequired?: boolean; reasons?: string[]; whitelisted?: boolean } | null;
+};
+
+type SimilarityData = {
+  repos: SimilarityRepo[];
+  pairs: SimilarityPair[];
+  thresholds: { structural: number; semantic: number; temporal: number };
+  windowDays: number;
+  identityVersion: number;
+  identityDims: string[];
+  semanticAxisAvailable: boolean;
+  semanticAxisMode: 'lexical' | 'embeddings' | 'disabled';
+  reposWithLabels: number;
+  reposWithCentroid: number;
+  semanticAxisNote: string;
+  galaxyProjection: { method: 'pca'; dim: 2 } | null;
+};
+
