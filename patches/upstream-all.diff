+/**
+ * Pure utilities for diffing two gitnexus graphs.
+ *
+ * Diff identity: we match nodes by `id` (path-based + content-hash, stable
+ * across exports of the same source code). Edges are matched by the
+ * (sourceId, targetId, type) triple. Two indexes built from the same git
+ * commit will diff cleanly to "all in both"; a sender with a few extra
+ * functions will show those as `onlyInB`.
+ *
+ * We deliberately skip semantic node comparison (file contents, line
+ * numbers, etc.) for the MVP — those add a lot of UI noise and can be
+ * surfaced later via a "modified" bucket once we have signatures.
+ */
+import type { GraphNode, GraphRelationship } from 'gitnexus-shared';
+
+export type DiffStatus = 'onlyInA' | 'onlyInB' | 'inBoth';
+
+export interface GraphDiff {
+  /** Per-node diff status, keyed by node id. Built from the union of A∪B. */
+  nodeStatus: Map<string, DiffStatus>;
+  /** Per-edge diff status, keyed by `${source}::${type}::${target}`. */
+  edgeStatus: Map<string, DiffStatus>;
+  /** Union of nodes from both graphs, deduped by id. */
+  unionNodes: GraphNode[];
+  /** Union of edges from both graphs, deduped by (source, type, target). */
+  unionEdges: GraphRelationship[];
+  /** Counts (handy for the stats banner so we don't recompute). */
+  counts: {
+    nodes: { onlyInA: number; onlyInB: number; inBoth: number };
+    edges: { onlyInA: number; onlyInB: number; inBoth: number };
+  };
+}
+
+const edgeKey = (e: GraphRelationship) => `${e.sourceId}::${e.type}::${e.targetId}`;
+
+export function computeGraphDiff(
+  graphA: { nodes: GraphNode[]; relationships: GraphRelationship[] },
+  graphB: { nodes: GraphNode[]; relationships: GraphRelationship[] },
+): GraphDiff {
+  const idsA = new Set(graphA.nodes.map((n) => n.id));
+  const idsB = new Set(graphB.nodes.map((n) => n.id));
+
+  const nodeStatus = new Map<string, DiffStatus>();
+  const unionNodes: GraphNode[] = [];
+  const seenNodes = new Set<string>();
+
+  // A pass: nodes from A. Each is either onlyInA (not in B) or inBoth.
+  for (const n of graphA.nodes) {
+    seenNodes.add(n.id);
+    nodeStatus.set(n.id, idsB.has(n.id) ? 'inBoth' : 'onlyInA');
+    unionNodes.push(n);
+  }
+  // B pass: only add nodes not seen in A.
+  for (const n of graphB.nodes) {
+    if (seenNodes.has(n.id)) continue;
+    nodeStatus.set(n.id, 'onlyInB');
+    unionNodes.push(n);
+  }
+
+  // Edges follow the same pattern but keyed by the (source, type, target)
+  // triple. Edges incident to nodes that exist in both graphs are still
+  // legitimately onlyInA/onlyInB if the edge itself differs (e.g. a new call
+  // relationship was added on the sender's side).
+  const keysA = new Set(graphA.relationships.map(edgeKey));
+  const keysB = new Set(graphB.relationships.map(edgeKey));
+
+  const edgeStatus = new Map<string, DiffStatus>();
+  const unionEdges: GraphRelationship[] = [];
+  const seenEdges = new Set<string>();
+
+  for (const e of graphA.relationships) {
+    const k = edgeKey(e);
+    seenEdges.add(k);
+    edgeStatus.set(k, keysB.has(k) ? 'inBoth' : 'onlyInA');
+    unionEdges.push(e);
+  }
+  for (const e of graphB.relationships) {
+    const k = edgeKey(e);
+    if (seenEdges.has(k)) continue;
+    edgeStatus.set(k, 'onlyInB');
+    unionEdges.push(e);
+  }
+
+  let nA = 0;
+  let nB = 0;
+  let nBoth = 0;
+  for (const s of nodeStatus.values()) {
+    if (s === 'onlyInA') nA++;
+    else if (s === 'onlyInB') nB++;
+    else nBoth++;
+  }
+  let eA = 0;
+  let eB = 0;
+  let eBoth = 0;
+  for (const s of edgeStatus.values()) {
+    if (s === 'onlyInA') eA++;
+    else if (s === 'onlyInB') eB++;
+    else eBoth++;
+  }
+
+  return {
+    nodeStatus,
+    edgeStatus,
+    unionNodes,
+    unionEdges,
+    counts: {
+      nodes: { onlyInA: nA, onlyInB: nB, inBoth: nBoth },
+      edges: { onlyInA: eA, onlyInB: eB, inBoth: eBoth },
+    },
+  };
+}
