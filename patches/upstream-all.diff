+// labels actually appear in. Kept short on purpose: we want to filter
+// the obvious noise ("the", "of", "et", "la") without accidentally
+// dropping content words. Token frequency does most of the work; the
+// stopword list is just a polish step.
+const STOPWORDS = new Set([
+  // English
+  'the', 'and', 'or', 'a', 'an', 'of', 'to', 'in', 'on', 'for', 'with',
+  'by', 'from', 'at', 'as', 'is', 'are', 'be', 'was', 'were', 'this',
+  'that', 'these', 'those', 'it', 'its', 'into', 'over', 'between',
+  // French
+  'le', 'la', 'les', 'un', 'une', 'des', 'de', 'du', 'et', 'ou', 'à',
+  'au', 'aux', 'dans', 'pour', 'avec', 'par', 'sur', 'sous', 'sans',
+  'son', 'sa', 'ses', 'ce', 'cette', 'ces', 'qui', 'que', 'quoi', 'dont',
+]);
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+async function readMeta(repoPath) {
+  try {
+    return JSON.parse(await readFile(join(repoPath, '.gitnexus', 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+// Tier 2bis.4: policy read via the unified config parser. Falls back
+// to .gitnexus-policy.json with deprecation warning. Returns null when
+// no policy is declared (most common case). Returns { _error } on
+// malformed JSON so the caller can surface it without aborting the
+// pair scan.
+async function readPolicy(repoPath) {
+  try {
+    const cfg = await getConfig(repoPath);
+    return cfg.policy;
+  } catch (err) {
+    return { _error: err.message };
+  }
+}
+
+async function readSemanticLabels(repoPath) {
+  try {
+    const raw = await readFile(join(repoPath, ...SEMANTIC_LABELS_PATH), 'utf8');
+    const parsed = JSON.parse(raw);
+    // Cache shape: { schemaVersion: 1, labels: { commId: { label, ... } } }
+    if (!parsed || typeof parsed.labels !== 'object') {
+      return { labels: [], embeddings: [], embeddingDim: 0 };
+    }
+    const labels = [];
+    const embeddings = [];
+    let embeddingDim = 0;
+    for (const entry of Object.values(parsed.labels)) {
+      if (!entry || typeof entry.label !== 'string' || entry.label.length === 0) continue;
+      labels.push(entry.label);
+      if (Array.isArray(entry.embedding) && entry.embedding.length > 0) {
+        if (embeddingDim === 0) embeddingDim = entry.embedding.length;
+        // Skip dimensionality mismatches — usually means the user
+        // switched embedding models. centroid cosine is meaningless
+        // across different vector spaces.
+        if (entry.embedding.length === embeddingDim) {
+          embeddings.push(entry.embedding);
+        }
+      }
+    }
+    return { labels, embeddings, embeddingDim };
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return { labels: [], embeddings: [], embeddingDim: 0 };
+    return { labels: [], embeddings: [], embeddingDim: 0 };
+  }
+}
+
+// Centroid of a list of vectors. Returns null if empty.
+function centroid(vectors) {
+  if (!vectors || vectors.length === 0) return null;
+  const dim = vectors[0].length;
+  const c = new Array(dim).fill(0);
+  for (const v of vectors) {
+    if (v.length !== dim) return null;
+    for (let i = 0; i < dim; i++) c[i] += v[i];
+  }
+  for (let i = 0; i < dim; i++) c[i] /= vectors.length;
+  return c;
+}
+
+function cosineDense(a, b) {
+  if (!a || !b || a.length !== b.length) return 0;
+  let dot = 0;
+  let na = 0;
+  let nb = 0;
+  for (let i = 0; i < a.length; i++) {
+    dot += a[i] * b[i];
+    na += a[i] * a[i];
+    nb += b[i] * b[i];
+  }
+  if (na === 0 || nb === 0) return 0;
+  return dot / (Math.sqrt(na) * Math.sqrt(nb));
+}
+
+function tokenizeLabel(text) {
+  // Lower + split on anything that isn't a letter/digit (keeps unicode
+  // letters thanks to \p{L}/\p{N}). Drop short tokens and stopwords.
+  return text
+    .toLowerCase()
+    .split(/[^\p{L}\p{N}]+/u)
+    .filter((tok) => tok.length >= 3 && !STOPWORDS.has(tok));
+}
+
+function bowVectorFromLabels(labels) {
+  // Unit weight per label — labeled communities are roughly comparable
+  // in scope (community detection produces communities of broadly
+  // similar size). Weighting by community member count would skew
+  // toward huge communities and overpower the long tail. Keep it flat.
+  const v = new Map();
+  for (const label of labels) {
+    const tokens = tokenizeLabel(label);
+    const seen = new Set();
+    for (const t of tokens) {
+      // Count each token once per label (not once per occurrence inside
+      // a single label) — "API API gateway" shouldn't double-count.
+      if (seen.has(t)) continue;
+      seen.add(t);
+      v.set(t, (v.get(t) || 0) + 1);
+    }
+  }
+  return v;
+}
+
+function cosineBow(va, vb) {
+  if (va.size === 0 || vb.size === 0) return 0;
+  let dot = 0;
+  let na = 0;
+  let nb = 0;
+  for (const [, x] of va) na += x * x;
+  for (const [, y] of vb) nb += y * y;
+  // Iterate the smaller map for dot product.
+  const [small, large] = va.size <= vb.size ? [va, vb] : [vb, va];
+  for (const [t, x] of small) {
+    const y = large.get(t);
+    if (y !== undefined) dot += x * y;
+  }
+  if (na === 0 || nb === 0) return 0;
+  return dot / (Math.sqrt(na) * Math.sqrt(nb));
+}
+
+async function readLicense(repoPath) {
+  for (const name of LICENSE_FILENAMES) {
+    try {
+      const txt = await readFile(join(repoPath, name), 'utf8');
+      return txt.trim();
+    } catch (err) {
+      if (!err || err.code !== 'ENOENT') return null;
+    }
+  }
+  return null;
+}
+
+// Live entropy: density + modularity from meta.json (matches the
+// /entropy endpoint's `compute()` for the live point).
+function entropyFromStats(stats) {
+  const nodes = Number(stats?.nodes) || 0;
+  const edges = Number(stats?.edges) || 0;
+  const communities = Number(stats?.communities) || 0;
+  const denom = nodes * (nodes - 1);
+  const density = denom > 0 ? (2 * edges) / denom : 0;
+  const modularity = nodes > 0 ? communities / nodes : 0;
+  return { density, modularity };
+}
+
+// Parse `git log --pretty=format:%an%x09%aI --name-only --no-merges`
+// into { authors: Map<name,commits>, perBucketActivity: Set<bucketId>,
+// lastCommitDate, filesTouched, perFileTouches: Map<path, count> }.
+function parseLogForRepo(stdout, windowMs) {
+  const authors = new Map();
+  const perBucketActivity = new Set();
+  const perFileTouches = new Map();
+  let lastCommitDate = null;
+  let currentAuthor = null;
+  let currentDateMs = null;
+  let filesInThisCommit = 0;
+  let filesTouched = 0;
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      if (currentAuthor !== null && filesInThisCommit > 0) {
+        authors.set(currentAuthor, (authors.get(currentAuthor) || 0) + 1);
+      }
+      currentAuthor = null;
+      currentDateMs = null;
+      filesInThisCommit = 0;
+      continue;
+    }
+    if (currentAuthor === null) {
+      // Header line: "<author>\t<isoDate>"
+      const tab = line.indexOf('\t');
+      if (tab < 0) continue;
+      currentAuthor = line.slice(0, tab);
+      const iso = line.slice(tab + 1);
+      const t = Date.parse(iso);
+      currentDateMs = Number.isFinite(t) ? t : null;
+      if (currentDateMs !== null) {
+        if (lastCommitDate === null || currentDateMs > lastCommitDate) lastCommitDate = currentDateMs;
+        perBucketActivity.add(Math.floor(currentDateMs / windowMs));
+      }
+      continue;
+    }
+    filesInThisCommit++;
+    filesTouched++;
+    perFileTouches.set(line, (perFileTouches.get(line) || 0) + 1);
+  }
+  // Trailing commit (no blank line at EOF).
+  if (currentAuthor !== null && filesInThisCommit > 0) {
+    authors.set(currentAuthor, (authors.get(currentAuthor) || 0) + 1);
+  }
+  return { authors, perBucketActivity, lastCommitDate, filesTouched, perFileTouches };
+}
+
+// 2D PCA projection of an N×D matrix → array of [x, y] per row.
+// Tier 2.6 — used by the Galaxy view to lay repos out in 2D where
+// distance ≈ structural similarity.
+//
+// Why PCA and not UMAP: this codebase has zero embedded-vector deps,
+// and UMAP-js would add ~50 KB to the bundle (or be a server-side
+// dep). For 5-10 repos, PCA captures enough of the variance to be
+// useful — UMAP's local-neighborhood preservation only pays off at
+// hundreds of points. Honest framing: this is "Galaxy v1 = PCA". If
+// we ever index hundreds of repos, 2.6.bis swaps in UMAP.
+//
+// Power-iteration approach (no SVD library needed):
+//   1. center the matrix (subtract column means)
+//   2. compute the D×D covariance matrix
+//   3. find the top 2 eigenvectors by deflated power iteration
+//   4. project: rows × top-2-eigvecs → N×2
+//
+// Edge cases: N<2 → returns null (can't project a single point).
+// N=2 → returns a horizontal line at y=0, points spaced by distance.
+function pcaProject2D(matrix) {
+  const N = matrix.length;
+  if (N < 2) return null;
+  const D = matrix[0].length;
+  if (D === 0) return null;
+  // For N=2, PCA degenerates — just project onto the line connecting them.
+  if (N === 2) {
+    let dot = 0;
+    for (let d = 0; d < D; d++) dot += (matrix[0][d] - matrix[1][d]) ** 2;
+    const dist = Math.sqrt(dot);
+    return [
+      [-dist / 2, 0],
+      [dist / 2, 0],
+    ];
+  }
+  // 1. Centre
+  const mean = new Array(D).fill(0);
+  for (const row of matrix) for (let d = 0; d < D; d++) mean[d] += row[d];
+  for (let d = 0; d < D; d++) mean[d] /= N;
+  const centred = matrix.map((row) => row.map((v, d) => v - mean[d]));
+  // 2. Covariance D×D
+  const cov = Array.from({ length: D }, () => new Array(D).fill(0));
+  for (const row of centred) {
+    for (let i = 0; i < D; i++) {
+      for (let j = i; j < D; j++) {
+        const v = row[i] * row[j];
+        cov[i][j] += v;
+        if (i !== j) cov[j][i] += v;
+      }
+    }
+  }
+  for (let i = 0; i < D; i++) for (let j = 0; j < D; j++) cov[i][j] /= N - 1;
+  // 3. Top-2 eigenvectors via power iteration with deflation
+  const pc1 = topEigenvector(cov, 200);
+  const cov2 = deflate(cov, pc1);
+  const pc2 = topEigenvector(cov2, 200);
+  // 4. Project
+  return centred.map((row) => [dotProd(row, pc1), dotProd(row, pc2)]);
+}
+
+function topEigenvector(matrix, iterations) {
+  const D = matrix.length;
+  // Deterministic seed to make the projection stable across requests —
+  // a random init would rotate the galaxy each refresh, which is
+  // disorienting. Start with a tilted unit vector that's never
