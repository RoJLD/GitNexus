index 0000000..9a7bffb
--- /dev/null
+++ b/gitnexus-web/src/lib/cluster-layout.ts
@@ -0,0 +1,242 @@
+/**
+ * Pure layout helpers for the Ghost Cluster surfaces.
+ *
+ * - Augmented graph overlay: convex-hull polygon halos around cluster
+ *   members, drawn as an SVG layer on top of the Sigma canvas.
+ * - Gantt panel: swimlane assignment (one row per cluster, sorted by
+ *   earliest plannedAt; an "Unclustered" lane at the bottom for ghosts
+ *   that belong to no cluster).
+ *
+ * All functions are pure: no DOM, no fetch, no module-level state.
+ * Tested in tests/unit/cluster-layout.test.mjs.
+ *
+ * See docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ * and docs/superpowers/plans/2026-05-27-roadmap-predictive-ghost-cluster.md
+ * (Tasks 8-9, Sections D-E).
+ */
+
+export type Point = { x: number; y: number };
+
+/**
+ * Andrew's monotone chain convex hull (O(n log n)).
+ *
+ * Returns the hull vertices in counter-clockwise order, with no
+ * duplicated start/end point. Returns a shallow clone of the input
+ * when there are 0 or 1 points (degenerate hull). Duplicate input
+ * points are collapsed implicitly by the cross-product check.
+ */
+export function convexHull(points: Point[]): Point[] {
+  if (!Array.isArray(points)) return [];
+  if (points.length <= 1) return points.map((p) => ({ x: p.x, y: p.y }));
+  // Sort lexicographically (x asc, then y asc).
+  const sorted = [...points].sort((a, b) => a.x - b.x || a.y - b.y);
+  const cross = (O: Point, A: Point, B: Point) =>
+    (A.x - O.x) * (B.y - O.y) - (A.y - O.y) * (B.x - O.x);
+
+  // Lower hull
+  const lower: Point[] = [];
+  for (const p of sorted) {
+    while (lower.length >= 2 && cross(lower[lower.length - 2], lower[lower.length - 1], p) <= 0) {
+      lower.pop();
+    }
+    lower.push(p);
+  }
+  // Upper hull
+  const upper: Point[] = [];
+  for (let i = sorted.length - 1; i >= 0; i--) {
+    const p = sorted[i];
+    while (upper.length >= 2 && cross(upper[upper.length - 2], upper[upper.length - 1], p) <= 0) {
+      upper.pop();
+    }
+    upper.push(p);
+  }
+  // Concatenate lower + upper, dropping the duplicated endpoints.
+  upper.pop();
+  lower.pop();
+  return [...lower, ...upper];
+}
+
+/**
+ * Returns the polygon to draw for a cluster halo.
+ *
+ * - `null` when there are 0 or 1 member positions (caller represents
+ *   the cluster as a circle around the single member, or skips render
+ *   if empty).
+ * - 2-point line when there are exactly 2 members (caller can render
+ *   as a thin pill / capsule).
+ * - Convex hull (>= 3 vertices) otherwise.
+ */
+export function clusterHullPolygon(memberPositions: Point[]): Point[] | null {
+  if (!Array.isArray(memberPositions) || memberPositions.length === 0) return null;
+  if (memberPositions.length === 1) return null;
+  if (memberPositions.length === 2) {
+    return [
+      { x: memberPositions[0].x, y: memberPositions[0].y },
+      { x: memberPositions[1].x, y: memberPositions[1].y },
+    ];
+  }
+  const hull = convexHull(memberPositions);
+  // After de-duplication, the hull may collapse to <3 vertices when
+  // all input points are collinear or coincident — fall back to the
+  // 2-point pill (or null for a singleton).
+  if (hull.length <= 1) return null;
+  if (hull.length === 2) return hull;
+  return hull;
+}
+
+/**
+ * Polygon centroid via the standard signed-area formula. Best suited
+ * to label placement on a convex hull. Degrades gracefully:
+ *
+ * - Empty polygon → `{ x: 0, y: 0 }` (caller should not render).
+ * - Single point → that point.
+ * - Two-point segment → midpoint.
+ * - Polygon with zero signed area (collinear) → arithmetic mean of
+ *   the vertices, which is still a sensible label anchor.
+ */
+export function polygonCentroid(polygon: Point[]): Point {
+  if (!Array.isArray(polygon) || polygon.length === 0) return { x: 0, y: 0 };
+  if (polygon.length === 1) return { x: polygon[0].x, y: polygon[0].y };
+  if (polygon.length === 2) {
+    return {
+      x: (polygon[0].x + polygon[1].x) / 2,
+      y: (polygon[0].y + polygon[1].y) / 2,
+    };
+  }
+  let area = 0;
+  let cx = 0;
+  let cy = 0;
+  const n = polygon.length;
+  for (let i = 0; i < n; i++) {
+    const p1 = polygon[i];
+    const p2 = polygon[(i + 1) % n];
+    const cross = p1.x * p2.y - p2.x * p1.y;
+    area += cross;
+    cx += (p1.x + p2.x) * cross;
+    cy += (p1.y + p2.y) * cross;
+  }
+  area /= 2;
+  if (area === 0) {
+    // Degenerate / collinear polygon — arithmetic mean of vertices.
+    let mx = 0;
+    let my = 0;
+    for (const p of polygon) {
+      mx += p.x;
+      my += p.y;
+    }
+    return { x: mx / n, y: my / n };
+  }
+  return { x: cx / (6 * area), y: cy / (6 * area) };
+}
+
+/**
+ * Gantt swimlane assignment.
+ *
+ * Inputs:
+ * - `rows`: pre-computed Gantt rows, each carrying at least an `id`
+ *   (the ghost id) and a `plannedAt` timestamp (string ISO or null).
+ *   Other fields are passed through untouched.
+ * - `clusters`: cluster objects with `{ id, title, memberIds[] }`.
+ *
+ * Output: ordered `{ lane, rows }` list. Clusters are sorted by the
+ * smallest `plannedAt` among their members (ascending). Ghosts that
+ * belong to no cluster land in a final "Unclustered" lane. A ghost
+ * present in N clusters is duplicated N times (one row per lane); a
+ * ghost simultaneously declared and auto-clustered will still appear
+ * in both lanes — the UI deduplicates labels, not data.
+ */
+export function assignSwimlanes(
+  rows: any[],
+  clusters: any[],
+): { lane: string; rows: any[] }[] {
+  if (!Array.isArray(rows)) rows = [];
+  if (!Array.isArray(clusters)) clusters = [];
+  const rowById = new Map<string, any>();
+  for (const r of rows) {
+    if (r && typeof r.id === 'string') rowById.set(r.id, r);
+  }
+
+  const memberSet = new Set<string>();
+  const clusterLanes: { lane: string; rows: any[]; sortKey: number }[] = [];
+
+  for (const c of clusters) {
+    if (!c || !Array.isArray(c.memberIds)) continue;
+    const laneRows: any[] = [];
+    let minPlanned = Number.POSITIVE_INFINITY;
+    for (const mid of c.memberIds) {
+      const r = rowById.get(mid);
+      if (!r) continue;
+      laneRows.push(r);
+      memberSet.add(mid);
+      const t = parsePlannedAt(r);
+      if (t !== null && t < minPlanned) minPlanned = t;
+    }
+    if (laneRows.length === 0) continue;
+    clusterLanes.push({
+      lane: c.title || c.id || 'cluster',
+      rows: laneRows,
+      // Clusters whose members have no plannedAt sort last among
+      // declared clusters, before the Unclustered lane.
+      sortKey: Number.isFinite(minPlanned) ? minPlanned : Number.POSITIVE_INFINITY,
+    });
+  }
+
+  // Stable sort: clusters by earliest plannedAt ascending; ties keep
+  // insertion order, which matches the declared-then-auto ordering
+  // produced upstream.
+  clusterLanes.sort((a, b) => a.sortKey - b.sortKey);
+
+  const unclustered: any[] = [];
+  for (const r of rows) {
+    if (!r || typeof r.id !== 'string') continue;
+    if (!memberSet.has(r.id)) unclustered.push(r);
+  }
+
+  const out: { lane: string; rows: any[] }[] = clusterLanes.map(({ lane, rows }) => ({ lane, rows }));
+  if (unclustered.length > 0) out.push({ lane: 'Unclustered', rows: unclustered });
+  return out;
+}
+
+function parsePlannedAt(row: any): number | null {
+  if (!row) return null;
+  const raw = row.plannedAt;
+  if (raw == null) return null;
+  if (typeof raw === 'number') return Number.isFinite(raw) ? raw : null;
+  if (typeof raw === 'string') {
+    const t = Date.parse(raw);
+    return Number.isFinite(t) ? t : null;
+  }
+  if (typeof raw === 'object' && typeof raw.date === 'string') {
+    const t = Date.parse(raw.date);
+    return Number.isFinite(t) ? t : null;
+  }
+  return null;
+}
+
+/**
+ * Point-in-polygon test via ray casting.
+ *
+ * Used by GraphCanvas to detect clicks on a cluster halo: project the
+ * pointer to canvas coordinates, then test against each cluster's
+ * polygon. Edge cases:
+ * - Polygons with < 3 vertices return `false` (a 1- or 2-vertex shape
+ *   has no interior — caller does hit-testing on the bounding circle
+ *   / pill, not on this polygon).
+ * - Vertices on the boundary may flip-flop; the caller is expected to
+ *   tolerate a 1-pixel epsilon in canvas space.
+ */
+export function pointInPolygon(p: Point, polygon: Point[]): boolean {
+  if (!p || !Array.isArray(polygon) || polygon.length < 3) return false;
+  let inside = false;
+  for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {
+    const xi = polygon[i].x;
+    const yi = polygon[i].y;
+    const xj = polygon[j].x;
+    const yj = polygon[j].y;
+    const intersect =
+      yi > p.y !== yj > p.y &&
+      p.x < ((xj - xi) * (p.y - yi)) / (yj - yi + 0) + xi;
+    if (intersect) inside = !inside;
+  }
+  return inside;
+}
diff --git a/gitnexus-web/src/lib/gantt-layout.ts b/gitnexus-web/src/lib/gantt-layout.ts
