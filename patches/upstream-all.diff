index 0000000..f6158f9
--- /dev/null
+++ b/gitnexus-web/src/lib/ghost-layout.ts
@@ -0,0 +1,252 @@
+/**
+ * Pure functions for placing ghost nodes on the Sigma canvas.
+ * Reused from frontend only — no I/O, no Sigma deps.
+ *
+ * See docs/superpowers/specs/2026-05-26-roadmap-predictive-augmented-graph-design.md
+ */
+
+export type ExpectedLink = { kind: 'path' | 'label'; value: string };
+
+export type GhostInput = {
+  id: string;
+  title: string;
+  tier: string | null;
+  status: 'planned' | 'materialized' | 'cancelled';
+  expectedLinks: ExpectedLink[];
+};
+
+export type ExistingNode = { id: string; x: number; y: number };
+
+export type GhostLayoutNode = {
+  id: string;             // prefixed with "ghost:" to avoid collision
+  ghostId: string;        // original ghost id
+  x: number;
+  y: number;
+  tier: string | null;
+  status: GhostInput['status'];
+  title: string;
+  anchored: boolean;
+};
+
+export type GhostLayoutEdge = {
+  source: string;
+  target: string;
+  tier: string | null;
+};
+
+function pathToRegex(pattern: string): RegExp {
+  let re = '';
+  for (let i = 0; i < pattern.length; i++) {
+    const c = pattern[i];
+    if (c === '*' && pattern[i + 1] === '*') { re += '.*'; i++; }
+    else if (c === '*') { re += '[^/]*'; }
+    else if (c === '?') { re += '[^/]'; }
+    else if (/[.+^${}()|[\]\\]/.test(c)) { re += '\\' + c; }
+    else { re += c; }
+  }
+  return new RegExp(re + '$');
+}
+
+export function matchExistingNodes(links: ExpectedLink[], nodeIds: string[]): string[] {
+  const out = new Set<string>();
+  for (const link of links) {
+    if (link.kind !== 'path') continue;
+    const hasWildcard = /[*?]/.test(link.value);
+    if (hasWildcard) {
+      const re = pathToRegex(link.value);
+      for (const id of nodeIds) if (re.test(id)) out.add(id);
+    } else {
+      for (const id of nodeIds) {
+        if (id.endsWith(link.value) || id.includes('/' + link.value)) out.add(id);
+      }
+    }
+  }
+  return [...out];
+}
+
+export function computeGhostLayout(
+  ghosts: GhostInput[],
+  existing: ExistingNode[],
+  options: { canvasBounds?: { xMax: number; yMin: number }; satelliteCols?: number } = {},
+): { ghostNodes: GhostLayoutNode[]; ghostEdges: GhostLayoutEdge[] } {
+  const xMax = options.canvasBounds?.xMax ?? 100;
+  const yMin = options.canvasBounds?.yMin ?? -50;
+  const cols = options.satelliteCols ?? 5;
+  const colWidth = 5;
+  const rowHeight = 5;
+
+  const ghostNodes: GhostLayoutNode[] = [];
+  const ghostEdges: GhostLayoutEdge[] = [];
+  const nodeById = new Map(existing.map(n => [n.id, n]));
+  let satelliteIndex = 0;
+
+  for (const g of ghosts) {
+    if (g.status === 'materialized') continue; // doublon avec real node
+    const matched = matchExistingNodes(g.expectedLinks, existing.map(n => n.id));
+    const ghostNodeId = `ghost:${g.id}`;
+    if (matched.length > 0) {
+      const xs = matched.map(id => nodeById.get(id)!.x);
+      const ys = matched.map(id => nodeById.get(id)!.y);
+      const x = xs.reduce((a, b) => a + b, 0) / xs.length;
+      const y = ys.reduce((a, b) => a + b, 0) / ys.length;
+      ghostNodes.push({ id: ghostNodeId, ghostId: g.id, x, y, tier: g.tier, status: g.status, title: g.title, anchored: true });
+      for (const matchedId of matched) {
+        ghostEdges.push({ source: ghostNodeId, target: matchedId, tier: g.tier });
+      }
+    } else {
+      const col = satelliteIndex % cols;
+      const row = Math.floor(satelliteIndex / cols);
+      ghostNodes.push({
+        id: ghostNodeId,
+        ghostId: g.id,
+        x: xMax - (cols - col) * colWidth,
+        y: yMin + row * rowHeight,
+        tier: g.tier,
+        status: g.status,
+        title: g.title,
+        anchored: false,
+      });
+      satelliteIndex += 1;
+    }
+  }
+  return { ghostNodes, ghostEdges };
+}
+
+const TIER_COLORS: Record<string, string> = {
+  '1': '#5b9bd5',  // bleu
+  '2': '#e1aa55',  // ambre
+  '3': '#9b59b6',  // violet
+};
+
+export function tierColor(tier: string | null): string {
+  if (!tier) return '#6d6d6d';
+  const major = String(tier).split('.')[0];
+  return TIER_COLORS[major] ?? '#6d6d6d';
+}
+
+/**
+ * Update 1 — time-decaying opacity for ghost nodes.
+ *
+ * Parses an ISO date (YYYY-MM-DD or full ISO timestamp), a quarter
+ * (YYYY-Qx where x ∈ 1..4), or a year-month (YYYY-MM).
+ * Returns null if the input is missing or unrecognised.
+ */
+export function parseTargetDate(value: string | null | undefined): Date | null {
+  if (!value || typeof value !== 'string') return null;
+  const s = value.trim();
+  if (!s) return null;
+  // YYYY-Qx form
+  const quarterMatch = s.match(/^(\d{4})-Q([1-4])$/i);
+  if (quarterMatch) {
+    const year = Number(quarterMatch[1]);
+    const q = Number(quarterMatch[2]);
+    // End of quarter: month = q*3 (1..12), day = last day of that month.
+    const endMonth = q * 3; // 3, 6, 9, 12
+    // Date constructor month is 0-indexed; day 0 of next month = last day of current month.
+    return new Date(Date.UTC(year, endMonth, 0, 23, 59, 59));
+  }
+  // YYYY-MM form
+  const monthMatch = s.match(/^(\d{4})-(\d{2})$/);
+  if (monthMatch) {
+    const year = Number(monthMatch[1]);
+    const month = Number(monthMatch[2]);
+    if (month < 1 || month > 12) return null;
+    return new Date(Date.UTC(year, month, 0, 23, 59, 59));
+  }
+  // Fallback: native Date parsing (ISO date / timestamp).
+  const t = Date.parse(s);
+  if (Number.isNaN(t)) return null;
+  return new Date(t);
+}
+
+export type GhostAlertLevel = 'fresh' | 'mature' | 'late' | 'critical' | 'cancelled';
+
+export type GhostVisualState = {
+  opacity: number;
+  outlineColor: string;
+  alertLevel: GhostAlertLevel;
+};
+
+export type GhostVisualInput = {
+  tier?: string | null;
+  status?: 'planned' | 'materialized' | 'cancelled' | string | null;
+  plannedAt?: { date?: string | null } | null;
+  declared?: { expectedBy?: string | null } | null;
+};
+
+/**
+ * Computes the visual state of a ghost node based on how much of its
+ * planned->expectedBy window has elapsed at `now`. The further past the
+ * expected date, the more opaque and alarming the outline.
+ *
+ * See spec : docs/superpowers/specs/2026-05-26-roadmap-predictive-augmented-graph-design.md
+ * (Update 1 — time-decaying opacity).
+ */
+export function computeGhostVisualState(ghost: GhostVisualInput, now: Date): GhostVisualState {
+  if (ghost.status === 'cancelled') {
+    return { opacity: 0.3, outlineColor: '#6d6d6d', alertLevel: 'cancelled' };
+  }
+  const tc = tierColor(ghost.tier ?? null);
+  const planned = ghost.plannedAt?.date ? new Date(ghost.plannedAt.date) : null;
+  const expectedBy = parseTargetDate(ghost.declared?.expectedBy);
+  if (!planned || Number.isNaN(planned.getTime()) || !expectedBy) {
+    return { opacity: 0.4, outlineColor: tc, alertLevel: 'fresh' };
+  }
+  const totalMs = expectedBy.getTime() - planned.getTime();
+  const elapsedMs = now.getTime() - planned.getTime();
+  const ratio = totalMs > 0 ? elapsedMs / totalMs : 1;
+  if (ratio < 0.5) return { opacity: 0.5, outlineColor: tc, alertLevel: 'fresh' };
+  if (ratio < 1.0) return { opacity: 0.4, outlineColor: tc, alertLevel: 'mature' };
+  if (ratio < 1.5) return { opacity: 0.3, outlineColor: '#e67e22', alertLevel: 'late' };
+  return { opacity: 0.2, outlineColor: '#c0392b', alertLevel: 'critical' };
+}
+
+/* ═══════════════════════════════════════════════════════════════
+ * Filter + status helpers (Section C / Task 7)
+ *
+ * These mirror the CORE's derivedStatus rule so the frontend never
+ * has to round-trip to the backend just to know whether a ghost is
+ * "planned", "materialized" or "cancelled". `passesFilter` is the
+ * single gate consumed by `applyGhostLayer` in useSigma.
+ * ═══════════════════════════════════════════════════════════════ */
+
+export type GhostFilters = {
+  showGhosts: boolean;
+  /** Which major tiers ("1", "2", "3") are visible. Tier "1.4" matches "1". */
+  tiers: string[];
+  showCancelled: boolean;
+};
+
+export const DEFAULT_GHOST_FILTERS: GhostFilters = {
+  showGhosts: false,
+  tiers: ['1', '2', '3'],
+  showCancelled: false,
+};
+
+/**
+ * Mirrors the CORE's derivedStatus rule : cancelled > materialized > planned.
+ * Accepts the runtime shape (the full ghost) or a minimal object with the
+ * two timestamps. Returns `'planned'` when neither has fired.
+ */
+export function derivedStatus(g: {
+  materializedAt?: unknown;
+  cancelledAt?: unknown;
+}): 'planned' | 'materialized' | 'cancelled' {
+  if (g.cancelledAt) return 'cancelled';
+  if (g.materializedAt) return 'materialized';
+  return 'planned';
+}
+
+/**
+ * Returns true when the ghost should be drawn on the canvas under
+ * the current filter state. Used by `applyGhostLayer` to gate
+ * insertion into the graph.
+ */
+export function passesFilter(ghost: GhostInput, f: GhostFilters): boolean {
+  if (!f.showGhosts) return false;
+  // Materialized ghosts are doublons of real nodes — never draw them.
+  if (ghost.status === 'materialized') return false;
+  if (ghost.status === 'cancelled' && !f.showCancelled) return false;
+  if (ghost.tier && !f.tiers.includes(String(ghost.tier).split('.')[0])) return false;
+  return true;
+}
diff --git a/gitnexus-web/src/lib/ghost-node-program.ts b/gitnexus-web/src/lib/ghost-node-program.ts
