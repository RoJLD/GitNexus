new file mode 100644
index 0000000..7929573
--- /dev/null
+++ b/docker-server-snapshot-auto.mjs
@@ -0,0 +1,532 @@
+/**
+ * Auto-snapshot aux pics d'entropy — Phase A of the incremental-
+ * snapshots spec (see docs/superpowers/specs/2026-05-26-incremental-
+ * snapshots-design.md + ...-auto-snapshot-peaks-spec.md).
+ *
+ * Endpoint:
+ *   POST /snapshot/auto?repo=<base>
+ *   Content-Type: application/json
+ *   Body (all optional, all overridable from .gitnexus.json > auto_snapshot):
+ *     {
+ *       "topPercent":   10,         // keep commits whose |Δ| is in the top P%
+ *       "windowDays":   90,         // analysis window
+ *       "debounceDays": 7,          // no two snapshots within N days
+ *       "minDelta":     0,          // absolute floor on |attributedDelta|
+ *       "excludeMerges": true,
+ *       "metric":       "density",  // "density" | "modularity"
+ *       "dryRun":       false,
+ *       "maxToCreate":  5           // hard cap (protects compute/storage)
+ *     }
+ *
+ * --- Algorithm ---
+ *
+ * 1. Load snapshot entropy timeline (per /entropy) + git log in window.
+ * 2. Attribute deltas by interpolation (same as /entropy/commits).
+ * 3. Filter: drop merges + stragglers + below-minDelta + outside top-P%.
+ * 4. Debounce: skip commits within `debounceDays` of an already-
+ *    snapshotted SHA, OR within `debounceDays` of an earlier-planned
+ *    SHA in this same pass (chronological iteration).
+ * 5. Cap at `maxToCreate`. Sort most-recent-first before capping.
+ * 6. If dryRun: return plan only. Otherwise: createSnapshot() each
+ *    eligible SHA sequentially (parallel = too aggressive on
+ *    `gitnexus analyze`).
+ *
+ * --- Why MVP doesn't ship UI ---
+ *
+ * Endpoint + MCP tool first. The button placement (Timeline vs
+ * EntropyCommitTimeline drill-down vs Settings) wants a real-usage
+ * signal before we wire it. Documented in the parent spec as Phase
+ * A.bis.
+ */
+
+import { spawn } from 'node:child_process';
+import { readdir, readFile, stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import {
+  findRepoByName,
+  createSnapshot,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { getConfig } from './docker-server-config.mjs';
+
+// Hard cap on `maxToCreate` regardless of what the caller asks. Overrideable
+// via env var for forensic / batch backfill scenarios. The default of 5
+// keeps the request well within typical HTTP timeouts (~25 min at 3-5
+// min per snapshot worst case).
+const HARD_CAP_MAX_TO_CREATE = Number(process.env.AUTO_SNAPSHOT_HARD_CAP) || 5;
+
+const DEFAULTS = {
+  topPercent: 10,
+  windowDays: 90,
+  debounceDays: 7,
+  minDelta: 0,
+  excludeMerges: true,
+  metric: 'density',
+  dryRun: false,
+  maxToCreate: 5,
+};
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+async function readMeta(storagePath) {
+  try {
+    return JSON.parse(await readFile(join(storagePath, 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+function entropyFromStats(stats) {
+  const nodes = Number(stats?.nodes) || 0;
+  const edges = Number(stats?.edges) || 0;
+  const communities = Number(stats?.communities) || 0;
+  const denom = nodes * (nodes - 1);
+  const density = denom > 0 ? (2 * edges) / denom : 0;
+  const modularity = nodes > 0 ? communities / nodes : 0;
+  return { density, modularity };
+}
+
+// Returns [{ sha (full), date (ISO), density, modularity }, ...].
+// Includes the live point at the end so commits between the last
+// snapshot and HEAD also get attributed.
+async function loadSnapshotTimeline(repoName, liveEntry) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') entries = [];
+    else throw err;
+  }
+  const points = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    let commit;
+    try {
+      commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+    } catch {
+      continue;
+    }
+    const meta = await readMeta(join(dir, e.name, 'source', '.gitnexus'));
+    points.push({
+      sha: commit.hash || e.name,
+      shortSha: e.name,
+      date: commit.date,
+      ...entropyFromStats(meta?.stats || {}),
+    });
+  }
+  // Live point
+  const liveMeta = await readMeta(join('/data/projects', repoName, '.gitnexus')).catch(() => null);
+  points.push({
+    sha: 'HEAD',
+    shortSha: 'HEAD',
+    date: liveEntry?.indexedAt || new Date().toISOString(),
+    isLive: true,
+    ...entropyFromStats(liveMeta?.stats || liveEntry?.stats || {}),
+  });
+  points.sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+  return points;
+}
+
+// Parse `git log --pretty=format:%H%x09%aI%x09%an%x09%P --no-merges-or-merges-depending --name-only`
+// → [{ sha, date, author, isMerge, files: [] }, ...].
+// We pass --merges as an alternate when excludeMerges is false; otherwise
+// we ask --no-merges to skip them at the source.
+function parseGitLogWithMergeFlag(stdout) {
+  const commits = [];
+  let header = null;
+  let files = [];
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      if (header) {
+        commits.push({ ...header, files });
+        header = null;
+        files = [];
+      }
+      continue;
+    }
+    if (header === null) {
+      const parts = line.split('\t');
+      if (parts.length < 4) continue;
+      const parents = (parts[3] || '').split(' ').filter(Boolean);
+      header = {
+        sha: parts[0],
+        date: parts[1],
+        author: parts[2],
+        isMerge: parents.length > 1,
+      };
+      continue;
+    }
+    files.push(line);
+  }
+  if (header) commits.push({ ...header, files });
+  return commits;
+}
+
+// Standard interpolation attribution (matches /entropy/commits algo).
+// For each adjacent snapshot pair, distribute the delta by filesTouched.
+function attributeDeltas(commits, snapshotPoints, metric) {
+  if (snapshotPoints.length < 2) {
+    return commits.map((c) => ({ ...c, attributed: null, window: null }));
+  }
+  // Build windows.
+  const windows = [];
+  for (let i = 0; i < snapshotPoints.length - 1; i++) {
+    const a = snapshotPoints[i];
+    const b = snapshotPoints[i + 1];
+    windows.push({
+      from: a.date,
+      to: b.date,
+      delta: ((b[metric] || 0) - (a[metric] || 0)),
+      commits: [],
+    });
+  }
+  // Bucket commits.
+  for (const c of commits) {
+    const t = Date.parse(c.date);
+    if (!Number.isFinite(t)) continue;
+    for (const w of windows) {
+      const ws = Date.parse(w.from);
+      const we = Date.parse(w.to);
+      if (Number.isFinite(ws) && Number.isFinite(we) && t >= ws && t < we) {
+        w.commits.push(c);
+        break;
+      }
+    }
+  }
+  // Distribute.
+  const out = [];
+  const inWindow = new Set();
+  for (const w of windows) {
+    const totalFiles = w.commits.reduce((s, c) => s + c.files.length, 0);
+    for (const c of w.commits) {
+      const share = totalFiles > 0 ? c.files.length / totalFiles : 0;
+      inWindow.add(c.sha);
+      out.push({
+        ...c,
+        attributed: w.delta * share,
+        window: [w.from, w.to],
+      });
+    }
+  }
+  // Append stragglers as attributed: null.
+  for (const c of commits) {
+    if (inWindow.has(c.sha)) continue;
+    out.push({ ...c, attributed: null, window: null });
+  }
+  return out;
+}
+
+async function listSnapshottedShas(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  const result = new Set();
+  try {
+    const entries = await readdir(dir, { withFileTypes: true });
+    for (const e of entries) {
+      if (!e.isDirectory()) continue;
+      try {
+        const commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+        if (commit.hash) result.add(commit.hash);
+        // shortHash as fallback so createSnapshot's safeSnapshotKey
+        // (which uses shortHash) doesn't double-create.
+        if (commit.shortHash) result.add(commit.shortHash);
+      } catch {
+        // Half-built snapshot — fall back to the dir name (= shortHash).
+        result.add(e.name);
+      }
+    }
+  } catch (err) {
+    if (err && err.code !== 'ENOENT') throw err;
+  }
+  return result;
+}
+
+function mergeParams(body, fromConfig) {
+  // Three layers, body wins over config wins over DEFAULTS.
+  const layer = (k) => {
+    if (body && body[k] !== undefined && body[k] !== null) return body[k];
+    if (fromConfig && fromConfig[k] !== undefined && fromConfig[k] !== null) return fromConfig[k];
+    return DEFAULTS[k];
+  };
+  // Helper that handles 0 correctly (Number(0) is falsy, can't use `|| DEFAULT`).
+  const num = (k, min, max) => {
+    const raw = layer(k);
+    const n = Number(raw);
+    if (!Number.isFinite(n)) return DEFAULTS[k];
+    return Math.max(min, Math.min(max, n));
+  };
+  return {
+    topPercent: num('topPercent', 0.1, 100),
+    windowDays: num('windowDays', 1, 3650),
+    debounceDays: num('debounceDays', 0, 365),
+    minDelta: Math.max(0, Number.isFinite(Number(layer('minDelta'))) ? Number(layer('minDelta')) : 0),
+    excludeMerges: layer('excludeMerges') !== false,
+    metric: layer('metric') === 'modularity' ? 'modularity' : 'density',
+    dryRun: !!layer('dryRun'),
+    maxToCreate: num('maxToCreate', 1, HARD_CAP_MAX_TO_CREATE),
+  };
+}
+
+async function handleSnapshotAuto(url, req, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+  const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
+  if (!hasGit) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `${baseRepo} is not a git repo (snapshots require git history)` }));
+    return;
+  }
+
+  // Body params + config fallback.
+  let body = {};
+  let raw = '';
+  for await (const chunk of req) raw += chunk;
+  if (raw) {
+    try { body = JSON.parse(raw); }
+    catch {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: 'invalid JSON body' }));
+      return;
+    }
+  }
+  let cfg;
+  try {
+    cfg = await getConfig(repoPath);
+  } catch (err) {
+    // Don't fail on malformed config — fall back to body + defaults.
+    process.stderr.write(`[snapshot-auto] getConfig failed: ${err.message}\n`);
+    cfg = {};
+  }
+  const params = mergeParams(body, cfg.autoSnapshot);
+
+  // Window in ISO.
+  const now = Date.now();
+  const sinceMs = now - params.windowDays * 24 * 3600 * 1000;
+  const sinceIso = new Date(sinceMs).toISOString();
+
+  // Snapshot entropy timeline.
+  const snapshotPoints = await loadSnapshotTimeline(baseRepo, live);
+  if (snapshotPoints.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({
+      repo: baseRepo,
+      dryRun: params.dryRun,
+      warning: 'Need at least 2 snapshots to compute deltas. Run /snapshot/bulk first to seed the timeline.',
+      candidatesTotal: 0, eligibleAfterFilters: 0, alreadySnapshotted: 0, plannedSnapshots: 0,
+      results: [], summary: { created: 0, skipped: 0, errors: 0 },
+      params,
+    }));
+    return;
+  }
+
+  // Git log in window.
+  let logOut;
+  try {
+    logOut = await runCmd('git', [
+      '-C', repoPath, 'log',
+      `--since=${sinceIso}`,
+      '--pretty=format:%H%x09%aI%x09%an%x09%P',
+      '--name-only',
+    ]);
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `git log failed: ${err.message}` }));
+    return;
+  }
+  const allCommits = parseGitLogWithMergeFlag(logOut);
+
+  // Attribute deltas + initial filters.
+  const attributed = attributeDeltas(allCommits, snapshotPoints, params.metric);
+  let pool = attributed;
+  if (params.excludeMerges) pool = pool.filter((c) => !c.isMerge);
+  pool = pool.filter((c) => c.attributed !== null);
+  pool = pool.filter((c) => Math.abs(c.attributed) >= params.minDelta);
+
+  // Top-P% by |Δ|. If P=100, keep all.
+  const sortedByAbs = pool.slice().sort((a, b) => Math.abs(b.attributed) - Math.abs(a.attributed));
+  const keepN = Math.max(1, Math.ceil((sortedByAbs.length * params.topPercent) / 100));
+  const topPool = new Set(sortedByAbs.slice(0, keepN).map((c) => c.sha));
+  let eligible = pool.filter((c) => topPool.has(c.sha));
+
+  // Already snapshotted?
+  const existing = await listSnapshottedShas(baseRepo);
+
+  // Debounce: chronological iteration, skip if within `debounceDays`
+  // of an already-snapshotted SHA OR an earlier-planned SHA.
+  eligible.sort((a, b) => Date.parse(a.date) - Date.parse(b.date));
+  const existingDates = snapshotPoints
+    .map((p) => Date.parse(p.date))
+    .filter(Number.isFinite);
+  const plannedDatesMs = [];
+  const debounceMs = params.debounceDays * 24 * 3600 * 1000;
+  const planned = [];
+  const debouncedOut = [];
+  for (const c of eligible) {
+    const cMs = Date.parse(c.date);
+    if (!Number.isFinite(cMs)) continue;
+    const nearExisting = existingDates.some((d) => Math.abs(d - cMs) < debounceMs);
+    const nearPlanned = plannedDatesMs.some((d) => Math.abs(d - cMs) < debounceMs);
+    if (existing.has(c.sha)) {
+      debouncedOut.push({ ...c, _reason: 'already-snapshotted' });
+      continue;
+    }
+    if (nearExisting || nearPlanned) {
+      debouncedOut.push({ ...c, _reason: 'debounce' });
+      continue;
+    }
+    planned.push(c);
+    plannedDatesMs.push(cMs);
+  }
+
+  // Cap. Sort most-recent-first before capping so we prioritize pics récents.
+  planned.sort((a, b) => Date.parse(b.date) - Date.parse(a.date));
+  const capped = planned.slice(0, params.maxToCreate);
+  const overflow = planned.slice(params.maxToCreate);
+
+  // Build results array — we'll mutate the entries we actually process.
+  const results = [];
+  const summary = { created: 0, skipped: 0, errors: 0 };
+
+  // dryRun path: report the plan without doing the work.
+  if (params.dryRun) {
+    for (const c of capped) {
+      results.push({
+        sha: c.sha, shortSha: c.sha.slice(0, 7),
+        date: c.date, author: c.author,
+        attributedDelta: c.attributed,
+        status: 'planned',
+      });
+    }
+    for (const c of overflow) {
+      results.push({
+        sha: c.sha, shortSha: c.sha.slice(0, 7),
+        date: c.date, author: c.author,
+        attributedDelta: c.attributed,
+        status: 'skipped',
+        reason: 'over-maxToCreate',
+      });
+    }
+    for (const c of debouncedOut) {
+      results.push({
+        sha: c.sha, shortSha: c.sha.slice(0, 7),
+        date: c.date, author: c.author,
+        attributedDelta: c.attributed,
+        status: c._reason === 'already-snapshotted' ? 'existing' : 'skipped',
+        reason: c._reason,
+      });
+    }
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({
+      repo: baseRepo,
+      dryRun: true,
+      params,
+      windowDays: params.windowDays,
+      metric: params.metric,
+      candidatesTotal: allCommits.length,
+      eligibleAfterFilters: eligible.length,
+      alreadySnapshotted: debouncedOut.filter((d) => d._reason === 'already-snapshotted').length,
+      plannedSnapshots: capped.length,
+      results,
+      summary,
+    }));
+    return;
+  }
+
+  // Real run: sequential createSnapshot calls.
+  for (const c of capped) {
+    try {
+      const r = await createSnapshot({
+        repoName: baseRepo,
+        commitRef: c.sha,
+        api: opts.api,
+        onPhase: (phase) => process.stderr.write(`[snapshot-auto] ${baseRepo}@${c.sha.slice(0, 7)}: ${phase}\n`),
+      });
+      if (r.existing) summary.skipped++;
+      else summary.created++;
+      results.push({
+        sha: c.sha, shortSha: c.sha.slice(0, 7),
+        date: c.date, author: c.author,
+        attributedDelta: c.attributed,
+        status: r.existing ? 'existing' : 'created',
+        snapshotKey: r.snapshot?.name || null,
+      });
+    } catch (err) {
+      summary.errors++;
+      results.push({
+        sha: c.sha, shortSha: c.sha.slice(0, 7),
+        date: c.date, author: c.author,
+        attributedDelta: c.attributed,
+        status: 'error',
+        error: err.message,
+      });
+    }
+  }
+  for (const c of overflow) {
+    results.push({
+      sha: c.sha, shortSha: c.sha.slice(0, 7),
+      date: c.date, author: c.author,
+      attributedDelta: c.attributed,
+      status: 'skipped',
+      reason: 'over-maxToCreate',
+    });
+  }
+  for (const c of debouncedOut) {
+    results.push({
+      sha: c.sha, shortSha: c.sha.slice(0, 7),
+      date: c.date, author: c.author,
+      attributedDelta: c.attributed,
+      status: c._reason === 'already-snapshotted' ? 'existing' : 'skipped',
+      reason: c._reason,
+    });
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({
+    repo: baseRepo,
+    dryRun: false,
+    params,
+    windowDays: params.windowDays,
+    metric: params.metric,
+    candidatesTotal: allCommits.length,
+    eligibleAfterFilters: eligible.length,
+    alreadySnapshotted: debouncedOut.filter((d) => d._reason === 'already-snapshotted').length,
+    plannedSnapshots: capped.length,
+    results,
+    summary,
+  }));
+}
+
+export async function handleSnapshotAutoRoute(req, url, res, opts) {
+  if (url.pathname === '/snapshot/auto' && req.method === 'POST') {
+    await handleSnapshotAuto(url, req, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-snapshot-from-pr.mjs b/docker-server-snapshot-from-pr.mjs
new file mode 100644
index 0000000..810a2bd
--- /dev/null
+++ b/docker-server-snapshot-from-pr.mjs
@@ -0,0 +1,236 @@
+/**
+ * PR-mode snapshot on-demand — Phase B of the incremental-snapshots
+ * design (see docs/superpowers/specs/2026-05-26-incremental-snapshots-
+ * design.md). Phase A (auto-snapshot aux pics) shipped first; Phase B
+ * sits next to it for the "I want the graph delta of this PR" workflow.
+ *
+ * Endpoint:
+ *   POST /snapshot/from-pr?repo=<base>&base=<ref>&head=<ref>
+ *   Body (optional):
+ *     {
+ *       "dryRun": false   // if true, resolves SHAs + plan but doesn't
+ *                         // actually create the snapshots
+ *     }
+ *
+ * Use case: a PR exists from feature/auth-refactor → main, and the
+ * user wants to see the graph delta the PR would introduce. They
+ * call this endpoint with `base=main&head=feature/auth-refactor` and
+ * get back two snapshot keys + a diffUrl. They can then open the
+ * existing diff-visual UI (red/green/grey graph) between those two
+ * snapshots, which is the actual review experience.
+ *
+ * --- Why this is NOT incremental snapshotting ---
+ *
+ * This is just "snapshot 2 specific commits on-demand", reusing the
+ * existing `createSnapshot` helper. No diff replay, no baseline+delta
+ * machinery. We're piggybacking on Phase 1 snapshot infrastructure and
+ * exposing it under a PR-shaped surface. True incremental snapshotting
+ * (Phase C) stays parked.
+ *
+ * --- Why not GitHub-specific in v1 ---
+ *
+ * The spec mentions a `?prNumber=42` variant that calls the GitHub API
+ * to resolve base/head. That needs an API token in config, a GitHub
+ * App for webhook auto-trigger, etc. — its own feature. Generic
+ * `base`/`head` covers the workflow without auth. GitHub variant can
+ * land as a follow-up if/when there's real demand.
+ *
+ * --- Response shape ---
+ *
+ *   {
+ *     "repo": "hmm_studio",
+ *     "dryRun": false,
+ *     "base": { "ref": "main", "sha": "abc...", "shortSha": "abc1234",
+ *               "snapshotKey": "hmm_studio@abc1234",
+ *               "status": "created" | "existing" | "planned" | "error",
+ *               "error": "..." (only on error) },
+ *     "head": { same shape },
+ *     "diffUrl": "/?project=hmm_studio&diff=hmm_studio@abc1234,hmm_studio@def5678"
+ *                (built only when both snapshots succeeded)
+ *   }
+ *
+ * If base resolves to the same SHA as head, we still snapshot once,
+ * return the same key on both sides, and set `diffUrl: null` with a
+ * `warning` field — the user is asking for a diff against itself.
+ */
+
+import { spawn } from 'node:child_process';
+import { stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { findRepoByName, createSnapshot } from './docker-server-snapshots.mjs';
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout.trim());
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim() || stdout.trim()}`));
+    });
+  });
+}
+
+// Resolve a ref (branch / tag / SHA / HEAD~N / etc.) to its full SHA.
+// `git rev-parse --verify` errors out on unknown refs, which is what
+// we want — the caller will turn that into a 404.
+async function resolveRefToSha(repoPath, ref) {
+  return runCmd('git', ['-C', repoPath, 'rev-parse', '--verify', `${ref}^{commit}`]);
+}
+
+// Build the same /?project=…&diff=A,B URL the frontend's diff mode
+// expects. The frontend's URL handler accepts the diff param and
+// pre-loads both snapshots into compare mode.
+function buildDiffUrl(repo, baseKey, headKey) {
+  const qs = new URLSearchParams({
+    project: repo,
+    diff: `${baseKey},${headKey}`,
+  });
+  return `/?${qs.toString()}`;
+}
+
+async function snapshotRef(repoName, ref, sha, dryRun, opts) {
+  const shortSha = sha.slice(0, 7);
+  const snapshotKey = `${repoName}@${shortSha}`;
+  if (dryRun) {
+    return { ref, sha, shortSha, snapshotKey, status: 'planned' };
+  }
+  try {
+    const r = await createSnapshot({
+      repoName,
+      commitRef: sha,
+      api: opts.api,
+      onPhase: (phase) =>
+        process.stderr.write(`[snapshot-from-pr] ${snapshotKey}: ${phase}\n`),
+    });
+    return {
+      ref,
+      sha,
+      shortSha,
+      snapshotKey: r.snapshot?.name || snapshotKey,
+      status: r.existing ? 'existing' : 'created',
+    };
+  } catch (err) {
+    return {
+      ref,
+      sha,
+      shortSha,
+      snapshotKey,
+      status: 'error',
+      error: err.message,
+    };
+  }
+}
+
+async function handleSnapshotFromPr(url, req, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const baseRef = url.searchParams.get('base');
+  const headRef = url.searchParams.get('head');
+
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  if (!baseRef || !headRef) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing base or head ref' }));
+    return;
+  }
+
+  // Optional body for dryRun (+ future opts). Empty body OK.
+  let body = {};
+  let raw = '';
+  for await (const chunk of req) raw += chunk;
+  if (raw) {
+    try {
+      body = JSON.parse(raw);
+    } catch {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: 'invalid JSON body' }));
+      return;
+    }
+  }
+  const dryRun = !!body.dryRun;
+
+  const baseRepo = repoName.split('@')[0];
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+  const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
+  if (!hasGit) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `${baseRepo} is not a git repo` }));
+    return;
+  }
+
+  // Resolve both refs upfront so we 404 the whole request if either
+  // is bogus, instead of half-snapshotting.
+  let baseSha;
+  let headSha;
+  try {
+    baseSha = await resolveRefToSha(repoPath, baseRef);
+  } catch (err) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `base ref not found: ${baseRef} (${err.message})` }));
+    return;
+  }
+  try {
+    headSha = await resolveRefToSha(repoPath, headRef);
+  } catch (err) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `head ref not found: ${headRef} (${err.message})` }));
+    return;
+  }
+
+  // Same-commit degenerate case: snapshot once, mirror on both sides,
+  // no diff URL.
+  if (baseSha === headSha) {
+    const single = await snapshotRef(baseRepo, baseRef, baseSha, dryRun, opts);
+    const headEcho = { ...single, ref: headRef };
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({
+      repo: baseRepo,
+      dryRun,
+      base: single,
+      head: headEcho,
+      diffUrl: null,
+      warning: `base and head resolve to the same commit ${baseSha.slice(0, 7)} — no diff possible`,
+    }));
+    return;
+  }
+
+  // Sequential snapshot creation. Parallel would be too aggressive on
+  // `gitnexus analyze` (both runs would compete for CPU and the
+  // worker pool). 2 sequential = ~6-10 minutes worst case.
+  const base = await snapshotRef(baseRepo, baseRef, baseSha, dryRun, opts);
+  const head = await snapshotRef(baseRepo, headRef, headSha, dryRun, opts);
+
+  const bothOk =
+    (base.status === 'created' || base.status === 'existing' || base.status === 'planned') &&
+    (head.status === 'created' || head.status === 'existing' || head.status === 'planned');
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({
+    repo: baseRepo,
+    dryRun,
+    base,
+    head,
+    diffUrl: bothOk ? buildDiffUrl(baseRepo, base.snapshotKey, head.snapshotKey) : null,
+  }));
+}
+
+export async function handleSnapshotFromPrRoute(req, url, res, opts) {
+  if (url.pathname === '/snapshot/from-pr' && req.method === 'POST') {
+    await handleSnapshotFromPr(url, req, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-snapshot-incremental.mjs b/docker-server-snapshot-incremental.mjs
new file mode 100644
index 0000000..4bb0a15
--- /dev/null
+++ b/docker-server-snapshot-incremental.mjs
@@ -0,0 +1,779 @@
+/**
+ * Incremental snapshot — Phase C of the incremental-snapshots design.
+ *
+ * Endpoint:
+ *   POST /snapshot/incremental?repo=<base>&commit=<sha>
+ *   Body (optional):
+ *     {
+ *       "filters": {
+ *         "dropGlobalNodes": true,
+ *         "dropEmptyFields": true,
+ *         "filterRelationships": "effectiveWriteSet",  // | "toWrite" | "none"
+ *         "includeLabels": null,                       // or string[]
+ *         "includeRelationshipTypes": null,            // or string[]
+ *         "maxNodes": null,                            // or number
+ *         "onMaxNodes": "error",                       // | "truncate-tail" | "truncate-low-degree"
+ *         "compress": "gzip"                           // | "none" | "brotli"
+ *       },
+ *       "force": false                                 // re-generate even if diff exists
+ *     }
+ *
+ * Behavior:
+ *   1. Validate repo + commit (must exist in git history).
+ *   2. Ensure a per-repo worktree exists (or create one) at a stable path
+ *      `<repoParent>/.gitnexus-incremental-worktree-<repoName>`. This dir
+ *      lives alongside the main checkout, shares the git objects via
+ *      worktree-add (no clone cost), and gets reused across calls.
+ *   3. `git checkout <sha>` in the worktree.
+ *   4. Trigger gitnexus analyze via /api/analyze on that path. The patched
+ *      analyze (scripts/patch-incremental-dump.mjs) writes the subgraph
+ *      dump to <worktree>/.gitnexus/_last-incremental-subgraph.json.
+ *   5. Read that dump, apply filters, optionally compress.
+ *   6. Persist to <repoPath>/.gitnexus/incremental/<sha>.json[.gz] with
+ *      a _meta header recording the filter config + before/after stats.
+ *   7. Return summary.
+ *
+ * --- Honest framing ---
+ *
+ * This is the PoC endpoint for the design in docs/superpowers/specs/
+ * 2026-05-26-incremental-snapshots-phase-c-design.md (§3.bis). It is
+ * end-to-end functional but:
+ *   - No reconstruction endpoint yet (Phase C step §4.3, separate work).
+ *   - No baseline rebuild logic yet (Phase C step §4.4).
+ *   - No /watches integration to auto-trigger on push (Phase C nice-to-have).
+ *
+ * Use it to: benchmark storage size across filter combos, validate the
+ * dump pipeline end-to-end, and feed real data to the reconstruction
+ * design before the next stage.
+ */
+
+import { spawn } from 'node:child_process';
+import { readFile, writeFile, mkdir, stat, rm, readdir } from 'node:fs/promises';
+import { join, dirname, basename } from 'node:path';
+import { gzipSync, brotliCompressSync, gunzipSync, brotliDecompressSync } from 'node:zlib';
+import { findRepoByName, SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+
+const SCHEMA_VERSION = 1;
+const ANALYZE_TIMEOUT_MS = 10 * 60 * 1000;
+
+const DEFAULT_FILTERS = {
+  dropGlobalNodes: true,
+  dropEmptyFields: true,
+  filterRelationships: 'effectiveWriteSet',
+  includeLabels: null,
+  includeRelationshipTypes: null,
+  maxNodes: null,
+  onMaxNodes: 'error',
+  compress: 'gzip',
+};
+
+// Nodes that are global (re-emitted on every analyze pass) and don't
+// belong in a per-commit diff. Matches the audit findings (Community
+// + Process in subgraph dumps).
+const GLOBAL_NODE_LABELS = new Set(['Community', 'Process']);
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout.trim());
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim() || stdout.trim()}`));
+    });
+  });
+}
+
+function mergeFilters(body) {
+  const f = body?.filters || {};
+  const merged = { ...DEFAULT_FILTERS };
+  for (const k of Object.keys(DEFAULT_FILTERS)) {
+    if (f[k] !== undefined) merged[k] = f[k];
+  }
+  // Normalize enums.
+  if (!['none', 'gzip', 'brotli'].includes(merged.compress)) merged.compress = 'gzip';
+  if (!['none', 'toWrite', 'effectiveWriteSet'].includes(merged.filterRelationships)) {
+    merged.filterRelationships = 'effectiveWriteSet';
+  }
+  if (!['error', 'truncate-tail', 'truncate-low-degree'].includes(merged.onMaxNodes)) {
+    merged.onMaxNodes = 'error';
+  }
+  return merged;
+}
+
+// Worktree path: alongside the main repo, predictable name.
+function worktreePath(repoPath) {
+  const parent = dirname(repoPath);
+  const name = basename(repoPath);
+  return join(parent, `.gitnexus-incremental-worktree-${name}`);
+}
+
+async function ensureWorktree(repoPath, wtPath, commit) {
+  const wtExists = await stat(wtPath).catch(() => null);
+  if (!wtExists) {
+    // First time: add a detached worktree at the requested commit.
+    await runCmd('git', ['-C', repoPath, 'worktree', 'add', '--detach', wtPath, commit]);
+    return { created: true };
+  }
+  // Already exists: just checkout the requested commit.
+  await runCmd('git', ['-C', wtPath, 'checkout', '--detach', commit]);
+  return { created: false };
+}
+
+async function triggerAnalyze(api, wtPath) {
+  const resp = await fetch(`${api}/api/analyze`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ path: wtPath, force: false }),
+  });
+  if (!resp.ok) throw new Error(`/api/analyze failed: HTTP ${resp.status}`);
+  const { jobId } = await resp.json();
+  if (!jobId) throw new Error('no jobId returned from /api/analyze');
+  const start = Date.now();
+  while (true) {
+    if (Date.now() - start > ANALYZE_TIMEOUT_MS) {
+      throw new Error('analyze timed out (10min)');
+    }
+    await new Promise((r) => setTimeout(r, 1000));
+    const statusResp = await fetch(`${api}/api/analyze/${encodeURIComponent(jobId)}`);
+    if (!statusResp.ok) throw new Error(`status fetch failed: HTTP ${statusResp.status}`);
+    const job = await statusResp.json();
+    if (job.status === 'complete') return { jobId, elapsedMs: Date.now() - start };
+    if (job.status === 'failed') throw new Error(`analyze failed: ${job.error || 'unknown'}`);
+  }
+}
+
+async function readDump(wtPath) {
+  const dumpPath = join(wtPath, '.gitnexus', '_last-incremental-subgraph.json');
+  let raw;
+  try {
+    raw = await readFile(dumpPath, 'utf8');
+  } catch (err) {
+    throw new Error(`dump not found at ${dumpPath} (patch-incremental-dump.mjs not active?): ${err.message}`);
+  }
+  return JSON.parse(raw);
+}
+
+// ── Filter application ──────────────────────────────────────────────
+
+function stripEmptyFields(rel) {
+  const out = { ...rel };
+  if (out.confidence === 1) delete out.confidence;
+  if (out.reason === '') delete out.reason;
+  return out;
+}
+
+function applyFilters(dump, filters) {
+  const rawStats = {
+    nodes: dump.nodes.length,
+    relationships: dump.relationships.length,
+  };
+
+  let nodes = dump.nodes;
+  let relationships = dump.relationships;
+
+  // Drop globals.
+  if (filters.dropGlobalNodes) {
+    nodes = nodes.filter((n) => !GLOBAL_NODE_LABELS.has(n.label));
+  }
+
+  // includeLabels whitelist.
+  if (Array.isArray(filters.includeLabels) && filters.includeLabels.length > 0) {
+    const wl = new Set(filters.includeLabels);
+    nodes = nodes.filter((n) => wl.has(n.label));
+  }
+
+  // Build node ID set to filter dangling relationships.
+  const keptNodeIds = new Set(nodes.map((n) => n.id));
+
+  // includeRelationshipTypes whitelist.
+  if (Array.isArray(filters.includeRelationshipTypes) && filters.includeRelationshipTypes.length > 0) {
+    const wl = new Set(filters.includeRelationshipTypes);
+    relationships = relationships.filter((r) => wl.has(r.type));
+  }
+
+  // Drop relationships whose endpoints aren't in the kept node set.
+  relationships = relationships.filter(
+    (r) => keptNodeIds.has(r.sourceId) && keptNodeIds.has(r.targetId),
+  );
+
+  // filterRelationships scope: 'none' keeps everything we have above;
+  // 'toWrite' narrows to those touching a file in hashDiff.toWrite;
+  // 'effectiveWriteSet' (default) narrows to effectiveWriteSet files.
+  // The endpoint resolves whether a relationship "touches" a path by
+  // looking at sourceId / targetId for File:<path> or for symbols whose
+  // ID encodes the file (Label:filepath:symbolname).
+  if (filters.filterRelationships !== 'none') {
+    const targetFiles = new Set(
+      filters.filterRelationships === 'toWrite'
+        ? dump.hashDiff.toWrite
+        : dump.effectiveWriteSet,
+    );
+    const idTouchesFile = (id) => {
+      if (typeof id !== 'string') return false;
+      // File:<path> or Folder:<path>
+      if (id.startsWith('File:') || id.startsWith('Folder:')) {
+        return targetFiles.has(id.slice(id.indexOf(':') + 1));
+      }
+      // Function:path:name etc. → path is the second segment.
+      const firstColon = id.indexOf(':');
+      const secondColon = id.indexOf(':', firstColon + 1);
+      if (secondColon < 0) return false;
+      const path = id.slice(firstColon + 1, secondColon);
+      return targetFiles.has(path);
+    };
+    relationships = relationships.filter(
+      (r) => idTouchesFile(r.sourceId) || idTouchesFile(r.targetId),
+    );
+  }
+
+  // Drop empty fields on relationships (small win, often-applied).
+  if (filters.dropEmptyFields) {
+    relationships = relationships.map(stripEmptyFields);
+  }
+
+  // maxNodes cap.
+  let truncated = null;
+  if (filters.maxNodes != null && nodes.length > filters.maxNodes) {
+    if (filters.onMaxNodes === 'error') {
+      throw new Error(
+        `subgraph has ${nodes.length} nodes (post-filter), exceeds maxNodes=${filters.maxNodes}. ` +
+        `Use filters.onMaxNodes='truncate-tail' or 'truncate-low-degree' to cap.`,
+      );
+    }
+    if (filters.onMaxNodes === 'truncate-low-degree') {
+      // Sort by degree desc, keep top N.
+      const degree = new Map();
+      for (const r of relationships) {
+        degree.set(r.sourceId, (degree.get(r.sourceId) || 0) + 1);
+        degree.set(r.targetId, (degree.get(r.targetId) || 0) + 1);
+      }
+      nodes = nodes
+        .slice()
+        .sort((a, b) => (degree.get(b.id) || 0) - (degree.get(a.id) || 0))
+        .slice(0, filters.maxNodes);
+      truncated = `low-degree: dropped ${rawStats.nodes - nodes.length} nodes`;
+    } else {
+      nodes = nodes.slice(0, filters.maxNodes);
+      truncated = `tail: dropped ${rawStats.nodes - nodes.length} nodes`;
+    }
+    // Re-filter relationships to the surviving node set.
+    const survivors = new Set(nodes.map((n) => n.id));
+    relationships = relationships.filter(
+      (r) => survivors.has(r.sourceId) && survivors.has(r.targetId),
+    );
+  }
+
+  return {
+    nodes,
+    relationships,
+    rawStats,
+    filteredStats: { nodes: nodes.length, relationships: relationships.length },
+    truncated,
+  };
+}
+
+function maybeCompress(buf, mode) {
+  if (mode === 'gzip') return { data: gzipSync(buf), ext: 'json.gz' };
+  if (mode === 'brotli') return { data: brotliCompressSync(buf), ext: 'json.br' };
+  return { data: buf, ext: 'json' };
+}
+
+// ── Route handler ───────────────────────────────────────────────────
+
+async function handleSnapshotIncremental(url, req, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const commit = url.searchParams.get('commit');
+
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  if (!commit || !/^[0-9a-f]{4,64}$/i.test(commit)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing or malformed commit (must be 4-64 hex chars)' }));
+    return;
+  }
+
+  // Body
+  let body = {};
+  let raw = '';
+  for await (const chunk of req) raw += chunk;
+  if (raw) {
+    try { body = JSON.parse(raw); }
+    catch {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: 'invalid JSON body' }));
+      return;
+    }
+  }
+  const filters = mergeFilters(body);
+  const force = !!body.force;
+  // reuseDump: skip the worktree+analyze and re-filter the dump left by a
+  // prior call for the SAME commit. Used by the bench to apply N filter
+  // combos to one analyze (6× fewer analyzes). Caller is responsible for
+  // having run a non-reuse pass on this commit first; we don't re-verify
+  // the dump's provenance beyond its existence.
+  const reuseDump = !!body.reuseDump;
+
+  const baseRepo = repoName.split('@')[0];
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+  if (!(await stat(join(repoPath, '.git')).catch(() => null))) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `${baseRepo} is not a git repo` }));
+    return;
+  }
+
+  // Resolve the commit to a full SHA.
+  let fullSha;
+  try {
+    fullSha = await runCmd('git', ['-C', repoPath, 'rev-parse', '--verify', `${commit}^{commit}`]);
+  } catch (err) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `commit not found: ${commit} (${err.message})` }));
+    return;
+  }
+
+  // Idempotency: check if a diff already exists.
+  const outDir = join(repoPath, '.gitnexus', 'incremental');
+  await mkdir(outDir, { recursive: true });
+  for (const ext of ['json.gz', 'json.br', 'json']) {
+    const candidate = join(outDir, `${fullSha}.${ext}`);
+    if (await stat(candidate).catch(() => null)) {
+      if (force) {
+        await rm(candidate).catch(() => {});
+      } else {
+        res.writeHead(200, { 'Content-Type': 'application/json' });
+        res.end(JSON.stringify({
+          repo: baseRepo,
+          commit: fullSha,
+          shortSha: fullSha.slice(0, 7),
+          existing: true,
+          existingPath: candidate,
+          hint: 'pass body.force=true to regenerate',
+        }));
+        return;
+      }
+    }
+  }
+
+  const wtPath = worktreePath(repoPath);
+  let worktreeStatus = { created: false, reused: false };
+  let tWorktree = 0;
+  let tAnalyze = 0;
+
+  if (reuseDump) {
+    // Skip worktree + analyze entirely. The dump from the previous
+    // (non-reuse) pass on this commit is still on disk in the worktree.
+    worktreeStatus = { created: false, reused: true };
+  } else {
+    // Worktree setup.
+    const t0 = Date.now();
+    try {
+      worktreeStatus = await ensureWorktree(repoPath, wtPath, fullSha);
+    } catch (err) {
+      res.writeHead(500, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `worktree setup failed: ${err.message}` }));
+      return;
+    }
+    tWorktree = Date.now() - t0;
+
+    // Analyze.
+    const tAnalyzeStart = Date.now();
+    try {
+      await triggerAnalyze(opts.api, wtPath);
+    } catch (err) {
+      res.writeHead(502, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `analyze failed: ${err.message}` }));
+      return;
+    }
+    tAnalyze = Date.now() - tAnalyzeStart;
+  }
+
+  // Read dump.
+  let dump;
+  try {
+    dump = await readDump(wtPath);
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+    return;
+  }
+
+  // Filter.
+  const tFilterStart = Date.now();
+  let filtered;
+  try {
+    filtered = applyFilters(dump, filters);
+  } catch (err) {
+    res.writeHead(413, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+    return;
+  }
+  const tFilter = Date.now() - tFilterStart;
+
+  // Compose final payload + compress + persist.
+  const payload = {
+    _meta: {
+      ts: new Date().toISOString(),
+      schemaVersion: SCHEMA_VERSION,
+      commit: fullSha,
+      shortSha: fullSha.slice(0, 7),
+      repoPath,
+      worktreeCreated: worktreeStatus.created,
+      filters,
+      hashDiff: dump.hashDiff,
+      effectiveWriteSet: dump.effectiveWriteSet,
+      stats: {
+        rawNodes: filtered.rawStats.nodes,
+        filteredNodes: filtered.filteredStats.nodes,
+        rawRelationships: filtered.rawStats.relationships,
+        filteredRelationships: filtered.filteredStats.relationships,
+        truncated: filtered.truncated,
+      },
+      timings: {
+        worktreeMs: tWorktree,
+        analyzeMs: tAnalyze,
+        filterMs: tFilter,
+      },
+    },
+    subgraph: {
+      nodes: filtered.nodes,
+      relationships: filtered.relationships,
+    },
+  };
+
+  const jsonBuf = Buffer.from(JSON.stringify(payload), 'utf8');
+  const rawBytes = jsonBuf.length;
+  const { data: finalBuf, ext } = maybeCompress(jsonBuf, filters.compress);
+  const compressedBytes = finalBuf.length;
+
+  const outPath = join(outDir, `${fullSha}.${ext}`);
+  await writeFile(outPath, finalBuf);
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({
+    repo: baseRepo,
+    commit: fullSha,
+    shortSha: fullSha.slice(0, 7),
+    existing: false,
+    diffPath: outPath,
+    filters,
+    stats: {
+      rawNodes: filtered.rawStats.nodes,
+      filteredNodes: filtered.filteredStats.nodes,
+      rawRelationships: filtered.rawStats.relationships,
+      filteredRelationships: filtered.filteredStats.relationships,
+      jsonBytes: rawBytes,
+      finalBytes: compressedBytes,
+      compressionRatio:
+        rawBytes > 0 ? Number((rawBytes / Math.max(1, compressedBytes)).toFixed(2)) : 0,
+      truncated: filtered.truncated,
+    },
+    timings: {
+      worktreeMs: tWorktree,
+      analyzeMs: tAnalyze,
+      filterMs: tFilter,
+      totalMs: tWorktree + tAnalyze + tFilter,
+    },
+  }));
+}
+
+export async function handleSnapshotIncrementalRoute(req, url, res, opts) {
+  if (url.pathname === '/snapshot/incremental' && req.method === 'POST') {
+    await handleSnapshotIncremental(url, req, res, opts);
+    return true;
+  }
+  return false;
+}
+
+// ════════════════════════════════════════════════════════════════════
+// Reconstruction: GET /graph/at-commit?repo=&commit=
+// Phase C step §4.3 — rebuild the graph at any commit by loading the
+// nearest baseline snapshot and replaying the per-commit diffs.
+// ════════════════════════════════════════════════════════════════════
+
+// Extract the owning file path from a node id. Mirrors the filter's
+// idTouchesFile logic so delete-by-file is consistent with what gitnexus
+// rewrites.
+//   File:<path> / Folder:<path>          → <path>
+//   Label:<path>:<name> (Function, …)    → <path>
+//   anything else (no parsable path)     → null
+function fileOfId(id) {
+  if (typeof id !== 'string') return null;
+  if (id.startsWith('File:') || id.startsWith('Folder:')) {
+    return id.slice(id.indexOf(':') + 1);
+  }
+  const firstColon = id.indexOf(':');
+  const secondColon = id.indexOf(':', firstColon + 1);
+  if (secondColon < 0) return null;
+  return id.slice(firstColon + 1, secondColon);
+}
+
+// Find the nearest snapshot that is an ancestor of targetSha, by commit
+// distance. Returns { sha, shortSha, snapshotName } or null.
+async function findNearestBaseline(repoPath, baseRepo, targetSha) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(baseRepo));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return null;
+    throw err;
+  }
+  const candidates = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    let commit;
+    try {
+      commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+    } catch {
+      continue;
+    }
+    const sha = commit.hash || e.name;
+    candidates.push({ sha, shortSha: e.name });
+  }
+  // Keep only ancestors of (or equal to) targetSha, measure distance.
+  let best = null;
+  for (const c of candidates) {
+    // is-ancestor exits 0 if c.sha is an ancestor of targetSha (or equal).
+    try {
+      await runCmd('git', ['-C', repoPath, 'merge-base', '--is-ancestor', c.sha, targetSha]);
+    } catch {
+      continue; // not an ancestor
+    }
+    let distance = 0;
+    try {
+      const out = await runCmd('git', ['-C', repoPath, 'rev-list', '--count', `${c.sha}..${targetSha}`]);
+      distance = Number(out) || 0;
+    } catch {
+      distance = Number.MAX_SAFE_INTEGER;
+    }
+    if (!best || distance < best.distance) {
+      best = { ...c, distance, snapshotName: `${baseRepo}@${c.shortSha}` };
+    }
+  }
+  return best;
+}
+
+async function loadSnapshotGraph(api, snapshotName) {
+  const resp = await fetch(`${api}/api/graph?repo=${encodeURIComponent(snapshotName)}`);
+  if (!resp.ok) throw new Error(`/api/graph for ${snapshotName} failed: HTTP ${resp.status}`);
+  const data = await resp.json();
+  return { nodes: data.nodes || [], relationships: data.relationships || [] };
+}
+
+// Read + decompress a persisted diff for a commit. Returns null if none.
+async function readDiff(repoPath, fullSha) {
+  const base = join(repoPath, '.gitnexus', 'incremental', fullSha);
+  for (const [ext, decode] of [
+    ['json.gz', (b) => gunzipSync(b)],
+    ['json.br', (b) => brotliDecompressSync(b)],
+    ['json', (b) => b],
+  ]) {
+    const path = `${base}.${ext}`;
+    try {
+      const buf = await readFile(path);
+      return JSON.parse(decode(buf).toString('utf8'));
+    } catch (err) {
+      if (err && err.code === 'ENOENT') continue;
+      throw err;
+    }
+  }
+  return null;
+}
+
+// Apply one diff to the in-memory graph maps. Faithful replay of
+// gitnexus' delete-then-insert: drop all nodes/rels belonging to files
+// in (effectiveWriteSet ∪ deleted), then insert the diff's subgraph,
+// then prune dangling relationships.
+function applyDiff(nodesMap, relsMap, diff) {
+  const meta = diff._meta || {};
+  const writeSet = new Set([
+    ...(meta.effectiveWriteSet || []),
+    ...((meta.hashDiff && meta.hashDiff.deleted) || []),
+  ]);
+
+  // 1. Delete nodes whose owning file is in the writeSet.
+  for (const [id] of nodesMap) {
+    const f = fileOfId(id);
+    if (f !== null && writeSet.has(f)) nodesMap.delete(id);
+  }
+  // 2. Delete relationships touching a writeSet file (either endpoint).
+  for (const [id, rel] of relsMap) {
+    const sf = fileOfId(rel.sourceId);
+    const tf = fileOfId(rel.targetId);
+    if ((sf !== null && writeSet.has(sf)) || (tf !== null && writeSet.has(tf))) {
+      relsMap.delete(id);
+    }
+  }
+  // 3. Insert the diff's nodes + relationships (post-commit state).
+  for (const n of diff.subgraph?.nodes || []) nodesMap.set(n.id, n);
+  for (const r of diff.subgraph?.relationships || []) relsMap.set(r.id, r);
+  // 4. Prune dangling relationships (endpoint no longer present).
+  for (const [id, rel] of relsMap) {
+    if (!nodesMap.has(rel.sourceId) || !nodesMap.has(rel.targetId)) {
+      relsMap.delete(id);
+    }
+  }
+}
+
+async function handleGraphAtCommit(url, req, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const commit = url.searchParams.get('commit');
+  const lazy = (url.searchParams.get('lazy') || '').toLowerCase() === 'true';
+
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  if (!commit || !/^[0-9a-f]{4,64}$/i.test(commit)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing or malformed commit (4-64 hex chars)' }));
+    return;
+  }
+
+  const baseRepo = repoName.split('@')[0];
+  const live = await findRepoByName(baseRepo, opts.api);
+  if (!live) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = live.repoPath || live.path;
+
+  let targetSha;
+  try {
+    targetSha = await runCmd('git', ['-C', repoPath, 'rev-parse', '--verify', `${commit}^{commit}`]);
+  } catch (err) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `commit not found: ${commit} (${err.message})` }));
+    return;
+  }
+
+  // 1. Nearest baseline snapshot.
+  const baseline = await findNearestBaseline(repoPath, baseRepo, targetSha);
+  if (!baseline) {
+    res.writeHead(409, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({
+      error: 'no snapshot is an ancestor of this commit — seed a baseline first',
+      needsBaseline: true,
+      hint: 'POST /snapshot/baseline-seed?repo=<base>&commit=<sha> (or /snapshot) to create a baseline, then retry',
+    }));
+    return;
+  }
+
+  // 2. Replay chain (baseline exclusive → target inclusive, chronological).
+  let chain = [];
+  if (baseline.sha !== targetSha) {
+    const out = await runCmd('git', ['-C', repoPath, 'rev-list', '--reverse', `${baseline.sha}..${targetSha}`]);
+    chain = out.split('\n').map((s) => s.trim()).filter(Boolean);
+  }
+
+  // 3. Check which diffs exist.
+  const missing = [];
+  for (const sha of chain) {
+    const d = await readDiff(repoPath, sha);
+    if (!d) missing.push(sha);
+  }
+
+  if (missing.length > 0 && !lazy) {
+    res.writeHead(409, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({
+      error: `${missing.length}/${chain.length} commits in the replay chain have no diff yet`,
+      baseline: { sha: baseline.sha, shortSha: baseline.shortSha, distance: baseline.distance },
+      missingDiffs: missing.map((s) => s.slice(0, 7)),
+      hint: 'POST /snapshot/incremental for each missing commit, or retry with ?lazy=true to generate them on the fly (slow: ~50s each)',
+    }));
+    return;
+  }
+
+  // 3b. Lazy: generate missing diffs on the fly via the same pipeline.
+  const tStart = Date.now();
+  let generated = 0;
+  if (missing.length > 0 && lazy) {
+    for (const sha of missing) {
+      // Reuse the worktree + analyze + filter + persist path by calling
+      // the handler's internals would be cleaner, but to keep this PoC
+      // simple we POST to ourselves on localhost.
+      const r = await fetch(
+        `http://127.0.0.1:${process.env.PORT || '4173'}/snapshot/incremental?repo=${encodeURIComponent(baseRepo)}&commit=${sha}`,
+        { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: '{}' },
+      );
+      if (!r.ok) {
+        res.writeHead(502, { 'Content-Type': 'application/json' });
+        res.end(JSON.stringify({ error: `lazy diff generation failed for ${sha.slice(0, 7)}: HTTP ${r.status}` }));
+        return;
+      }
+      generated++;
+    }
+  }
+
+  // 4. Load baseline graph + replay.
+  let graphArr;
+  try {
+    graphArr = await loadSnapshotGraph(opts.api, baseline.snapshotName);
+  } catch (err) {
+    res.writeHead(502, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `baseline graph load failed: ${err.message}` }));
+    return;
+  }
+  const nodesMap = new Map(graphArr.nodes.map((n) => [n.id, n]));
+  const relsMap = new Map(graphArr.relationships.map((r) => [r.id, r]));
+  const baselineCounts = { nodes: nodesMap.size, relationships: relsMap.size };
+
+  const appliedFilters = new Set();
+  for (const sha of chain) {
+    const diff = await readDiff(repoPath, sha);
+    if (!diff) continue; // shouldn't happen post-lazy, but guard
+    applyDiff(nodesMap, relsMap, diff);
+    if (diff._meta?.filters) {
+      appliedFilters.add(JSON.stringify({
+        dropGlobalNodes: diff._meta.filters.dropGlobalNodes,
+        includeLabels: diff._meta.filters.includeLabels,
+        includeRelationshipTypes: diff._meta.filters.includeRelationshipTypes,
+      }));
+    }
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({
+    repo: baseRepo,
+    commit: targetSha,
+    shortSha: targetSha.slice(0, 7),
+    baseline: { sha: baseline.sha, shortSha: baseline.shortSha, snapshotName: baseline.snapshotName, distance: baseline.distance },
+    replay: {
+      commitsInChain: chain.length,
+      diffsApplied: chain.length - (missing.length - generated),
+      lazyGenerated: generated,
+      // If diffs were created with heterogeneous filters, the reconstruction
+      // is only as complete as the most-restrictive diff in the chain.
+      filterConsistency: appliedFilters.size <= 1 ? 'consistent' : 'MIXED — reconstruction fidelity varies across the chain',
+    },
+    baselineCounts,
+    reconstructedCounts: { nodes: nodesMap.size, relationships: relsMap.size },
+    reconstructMs: Date.now() - tStart,
+    // The reconstructed graph in /api/graph shape.
+    nodes: [...nodesMap.values()],
+    relationships: [...relsMap.values()],
+  }));
+}
+
+export async function handleGraphAtCommitRoute(req, url, res, opts) {
+  if (url.pathname === '/graph/at-commit' && req.method === 'GET') {
+    await handleGraphAtCommit(url, req, res, opts);
+    return true;
+  }
+  return false;
+}
