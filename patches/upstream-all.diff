diff --git a/gitnexus-web/src/components/EntropyBadge.tsx b/gitnexus-web/src/components/EntropyBadge.tsx
new file mode 100644
index 0000000..07a59b5
--- /dev/null
+++ b/gitnexus-web/src/components/EntropyBadge.tsx
@@ -0,0 +1,140 @@
+import { useEffect, useState } from 'react';
+import { Activity, TrendingUp, TrendingDown, Minus } from '@/lib/lucide-icons';
+
+/**
+ * Small always-on health badge in the Timeline bar.
+ *
+ * Pulls /entropy?repo=<base> when the active project changes, then
+ * shows the current density value and a trend arrow comparing it to the
+ * earliest snapshot. The tooltip exposes the underlying counts so the
+ * user can sanity-check the headline number.
+ *
+ * Intentionally lightweight — no global state, no separate panel. The
+ * use case is "glance and move on"; we'll graduate to a full chart in a
+ * future tier if the badge alone proves too thin.
+ */
+
+interface EntropyPoint {
+  name: string;
+  date: string;
+  isLive: boolean;
+  nodes: number;
+  edges: number;
+  communities: number;
+  density: number;
+  modularity: number;
+}
+
+interface EntropyResponse {
+  totalPoints: number;
+  timeline: EntropyPoint[];
+  headline: {
+    currentDensity: number;
+    currentModularity: number;
+    densityTrend: number | null;
+  };
+}
+
+interface EntropyBadgeProps {
+  repoName: string;
+}
+
+export const EntropyBadge = ({ repoName }: EntropyBadgeProps) => {
+  const [data, setData] = useState<EntropyResponse | null>(null);
+  const [loading, setLoading] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+
+  useEffect(() => {
+    if (!repoName) return;
+    const baseRepo = repoName.split('@')[0];
+    let cancelled = false;
+    setLoading(true);
+    setError(null);
+    fetch(`/entropy?repo=${encodeURIComponent(baseRepo)}`, { cache: 'no-store' })
+      .then((r) => (r.ok ? r.json() : r.json().then((b) => Promise.reject(b.error || r.statusText))))
+      .then((d: EntropyResponse) => {
+        if (cancelled) return;
+        setData(d);
+      })
+      .catch((err) => {
+        if (cancelled) return;
+        setError(typeof err === 'string' ? err : 'failed');
+      })
+      .finally(() => {
+        if (!cancelled) setLoading(false);
+      });
+    return () => {
+      cancelled = true;
+    };
+  }, [repoName]);
+
+  // The badge only earns its slot when we have at least 2 points (i.e.
+  // when "trend" actually means something). Otherwise hide silently —
+  // the user gets the Timeline bar regardless.
+  if (loading || error) return null;
+  if (!data || data.totalPoints < 2) return null;
+
+  const { currentDensity, currentModularity, densityTrend } = data.headline;
+  const trend = densityTrend ?? 1;
+  const trendPct = Math.round((trend - 1) * 100);
+  const trendArrow =
+    Math.abs(trendPct) < 5 ? (
+      <Minus className="h-2.5 w-2.5" />
+    ) : trendPct > 0 ? (
+      <TrendingUp className="h-2.5 w-2.5" />
+    ) : (
+      <TrendingDown className="h-2.5 w-2.5" />
+    );
+  const trendColor =
+    Math.abs(trendPct) < 5
+      ? 'text-text-muted'
+      : trendPct > 0
+        ? 'text-amber-300'
+        : 'text-emerald-300';
+
+  // Density is usually tiny (<0.05). Show scientific-ish notation for
+  // sub-1% values, otherwise a plain percentage.
+  const densityStr =
+    currentDensity < 0.01
+      ? currentDensity.toExponential(2)
+      : (currentDensity * 100).toFixed(2) + '%';
+
+  const last = data.timeline[data.timeline.length - 1];
+  const first = data.timeline[0];
+  const tooltip = [
+    `Current point: ${last.isLive ? 'LIVE' : last.name.split('@')[1] || last.name}`,
+    `  nodes: ${last.nodes}`,
+    `  edges: ${last.edges}`,
+    `  communities: ${last.communities}`,
+    `  density: ${last.density.toExponential(3)}`,
+    `  modularity ratio: ${last.modularity.toFixed(4)}`,
+    '',
+    `Baseline: ${first.isLive ? 'LIVE' : first.name.split('@')[1] || first.name}`,
+    `  density: ${first.density.toExponential(3)}`,
+    '',
+    densityTrend !== null
+      ? `Density trend: ×${trend.toFixed(2)} (${trendPct >= 0 ? '+' : ''}${trendPct}%)`
+      : 'Density trend: n/a (baseline has 0 density)',
+    '',
+    'Higher density = more interconnected = harder to refactor in isolation.',
+  ].join('\n');
+
+  return (
+    <div
