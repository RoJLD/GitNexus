+/**
+ * Default embedding model names per provider. Picked for "small &
+ * cheap" — we're embedding short label phrases, not long documents.
+ *   - OpenAI text-embedding-3-small: 1536 dim, $0.02/1M tokens
+ *   - Gemini text-embedding-004: 768 dim, free tier
+ *   - Ollama nomic-embed-text: 768 dim, local
+ *   - Azure: uses whatever the user deployed (deploymentName from
+ *     azureConfig — there's no way to "guess" Azure deployment names)
+ */
+const DEFAULT_EMBEDDING_MODELS = {
+  openai: 'text-embedding-3-small',
+  gemini: 'text-embedding-004',
+  ollama: 'nomic-embed-text',
+} as const;
+
+/**
+ * Build an Embeddings client for providers that expose embeddings APIs.
+ * Returns null for providers without native embeddings (Anthropic,
+ * OpenRouter, MiniMax, GLM) — the caller is expected to fall back to
+ * a non-embedding signal (e.g. lexical similarity).
+ *
+ * Tier 2.5b.bis — used by SimilarityPanel "Embed labels" to upgrade
+ * the semantic axis from lexical (Tier 2.5b) to true embedding-based.
+ *
+ * For OpenAI / Gemini / Ollama we use small, cheap default models —
+ * we're embedding short label phrases (1-4 words typically), not long
+ * documents. For Azure the user's deploymentName is what we use, since
+ * Azure deployment names are arbitrary and we can't guess.
+ */
+export const createEmbeddingsModel = (config: ProviderConfig): Embeddings | null => {
+  switch (config.provider) {
+    case 'openai': {
+      const c = config as OpenAIConfig;
+      if (!c.apiKey || c.apiKey.trim() === '') return null;
+      return new OpenAIEmbeddings({
+        apiKey: c.apiKey,
+        model: DEFAULT_EMBEDDING_MODELS.openai,
+        configuration: c.baseUrl ? { baseURL: c.baseUrl } : undefined,
+      });
+    }
+    case 'azure-openai': {
+      const c = config as AzureOpenAIConfig;
+      // Reuse the same deployment as the chat model. If the user
+      // deployed only a chat model and not an embeddings model, this
+      // will surface as a 404 at call time, which the labeler will
+      // catch and report — better than silently doing nothing.
+      return new AzureOpenAIEmbeddings({
+        azureOpenAIApiKey: c.apiKey,
+        azureOpenAIApiInstanceName: extractInstanceName(c.endpoint),
+        azureOpenAIApiEmbeddingsDeploymentName: c.deploymentName,
+        azureOpenAIApiVersion: c.apiVersion ?? '2024-12-01-preview',
+      });
+    }
+    case 'gemini': {
+      const c = config as GeminiConfig;
+      if (!c.apiKey || c.apiKey.trim() === '') return null;
+      return new GoogleGenerativeAIEmbeddings({
+        apiKey: c.apiKey,
+        model: DEFAULT_EMBEDDING_MODELS.gemini,
+      });
+    }
+    case 'ollama': {
+      const c = config as OllamaConfig;
+      return new OllamaEmbeddings({
+        baseUrl: c.baseUrl ?? DEFAULT_OLLAMA_BASE_URL,
+        model: DEFAULT_EMBEDDING_MODELS.ollama,
+      });
