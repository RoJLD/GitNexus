--- /dev/null
+++ b/gitnexus-web/src/components/CanvasMultigraph.tsx
@@ -0,0 +1,39 @@
+import { useEffect, useRef } from 'react';
+import type { GraphConfigEntry } from '@/services/MultigraphLoader';
+
+export type ZoomLevel = 'meta' | 'graph' | 'node' | 'inspector';
+
+interface CanvasMultigraphProps {
+  selectedGraph: GraphConfigEntry | null;
+  zoomLevel: ZoomLevel;
+}
+
+export function CanvasMultigraph({ selectedGraph, zoomLevel }: CanvasMultigraphProps) {
+  const containerRef = useRef<HTMLDivElement>(null);
+
+  useEffect(() => {
+    if (!selectedGraph || !containerRef.current) return;
+    containerRef.current.dataset.graphName = selectedGraph.name;
+  }, [selectedGraph]);
+
+  if (!selectedGraph) {
+    return (
+      <main className="flex-1 flex items-center justify-center bg-slate-950 text-slate-400">
+        <div className="text-center">
+          <p>Select a graph from the sidebar to begin.</p>
+          <p className="text-xs mt-2" data-testid="canvas-mode">{zoomLevel}</p>
+        </div>
+      </main>
+    );
+  }
+
+  return (
+    <main className="flex-1 bg-slate-950 text-slate-100 p-4">
+      <header className="flex justify-between mb-2">
+        <h2 className="text-xl font-semibold">{selectedGraph.name}</h2>
+        <span className="text-xs" data-testid="canvas-mode">{zoomLevel}</span>
+      </header>
+      <div ref={containerRef} className="w-full h-[calc(100vh-8rem)] bg-slate-900 rounded" />
+    </main>
+  );
+}
diff --git a/gitnexus-web/src/components/GraphSidebar.tsx b/gitnexus-web/src/components/GraphSidebar.tsx
new file mode 100644
index 0000000..2b23f34
--- /dev/null
+++ b/gitnexus-web/src/components/GraphSidebar.tsx
@@ -0,0 +1,44 @@
+import { useMemo } from 'react';
+import type { GraphConfigEntry } from '@/services/MultigraphLoader';
+
+interface GraphSidebarProps {
+  graphs: GraphConfigEntry[];
+  onSelect: (name: string) => void;
+  selected: string | null;
+}
+
+export function GraphSidebar({ graphs, onSelect, selected }: GraphSidebarProps) {
+  const grouped = useMemo(() => {
+    const m = new Map<string, GraphConfigEntry[]>();
+    for (const g of graphs) {
+      const k = g.schema_type;
+      if (!m.has(k)) m.set(k, []);
+      m.get(k)!.push(g);
+    }
+    return m;
+  }, [graphs]);
+
+  return (
+    <aside className="w-64 bg-slate-900 text-slate-100 p-4 overflow-y-auto" role="navigation">
+      <h2 className="text-lg font-semibold mb-3">Graphs</h2>
+      {[...grouped.entries()].map(([schemaType, list]) => (
+        <section key={schemaType} className="mb-4">
+          <h3 className="text-xs uppercase text-slate-400 mb-1">{schemaType}</h3>
+          <ul>
+            {list.map(g => (
+              <li
+                key={g.name}
+                className={`cursor-pointer py-1 px-2 rounded ${
+                  selected === g.name ? 'bg-violet-600' : 'hover:bg-slate-800'
+                }`}
+                onClick={() => onSelect(g.name)}
+              >
+                {g.name}
+              </li>
+            ))}
+          </ul>
+        </section>
+      ))}
+    </aside>
+  );
+}
