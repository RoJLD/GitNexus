+    // Rewrite meta.json to point at the new absolute repoPath. /api/analyze
+    // will treat this as an existing index and just register it.
+    const metaPath = join(target, '.gitnexus', 'meta.json');
+    try {
+      const raw = await readFile(metaPath, 'utf8');
+      const meta = JSON.parse(raw);
+      meta.repoPath = target;
+      delete meta.exportedFromRepoName;
+      delete meta.exportedAt;
+      delete meta.exportMode;
+      await writeFile(metaPath, JSON.stringify(meta, null, 2), 'utf8');
+    } catch {
+      // No meta.json — analyze will rebuild it.
+    }
+
+    // Two registration strategies:
+    //   1. registerOnly=1 — write the registry entry directly. No /api/analyze
+    //      call, so the imported index isn't touched. The repo shows up in
+    //      the dropdown and its graph is browsable. Code Inspector will fail
+    //      gracefully when source isn't on disk.
+    //   2. default — call /api/analyze (force:false). Useful when the target
+    //      already contains the matching source code (fast-path triggers via
+    //      run-analyze.ts:165 lastCommit check). Otherwise the worker rebuilds
+    //      from the target and overwrites the imported index.
+    const registerOnly = url.searchParams.get('registerOnly') === '1';
+    const skipAnalyze = url.searchParams.get('skipAnalyze') === '1';
