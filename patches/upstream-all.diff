@@ -0,0 +1,54 @@
+/**
+ * ClustersCard — 7th card on the audit summary strip, rendered next to
+ * Expired. Shows "N clusters · X% complete in median" so the user can
+ * see at a glance whether the declared groupings are converging.
+ * Click opens the ClusterDrillModal.
+ *
+ * Section H / Task 13 of
+ * docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ */
+
+import type { ClusterRuntime } from '../../services/clusters-client';
+
+type Props = {
+  clusters: ClusterRuntime[];
+  onClick?: () => void;
+};
+
+function median(values: number[]): number {
+  if (values.length === 0) return 0;
+  const sorted = [...values].sort((a, b) => a - b);
+  const mid = Math.floor(sorted.length / 2);
+  return sorted.length % 2 === 1
+    ? sorted[mid]
+    : (sorted[mid - 1] + sorted[mid]) / 2;
+}
+
+export default function ClustersCard({ clusters, onClick }: Props) {
+  if (!clusters || clusters.length === 0) return null;
+  const completions = clusters.map((c) => c.aggregate?.completionPct ?? 0);
+  const medianPct = median(completions);
+  const expiredCount = clusters.filter((c) => c.synthesizedStatus === 'expired').length;
+
+  return (
+    <div
+      className="stat status-cluster"
+      data-testid="stat-clusters"
+      onClick={onClick}
+      role={onClick ? 'button' : undefined}
+      tabIndex={onClick ? 0 : undefined}
+      style={onClick ? { cursor: 'pointer' } : undefined}
+    >
+      <div className="value">{clusters.length}</div>
+      <div className="label">Clusters</div>
+      <div className="badge" title="Median completion across clusters">
+        {medianPct.toFixed(0)}% median
+      </div>
+      {expiredCount > 0 && (
+        <div className="badge badge-red" title={`${expiredCount} expired cluster(s)`}>
+          {expiredCount} expired
+        </div>
+      )}
+    </div>
+  );
+}
diff --git a/gitnexus-web/src/components/audit/GhostTable.tsx b/gitnexus-web/src/components/audit/GhostTable.tsx
