+                        disabled={!canHighlight}
+                        className="flex w-full flex-col gap-0.5 border-b border-border-subtle px-3 py-2 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+                        title={
