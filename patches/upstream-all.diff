index 0000000..475306a
--- /dev/null
+++ b/gitnexus-web/src/components/DissonancePanel.tsx
@@ -0,0 +1,330 @@
+import { useMemo, useState } from 'react';
+import {
+  X,
+  Loader2,
+  AlertCircle,
+  Download,
+  Target,
+  ChevronRight,
+  ChevronDown,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Dissonance panel — Tier 2.2.
+ *
+ * Header: purity score (0..1, higher = code matches declared domains)
+ * with a colored gauge, plus the totals (declared domains, files
+ * involved, communities seen).
+ *
+ * Body:
+ *   - Per-domain sections (collapsible) showing which communities the
+ *     domain spans, plus its dominant community and confidence.
+ *   - A flat "Misplaced files" list (the ones whose community ≠ their
+ *     domain's dominant). Click a file to highlight it in the live
+ *     graph — these are the refactor candidates.
+ *   - A small "domain declared but no symbols" section so the user
+ *     knows which paths their globs cover that gitnexus can't pin to
+ *     a community (typical for docs/configs).
+ *
+ * Position: top-right, same slot as Coupling/Ownership. Mutually
+ * exclusive with both via Timeline toggles. The data is essentially
+ * static for the current live graph — no point sharing the slot.
+ */
+
+const PANEL_WIDTH_PX = 420;
+
+function purityColor(p: number): string {
+  if (p >= 0.85) return 'text-emerald-300 bg-emerald-500/15 border-emerald-500/30';
+  if (p >= 0.6) return 'text-amber-300 bg-amber-500/15 border-amber-500/30';
+  return 'text-red-300 bg-red-500/15 border-red-500/30';
+}
+
+export const DissonancePanel = () => {
+  const {
+    projectName,
+    dissonanceActive,
+    dissonanceLoading,
+    dissonanceError,
+    dissonanceData,
+    graph,
+    setHighlightedNodeIds,
+    exitDissonanceMode,
+  } = useAppState();
+  const baseRepo = (projectName || '').split('@')[0];
+  const [search, setSearch] = useState('');
+  const [openDomains, setOpenDomains] = useState<Set<string>>(new Set());
+  const [showMisplaced, setShowMisplaced] = useState(true);
+  const [showOrphans, setShowOrphans] = useState(false);
+
+  const fileIdByPath = useMemo(() => {
+    const m = new Map<string, string>();
+    if (!graph) return m;
+    for (const n of graph.nodes) {
+      if (n.label === 'File' && n.properties.filePath) {
+        m.set(n.properties.filePath, n.id);
+      }
+    }
+    return m;
+  }, [graph]);
+
+  const filteredMisplaced = useMemo(() => {
+    if (!dissonanceData) return [];
+    const q = search.trim().toLowerCase();
+    if (!q) return dissonanceData.misplaced;
+    return dissonanceData.misplaced.filter(
+      (m) =>
+        m.file.toLowerCase().includes(q) ||
+        m.domain.toLowerCase().includes(q) ||
+        (m.actualCommunityLabel || '').toLowerCase().includes(q),
+    );
+  }, [dissonanceData, search]);
+
+  if (!dissonanceActive && !dissonanceLoading && !dissonanceError) return null;
+
+  return (
+    <div
+      className="pointer-events-auto absolute top-3 right-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width: PANEL_WIDTH_PX, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <Target className="h-3.5 w-3.5 text-violet-300" />
+        <span className="text-xs font-semibold text-text-primary">Dissonance</span>
+        {dissonanceData && (
+          <a
+            href={`/dissonance?repo=${encodeURIComponent(baseRepo)}&format=csv`}
+            download
+            className="ml-auto shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+            title="Download per-file dissonance as CSV"
+          >
+            <Download className="h-3.5 w-3.5" />
+          </a>
+        )}
+        <button
+          type="button"
+          onClick={() => exitDissonanceMode()}
+          className={`${dissonanceData ? '' : 'ml-auto'} shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary`}
+          title="Close panel"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+
+      {dissonanceLoading && (
+        <div className="flex items-center justify-center gap-2 py-6 text-xs text-text-muted">
+          <Loader2 className="h-3.5 w-3.5 animate-spin" />
+          Computing dissonance…
+        </div>
+      )}
+      {dissonanceError && (
+        <div className="flex items-start gap-2 px-3 py-3 text-xs text-red-400 whitespace-pre-wrap font-mono">
+          <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+          <span className="break-all">{dissonanceError}</span>
+        </div>
+      )}
+
+      {dissonanceData && !dissonanceLoading && (
+        <>
+          {/* Header strip: purity score + counts */}
+          <div className="space-y-1.5 border-b border-border-subtle bg-elevated px-3 py-2">
+            <div className="flex items-center gap-2 text-[11px]">
+              <span className="text-text-muted">Purity:</span>
+              <span
+                className={`rounded border px-1.5 py-0.5 font-mono font-semibold ${purityColor(dissonanceData.purity)}`}
+                title="1 = each domain lives in one community. Lower = scattered."
+              >
+                {(dissonanceData.purity * 100).toFixed(1)}%
+              </span>
+              <span className="text-text-muted">
+                · dissonance {(dissonanceData.dissonance * 100).toFixed(1)}%
+              </span>
+            </div>
+            <div className="text-[10px] text-text-muted">
+              {dissonanceData.totals.domainsDeclared} domains ·{' '}
+              {dissonanceData.totals.filesAttributed}/{dissonanceData.totals.filesKnown} files
+              attributed · {dissonanceData.totals.communitiesSeen} communities
+            </div>
+          </div>
+
+          {/* Search */}
+          <div className="shrink-0 border-b border-border-subtle px-3 py-2">
+            <input
+              type="text"
+              value={search}
+              onChange={(e) => setSearch(e.target.value)}
+              placeholder="Filter misplaced files…"
+              className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+              spellCheck={false}
+              autoComplete="off"
+            />
+          </div>
+
+          <div className="flex-1 overflow-y-auto">
+            {/* Per-domain breakdown */}
+            <div className="border-b border-border-subtle">
+              {dissonanceData.perDomain.map((d) => {
+                const isOpen = openDomains.has(d.domain);
+                return (
+                  <div key={d.domain} className="border-b border-border-subtle">
+                    <button
+                      type="button"
+                      onClick={() =>
+                        setOpenDomains((prev) => {
+                          const next = new Set(prev);
+                          if (next.has(d.domain)) next.delete(d.domain);
+                          else next.add(d.domain);
+                          return next;
+                        })
+                      }
+                      className="flex w-full items-center gap-2 px-3 py-1.5 text-left transition-colors hover:bg-hover cursor-pointer"
+                    >
+                      {isOpen ? (
+                        <ChevronDown className="h-3 w-3 shrink-0 text-text-muted" />
+                      ) : (
+                        <ChevronRight className="h-3 w-3 shrink-0 text-text-muted" />
+                      )}
+                      <span className="text-[11px] font-semibold text-text-primary">
+                        {d.domain}
+                      </span>
+                      <span className="font-mono text-[10px] text-text-muted">
+                        {d.filesTotal} files · {d.communitiesTouched} clusters · dominant{' '}
+                        {(d.dominantShare * 100).toFixed(0)}%
+                      </span>
+                    </button>
+                    {isOpen && (
+                      <div className="space-y-0.5 px-3 pb-2">
+                        {d.breakdown.map((b) => (
+                          <div
+                            key={b.communityId}
+                            className="flex items-center gap-2 font-mono text-[10px] text-text-secondary"
+                            title={`Community ${b.communityId}`}
+                          >
+                            <span className="w-32 truncate">{b.communityId}</span>
+                            <div className="h-1 flex-1 overflow-hidden rounded bg-elevated">
+                              <div
+                                className="h-full bg-accent"
+                                style={{ width: `${b.share * 100}%` }}
+                              />
+                            </div>
+                            <span className="w-10 text-right">
+                              {(b.share * 100).toFixed(0)}%
+                            </span>
+                            <span className="w-8 text-right text-text-muted">
+                              {b.count}
+                            </span>
+                          </div>
+                        ))}
+                      </div>
+                    )}
+                  </div>
+                );
+              })}
+            </div>
+
+            {/* Misplaced */}
+            <div>
+              <button
+                type="button"
+                onClick={() => setShowMisplaced((v) => !v)}
+                className="flex w-full items-center gap-2 border-b border-border-subtle bg-elevated px-3 py-1.5 text-left transition-colors hover:bg-hover cursor-pointer"
+              >
+                {showMisplaced ? (
+                  <ChevronDown className="h-3 w-3 shrink-0 text-text-muted" />
+                ) : (
+                  <ChevronRight className="h-3 w-3 shrink-0 text-text-muted" />
+                )}
+                <span className="text-[11px] font-semibold text-red-300">Misplaced files</span>
+                <span className="font-mono text-[10px] text-text-muted">
+                  {filteredMisplaced.length}
+                  {filteredMisplaced.length !== dissonanceData.misplaced.length &&
+                    ` of ${dissonanceData.misplaced.length}`}
+                </span>
+              </button>
+              {showMisplaced &&
+                (filteredMisplaced.length === 0 ? (
+                  <div className="px-3 py-2 text-[10px] italic text-text-muted">
+                    {dissonanceData.misplaced.length === 0
+                      ? 'None — every file matches its domain\'s dominant community. ✓'
+                      : 'No matches for current filter.'}
+                  </div>
+                ) : (
+                  filteredMisplaced.map((m) => {
+                    const fileId = fileIdByPath.get(m.file);
+                    const canHighlight = !!fileId;
+                    return (
+                      <button
+                        key={m.file}
+                        type="button"
+                        onClick={() => {
+                          if (!canHighlight) return;
+                          setHighlightedNodeIds(new Set([fileId!]));
+                        }}
+                        disabled={!canHighlight}
+                        className="flex w-full flex-col gap-0.5 border-b border-border-subtle px-3 py-2 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+                        title={
+                          canHighlight
+                            ? `Highlight ${m.file} in the graph`
+                            : 'File no longer exists in the live graph'
+                        }
+                      >
+                        <div className="flex min-w-0 items-center gap-2 font-mono text-[11px]">
+                          <span className="shrink-0 rounded border border-violet-500/30 bg-violet-500/15 px-1.5 py-0 font-semibold text-violet-300">
+                            {m.domain}
+                          </span>
+                          <span className="truncate text-text-primary">{m.file}</span>
+                        </div>
+                        <div className="truncate font-mono text-[10px] text-text-muted">
+                          actual: {m.actualCommunityLabel || m.actualCommunity} · expected:{' '}
+                          {m.expectedCommunity}
+                          {m.confidence != null && ` · conf ${Math.round(m.confidence * 100)}%`}
+                        </div>
+                      </button>
+                    );
+                  })
+                ))}
+            </div>
+
+            {/* Domain-declared-but-no-community */}
+            {dissonanceData.domainWithoutCommunity.length > 0 && (
+              <div>
+                <button
+                  type="button"
+                  onClick={() => setShowOrphans((v) => !v)}
+                  className="flex w-full items-center gap-2 border-b border-border-subtle bg-elevated px-3 py-1.5 text-left transition-colors hover:bg-hover cursor-pointer"
+                >
+                  {showOrphans ? (
+                    <ChevronDown className="h-3 w-3 shrink-0 text-text-muted" />
+                  ) : (
+                    <ChevronRight className="h-3 w-3 shrink-0 text-text-muted" />
+                  )}
+                  <span className="text-[11px] font-semibold text-amber-300">
+                    Declared but no community
+                  </span>
+                  <span className="font-mono text-[10px] text-text-muted">
+                    {dissonanceData.domainWithoutCommunity.length}
+                  </span>
+                </button>
+                {showOrphans &&
+                  dissonanceData.domainWithoutCommunity.slice(0, 200).map((o) => (
+                    <div
+                      key={o.file}
+                      className="flex min-w-0 items-center gap-2 border-b border-border-subtle px-3 py-1 font-mono text-[10px] text-text-muted"
+                      title="No symbols → no community attribution. Typical for configs/docs."
+                    >
+                      <span className="shrink-0 rounded bg-elevated px-1 py-0">{o.domain}</span>
+                      <span className="truncate text-text-secondary">{o.file}</span>
+                    </div>
+                  ))}
+                {dissonanceData.domainWithoutCommunity.length > 200 && (
+                  <div className="px-3 py-1 text-[10px] italic text-text-muted">
+                    Showing 200 of {dissonanceData.domainWithoutCommunity.length}.
+                  </div>
+                )}
+              </div>
+            )}
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
