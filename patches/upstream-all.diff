+                          >
+                            {p.b.repo.slice(0, 8)}
+                          </span>
+                          <span className="min-w-0 truncate text-text-primary">{p.b.path}</span>
+                        </div>
+                        <div className="flex items-center gap-3 text-[10px] text-text-muted">
