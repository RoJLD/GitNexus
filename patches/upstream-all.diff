+  const edges = pairs
+    .map((pair) => {
+      const a = pts.find((p) => p.name === pair.a);
+      const b = pts.find((p) => p.name === pair.b);
+      if (!a || !b) return null;
+      const sem = pair.semanticScore ?? 0;
+      const strength = (pair.structuralScore + sem + pair.temporalCoupling) / 3;
+      if (strength < GALAXY_EDGE_THRESHOLD) return null;
+      return { a, b, strength, pair };
+    })
+    .filter(Boolean) as { a: typeof pts[0]; b: typeof pts[0]; strength: number; pair: SimilarityPair }[];
+
+  return (
+    <div className="px-3 py-2">
+      {/* PCA / UMAP method toggle (Tier 2.6 + 2.6.bis). PCA is the
+          default because it ships pre-computed in the response; UMAP
