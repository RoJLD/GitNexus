diff --git a/gitnexus-web/src/components/BulkSnapshotModal.tsx b/gitnexus-web/src/components/BulkSnapshotModal.tsx
new file mode 100644
index 0000000..487fd21
--- /dev/null
+++ b/gitnexus-web/src/components/BulkSnapshotModal.tsx
@@ -0,0 +1,428 @@
+import { useEffect, useRef, useState } from 'react';
+import {
+  X,
+  Camera,
+  Loader2,
+  Check,
+  AlertCircle,
+  Clock,
+  ChevronRight,
+} from '@/lib/lucide-icons';
+
+/**
+ * Modal that drives /snapshot/bulk. Two phases:
+ *
+ *   1. Form: user picks how many snapshots and over what time window.
+ *      Submitting POSTs to /snapshot/bulk and switches to phase 2.
+ *
+ *   2. Progress: subscribes to /snapshot/bulk/<jobId> via SSE and shows
+ *      a live commit-by-commit progress list. The user can abort, in
+ *      which case the loop stops at the next commit boundary (in-flight
+ *      commits complete normally to keep the on-disk state consistent).
+ *
+ * On `done`, we call `onComplete` so the parent refreshes the registry and
+ * the snapshots panel without an additional fetch on our part.
+ */
+
+interface BulkSnapshotModalProps {
+  repoName: string;
+  isOpen: boolean;
+  onClose: () => void;
+  onComplete: () => void;
+}
+
+type Mode = 'lastN' | 'spaced';
+
+interface CommitInfo {
+  hash: string;
+  shortHash: string;
+  date: string;
+  message: string;
+}
+
+interface BulkEvent {
+  type: string;
+  index?: number;
+  total?: number;
+  commit?: CommitInfo;
+  phase?: string;
+  existing?: boolean;
+  error?: string;
+  created?: number;
+  skipped?: number;
+  failed?: number;
+  commits?: CommitInfo[];
+}
+
+export const BulkSnapshotModal = ({
+  repoName,
+  isOpen,
+  onClose,
+  onComplete,
+}: BulkSnapshotModalProps) => {
+  const [count, setCount] = useState(10);
+  const [mode, setMode] = useState<Mode>('spaced');
+  const [sinceDays, setSinceDays] = useState(30);
+  const [jobId, setJobId] = useState<string | null>(null);
+  const [events, setEvents] = useState<BulkEvent[]>([]);
+  const [running, setRunning] = useState(false);
+  const [error, setError] = useState<string | null>(null);
+  const [summary, setSummary] = useState<BulkEvent | null>(null);
+  const esRef = useRef<EventSource | null>(null);
+
+  // Clean up the SSE connection on unmount / when the modal closes.
+  useEffect(() => {
+    if (!isOpen) {
+      esRef.current?.close();
+      esRef.current = null;
+    }
+    return () => {
+      esRef.current?.close();
+      esRef.current = null;
+    };
+  }, [isOpen]);
+
+  const handleStart = async () => {
+    setError(null);
+    setEvents([]);
+    setSummary(null);
+    setRunning(true);
+    try {
+      const resp = await fetch(`/snapshot/bulk?repo=${encodeURIComponent(repoName)}`, {
+        method: 'POST',
+        headers: { 'Content-Type': 'application/json' },
+        body: JSON.stringify({ mode, count, sinceDays: mode === 'spaced' ? sinceDays : null }),
+      });
+      if (!resp.ok) {
+        const body = await resp.json().catch(() => ({}));
+        throw new Error(body.error || `HTTP ${resp.status}`);
+      }
+      const { jobId: id } = await resp.json();
+      setJobId(id);
+
+      const es = new EventSource(`/snapshot/bulk/${encodeURIComponent(id)}`);
+      esRef.current = es;
+      es.onmessage = (e) => {
+        try {
+          const event: BulkEvent = JSON.parse(e.data);
+          setEvents((prev) => [...prev, event]);
+          if (event.type === 'done' || event.type === 'aborted') {
+            setSummary(event);
+            setRunning(false);
+            es.close();
+            esRef.current = null;
+            // Tell the parent so the snapshots panel refetches.
+            onComplete();
+          }
+        } catch {
+          // Bad event — ignore.
+        }
+      };
+      es.onerror = () => {
+        // EventSource will auto-reconnect; if the job actually died, the
+        // backend returns 404 and the stream stays closed. We surface the
+        // error if we never received a started event.
+        if (events.length === 0) {
+          setError('Lost connection to the snapshot stream.');
+          setRunning(false);
+          es.close();
+          esRef.current = null;
+        }
+      };
+    } catch (err) {
+      setError(err instanceof Error ? err.message : 'Failed to start bulk snapshot');
+      setRunning(false);
+    }
+  };
+
+  const handleAbort = async () => {
+    if (!jobId) return;
+    try {
+      await fetch(`/snapshot/bulk/${encodeURIComponent(jobId)}`, { method: 'DELETE' });
+    } catch {}
+  };
+
+  if (!isOpen) return null;
+
+  // Derive a per-commit state summary from the event stream so we don't
+  // re-render the whole list on every event.
+  const startedEvent = events.find((e) => e.type === 'started');
+  const total = startedEvent?.total ?? 0;
+  const perCommitState = new Map<string, { phase: string; status: 'pending' | 'running' | 'done' | 'error' | 'existing'; error?: string }>();
+  if (startedEvent?.commits) {
+    for (const c of startedEvent.commits) {
+      perCommitState.set(c.hash, { phase: 'queued', status: 'pending' });
+    }
+  }
+  for (const ev of events) {
+    if (!ev.commit) continue;
+    const cur = perCommitState.get(ev.commit.hash) ?? { phase: 'queued', status: 'pending' as const };
+    if (ev.type === 'commit-start') cur.status = 'running';
+    else if (ev.type === 'commit-phase') cur.phase = ev.phase || cur.phase;
+    else if (ev.type === 'commit-done') {
+      cur.status = ev.existing ? 'existing' : 'done';
+      cur.phase = 'done';
+    } else if (ev.type === 'commit-error') {
+      cur.status = 'error';
+      cur.error = ev.error;
+    }
+    perCommitState.set(ev.commit.hash, cur);
+  }
+  const completedCount = events.filter(
+    (e) => e.type === 'commit-done' || e.type === 'commit-error',
+  ).length;
+  const pct = total > 0 ? Math.round((completedCount / total) * 100) : 0;
+
+  return (
+    <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm">
+      <div className="w-[min(640px,calc(100vw-2rem))] max-h-[min(720px,calc(100vh-4rem))] overflow-hidden rounded-2xl border border-border-subtle bg-surface shadow-2xl flex flex-col">
+        {/* Header */}
+        <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-4 py-3">
+          <Camera className="h-4 w-4 text-accent" />
+          <span className="font-medium text-text-primary">Bulk snapshot</span>
+          <span className="font-mono text-xs text-text-muted truncate">{repoName}</span>
+          <button
+            type="button"
+            onClick={onClose}
+            disabled={running}
+            className="ml-auto cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary disabled:opacity-30 disabled:cursor-not-allowed"
+            title={running ? 'Stop or wait for completion first' : 'Close'}
+          >
+            <X className="h-4 w-4" />
+          </button>
+        </div>
+
+        {/* Form (only before we start) */}
+        {!jobId && (
+          <div className="space-y-4 p-4 overflow-y-auto">
+            <div className="space-y-2">
+              <label className="block text-xs font-medium tracking-wider text-text-secondary uppercase">
+                Sampling mode
+              </label>
+              <div className="flex gap-1 rounded-lg bg-elevated p-1">
+                <button
+                  type="button"
+                  onClick={() => setMode('spaced')}
+                  className={`flex flex-1 items-center justify-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium transition-all ${
+                    mode === 'spaced'
+                      ? 'bg-accent text-white'
+                      : 'text-text-muted hover:text-text-secondary cursor-pointer'
+                  }`}
+                >
+                  <Clock className="h-3 w-3" />
+                  Evenly spaced
+                </button>
+                <button
+                  type="button"
+                  onClick={() => setMode('lastN')}
+                  className={`flex flex-1 items-center justify-center gap-1.5 rounded-md px-3 py-1.5 text-xs font-medium transition-all ${
+                    mode === 'lastN'
+                      ? 'bg-accent text-white'
+                      : 'text-text-muted hover:text-text-secondary cursor-pointer'
+                  }`}
+                >
+                  Last N commits
+                </button>
+              </div>
+              <p className="text-xs text-text-muted">
+                {mode === 'spaced'
+                  ? 'Picks N commits evenly across a time window. Best for seeing project trajectory.'
+                  : 'Snapshots the N most recent commits. Best for recent activity zoom-in.'}
+              </p>
+            </div>
+
+            <div className="grid grid-cols-2 gap-3">
+              <div className="space-y-1.5">
+                <label className="block text-xs font-medium tracking-wider text-text-secondary uppercase">
+                  Snapshots ({count})
+                </label>
+                <input
+                  type="range"
+                  min={2}
+                  max={50}
+                  value={count}
+                  onChange={(e) => setCount(parseInt(e.target.value, 10))}
+                  className="w-full accent-accent"
+                />
+                <div className="flex justify-between text-[10px] text-text-muted">
+                  <span>2</span>
+                  <span>50</span>
+                </div>
+              </div>
+
+              {mode === 'spaced' && (
+                <div className="space-y-1.5">
+                  <label className="block text-xs font-medium tracking-wider text-text-secondary uppercase">
+                    Window ({sinceDays} days)
+                  </label>
+                  <input
+                    type="range"
+                    min={7}
+                    max={365}
+                    value={sinceDays}
+                    onChange={(e) => setSinceDays(parseInt(e.target.value, 10))}
+                    className="w-full accent-accent"
+                  />
+                  <div className="flex justify-between text-[10px] text-text-muted">
+                    <span>7d</span>
+                    <span>1y</span>
+                  </div>
+                </div>
+              )}
+            </div>
+
+            <div className="rounded-lg border border-amber-500/30 bg-amber-500/10 px-3 py-2 text-xs text-amber-200">
+              Each snapshot takes ~10-60s (clone + analyze). {count} snapshots ≈{' '}
+              {Math.ceil((count * 30) / 60)}-{count} minutes. Existing snapshots are skipped
+              (idempotent), so you can re-run safely.
+            </div>
+
+            {error && (
+              <div className="flex items-center gap-2 text-xs text-red-400">
+                <AlertCircle className="h-3.5 w-3.5" />
+                {error}
+              </div>
+            )}
+
+            <button
+              type="button"
+              onClick={handleStart}
+              disabled={running}
+              className="flex w-full items-center justify-center gap-2 rounded-xl bg-accent px-4 py-3 text-sm font-medium text-white shadow-glow-soft transition-all hover:-translate-y-0.5 hover:bg-accent/90 disabled:cursor-not-allowed disabled:opacity-50"
+            >
+              {running ? (
+                <>
+                  <Loader2 className="h-4 w-4 animate-spin" />
+                  Starting…
+                </>
+              ) : (
+                <>
+                  <Camera className="h-4 w-4" />
+                  Capture {count} snapshots
+                </>
+              )}
+            </button>
+          </div>
+        )}
+
+        {/* Progress view (after kickoff) */}
+        {jobId && (
+          <div className="space-y-3 p-4 overflow-y-auto">
+            {/* Overall progress bar */}
+            <div className="space-y-1.5">
+              <div className="flex items-center justify-between text-xs">
+                <span className="font-medium text-text-secondary">
+                  {summary?.type === 'done'
+                    ? 'Completed'
+                    : summary?.type === 'aborted'
+                      ? 'Aborted'
+                      : 'Capturing…'}{' '}
+                  {completedCount} / {total}
+                </span>
+                <span className="font-mono text-text-muted">{pct}%</span>
+              </div>
+              <div className="h-2 overflow-hidden rounded-full bg-elevated">
+                <div
+                  className={`h-full rounded-full transition-all duration-300 ${
+                    summary?.type === 'aborted'
+                      ? 'bg-amber-500'
+                      : summary?.type === 'done'
+                        ? 'bg-emerald-500'
+                        : 'bg-gradient-to-r from-accent to-node-interface'
+                  }`}
+                  style={{ width: `${pct}%` }}
+                />
+              </div>
+            </div>
+
+            {summary && (
+              <div className="flex items-center gap-3 rounded-lg border border-border-subtle bg-elevated px-3 py-2 text-xs">
+                <Check className="h-3.5 w-3.5 text-emerald-400" />
+                <span className="text-text-secondary">
+                  {summary.created ?? 0} new · {summary.skipped ?? 0} already existed ·{' '}
+                  {summary.failed ?? 0} failed
+                </span>
+              </div>
+            )}
+
+            {/* Per-commit list */}
+            <div className="max-h-72 space-y-0.5 overflow-y-auto rounded-lg border border-border-subtle bg-void p-2">
+              {startedEvent?.commits?.map((c, i) => {
+                const state = perCommitState.get(c.hash);
+                return (
+                  <div
+                    key={c.hash}
+                    className="flex items-center gap-2 rounded px-2 py-1 text-xs hover:bg-hover"
+                    title={`${c.message}\n${c.date}\n${c.hash}`}
+                  >
+                    <span className="w-6 text-right font-mono text-[10px] text-text-muted">
+                      {i + 1}
+                    </span>
+                    <span className="w-16 truncate font-mono text-[11px] text-accent">
+                      {c.shortHash}
+                    </span>
+                    <span className="flex-1 truncate text-text-secondary">
+                      {c.message || '(no message)'}
+                    </span>
+                    {state?.status === 'pending' && (
+                      <span className="shrink-0 text-[10px] text-text-muted">queued</span>
+                    )}
+                    {state?.status === 'running' && (
+                      <span className="flex shrink-0 items-center gap-1 text-[10px] text-accent">
+                        <Loader2 className="h-3 w-3 animate-spin" />
+                        {state.phase}
+                      </span>
+                    )}
+                    {state?.status === 'existing' && (
+                      <span className="flex shrink-0 items-center gap-1 text-[10px] text-text-muted">
+                        <ChevronRight className="h-3 w-3" />
+                        already done
+                      </span>
+                    )}
+                    {state?.status === 'done' && (
+                      <span className="flex shrink-0 items-center gap-1 text-[10px] text-emerald-400">
+                        <Check className="h-3 w-3" />
+                        done
+                      </span>
+                    )}
+                    {state?.status === 'error' && (
+                      <span
+                        className="flex shrink-0 items-center gap-1 text-[10px] text-red-400"
+                        title={state.error}
+                      >
+                        <AlertCircle className="h-3 w-3" />
+                        error
+                      </span>
+                    )}
+                  </div>
+                );
+              })}
+            </div>
+
+            <div className="flex items-center gap-2">
+              {!summary && (
+                <button
+                  type="button"
+                  onClick={handleAbort}
+                  className="flex items-center gap-1.5 rounded-lg border border-amber-500/40 bg-amber-500/10 px-3 py-1.5 text-xs font-medium text-amber-300 transition-all hover:bg-amber-500/20 cursor-pointer"
+                >
+                  <X className="h-3 w-3" />
+                  Abort
+                </button>
+              )}
+              {summary && (
+                <button
+                  type="button"
+                  onClick={onClose}
+                  className="ml-auto flex items-center gap-1.5 rounded-lg bg-accent px-4 py-1.5 text-xs font-medium text-white transition-all hover:bg-accent/90 cursor-pointer"
+                >
+                  Close
+                </button>
+              )}
+            </div>
+          </div>
+        )}
+      </div>
+    </div>
+  );
+};
diff --git a/gitnexus-web/src/components/CouplingPanel.tsx b/gitnexus-web/src/components/CouplingPanel.tsx
new file mode 100644
index 0000000..f91c568
--- /dev/null
+++ b/gitnexus-web/src/components/CouplingPanel.tsx
@@ -0,0 +1,204 @@
+import { useMemo, useState } from 'react';
+import {
+  X,
+  ArrowRight,
+  AlertCircle,
+  Loader2,
+  Download,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Floating panel listing top-N temporal-coupling pairs.
+ *
+ * Hidden unless `couplingActive` is true. Each row shows two file paths
+ * connected by an arrow, the Jaccard similarity (how often they change
+ * together), and the raw co-change count. Clicking a row highlights both
+ * files on the graph using the existing highlightedNodeIds machinery —
+ * the same green/cyan affordance the user already knows from query
+ * results, so no new visual language to learn.
+ *
+ * Position: docked top-right under the header, scrollable up to 500px.
+ * Width: a fixed pixel value so paths don't reflow as the user picks
+ * different items (the graph behind it would otherwise jitter).
+ */
+
+const PANEL_WIDTH_PX = 340;
+
+export const CouplingPanel = () => {
+  const {
+    projectName,
+    couplingActive,
+    couplingLoading,
+    couplingError,
+    couplingData,
+    graph,
+    setHighlightedNodeIds,
+    exitCouplingMode,
+  } = useAppState();
+  const baseRepo = (projectName || '').split('@')[0];
+  const [minJaccard, setMinJaccard] = useState(0.5);
+  const [search, setSearch] = useState('');
+
+  // Build a path → File-node-id index from the live graph so a row click
+  // can highlight both endpoints. Doing this lazily / memoized keeps the
+  // panel light even on very large graphs (5k+ files).
+  const fileIdByPath = useMemo(() => {
+    const m = new Map<string, string>();
+    if (!graph) return m;
+    for (const n of graph.nodes) {
+      if (n.label === 'File' && n.properties.filePath) {
+        m.set(n.properties.filePath, n.id);
+      }
+    }
+    return m;
+  }, [graph]);
+
+  const filteredPairs = useMemo(() => {
+    if (!couplingData) return [];
+    const q = search.trim().toLowerCase();
+    return couplingData.pairs.filter((p) => {
+      if (p.jaccard < minJaccard) return false;
+      if (q && !p.a.toLowerCase().includes(q) && !p.b.toLowerCase().includes(q)) return false;
+      return true;
+    });
+  }, [couplingData, minJaccard, search]);
+
+  if (!couplingActive && !couplingLoading && !couplingError) return null;
+
+  return (
+    <div
+      className="pointer-events-auto absolute top-3 right-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width: PANEL_WIDTH_PX, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      {/* Header */}
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <span className="text-xs font-semibold text-text-primary">Temporal coupling</span>
+        {couplingData && (
+          <span className="font-mono text-[10px] text-text-muted">
+            over {couplingData.totalTransitions} transition
+            {couplingData.totalTransitions > 1 ? 's' : ''}
+          </span>
+        )}
+        {couplingData && couplingData.pairs.length > 0 && (
+          <a
+            href={`/coupling?repo=${encodeURIComponent(baseRepo)}&top=100&format=csv`}
+            download
+            className="ml-auto shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+            title="Download all pairs as CSV"
+          >
+            <Download className="h-3.5 w-3.5" />
+          </a>
+        )}
+        <button
+          type="button"
+          onClick={() => exitCouplingMode()}
+          className={`${couplingData?.pairs.length ? '' : 'ml-auto'} shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary`}
+          title="Exit coupling mode"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+
+      {couplingLoading && (
+        <div className="flex items-center justify-center gap-2 py-6 text-xs text-text-muted">
+          <Loader2 className="h-3.5 w-3.5 animate-spin" />
+          Computing coupling…
+        </div>
+      )}
+
+      {couplingError && (
+        <div className="flex items-start gap-2 px-3 py-3 text-xs text-red-400">
+          <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+          <span>{couplingError}</span>
+        </div>
+      )}
+
+      {couplingData && !couplingLoading && (
+        <>
+          {/* Filters */}
+          <div className="space-y-2 border-b border-border-subtle px-3 py-2">
+            <input
+              type="text"
+              value={search}
+              onChange={(e) => setSearch(e.target.value)}
+              placeholder="Filter by path…"
+              className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+              spellCheck={false}
+              autoComplete="off"
+            />
+            <div className="flex items-center gap-2 text-[10px] text-text-muted">
+              <span className="shrink-0">Min Jaccard:</span>
+              <input
+                type="range"
+                min={0}
+                max={1}
+                step={0.05}
+                value={minJaccard}
+                onChange={(e) => setMinJaccard(parseFloat(e.target.value))}
+                className="flex-1 accent-accent"
+              />
+              <span className="shrink-0 font-mono">{minJaccard.toFixed(2)}</span>
+            </div>
+          </div>
+
+          {/* Pairs list */}
+          <div className="flex-1 overflow-y-auto">
+            {filteredPairs.length === 0 ? (
+              <div className="px-3 py-4 text-center text-[11px] text-text-muted italic">
+                No pairs match the filters. Try lowering Min Jaccard.
+              </div>
+            ) : (
+              filteredPairs.map((p) => {
+                const aId = fileIdByPath.get(p.a);
+                const bId = fileIdByPath.get(p.b);
+                const canHighlight = aId && bId;
+                return (
+                  <button
+                    key={`${p.a}\0${p.b}`}
+                    type="button"
+                    onClick={() => {
+                      if (!canHighlight) return;
+                      // Replace highlights so subsequent clicks don't pile up;
+                      // the user can click another row to swap.
+                      setHighlightedNodeIds(new Set([aId!, bId!]));
+                    }}
+                    disabled={!canHighlight}
+                    className="group flex w-full flex-col gap-1 border-b border-border-subtle px-3 py-2 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+                    title={
+                      canHighlight
+                        ? `Click to highlight both files in the graph (${p.count} co-changes)`
+                        : `One or both files no longer exist in the live graph (${p.count} co-changes)`
+                    }
+                  >
+                    <div className="flex min-w-0 items-center gap-1.5 font-mono text-[11px]">
+                      <span className="truncate text-text-primary">{p.a}</span>
+                      <ArrowRight className="h-2.5 w-2.5 shrink-0 text-text-muted" />
+                      <span className="truncate text-text-primary">{p.b}</span>
+                    </div>
+                    <div className="flex items-center gap-3 text-[10px] text-text-muted">
+                      <span
+                        className="rounded bg-accent/15 px-1.5 py-0.5 font-mono text-accent"
+                        title="Jaccard similarity (1 = always together, 0 = never)"
+                      >
+                        {p.jaccard.toFixed(2)}
+                      </span>
+                      <span className="font-mono">{p.count}× together</span>
+                      {!canHighlight && (
+                        <span className="text-amber-400/80">not in live graph</span>
+                      )}
+                    </div>
+                  </button>
+                );
+              })
+            )}
+          </div>
+
+          <div className="shrink-0 border-t border-border-subtle bg-elevated px-3 py-1.5 text-[10px] text-text-muted">
+            Showing {filteredPairs.length} of {couplingData.pairs.length} pairs
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
diff --git a/gitnexus-web/src/components/DiffBanner.tsx b/gitnexus-web/src/components/DiffBanner.tsx
new file mode 100644
index 0000000..f315205
