+    await rm(stage, { recursive: true, force: true }).catch(() => {});
+  }
+}
+
+// Path to the global registry. Same mount path as the API container so we
+// race-free over the same file. Server reads it fresh on every /api/repos
+// call (see repo-manager.ts readRegistry), so direct writes show up
+// immediately on the next list.
+const REGISTRY_PATH = '/data/gitnexus/registry.json';
+
+async function readRegistryFile() {
+  try {
+    const raw = await readFile(REGISTRY_PATH, 'utf8');
+    const parsed = JSON.parse(raw);
+    return Array.isArray(parsed) ? parsed : [];
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+}
+
+async function writeRegistryFile(entries) {
+  await mkdir(dirname(REGISTRY_PATH), { recursive: true });
+  await writeFile(REGISTRY_PATH, JSON.stringify(entries, null, 2), 'utf8');
+}
+
+// Register an imported repo directly in registry.json without going through
+// /api/analyze. We pull the stats and timestamps from the imported meta.json
+// so the dropdown reflects what the sender actually exported, and we leave
+// the lbug file untouched so the graph is intact when the user opens it.
+async function registerLocally(target) {
+  const metaPath = join(target, '.gitnexus', 'meta.json');
+  let meta = {};
+  try {
