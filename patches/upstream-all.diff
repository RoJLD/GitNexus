+              className="flex w-full cursor-pointer items-center justify-center gap-2 rounded-md border border-border-subtle bg-surface px-3 py-1.5 text-[11px] font-medium text-text-secondary transition-all hover:bg-hover hover:text-text-primary"
+            >
