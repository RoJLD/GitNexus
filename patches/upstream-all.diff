+
+// Gini coefficient on a numeric distribution. Returns 0 for perfect
+// equality (all values equal), 1 for perfect inequality (all weight on
+// one item). Standard definition; we sort + use the cumulative-share
+// formula which is O(n log n) but doesn't matter here.
+function gini(values) {
+  if (!Array.isArray(values) || values.length === 0) return 0;
+  const sorted = values.slice().sort((a, b) => a - b);
+  const n = sorted.length;
+  let sum = 0;
+  let weightedSum = 0;
+  for (let i = 0; i < n; i++) {
+    sum += sorted[i];
+    weightedSum += (i + 1) * sorted[i];
+  }
+  if (sum === 0) return 0;
+  return (2 * weightedSum) / (n * sum) - (n + 1) / n;
+}
+
+// Shannon entropy normalized to [0, 1] by dividing by log2(N) where N
+// is the number of distinct buckets. A repo with all files in one
+// extension scores 0; a repo with even distribution across many
+// extensions scores close to 1.
+function normalizedShannon(counts) {
+  const values = counts.filter((c) => c > 0);
+  if (values.length <= 1) return 0;
+  const total = values.reduce((s, c) => s + c, 0);
+  if (total === 0) return 0;
+  let h = 0;
+  for (const c of values) {
+    const p = c / total;
+    h -= p * Math.log2(p);
+  }
+  const hMax = Math.log2(values.length);
+  return hMax > 0 ? h / hMax : 0;
+}
+
+// Median of a numeric array. Returns 0 for empty input.
+function median(values) {
+  if (!values || values.length === 0) return 0;
+  const sorted = values.slice().sort((a, b) => a - b);
+  const mid = Math.floor(sorted.length / 2);
+  return sorted.length % 2 === 0 ? (sorted[mid - 1] + sorted[mid]) / 2 : sorted[mid];
+}
+
+// Single-pass walk of the repo's working tree. Returns up to
+// MAX_FILES_WALK file entries with size + depth + extension. Skips
+// dot-dirs and the IGNORED_DIRS set so we don't measure node_modules.
+// depth = 0 for files at the repo root.
+async function walkRepoFiles(repoPath) {
+  const out = [];
+  async function recurse(dir, depth) {
+    if (out.length >= MAX_FILES_WALK) return;
+    let entries;
+    try {
+      entries = await readdir(dir, { withFileTypes: true });
+    } catch {
+      return;
+    }
+    for (const e of entries) {
+      if (out.length >= MAX_FILES_WALK) return;
+      if (e.name.startsWith('.') && e.name !== '.gitnexus') continue; // skip hidden, EXCEPT keep .gitnexus filtered explicitly below
+      if (IGNORED_DIRS.has(e.name)) continue;
+      const full = join(dir, e.name);
+      if (e.isDirectory()) {
+        await recurse(full, depth + 1);
+      } else if (e.isFile()) {
+        let size = 0;
+        try {
+          const st = await stat(full);
+          size = st.size;
+        } catch {
+          continue;
+        }
+        const dot = e.name.lastIndexOf('.');
+        const ext = dot > 0 ? e.name.slice(dot + 1).toLowerCase() : '';
+        out.push({ size, depth, ext });
+      }
+    }
+  }
+  await recurse(repoPath, 0);
+  return out;
+}
+
+// Growth rate: normalized slope of node-count over snapshot timeline.
+// Returns ratio (final - initial) / initial, clamped to [-1, 1] then
+// mapped to [0, 1] via (x + 1) / 2 so the dim sits in the same range
+// as the others.
+async function growthRateFromSnapshots(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return 0.5; // neutral when no snapshots
+    return 0.5;
+  }
+  const points = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+      const meta = JSON.parse(
+        await readFile(join(dir, e.name, 'source', '.gitnexus', 'meta.json'), 'utf8'),
+      );
+      const nodes = Number(meta?.stats?.nodes);
+      const date = Date.parse(commit?.date);
+      if (Number.isFinite(nodes) && Number.isFinite(date)) {
+        points.push({ date, nodes });
+      }
+    } catch {
+      // skip half-built snapshot
+    }
+  }
+  if (points.length < 2) return 0.5;
+  points.sort((a, b) => a.date - b.date);
+  const first = points[0];
+  const last = points[points.length - 1];
+  if (first.nodes <= 0) return 0.5;
+  const ratio = (last.nodes - first.nodes) / first.nodes;
+  // Clamp to [-1, 1] then shift to [0, 1].
+  const clamped = Math.max(-1, Math.min(1, ratio));
+  return (clamped + 1) / 2;
+}
+
+function busFactor(authorMap, pct = 0.8) {
+  const sorted = [...authorMap.values()].sort((a, b) => b - a);
+  const total = sorted.reduce((s, c) => s + c, 0);
+  if (total === 0) return { bf: 0, topShare: 0, total: 0 };
+  let cum = 0;
+  let bf = 0;
+  for (const c of sorted) {
+    bf++;
+    cum += c;
+    if (cum / total >= pct) break;
+  }
+  return { bf, topShare: sorted[0] / total, total };
+}
+
+// Foundational ratio: fraction of node ids present in every snapshot
+// from start to live. We use snapshot meta.json node counts as a proxy
+// when we don't have the full id list — that's a much cheaper signal
+// than running /lifespan and good enough for a 5-dim identity vector.
+// If only 1 timeline point exists, returns null (caller fills with 0).
+async function foundationalRatioCheap(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return null;
+    return null;
+  }
+  const snapshotNodeCounts = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const meta = JSON.parse(
+        await readFile(join(dir, e.name, 'source', '.gitnexus', 'meta.json'), 'utf8'),
+      );
+      const n = Number(meta?.stats?.nodes);
+      if (Number.isFinite(n) && n > 0) snapshotNodeCounts.push(n);
+    } catch {
+      // half-built snapshot, skip
+    }
+  }
+  if (snapshotNodeCounts.length < 2) return null;
+  // Without per-id intersection (too expensive here), approximate
+  // "foundational ratio" as min(snapshots) / max(snapshots) — a repo
+  // whose node count is stable across all snapshots gets a high score;
+  // one that grew or shrank dramatically gets a low one. Imperfect
+  // proxy but coherent across repos in [0, 1].
+  const minN = Math.min(...snapshotNodeCounts);
+  const maxN = Math.max(...snapshotNodeCounts);
+  return maxN > 0 ? minN / maxN : 0;
+}
+
+async function buildRepoSnapshot(repoName, api) {
+  const live = await findRepoByName(repoName, api);
+  if (!live) return { error: `repo not found: ${repoName}` };
+  const repoPath = live.repoPath || live.path;
+  const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
