+                    disabled={!canHighlight}
+                    className="group flex w-full flex-col gap-1 border-b border-border-subtle px-3 py-2 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+                    title={
+                      canHighlight
+                        ? `Click to highlight both files in the graph (${p.count} co-changes)`
+                        : `One or both files no longer exist in the live graph (${p.count} co-changes)`
+                    }
+                  >
+                    <div className="flex min-w-0 items-center gap-1.5 font-mono text-[11px]">
+                      <span className="truncate text-text-primary">{p.a}</span>
+                      <ArrowRight className="h-2.5 w-2.5 shrink-0 text-text-muted" />
+                      <span className="truncate text-text-primary">{p.b}</span>
+                    </div>
+                    <div className="flex items-center gap-3 text-[10px] text-text-muted">
+                      <span
+                        className="rounded bg-accent/15 px-1.5 py-0.5 font-mono text-accent"
+                        title="Jaccard similarity (1 = always together, 0 = never)"
+                      >
+                        {p.jaccard.toFixed(2)}
+                      </span>
+                      <span className="font-mono">{p.count}× together</span>
+                      {!canHighlight && (
+                        <span className="text-amber-400/80">not in live graph</span>
+                      )}
+                    </div>
+                  </button>
+                );
+              })
+            )}
+          </div>
+
+          <div className="shrink-0 border-t border-border-subtle bg-elevated px-3 py-1.5 text-[10px] text-text-muted">
+            Showing {filteredPairs.length} of {couplingData.pairs.length} pairs
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
