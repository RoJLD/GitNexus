@@ -0,0 +1,188 @@
+/**
+ * What-if mutation engine — ROADMAP Tier 2.3.
+ *
+ * Pure transformations on a loaded gitnexus graph snapshot. Given a
+ * KnowledgeGraph and an ordered list of structural mutations, returns
+ * a new KnowledgeGraph that reflects what the user *would* see after
+ * applying those changes — without touching disk, without re-running
+ * gitnexus analyze, without any backend round-trip.
+ *
+ * Three mutation kinds are supported in this MVP, ranked by signal:
+ *
+ *   - rename({ oldName, newName, label? })
+ *       Match every node whose `properties.name === oldName` (optionally
+ *       filtered by node label like Function/Class). Rename the node
+ *       and re-key its id by replacing the trailing :name segment.
+ *
+ *   - move({ oldPath, newPath })
+ *       Move a File and every symbol defined inside it. The new id is
+ *       computed by string-substituting the path prefix in the node id
+ *       (and in the `filePath` property where present).
+ *
+ *   - delete({ nodeId | filePath })
+ *       Remove the targeted node(s) and every relationship touching
+ *       them. If a `filePath` is given, every node attributed to that
+ *       file is dropped — same cascade as `move`.
+ *
+ * Out of scope intentionally: `split-folder` (needs a per-file mapping
+ * UI we'd rather design after we see what users do with the simple
+ * three), and any semantic transformation ("SQL → GraphQL"). The
+ * latter is impossible without a real code-rewriting model.
+ *
+ * Each call returns a *new* KnowledgeGraph. The caller can then diff
+ * it against the original via the existing `computeGraphDiff` utility
+ * — what-if reuses the diff coloring infrastructure entirely.
+ */
+
+import type { GraphNode, GraphRelationship } from 'gitnexus-shared';
+import { createKnowledgeGraph } from '../core/graph/graph';
+import type { KnowledgeGraph } from '../core/graph/types';
+
+export type Mutation =
+  | { kind: 'rename'; oldName: string; newName: string; label?: string }
+  | { kind: 'move'; oldPath: string; newPath: string }
+  | { kind: 'delete'; nodeId?: string; filePath?: string };
+
+/**
+ * Re-derive a node id when we rename. gitnexus ids follow `Label:rest`
+ * conventions with the name commonly at the tail. We do a structural
+ * rewrite rather than a blind string replace to avoid hitting the same
+ * name inside an unrelated file path or section title.
+ */
+function renamedId(id: string, oldName: string, newName: string): string {
+  const parts = id.split(':');
+  // Most ids end with the symbol name as the last segment; some include
+  // a trailing :<line> too — handle both.
+  for (let i = parts.length - 1; i >= 0; i--) {
+    if (parts[i] === oldName) {
+      parts[i] = newName;
+      return parts.join(':');
+    }
+  }
+  // Fall back to no-op when the name isn't an exact segment match —
+  // safer than corrupting unrelated ids.
+  return id;
+}
+
+/**
+ * Substitute a path prefix in any string. Used for both ids (which
+ * embed the file path) and the `filePath` property. The prefix must
+ * end on a segment boundary, so "src/foo" doesn't match "src/foobar".
+ */
+function substitutePath(s: string, oldPath: string, newPath: string): string {
+  if (s === oldPath) return newPath;
+  if (s.startsWith(oldPath + '/')) return newPath + s.slice(oldPath.length);
+  // Some ids embed the path with a trailing ":" — try that too.
+  if (s.startsWith(oldPath + ':')) return newPath + s.slice(oldPath.length);
+  return s;
+}
+
+/**
+ * True if a node belongs to the given file path (its primary
+ * attribution, not edge-incident). Used by the cascading delete /
+ * move operations.
+ */
+function nodeOwnedByFile(node: GraphNode, filePath: string): boolean {
+  if (node.label === 'File' && node.properties.filePath === filePath) return true;
+  if (node.properties.filePath === filePath) return true;
+  // Fallback: parse the id (some node ids embed the path even when the
+  // property is missing because of legacy indexes).
+  const parts = node.id.split(':');
+  return parts.length >= 2 && parts[1] === filePath;
+}
+
+/**
+ * Apply one mutation to a {nodes, rels} working pair. Mutates in place
+ * — the caller passes a defensive copy from `applyMutations` below.
+ */
+function applyOne(
+  nodes: GraphNode[],
+  rels: GraphRelationship[],
+  m: Mutation,
+): { nodes: GraphNode[]; rels: GraphRelationship[] } {
+  if (m.kind === 'rename') {
+    // We rebuild the id map first so edges can be rewritten in one pass.
+    const idMap = new Map<string, string>();
+    const nextNodes = nodes.map((n) => {
+      if (n.properties.name !== m.oldName) return n;
+      if (m.label && n.label !== m.label) return n;
+      const newId = renamedId(n.id, m.oldName, m.newName);
+      idMap.set(n.id, newId);
+      return {
+        ...n,
+        id: newId,
+        properties: { ...n.properties, name: m.newName },
+      };
+    });
+    const nextRels = rels.map((r) => {
+      const src = idMap.get(r.sourceId) ?? r.sourceId;
+      const tgt = idMap.get(r.targetId) ?? r.targetId;
+      if (src === r.sourceId && tgt === r.targetId) return r;
+      return { ...r, sourceId: src, targetId: tgt };
+    });
+    return { nodes: nextNodes, rels: nextRels };
+  }
+
+  if (m.kind === 'move') {
+    const idMap = new Map<string, string>();
+    const nextNodes = nodes.map((n) => {
+      const filePath = (n.properties as { filePath?: string }).filePath;
+      const idAffected =
+        substitutePath(n.id, m.oldPath, m.newPath) !== n.id;
+      const propAffected = filePath && substitutePath(filePath, m.oldPath, m.newPath) !== filePath;
+      if (!idAffected && !propAffected) return n;
+      const newId = substitutePath(n.id, m.oldPath, m.newPath);
+      if (newId !== n.id) idMap.set(n.id, newId);
+      const newProps = { ...n.properties };
+      if (filePath) {
+        newProps.filePath = substitutePath(filePath, m.oldPath, m.newPath);
+      }
+      return { ...n, id: newId, properties: newProps };
+    });
+    const nextRels = rels.map((r) => {
+      const src = idMap.get(r.sourceId) ?? r.sourceId;
+      const tgt = idMap.get(r.targetId) ?? r.targetId;
+      if (src === r.sourceId && tgt === r.targetId) return r;
+      return { ...r, sourceId: src, targetId: tgt };
+    });
+    return { nodes: nextNodes, rels: nextRels };
+  }
+
+  if (m.kind === 'delete') {
+    // Build the set of ids to remove. Either a single nodeId, or all
+    // nodes attributed to a given filePath (cascade).
+    const toRemove = new Set<string>();
+    if (m.nodeId) toRemove.add(m.nodeId);
+    if (m.filePath) {
+      for (const n of nodes) {
+        if (nodeOwnedByFile(n, m.filePath)) toRemove.add(n.id);
+      }
+    }
+    if (toRemove.size === 0) return { nodes, rels };
+    const nextNodes = nodes.filter((n) => !toRemove.has(n.id));
+    const nextRels = rels.filter((r) => !toRemove.has(r.sourceId) && !toRemove.has(r.targetId));
+    return { nodes: nextNodes, rels: nextRels };
+  }
+
+  return { nodes, rels };
+}
+
+/**
+ * Apply a sequence of mutations to a graph. The order matters — e.g.
+ * a `move` followed by a `delete` on the new path is meaningful;
+ * the reverse would no-op. Returns a brand-new KnowledgeGraph.
+ */
+export function applyMutations(graph: KnowledgeGraph, mutations: Mutation[]): KnowledgeGraph {
+  // Defensive copy so the caller's graph stays pristine.
+  let nodes: GraphNode[] = [...graph.nodes];
+  let rels: GraphRelationship[] = [...graph.relationships];
+  for (const m of mutations) {
+    const next = applyOne(nodes, rels, m);
+    nodes = next.nodes;
+    rels = next.rels;
+  }
+  const out = createKnowledgeGraph();
+  for (const n of nodes) out.addNode(n);
+  for (const r of rels) out.addRelationship(r);
+  return out;
+}
diff --git a/gitnexus-web/src/services/semantic-labeler.ts b/gitnexus-web/src/services/semantic-labeler.ts
