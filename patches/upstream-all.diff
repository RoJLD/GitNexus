+import { useEffect, useMemo, useState } from 'react';
+import {
+  X,
+  AlertCircle,
+  Loader2,
+  Network,
+  ShieldAlert,
+  Info,
+  Sparkles,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Cross-repo similarity panel — ROADMAP Tier 2.5.
+ *
+ * Aggregates the per-repo analytics (entropy, ownership, lifespan,
+ * git activity) into a 5-dim identity vector per repo and shows the
+ * pairwise diagnostic in a small matrix.
+ *
+ * v1 ships the structural × temporal plane (4 quadrants). The semantic
+ * axis is documented in the response (`semanticAxisAvailable: false`)
+ * but not computed — same rationale as /semantic-labels: the LLM
+ * credentials live client-side and embedding the labels needs a
+ * separate embeddings client, deferred to v1.1.
+ *
+ * Position: top-right slot, mutex with Coupling/Ownership/Dissonance/
+ * What-If. The panel auto-fetches when toggled on, using every
+ * non-snapshot repo in `availableRepos` (capped at 8 by the backend).
+ */
+
+const PANEL_WIDTH_PX = 460;
+
+type SimilarityRepo = {
+  name: string;
+  identityVector: Record<string, number>;
+  stats: {
+    nodes: number;
+    edges: number;
+    communities: number;
+    authorsCount: number;
+    busFactor: number;
+  };
+  hasGit: boolean;
+  gitError: string | null;
+  licensePresent: boolean;
+  policy: { isolation_required: boolean; reason: string | null; allow_merge_with: string[] } | null;
+  lastCommitDate: string | null;
+  semanticLabelsCount: number;
+  semanticEmbeddingsCount: number;
+  hasLabelCentroid: boolean;
+};
+
+type SimilarityPair = {
+  a: string;
+  b: string;
+  structuralScore: number;
+  semanticScore: number | null;
+  semanticMode: 'embeddings' | 'lexical' | 'none';
+  temporalCoupling: number;
+  quadrant: string;
+  recommendation: string | null;
+  warnings: string[];
+  dominantFeatures: string[];
+  policyApplied: { isolationRequired?: boolean; reasons?: string[]; whitelisted?: boolean } | null;
+};
+
+type SimilarityData = {
+  repos: SimilarityRepo[];
+  pairs: SimilarityPair[];
+  thresholds: { structural: number; semantic: number; temporal: number };
+  windowDays: number;
+  identityVersion: number;
+  identityDims: string[];
+  semanticAxisAvailable: boolean;
+  semanticAxisMode: 'lexical' | 'embeddings' | 'disabled';
+  reposWithLabels: number;
+  reposWithCentroid: number;
+  semanticAxisNote: string;
+};
+
+// Quadrant → tailwind color tokens. The 4 v1 quadrants get distinct
+// hues so the matrix reads at a glance; the others (semantic-axis
+// dependent) are listed for future use.
+const QUADRANT_COLORS: Record<string, string> = {
+  'Jumeaux actifs': 'bg-emerald-500/40 hover:bg-emerald-500/60 border-emerald-500/60',
+  'Jumeaux isolés': 'bg-amber-500/40 hover:bg-amber-500/60 border-amber-500/60',
+  'Jumeaux (isolation intentionnelle)': 'bg-slate-500/30 hover:bg-slate-500/50 border-slate-500/50',
+  'Patterns + collision': 'bg-orange-500/40 hover:bg-orange-500/60 border-orange-500/60',
+  'Patterns partagés': 'bg-sky-500/40 hover:bg-sky-500/60 border-sky-500/60',
+  'Collision réelle': 'bg-red-500/40 hover:bg-red-500/60 border-red-500/60',
+  'Domaines parallèles': 'bg-indigo-500/30 hover:bg-indigo-500/50 border-indigo-500/50',
+  'Couplage caché': 'bg-fuchsia-500/40 hover:bg-fuchsia-500/60 border-fuchsia-500/60',
+  'Indépendants': 'bg-elevated hover:bg-hover border-border-default',
+};
+
+function quadrantColor(q: string): string {
+  return QUADRANT_COLORS[q] || 'bg-elevated hover:bg-hover border-border-default';
+}
+
+function fmtScore(n: number | null): string {
+  if (n === null) return '—';
+  return n.toFixed(2);
+}
+
+function dimLabel(dim: string): string {
+  switch (dim) {
+    case 'density': return 'graph density';
+    case 'modularity': return 'modularity';
+    case 'busFactorNorm': return 'bus factor (norm)';
+    case 'topAuthorShare': return 'top-author share';
+    case 'foundationalRatio': return 'foundational ratio';
+    case 'growthRate': return 'growth rate';
+    case 'churnConcentration': return 'churn concentration (Gini)';
+    case 'fileSizePareto': return 'file-size Pareto (Gini)';
+    case 'languageDiversity': return 'language diversity (Shannon)';
+    case 'treeDepth': return 'tree depth (median)';
+    default: return dim;
+  }
+}
+
+export const SimilarityPanel = () => {
+  const {
+    projectName,
+    availableRepos,
+    similarityActive,
+    similarityLoading,
+    similarityError,
+    similarityData,
+    similarityWindowDays,
+    setSimilarityWindowDays,
+    exitSimilarityMode,
+    refreshSimilarity,
+    embedSimilarityLabels,
+    embedSimilarityLoading,
+    embedSimilarityProgress,
+    embedSimilarityError,
+    embedSimilaritySupported,
+  } = useAppState();
+
+  const baseRepo = (projectName || '').split('@')[0];
+  const [selectedPair, setSelectedPair] = useState<{ a: string; b: string } | null>(null);
+
+  // Eligible repo set: all indexed repos that aren't snapshots. The
+  // backend caps at MAX_REPOS=8, so an oversized fleet just gets the
+  // first 8 alphabetically — we keep the same behavior here for
+  // visibility into what's being compared.
+  const eligibleRepos = useMemo(
+    () => availableRepos.map((r) => r.name).filter((n) => !n.includes('@')),
+    [availableRepos],
+  );
+
+  // Auto-fetch on entering similarity mode. Re-fetch when the eligible
+  // repo set changes (new repo indexed) or window changes.
+  useEffect(() => {
+    if (!similarityActive || eligibleRepos.length < 2) return;
+    void refreshSimilarity(eligibleRepos);
+  }, [similarityActive, eligibleRepos, similarityWindowDays, refreshSimilarity]);
+
+  // Index pairs by (a,b) and (b,a) for O(1) cell lookup.
+  const pairIndex = useMemo(() => {
+    const m = new Map<string, SimilarityPair>();
+    if (!similarityData) return m;
+    for (const p of similarityData.pairs) {
+      m.set(`${p.a}::${p.b}`, p);
+      m.set(`${p.b}::${p.a}`, p);
+    }
+    return m;
+  }, [similarityData]);
+
+  const selected = selectedPair
+    ? pairIndex.get(`${selectedPair.a}::${selectedPair.b}`) || null
+    : null;
+
+  if (!similarityActive && !similarityLoading && !similarityError) return null;
+
+  const reposShown = similarityData?.repos.map((r) => r.name) || [];
+
+  return (
+    <div
+      className="pointer-events-auto absolute top-3 right-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width: PANEL_WIDTH_PX, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <Network className="h-3.5 w-3.5 text-cyan-300" />
+        <span className="text-xs font-semibold text-text-primary">Cross-repo similarity</span>
+        {similarityData && (
+          <span className="font-mono text-[10px] text-text-muted">
+            {similarityData.repos.length} repos · {similarityData.windowDays}d window
+          </span>
+        )}
+        {/* Embed labels — only shown when the active provider supports
+            embeddings AND at least one repo has cached labels (otherwise
+            there's nothing to embed). Clicking starts a multi-repo pass
+            that upgrades the semantic axis from lexical to dense cosine. */}
+        {similarityData && embedSimilaritySupported && similarityData.reposWithLabels > 0 && (
+          <button
+            type="button"
+            onClick={() => {
+              const labeled = similarityData.repos
+                .filter((r) => r.semanticLabelsCount > 0)
+                .map((r) => r.name);
+              if (labeled.length > 0) {
+                void embedSimilarityLabels(labeled, false);
+              }
