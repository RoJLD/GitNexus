index 0000000..42af117
--- /dev/null
+++ b/gitnexus-web/src/services/semantic-labeler.ts
@@ -0,0 +1,443 @@
+/**
+ * Semantic labeler — ROADMAP Tier 2.1, frontend orchestration.
+ *
+ * Walks every Community in the active repo, asks the user's configured
+ * LLM provider to invent a domain label from the community's member
+ * names, and POSTs the result to `/semantic-labels?repo=…` for
+ * persistence. The server-side cache is the source of truth — this
+ * service is just the "fill the cache" pipeline.
+ *
+ * Reusing the existing `createChatModel(config)` from the chat agent
+ * means we automatically support every provider the user has wired up
+ * (OpenAI, Azure, Gemini, Anthropic, Ollama, OpenRouter, MiniMax, GLM)
+ * without per-provider plumbing. Same API key, same provider quota,
+ * one configuration to manage.
+ *
+ * The pipeline is small but the design choices matter:
+ *
+ *   - Concurrency = 3 by default. One per provider call is "polite"
+ *     enough that consumer rate limits don't fire; higher saves time
+ *     on big repos with 50+ communities.
+ *   - Per-community fan-in: top 30 member names by symbol kind
+ *     (Functions/Classes first, then Methods, finally Files). Past
+ *     30 names, the signal saturates and we just spend tokens.
+ *   - Strict-JSON prompt + JSON.parse. If the model wraps the JSON in
+ *     prose, we strip the fence; if it still won't parse, we drop the
+ *     entry rather than poisoning the cache with a half-label.
+ *   - Best-effort: a single community failing doesn't abort the run.
+ *     The progress callback emits the failure so the UI can surface it.
+ */
+
+import { runQuery, getBackendUrl } from './backend-client';
+import { createChatModel, createEmbeddingsModel } from '../core/llm/agent';
+import { getActiveProviderConfig } from '../core/llm/settings-service';
+import { HumanMessage } from '@langchain/core/messages';
+
+export interface SemanticLabel {
+  label: string;
+  confidence: number;
+  evidenceNodes: string[];
+  labeledAt?: string;
+  provider?: string;
+  model?: string;
+  /** Embedding vector for the label (Tier 2.5b.bis). Populated by
+   *  embedSemanticLabels; absent when only the lexical label exists. */
+  embedding?: number[];
+  /** Embedding provider+model — used to invalidate when the user
+   *  switches providers and we want fresh vectors. */
+  embeddingProvider?: string;
+  embeddingModel?: string;
+}
+
+export interface SemanticLabelsCache {
+  schemaVersion: number;
+  labels: Record<string, SemanticLabel>;
+}
+
+export interface CommunitySeed {
+  communityId: string;
+  heuristicLabel: string | null;
+  /** Member identifiers chosen for the LLM prompt (best-effort top N). */
+  memberNames: string[];
+  /** Total members for context (we cap memberNames). */
+  totalMembers: number;
+}
+
+const TOP_MEMBERS_PER_COMMUNITY = 30;
+const DEFAULT_CONCURRENCY = 3;
+
+/**
+ * Fetch the cache snapshot from the backend. Returns an empty cache
+ * (with current schemaVersion) if the file doesn't exist yet.
+ */
+export async function fetchSemanticLabels(repo: string): Promise<SemanticLabelsCache> {
+  const url = `${webRoot()}/semantic-labels?repo=${encodeURIComponent(repo)}`;
+  const resp = await fetch(url, { cache: 'no-store' });
+  if (!resp.ok) throw new Error(`fetch semantic-labels: HTTP ${resp.status}`);
+  const body = await resp.json();
+  return { schemaVersion: body.schemaVersion ?? 1, labels: body.labels ?? {} };
+}
+
+/**
+ * Persist a batch of newly-generated labels. Merge semantics are
+ * last-write-wins per communityId, handled server-side.
+ */
+export async function postSemanticLabels(
+  repo: string,
+  labels: Record<string, SemanticLabel>,
+  provider: string,
+  model: string,
+): Promise<void> {
+  const url = `${webRoot()}/semantic-labels?repo=${encodeURIComponent(repo)}`;
+  const resp = await fetch(url, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ labels, provider, model }),
+  });
+  if (!resp.ok) {
+    const text = await resp.text().catch(() => '');
+    throw new Error(`post semantic-labels: HTTP ${resp.status} ${text}`);
+  }
+}
+
+/**
+ * Enumerate all communities and a sample of their member symbols. We
+ * grab Function/Class/Method names first (highest signal for naming),
+ * fall back to Files when a community has no symbols (rare).
+ */
+export async function enumerateCommunities(repo: string): Promise<CommunitySeed[]> {
+  const rows = await runQuery(
+    `
+    MATCH (s)-[:CodeRelation {type: 'MEMBER_OF'}]->(c:Community)
+    WHERE s.label IN ['Function', 'Class', 'Method']
+    RETURN c.id AS communityId,
+           c.heuristicLabel AS heuristicLabel,
+           collect(s.name)[..${TOP_MEMBERS_PER_COMMUNITY}] AS names,
+           count(s) AS total
+    `,
+    repo,
+  ).catch(() => [] as any[]);
+
+  // If the symbols query came back empty, fall back to file names. This
+  // can happen on docs-only repos.
+  let rawRows = rows;
+  if (!rows.length) {
+    rawRows = await runQuery(
+      `
+      MATCH (f:File)-[:CodeRelation {type: 'MEMBER_OF'}]->(c:Community)
+      RETURN c.id AS communityId,
+             c.heuristicLabel AS heuristicLabel,
+             collect(f.filePath)[..${TOP_MEMBERS_PER_COMMUNITY}] AS names,
+             count(f) AS total
+      `,
+      repo,
+    ).catch(() => [] as any[]);
+  }
+
+  return rawRows
+    .map((row: any) => ({
+      communityId: row.communityId ?? row['c.id'],
+      heuristicLabel: row.heuristicLabel ?? row['c.heuristicLabel'] ?? null,
+      memberNames: Array.isArray(row.names) ? row.names.filter((n: unknown) => typeof n === 'string') : [],
+      totalMembers: Number(row.total ?? row['count(s)'] ?? row['count(f)'] ?? 0),
+    }))
+    .filter((s) => typeof s.communityId === 'string' && s.communityId.length > 0);
+}
+
+const SYSTEM_PROMPT = `You name software domains.
+Given the top-30 symbol names from one community of a codebase, propose
+a SHORT domain label (1-3 words, Title Case).
+
+Respond ONLY with strict JSON, no prose around it:
+{
+  "label": "Title Case Label",
+  "confidence": 0.0 to 1.0,
+  "reasoning": "one-sentence why"
+}
+
+Pick a label that someone seeing this repo for the first time would
+recognize. Examples of good labels: "Authentication", "Order Pricing",
+"Image Upload", "HTTP Routing", "Time Series Analysis".
+Avoid generic words alone: "Utils", "Helpers", "Module" are bad unless
+the symbols truly all look like utilities.`;
+
+function buildUserPrompt(seed: CommunitySeed): string {
+  const heuristic = seed.heuristicLabel ? `\nUpstream heuristic guess: "${seed.heuristicLabel}"` : '';
+  const truncatedNote =
+    seed.totalMembers > seed.memberNames.length
+      ? `\n(showing ${seed.memberNames.length} of ${seed.totalMembers} members)`
+      : '';
+  return `Symbol names in this community:${truncatedNote}
+${seed.memberNames.map((n) => `- ${n}`).join('\n')}${heuristic}`;
+}
+
+/**
+ * Extract a JSON object from a possibly-fenced or prose-wrapped reply.
+ * Returns null if nothing parses, so the caller can drop the entry.
+ */
+function tryParseLabel(text: string): { label: string; confidence: number } | null {
+  // Strip ```json fences if present.
+  let s = text.trim();
+  const fence = s.match(/```(?:json)?\s*([\s\S]*?)```/);
+  if (fence) s = fence[1].trim();
+  // Last-resort: extract the first {...} block.
+  if (!s.startsWith('{')) {
+    const m = s.match(/\{[\s\S]*\}/);
+    if (m) s = m[0];
+  }
+  try {
+    const parsed = JSON.parse(s);
+    if (typeof parsed?.label !== 'string' || parsed.label.trim().length === 0) return null;
+    const label = parsed.label.trim().slice(0, 80);
+    const confidence =
+      typeof parsed.confidence === 'number' && parsed.confidence >= 0 && parsed.confidence <= 1
+        ? parsed.confidence
+        : 0.6;
+    return { label, confidence };
+  } catch {
+    return null;
+  }
+}
+
+export interface LabelProgress {
+  done: number;
+  total: number;
+  current?: CommunitySeed;
+  newLabel?: SemanticLabel;
+  error?: string;
+}
+
+/**
+ * Drive the full labelling pipeline. Caller decides when to start
+ * (e.g. a button click). The promise resolves with the final cache
+ * snapshot. Onprogress fires after every community.
+ *
+ * Cancellation: pass an AbortSignal — we check it between communities
+ * and skip the remaining ones. In-flight LLM calls keep their token
+ * cost but don't pollute the cache because we POST in a single batch
+ * at the end.
+ */
+export async function generateSemanticLabels(opts: {
+  repo: string;
+  onProgress?: (p: LabelProgress) => void;
+  concurrency?: number;
+  signal?: AbortSignal;
+  /** When true, regenerate even communities that already have a label. */
+  overwrite?: boolean;
+}): Promise<{ labels: Record<string, SemanticLabel>; provider: string; model: string }> {
+  const config = getActiveProviderConfig();
+  if (!config) {
+    throw new Error(
+      'No LLM provider configured. Open Settings (gear icon, top-right) and pick a provider + API key.',
+    );
+  }
+  const model = createChatModel(config);
+  const providerName = config.provider;
+  const modelName = (config as { model?: string }).model || 'unknown';
+
+  const seeds = await enumerateCommunities(opts.repo);
+  if (seeds.length === 0) {
+    return { labels: {}, provider: providerName, model: modelName };
+  }
+
+  // Drop communities we already have unless overwrite is set. The cache
+  // is durable, so re-running this is cheap when most labels exist.
+  let toLabel = seeds;
+  if (!opts.overwrite) {
+    const existing = await fetchSemanticLabels(opts.repo);
+    const have = new Set(Object.keys(existing.labels));
+    toLabel = seeds.filter((s) => !have.has(s.communityId));
+  }
+
+  const total = toLabel.length;
+  let done = 0;
+  const newLabels: Record<string, SemanticLabel> = {};
+  const concurrency = Math.max(1, opts.concurrency ?? DEFAULT_CONCURRENCY);
+
+  // Worker pool: each worker pulls the next seed off the shared array.
+  const queue = [...toLabel];
+  await Promise.all(
+    Array.from({ length: Math.min(concurrency, queue.length) }, async () => {
+      while (queue.length > 0) {
+        if (opts.signal?.aborted) return;
+        const seed = queue.shift();
+        if (!seed) return;
+        try {
+          const response = await model.invoke([
+            new HumanMessage({ content: `${SYSTEM_PROMPT}\n\n${buildUserPrompt(seed)}` }),
+          ]);
+          const text = typeof response.content === 'string'
+            ? response.content
+            : Array.isArray(response.content)
+              ? response.content.map((c: any) => (typeof c === 'string' ? c : c?.text ?? '')).join('')
+              : String(response.content);
+          const parsed = tryParseLabel(text);
+          if (parsed) {
+            const entry: SemanticLabel = {
+              label: parsed.label,
+              confidence: parsed.confidence,
+              evidenceNodes: seed.memberNames.slice(0, 5),
+            };
+            newLabels[seed.communityId] = entry;
+            done++;
+            opts.onProgress?.({ done, total, current: seed, newLabel: entry });
+          } else {
+            done++;
+            opts.onProgress?.({ done, total, current: seed, error: 'unparseable LLM reply' });
+          }
+        } catch (err) {
+          done++;
+          opts.onProgress?.({
+            done,
+            total,
+            current: seed,
+            error: err instanceof Error ? err.message : 'LLM call failed',
+          });
+        }
+      }
+    }),
+  );
+
+  // Single POST at the end so partial runs don't leave the cache in an
+  // odd state on cancellation.
+  if (Object.keys(newLabels).length > 0) {
+    await postSemanticLabels(opts.repo, newLabels, providerName, modelName);
+  }
+
+  return { labels: newLabels, provider: providerName, model: modelName };
+}
+
+// ── Embeddings (Tier 2.5b.bis) ───────────────────────────────────────
+
+export interface EmbedProgress {
+  done: number;
+  total: number;
+  current?: string; // communityId currently being embedded
+  error?: string;
+}
+
+/**
+ * Embed already-generated labels for a repo. Reads the cache, runs
+ * embedDocuments on labels that don't have an embedding yet (or whose
+ * embedding was produced by a different model), POSTs the augmented
+ * cache back.
+ *
+ * No-op for providers without embeddings support (Anthropic, OpenRouter,
+ * MiniMax, GLM) — returns `{skipped: true, reason}` so the caller can
+ * surface the right "your provider can't do this" message.
+ *
+ * Batching: most embedding APIs accept up to 16-100 documents per call,
+ * and our label set is typically 20-80 labels per repo, so a single
+ * batch is usually enough. Falls back to sequential if the SDK
+ * complains.
+ */
+export async function embedSemanticLabels(opts: {
+  repo: string;
+  onProgress?: (p: EmbedProgress) => void;
+  signal?: AbortSignal;
+  /** When true, re-embed labels even when an embedding already exists. */
+  overwrite?: boolean;
+}): Promise<{ embedded: number; skipped?: boolean; reason?: string }> {
+  const config = getActiveProviderConfig();
+  if (!config) {
+    return { embedded: 0, skipped: true, reason: 'No LLM provider configured.' };
+  }
+  const embedder = createEmbeddingsModel(config);
+  if (!embedder) {
+    return {
+      embedded: 0,
+      skipped: true,
+      reason: `Provider "${config.provider}" has no native embeddings API. Configure OpenAI / Azure / Gemini / Ollama instead, or rely on lexical similarity (Tier 2.5b).`,
+    };
+  }
+  const providerName = config.provider;
+  const modelName = (config as { model?: string }).model || 'unknown';
+
+  const cache = await fetchSemanticLabels(opts.repo);
+  const entries = Object.entries(cache.labels);
+  if (entries.length === 0) {
+    return { embedded: 0, skipped: true, reason: 'No cached labels — run "Generate semantic labels" first.' };
+  }
+
+  // Decide what to embed: missing-or-stale-model entries unless overwrite.
+  const toEmbed: Array<{ id: string; text: string }> = [];
+  for (const [id, entry] of entries) {
+    const hasFreshEmbedding =
+      Array.isArray(entry.embedding) &&
+      entry.embedding.length > 0 &&
+      entry.embeddingProvider === providerName;
+    if (opts.overwrite || !hasFreshEmbedding) {
+      toEmbed.push({ id, text: entry.label });
+    }
+  }
+  const total = toEmbed.length;
+  if (total === 0) {
+    return { embedded: 0 };
+  }
+
+  opts.onProgress?.({ done: 0, total });
+
+  let vectors: number[][];
+  try {
+    vectors = await embedder.embedDocuments(toEmbed.map((e) => e.text));
+  } catch (err) {
+    // If batch fails, retry one-by-one so we get partial progress.
+    vectors = [];
+    for (let i = 0; i < toEmbed.length; i++) {
+      if (opts.signal?.aborted) break;
+      try {
+        const v = await embedder.embedQuery(toEmbed[i].text);
+        vectors.push(v);
+        opts.onProgress?.({ done: i + 1, total, current: toEmbed[i].id });
+      } catch (err2) {
+        opts.onProgress?.({
+          done: i + 1,
+          total,
+          current: toEmbed[i].id,
+          error: err2 instanceof Error ? err2.message : String(err2),
+        });
+        vectors.push([]); // keep alignment; we'll skip empty below
+      }
+    }
+    if (vectors.length === 0) {
+      throw err instanceof Error
+        ? err
+        : new Error('embedding call failed and one-by-one fallback returned nothing');
+    }
+  }
+
+  // Merge into cache.
+  const merged: Record<string, SemanticLabel> = {};
+  for (let i = 0; i < toEmbed.length; i++) {
+    const vec = vectors[i];
+    if (!Array.isArray(vec) || vec.length === 0) continue;
+    const prev = cache.labels[toEmbed[i].id];
+    merged[toEmbed[i].id] = {
+      ...prev,
+      embedding: vec,
+      embeddingProvider: providerName,
+      embeddingModel: modelName,
+    };
+  }
+
+  if (Object.keys(merged).length > 0) {
+    await postSemanticLabels(opts.repo, merged, providerName, modelName);
+  }
+  opts.onProgress?.({ done: total, total });
+  return { embedded: Object.keys(merged).length };
+}
+
+// ── small helpers ────────────────────────────────────────────────────
+
+/**
+ * Same-origin path: docker-server-snapshots etc. live on :4173 and the
+ * frontend talks to them via relative URLs. We deliberately don't reuse
+ * getBackendUrl() because that points at the gitnexus *API* on :4747.
+ */
+function webRoot(): string {
+  // window.origin works in the browser; defensive '' for tests / SSR.
+  if (typeof window !== 'undefined' && window.location) return window.location.origin;
+  // getBackendUrl is imported only to keep tree-shaking honest — not used.
+  void getBackendUrl;
+  return '';
+}
diff --git a/gitnexus-web/src/services/snapshot-ghosts-cache.ts b/gitnexus-web/src/services/snapshot-ghosts-cache.ts
new file mode 100644
index 0000000..1ba3d67
--- /dev/null
+++ b/gitnexus-web/src/services/snapshot-ghosts-cache.ts
@@ -0,0 +1,112 @@
+/**
+ * Per-repo cache of per-snapshot ghost sets, for the Augmented Timeline.
+ *
+ * Hits `/snapshots?repo=` then fans out parallel `/ghosts/at?repo=&commit=`
+ * fetches via a 3-worker pool, capped at the 50 most recent snapshots
+ * to bound the initial pre-fetch. Result is a `Map<shortHash, SnapshotGhosts>`
+ * keyed by commit shortHash + the snapshot's commit date.
+ *
+ * Cache layer: a module-level `Map<repoName, { at, promise }>` with a
+ * 30 s TTL — repeated callers within 30 s share the in-flight promise.
+ *
+ * See docs/superpowers/specs/2026-05-27-roadmap-predictive-augmented-timeline-design.md
+ *   §3.2 (parallel pool + cap + TTL).
+ */
+
+import type { SnapshotGhosts } from '../lib/augmented-timeline';
+
+const TTL_MS = 30_000;
+const POOL = 3;
+const CAP = 50;
+
+type CacheEntry = {
+  at: number;
+  promise: Promise<Map<string, SnapshotGhosts>>;
+};
+
+const cache = new Map<string, CacheEntry>();
+
+/** Drop every cached repo entry — used by tests + on explicit invalidation. */
+export function clearSnapshotGhostsCache(): void {
+  cache.clear();
+}
+
+type SnapshotListItem = {
+  key?: string;
+  name?: string;
+  commit?: {
+    shortHash?: string;
+    date?: string;
+  };
+};
+
+/**
+ * Pre-fetch every per-snapshot ghosts.json for a repo. Returns a Map
+ * keyed by the snapshot's commit shortHash with the parsed ghost set
+ * + the commit's ISO date — both needed by `selectGhostsAt` to do
+ * closest-prior lookup.
+ *
+ * Idempotent within the 30 s TTL window: subsequent callers share the
+ * same in-flight promise so the network round-trips happen once.
+ * `signal` aborts in-flight fetches if the caller unmounts.
+ */
+export async function prefetchSnapshotGhosts(
+  repo: string,
+  signal?: AbortSignal,
+): Promise<Map<string, SnapshotGhosts>> {
+  const now = Date.now();
+  const cached = cache.get(repo);
+  if (cached && now - cached.at < TTL_MS) return cached.promise;
+
+  const promise = (async (): Promise<Map<string, SnapshotGhosts>> => {
+    const out = new Map<string, SnapshotGhosts>();
+
+    let snapshots: SnapshotListItem[] = [];
+    try {
+      const listRes = await fetch(
+        `/snapshots?repo=${encodeURIComponent(repo)}`,
+        signal ? { signal } : {},
+      );
+      if (!listRes.ok) return out;
+      const listBody = await listRes.json();
+      snapshots = Array.isArray(listBody?.snapshots) ? listBody.snapshots : [];
+    } catch {
+      return out;
+    }
+
+    // Cap to the CAP most recent (server returns newest-first; slice
+    // from the top so we keep the freshest history). Reversing isn't
+    // necessary — the cache is keyed by sha and date does the sorting
+    // work at lookup time in `selectGhostsAt`.
+    const capped = snapshots.slice(0, CAP);
+
+    const queue: SnapshotListItem[] = [...capped];
+    async function worker(): Promise<void> {
+      while (queue.length) {
+        const s = queue.shift();
+        if (!s) return;
+        const sha = s.commit?.shortHash || s.key;
+        const date = s.commit?.date;
+        if (!sha || !date) continue;
+        try {
+          const r = await fetch(
+            `/ghosts/at?repo=${encodeURIComponent(repo)}&commit=${encodeURIComponent(sha)}`,
+            signal ? { signal } : {},
+          );
+          if (!r.ok) continue;
+          const body = await r.json();
+          out.set(sha, { sha, date, ghosts: Array.isArray(body?.ghosts) ? body.ghosts : [] });
+        } catch {
+          // Skip silently — partial fetch is better than an outright
+          // throw that would kill the entire cache build for a single
+          // missing sidecar. Aborts also land here.
+        }
+      }
+    }
+    await Promise.all(Array.from({ length: POOL }, () => worker()));
+    return out;
+  })();
+
+  cache.set(repo, { at: now, promise });
+  return promise;
+}
