+/**
+ * ClusterDrillModal — opens from the 7th "Clusters" audit card.
+ * Lists the top 5-10 clusters sorted by completionPct ASC (the
+ * "furthest from done first" view), each row expandable to show the
+ * member list with per-member status badges.
+ *
+ * Section H / Task 13 of
+ * docs/superpowers/specs/2026-05-27-roadmap-predictive-ghost-cluster.md
+ */
+
+import { useMemo, useState } from 'react';
+import type { ClusterRuntime } from '../../services/clusters-client';
+
+type Ghost = {
+  id: string;
+  declared?: { title?: string };
+  materializedAt?: unknown;
+  cancelledAt?: unknown;
+};
+
+type Props = {
+  clusters: ClusterRuntime[];
+  ghosts?: Ghost[];
+  open: boolean;
+  onClose: () => void;
+  onGhostClick?: (ghostId: string) => void;
+  /** Hard cap on rows. Default 10 keeps the modal scannable on a
+   *  laptop screen; pass `Infinity` to disable. */
+  topN?: number;
+};
+
+function memberStatus(g?: Ghost): 'materialized' | 'cancelled' | 'planned' {
+  if (!g) return 'planned';
+  if (g.materializedAt) return 'materialized';
+  if (g.cancelledAt) return 'cancelled';
+  return 'planned';
+}
+
+function statusGlyph(s: 'materialized' | 'cancelled' | 'planned'): string {
+  if (s === 'materialized') return '✓';
+  if (s === 'cancelled') return '✕';
+  return '·';
+}
+
+export default function ClusterDrillModal({
+  clusters,
+  ghosts,
+  open,
+  onClose,
+  onGhostClick,
+  topN = 10,
+}: Props) {
+  const [expanded, setExpanded] = useState<Set<string>>(new Set());
+
+  const sorted = useMemo(() => {
+    if (!clusters) return [];
+    return [...clusters]
+      .sort(
+        (a, b) =>
+          (a.aggregate?.completionPct ?? 0) - (b.aggregate?.completionPct ?? 0),
+      )
+      .slice(0, topN);
+  }, [clusters, topN]);
+
+  const ghostsById = useMemo(() => {
+    const map = new Map<string, Ghost>();
+    for (const g of ghosts ?? []) map.set(g.id, g);
+    return map;
+  }, [ghosts]);
+
+  if (!open) return null;
+
+  const toggle = (id: string) => {
+    setExpanded((prev) => {
+      const next = new Set(prev);
+      if (next.has(id)) next.delete(id);
+      else next.add(id);
+      return next;
+    });
+  };
+
+  return (
+    <div
+      className="cluster-drill-modal cleanup-modal"
+      data-testid="cluster-drill-modal"
+      role="dialog"
+    >
+      <div className="modal-content">
+        <header>
+          <h2>Clusters — drill-down</h2>
+          <button type="button" onClick={onClose} aria-label="close">
+            ×
+          </button>
+        </header>
+        {sorted.length === 0 ? (
+          <p>No clusters declared or auto-derived for this repo.</p>
+        ) : (
+          <ul className="cluster-drill-list">
+            {sorted.map((c) => {
+              const isOpen = expanded.has(c.id);
+              const pct = c.aggregate?.completionPct ?? 0;
+              return (
+                <li
+                  key={c.id}
+                  data-testid={`cluster-drill-${c.id}`}
+                  className={`cluster-row status-${c.synthesizedStatus}`}
+                >
+                  <button
+                    type="button"
+                    className="cluster-drill-toggle"
+                    onClick={() => toggle(c.id)}
+                    data-testid={`cluster-drill-toggle-${c.id}`}
+                  >
+                    <span className="caret">{isOpen ? '▾' : '▸'}</span>
+                    <strong>{c.title}</strong>
+                    <span className="badge source">{c.source}</span>
+                    <span className="badge status">{c.synthesizedStatus}</span>
+                    <span className="completion">{pct.toFixed(0)}%</span>
+                    <span className="members-count">
+                      {c.aggregate?.materialized ?? 0}/{c.aggregate?.total ?? 0}
+                    </span>
+                  </button>
+                  {isOpen && (
+                    <ul className="cluster-members" data-testid={`cluster-drill-members-${c.id}`}>
+                      {c.memberIds.map((mid) => {
+                        const ghost = ghostsById.get(mid);
+                        const status = memberStatus(ghost);
+                        const label = ghost?.declared?.title ?? mid;
+                        return (
+                          <li key={mid}>
+                            <button
+                              type="button"
+                              className={`member member-${status}`}
+                              onClick={() => onGhostClick?.(mid)}
+                              data-testid={`cluster-drill-member-${mid}`}
+                            >
+                              <span className={`glyph status-${status}`}>
+                                {statusGlyph(status)}
+                              </span>
+                              <span>{label}</span>
+                            </button>
+                          </li>
+                        );
+                      })}
+                    </ul>
+                  )}
+                </li>
+              );
+            })}
+          </ul>
+        )}
+      </div>
+    </div>
+  );
+}
