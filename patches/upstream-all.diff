+  const [search, setSearch] = useState('');
+
+  // Cross-repo mode (ROADMAP Tier 1.2). Toggled inside this panel
+  // rather than via the global Timeline button — keeps it self-contained
+  // and avoids piling more toggles on the bar. Eligible repos are the
+  // user's real repos minus snapshots and minus the current one.
+  const eligibleCrossRepos = useMemo(
+    () =>
+      availableRepos
+        .map((r) => r.name)
+        .filter((n) => !n.includes('@') && n !== baseRepo),
+    [availableRepos, baseRepo],
+  );
+  const [crossMode, setCrossMode] = useState(false);
+  const [crossData, setCrossData] = useState<{
+    repos: string[];
+    windowHours: number;
+    totalBuckets: number;
+    totalCrossPairs: number;
+    pairs: {
+      a: { repo: string; path: string };
+      b: { repo: string; path: string };
+      count: number;
+      jaccard: number;
+    }[];
+  } | null>(null);
+  const [crossLoading, setCrossLoading] = useState(false);
+  const [crossError, setCrossError] = useState<string | null>(null);
+
+  // Fetch cross-repo data when the user toggles into cross mode. Re-run
+  // when the eligible repo set changes (e.g. user just indexed a new
+  // repo elsewhere).
+  useEffect(() => {
+    if (!crossMode || !couplingActive || eligibleCrossRepos.length === 0) return;
+    let cancelled = false;
+    setCrossLoading(true);
+    setCrossError(null);
+    const repos = [baseRepo, ...eligibleCrossRepos].join(',');
+    fetch(`/coupling/cross?repos=${encodeURIComponent(repos)}&top=100`, {
+      cache: 'no-store',
+    })
+      .then((r) => r.json().then((b) => (r.ok ? b : Promise.reject(b.error || `HTTP ${r.status}`))))
+      .then((d) => {
+        if (!cancelled) setCrossData(d);
+      })
+      .catch((err) => {
+        if (!cancelled) setCrossError(typeof err === 'string' ? err : 'Cross-repo coupling failed');
+      })
+      .finally(() => {
+        if (!cancelled) setCrossLoading(false);
+      });
+    return () => {
+      cancelled = true;
+    };
+  }, [crossMode, couplingActive, baseRepo, eligibleCrossRepos]);
+
+  // Build a path → File-node-id index from the live graph so a row click
+  // can highlight both endpoints. Doing this lazily / memoized keeps the
+  // panel light even on very large graphs (5k+ files).
+  const fileIdByPath = useMemo(() => {
+    const m = new Map<string, string>();
+    if (!graph) return m;
+    for (const n of graph.nodes) {
+      if (n.label === 'File' && n.properties.filePath) {
+        m.set(n.properties.filePath, n.id);
+      }
+    }
+    return m;
+  }, [graph]);
+
+  const filteredPairs = useMemo(() => {
+    if (!couplingData) return [];
+    const q = search.trim().toLowerCase();
+    return couplingData.pairs.filter((p) => {
+      if (p.jaccard < minJaccard) return false;
+      if (q && !p.a.toLowerCase().includes(q) && !p.b.toLowerCase().includes(q)) return false;
+      return true;
+    });
+  }, [couplingData, minJaccard, search]);
+
+  if (!couplingActive && !couplingLoading && !couplingError) return null;
+
+  return (
+    <div
+      className="pointer-events-auto absolute top-3 right-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width: PANEL_WIDTH_PX, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      {/* Header */}
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <span className="text-xs font-semibold text-text-primary">
+          {crossMode ? 'Cross-repo coupling' : 'Temporal coupling'}
+        </span>
+        {!crossMode && couplingData && (
+          <span className="font-mono text-[10px] text-text-muted">
+            over {couplingData.totalTransitions} transition
+            {couplingData.totalTransitions > 1 ? 's' : ''}
+          </span>
+        )}
+        {crossMode && crossData && (
+          <span className="font-mono text-[10px] text-text-muted" title={crossData.repos.join(' + ')}>
+            {crossData.repos.length} repos · {crossData.totalBuckets} windows
+          </span>
+        )}
+        {/* Cross-repo toggle — only useful when there's at least one
+            other indexed repo to compare against. Disabled otherwise. */}
+        {eligibleCrossRepos.length > 0 && (
+          <button
+            type="button"
+            onClick={() => setCrossMode((v) => !v)}
+            className={`shrink-0 cursor-pointer rounded p-1 transition-colors ${
+              crossMode
+                ? 'bg-accent/20 text-accent'
+                : 'text-text-muted hover:bg-hover hover:text-text-primary'
+            }`}
+            title={
+              crossMode
+                ? 'Switch back to single-repo coupling'
+                : `Switch to cross-repo coupling (${eligibleCrossRepos.join(', ')})`
+            }
+          >
+            <Layers className="h-3.5 w-3.5" />
+          </button>
+        )}
+        {couplingData && couplingData.pairs.length > 0 && (
+          <a
+            href={`/coupling?repo=${encodeURIComponent(baseRepo)}&top=100&format=csv`}
+            download
+            className="ml-auto shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+            title="Download all pairs as CSV"
+          >
+            <Download className="h-3.5 w-3.5" />
+          </a>
+        )}
+        <button
+          type="button"
+          onClick={() => exitCouplingMode()}
+          className={`${couplingData?.pairs.length ? '' : 'ml-auto'} shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary`}
+          title="Exit coupling mode"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+
+      {couplingLoading && (
+        <div className="flex items-center justify-center gap-2 py-6 text-xs text-text-muted">
+          <Loader2 className="h-3.5 w-3.5 animate-spin" />
+          Computing coupling…
+        </div>
+      )}
+
+      {couplingError && (
+        <div className="flex items-start gap-2 px-3 py-3 text-xs text-red-400">
+          <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+          <span>{couplingError}</span>
+        </div>
+      )}
+
+      {/* Cross-repo mode: completely different data shape, render the
+          pairs with their repo prefixes. Click only highlights when
+          the file lives in the active repo's graph. */}
+      {crossMode && (
+        <>
+          {crossLoading && (
+            <div className="flex items-center justify-center gap-2 py-6 text-xs text-text-muted">
+              <Loader2 className="h-3.5 w-3.5 animate-spin" />
+              Scanning git logs of {1 + eligibleCrossRepos.length} repos…
+            </div>
+          )}
+          {crossError && (
+            <div className="flex items-start gap-2 px-3 py-3 text-xs text-red-400">
+              <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+              <span>{crossError}</span>
+            </div>
+          )}
+          {crossData && !crossLoading && (
+            <>
+              <div className="flex-1 overflow-y-auto">
+                {crossData.pairs.length === 0 ? (
+                  <div className="px-3 py-4 text-center text-[11px] text-text-muted italic">
+                    No cross-repo co-changes detected. The repos may have no
+                    overlapping commit windows.
+                  </div>
+                ) : (
+                  crossData.pairs.map((p, i) => {
+                    // Only the file in the *active* repo can be highlighted
+                    // since the graph only shows nodes from the active repo.
+                    const localSide =
+                      p.a.repo === baseRepo ? p.a : p.b.repo === baseRepo ? p.b : null;
+                    const fileId = localSide ? fileIdByPath.get(localSide.path) : undefined;
+                    const canHighlight = !!fileId;
+                    return (
+                      <button
+                        key={`${i}-${p.a.repo}-${p.b.repo}`}
+                        type="button"
+                        onClick={() => {
+                          if (canHighlight) setHighlightedNodeIds(new Set([fileId!]));
+                        }}
+                        disabled={!canHighlight}
+                        className="group flex w-full flex-col gap-1 border-b border-border-subtle px-3 py-2 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+                        title={
+                          canHighlight
+                            ? `Highlight ${localSide!.path} in the active graph (${p.count} co-changes)`
+                            : `Neither file lives in the active graph (${p.count} co-changes)`
+                        }
+                      >
+                        <div className="flex min-w-0 items-center gap-1.5 font-mono text-[11px]">
+                          <span
+                            className="shrink-0 rounded bg-accent/15 px-1 py-0 text-[9px] font-semibold text-accent"
+                            title={p.a.repo}
+                          >
+                            {p.a.repo.slice(0, 8)}
+                          </span>
+                          <span className="min-w-0 truncate text-text-primary">{p.a.path}</span>
+                          <ArrowRight className="h-2.5 w-2.5 shrink-0 text-text-muted" />
+                          <span
+                            className="shrink-0 rounded bg-emerald-500/15 px-1 py-0 text-[9px] font-semibold text-emerald-300"
+                            title={p.b.repo}
+                          >
+                            {p.b.repo.slice(0, 8)}
+                          </span>
+                          <span className="min-w-0 truncate text-text-primary">{p.b.path}</span>
+                        </div>
+                        <div className="flex items-center gap-3 text-[10px] text-text-muted">
+                          <span className="rounded bg-accent/15 px-1.5 py-0.5 font-mono text-accent">
+                            {p.jaccard.toFixed(2)}
+                          </span>
+                          <span className="font-mono">{p.count}× together</span>
+                        </div>
+                      </button>
+                    );
+                  })
+                )}
+              </div>
+              <div className="shrink-0 border-t border-border-subtle bg-elevated px-3 py-1.5 text-[10px] text-text-muted">
+                Cross-repo: {crossData.pairs.length} pairs (capped at 100)
+              </div>
+            </>
+          )}
+        </>
+      )}
+
+      {!crossMode && couplingData && !couplingLoading && (
+        <>
+          {/* Filters */}
+          <div className="space-y-2 border-b border-border-subtle px-3 py-2">
+            <input
+              type="text"
+              value={search}
+              onChange={(e) => setSearch(e.target.value)}
+              placeholder="Filter by path…"
+              className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+              spellCheck={false}
+              autoComplete="off"
+            />
+            <div className="flex items-center gap-2 text-[10px] text-text-muted">
+              <span className="shrink-0">Min Jaccard:</span>
+              <input
+                type="range"
+                min={0}
+                max={1}
+                step={0.05}
+                value={minJaccard}
+                onChange={(e) => setMinJaccard(parseFloat(e.target.value))}
+                className="flex-1 accent-accent"
+              />
+              <span className="shrink-0 font-mono">{minJaccard.toFixed(2)}</span>
+            </div>
+          </div>
+
+          {/* Pairs list */}
+          <div className="flex-1 overflow-y-auto">
+            {filteredPairs.length === 0 ? (
+              <div className="px-3 py-4 text-center text-[11px] text-text-muted italic">
+                No pairs match the filters. Try lowering Min Jaccard.
+              </div>
+            ) : (
+              filteredPairs.map((p) => {
+                const aId = fileIdByPath.get(p.a);
+                const bId = fileIdByPath.get(p.b);
+                const canHighlight = aId && bId;
+                return (
+                  <button
+                    key={`${p.a}\0${p.b}`}
+                    type="button"
+                    onClick={() => {
+                      if (!canHighlight) return;
+                      // Replace highlights so subsequent clicks don't pile up;
+                      // the user can click another row to swap.
+                      setHighlightedNodeIds(new Set([aId!, bId!]));
+                    }}
+                    disabled={!canHighlight}
+                    className="group flex w-full flex-col gap-1 border-b border-border-subtle px-3 py-2 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+                    title={
+                      canHighlight
+                        ? `Click to highlight both files in the graph (${p.count} co-changes)`
+                        : `One or both files no longer exist in the live graph (${p.count} co-changes)`
+                    }
+                  >
+                    <div className="flex min-w-0 items-center gap-1.5 font-mono text-[11px]">
+                      <span className="truncate text-text-primary">{p.a}</span>
+                      <ArrowRight className="h-2.5 w-2.5 shrink-0 text-text-muted" />
+                      <span className="truncate text-text-primary">{p.b}</span>
+                    </div>
+                    <div className="flex items-center gap-3 text-[10px] text-text-muted">
+                      <span
+                        className="rounded bg-accent/15 px-1.5 py-0.5 font-mono text-accent"
+                        title="Jaccard similarity (1 = always together, 0 = never)"
+                      >
+                        {p.jaccard.toFixed(2)}
+                      </span>
+                      <span className="font-mono">{p.count}× together</span>
+                      {!canHighlight && (
+                        <span className="text-amber-400/80">not in live graph</span>
+                      )}
+                    </div>
+                  </button>
+                );
+              })
+            )}
+          </div>
+
+          <div className="shrink-0 border-t border-border-subtle bg-elevated px-3 py-1.5 text-[10px] text-text-muted">
+            Showing {filteredPairs.length} of {couplingData.pairs.length} pairs
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
