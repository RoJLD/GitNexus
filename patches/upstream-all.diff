+/**
+ * Bulk snapshot endpoints — Phase 2 of the gitnexus time-travel feature.
+ *
+ * Indexes N commits from a repo's history in one operation, with live
+ * progress streamed back to the UI. Each commit goes through the same
+ * pipeline as the single-snapshot endpoint (clone → checkout → analyze →
+ * register), so the result is identical to clicking 📷 N times by hand —
+ * just orchestrated and observable.
+ *
+ * Endpoints:
+ *   POST   /snapshot/bulk?repo=<name>     body: { mode, count, sinceDays }
+ *                                          → { jobId, commits }
+ *   GET    /snapshot/bulk/:jobId          → SSE stream of progress events
+ *   DELETE /snapshot/bulk/:jobId          → abort the loop (snapshots
+ *                                            already created are kept)
+ *
+ * Sampling modes:
+ *   - "lastN":  the N most-recent commits from HEAD backwards.
+ *   - "spaced": N commits evenly spread over the last `sinceDays` days,
+ *               so we capture the project's trajectory rather than a
+ *               cluster of consecutive commits.
+ *
+ * Job state lives in memory only. If the container restarts mid-job, the
+ * partial snapshots stay on disk (idempotency handles re-runs), but the
+ * job's progress channel is lost. That's fine: this is a low-frequency
+ * operation triggered manually from the UI.
+ *
+ * SSE event types (each emitted as a JSON-encoded `data:` line):
+ *   { type: 'started',  total, commits: [...] }
+ *   { type: 'commit-start',  index, total, commit }
+ *   { type: 'commit-phase',  index, total, commit, phase }
+ *   { type: 'commit-done',   index, total, commit, existing, snapshot }
+ *   { type: 'commit-error',  index, total, commit, error }
+ *   { type: 'aborted',       done, total }
+ *   { type: 'done',          created, skipped, failed, total }
+ */
+
+import { randomUUID } from 'node:crypto';
+import {
+  createSnapshot,
+  findRepoByName,
+  runCmd,
+} from './docker-server-snapshots.mjs';
+
+const jobs = new Map();
+// Keep finished jobs around briefly so a UI that subscribes a moment after
+// the last event still gets a final state instead of a 404.
+const FINISHED_JOB_TTL_MS = 60 * 1000;
+
+function newJob() {
+  const id = randomUUID();
+  const subscribers = new Set();
+  const buffer = [];
+  const job = {
+    id,
+    state: 'pending', // pending | running | done | aborted | failed
+    aborted: false,
+    subscribers,
+    buffer,
+    finishedAt: null,
+    summary: null,
+    emit(event) {
+      buffer.push(event);
+      for (const res of subscribers) {
+        try {
+          res.write(`data: ${JSON.stringify(event)}\n\n`);
+        } catch {
+          // Subscriber gone; will be reaped below.
+        }
+      }
+    },
+  };
+  jobs.set(id, job);
+  return job;
+}
+
+function reapFinishedJobs() {
+  const now = Date.now();
+  for (const [id, job] of jobs) {
+    if (job.finishedAt && now - job.finishedAt > FINISHED_JOB_TTL_MS) {
+      jobs.delete(id);
+    }
+  }
+}
+
+/**
+ * Read commits via `git log` with the requested filters. We get the
+ * minimal info upfront — full metadata is fetched again when each commit
+ * is actually snapshotted (via getCommitInfo in the snapshot module),
+ * keeping this listing cheap even for huge repos.
+ */
+async function listCommits(repoPath, sinceDays) {
+  const sinceArg = sinceDays && sinceDays > 0 ? [`--since=${sinceDays} days ago`] : [];
+  const out = await runCmd('git', [
+    '-C',
+    repoPath,
+    'log',
+    '--pretty=format:%H%x00%h%x00%aI%x00%s',
+    ...sinceArg,
+  ]);
+  return out
+    .split('\n')
+    .map((line) => line.trim())
+    .filter(Boolean)
+    .map((line) => {
+      const [hash, shortHash, date, ...messageParts] = line.split('\0');
+      return { hash, shortHash, date, message: messageParts.join('\0') };
+    });
+}
+
+function sampleCommits(commits, count, mode) {
+  if (commits.length === 0) return [];
+  if (commits.length <= count) return commits;
+  if (mode === 'lastN') return commits.slice(0, count);
+
+  // 'spaced': pick `count` commits evenly across the full range. commits[0]
+  // is the newest, commits.length-1 the oldest. Always include both
+  // endpoints so the user gets a clear "before vs after" anchor.
+  const result = [];
+  const step = (commits.length - 1) / (count - 1);
+  for (let i = 0; i < count; i++) {
+    const idx = Math.round(i * step);
+    result.push(commits[idx]);
+  }
+  // Dedupe in case the rounding produced duplicates (very small ranges).
+  const seen = new Set();
+  return result.filter((c) => (seen.has(c.hash) ? false : seen.add(c.hash) || true));
+}
+
+async function handleCreateBulk(url, req, res, opts) {
+  reapFinishedJobs();
+
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+
+  // Read JSON body (small, no streaming needed).
+  let body = '';
+  for await (const chunk of req) body += chunk;
+  let params = {};
+  if (body) {
+    try {
+      params = JSON.parse(body);
+    } catch {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: 'invalid JSON body' }));
+      return;
+    }
+  }
+  const mode = params.mode === 'spaced' ? 'spaced' : 'lastN';
+  const count = Math.max(1, Math.min(100, Number(params.count) || 10));
+  const sinceDays = params.sinceDays != null ? Math.max(1, Number(params.sinceDays) || 30) : null;
+
+  const repo = await findRepoByName(repoName, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+
+  let commits;
+  try {
+    commits = await listCommits(repoPath, sinceDays);
+  } catch (err) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `git log failed: ${err.message}` }));
+    return;
+  }
+  const selected = sampleCommits(commits, count, mode);
+
+  if (selected.length === 0) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'no commits matched the filters' }));
+    return;
+  }
+
+  const job = newJob();
+  job.state = 'running';
+  job.total = selected.length;
+  job.commits = selected;
+
+  // Kick off the async loop. We return immediately with the jobId so the
+  // client can subscribe to the SSE stream.
+  (async () => {
+    let created = 0;
+    let skipped = 0;
+    let failed = 0;
+    job.emit({ type: 'started', total: selected.length, commits: selected });
+
+    for (let i = 0; i < selected.length; i++) {
+      if (job.aborted) break;
+      const commit = selected[i];
+      job.emit({ type: 'commit-start', index: i, total: selected.length, commit });
+      try {
+        const result = await createSnapshot({
+          repoName,
+          commitRef: commit.hash,
+          api: opts.api,
+          onPhase: (phase) =>
+            job.emit({ type: 'commit-phase', index: i, total: selected.length, commit, phase }),
+        });
+        if (result.existing) skipped++;
+        else created++;
+        job.emit({
+          type: 'commit-done',
+          index: i,
+          total: selected.length,
+          commit,
+          existing: result.existing,
+          snapshot: result.snapshot,
+        });
+      } catch (err) {
+        failed++;
+        job.emit({
+          type: 'commit-error',
+          index: i,
+          total: selected.length,
+          commit,
+          error: err?.message || 'snapshot failed',
+        });
+      }
+    }
+
+    if (job.aborted) {
+      job.state = 'aborted';
+      job.emit({ type: 'aborted', done: created + skipped + failed, total: selected.length });
+    } else {
+      job.state = 'done';
+      job.emit({
+        type: 'done',
+        created,
+        skipped,
+        failed,
+        total: selected.length,
+      });
+    }
+    job.summary = { created, skipped, failed, total: selected.length };
+    job.finishedAt = Date.now();
+    // Detach any lingering subscribers; they've already received the final
+    // event. Subsequent GETs within the TTL window will replay from buffer.
+    for (const res of job.subscribers) {
+      try {
+        res.end();
+      } catch {}
+    }
+    job.subscribers.clear();
+  })().catch((err) => {
+    console.error('[bulk-snapshot] loop crashed:', err);
+    job.state = 'failed';
+    job.finishedAt = Date.now();
+    job.emit({ type: 'commit-error', index: -1, total: 0, commit: null, error: err?.message });
+  });
+
+  res.writeHead(202, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ jobId: job.id, total: selected.length, commits: selected }));
+}
+
+function handleStreamBulk(jobId, req, res) {
+  reapFinishedJobs();
+  const job = jobs.get(jobId);
+  if (!job) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'job not found' }));
+    return;
+  }
+
+  res.writeHead(200, {
+    'Content-Type': 'text/event-stream; charset=utf-8',
+    'Cache-Control': 'no-store',
+    Connection: 'keep-alive',
+    // Disable buffering at any proxy layer between us and the browser.
+    'X-Accel-Buffering': 'no',
+  });
+  // Replay buffered events so a late subscriber sees the full history.
+  for (const event of job.buffer) {
+    res.write(`data: ${JSON.stringify(event)}\n\n`);
+  }
+  // If the job already finished, close immediately — no need to keep the
+  // stream open for events that will never come.
+  if (job.state === 'done' || job.state === 'aborted' || job.state === 'failed') {
+    res.end();
+    return;
+  }
+  job.subscribers.add(res);
+  req.on('close', () => {
+    job.subscribers.delete(res);
+  });
+}
+
+function handleAbortBulk(jobId, res) {
+  const job = jobs.get(jobId);
+  if (!job) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'job not found' }));
+    return;
+  }
+  job.aborted = true;
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ok: true, aborted: true }));
+}
+
+export async function handleSnapshotBulkRoute(req, url, res, opts) {
+  if (url.pathname === '/snapshot/bulk' && req.method === 'POST') {
+    await handleCreateBulk(url, req, res, opts);
+    return true;
+  }
+  // /snapshot/bulk/<jobId> for GET (SSE) and DELETE (abort)
+  const m = url.pathname.match(/^\/snapshot\/bulk\/([A-Za-z0-9-]+)$/);
+  if (m) {
+    if (req.method === 'GET') {
+      handleStreamBulk(m[1], req, res);
+      return true;
+    }
+    if (req.method === 'DELETE') {
+      handleAbortBulk(m[1], res);
+      return true;
+    }
+  }
+  return false;
+}
diff --git a/docker-server-snapshots.mjs b/docker-server-snapshots.mjs
new file mode 100644
index 0000000..c20c6e4
--- /dev/null
+++ b/docker-server-snapshots.mjs
@@ -0,0 +1,349 @@
+/**
+ * Snapshot endpoints — Phase 1 of the gitnexus time-travel feature.
+ *
+ * Each "snapshot" is a fully-indexed view of a repo at a specific git
+ * commit, stored under /data/gitnexus/snapshots/<repoName>/<shortHash>/
+ * and registered in the global gitnexus registry as `<repoName>@<shortHash>`.
+ * Snapshots are real registered repos — they show up in the dropdown, work
+ * with the diff feature, are queryable via MCP, etc. The only thing that
+ * marks them as snapshots is the `@` in the name and a `commit.json`
+ * sibling file with the git metadata.
+ *
+ * Storage layout:
+ *   /data/gitnexus/snapshots/<repoName>/<shortHash>/
+ *     source/                  ← git clone, checked out at <commit>
+ *       .gitnexus/lbug         ← created by `/api/analyze`
+ *       .gitnexus/meta.json
+ *       ...source files...     ← kept so the Code Inspector still works
+ *     commit.json              ← { hash, shortHash, message, author, date, parent }
+ *
+ * Why we keep the source: gitnexus's `/api/file` reads the actual file
+ * from disk. Without source, the graph is browsable but file contents are
+ * empty. Since git clone is fast (object hardlinks) and our 916 GB volume
+ * isn't tight, we trade disk for a complete time-travel experience.
+ *
+ * Endpoints:
+ *   POST /snapshot?repo=<name>&commit=<HEAD|hash>   create a snapshot
+ *   GET  /snapshots?repo=<name>                     list snapshots for a repo
+ *   DELETE /snapshot?repo=<name>&commit=<short>     delete a snapshot
+ *
+ * The snapshot endpoint is synchronous (returns when analyze + register
+ * are done). For Phase 2 we'll expose progress via SSE; for now the UI
+ * shows an indeterminate spinner while it runs.
+ */
+
+import { mkdir, readFile, readdir, rm, stat, writeFile } from 'node:fs/promises';
+import { dirname, join, basename } from 'node:path';
+import { spawn } from 'node:child_process';
+
+export const SNAPSHOTS_ROOT = '/data/gitnexus/snapshots';
+const REGISTRY_PATH = '/data/gitnexus/registry.json';
+
+export function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} ${args.join(' ')} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+// Sanitize a git ref or short hash so it's safe as a directory name. We
+// accept alphanumerics, hyphens, dots, underscores, slashes (for refs like
+// "origin/main") and turn anything else into "_". Short hashes from
+// `git rev-parse --short` will always pass through cleanly.
+export function safeSnapshotKey(s) {
+  return String(s).replace(/[^A-Za-z0-9._/-]/g, '_').replace(/\/+/g, '_').slice(0, 64) || 'unknown';
+}
+
+// Sentinelle "baseline interne caché" (commit-level time-travel §3.3) :
+// la présence de <snapshotDir>/.hidden exclut le snapshot du listing UI.
+// findNearestBaseline ne consulte PAS ce marqueur (la reconstruction voit
+// tous les baselines) — il ne masque que l'affichage.
+export function hiddenMarkerPath(snapshotDir) {
+  return join(snapshotDir, '.hidden');
+}
+
+export async function readRegistry() {
+  try {
+    const raw = await readFile(REGISTRY_PATH, 'utf8');
+    const parsed = JSON.parse(raw);
+    return Array.isArray(parsed) ? parsed : [];
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+}
+
+export async function writeRegistry(entries) {
+  await mkdir(dirname(REGISTRY_PATH), { recursive: true });
+  await writeFile(REGISTRY_PATH, JSON.stringify(entries, null, 2), 'utf8');
+}
+
+export async function findRepoByName(name, api) {
+  try {
+    const res = await fetch(`${api}/api/repos`);
+    if (!res.ok) return null;
+    const data = await res.json();
+    const list = Array.isArray(data) ? data : data.repos;
+    if (!Array.isArray(list)) return null;
+    return list.find((r) => r.name === name) || null;
+  } catch {
+    return null;
+  }
+}
+
+// Pull commit metadata via a single `git log -1` call so we don't make N
+// round-trips for hash, message, author, date. The %x00 separator is safer
+// than tabs/pipes because commit messages can contain anything.
+export async function getCommitInfo(repoPath, commitRef) {
+  const fmt = ['%H', '%h', '%s', '%an', '%ae', '%aI', '%P'].join('%x00');
+  const out = await runCmd('git', ['-C', repoPath, 'log', '-1', `--format=${fmt}`, commitRef]);
+  const [hash, shortHash, message, author, email, date, parent] = out.trim().split('\0');
+  return { hash, shortHash, message, author, email, date, parent: parent || null };
+}
+
+/**
+ * Pure, HTTP-free snapshot creation. Used by /snapshot directly and by the
+ * bulk pipeline (Phase 2) which loops over many commits. Throws on error
+ * (including malformed input) so the caller can decide how to surface it.
+ *
+ * The returned object is the same shape the /snapshot endpoint emits.
+ */
+export async function createSnapshot({ repoName, commitRef, api, onPhase }) {
+  if (!repoName) throw new Error('missing repo');
+
+  const repo = await findRepoByName(repoName, api);
+  if (!repo) throw new Error(`repo not found: ${repoName}`);
+
+  const repoPath = repo.repoPath || repo.path;
+  const gitDir = join(repoPath, '.git');
+  if (!(await stat(gitDir).catch(() => null))) {
+    throw new Error(`repo at ${repoPath} is not a git repository — snapshots require git history`);
+  }
+
+  onPhase?.('resolving-commit');
+  const commit = await getCommitInfo(repoPath, commitRef || 'HEAD');
+
+  const key = safeSnapshotKey(commit.shortHash);
+  const snapshotDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName), key);
+  const sourceDir = join(snapshotDir, 'source');
+  const snapshotName = `${repoName}@${key}`;
+
+  // Idempotency: if a snapshot for this exact commit already exists and is
+  // valid, return it instead of redoing the work.
+  const existing = await stat(join(sourceDir, '.gitnexus', 'lbug')).catch(() => null);
+  if (existing) {
+    onPhase?.('existing');
+    return { existing: true, snapshot: { name: snapshotName, path: sourceDir, commit, dir: snapshotDir } };
+  }
+
+  // Start fresh.
+  await rm(snapshotDir, { recursive: true, force: true }).catch(() => {});
+  await mkdir(snapshotDir, { recursive: true });
+
+  try {
+    onPhase?.('cloning');
+    // Same-filesystem clone uses hardlinks for objects → fast + small.
+    // No --depth=1 because some gitnexus analyzers consult git history.
+    await runCmd('git', ['clone', repoPath, sourceDir]);
+    await runCmd('git', ['-C', sourceDir, 'checkout', '--detach', commit.hash]);
+
+    // Roadmap-predictive: snapshot ghosts.json from ROADMAP.md at this commit.
+    // Non-fatal — a snapshot without ghosts.json is still a valid snapshot.
+    try {
+      const { syncGhostsForSnapshot } = await import('./docker-server-ghosts.mjs');
+      await syncGhostsForSnapshot(sourceDir, snapshotDir, commit.hash);
+    } catch (err) {
+      console.warn(`[ghosts] sync failed for snapshot ${commit.shortHash}: ${err.message}`);
+    }
+
+    onPhase?.('analyzing');
+    const analyzeResp = await fetch(`${api}/api/analyze`, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify({ path: sourceDir, force: false }),
+    });
+    if (!analyzeResp.ok) throw new Error(`/api/analyze failed: ${analyzeResp.status}`);
+    const { jobId } = await analyzeResp.json();
+    if (!jobId) throw new Error('no jobId returned from /api/analyze');
+
+    const start = Date.now();
+    const timeoutMs = 10 * 60 * 1000;
+    while (true) {
+      if (Date.now() - start > timeoutMs) throw new Error('analyze timed out (10min)');
+      await new Promise((r) => setTimeout(r, 1000));
+      const statusResp = await fetch(`${api}/api/analyze/${encodeURIComponent(jobId)}`);
+      if (!statusResp.ok) throw new Error(`status fetch failed: ${statusResp.status}`);
+      const job = await statusResp.json();
+      if (job.status === 'complete') break;
+      if (job.status === 'failed') throw new Error(`analyze failed: ${job.error || 'unknown'}`);
+    }
+
+    onPhase?.('registering');
+    await writeFile(join(snapshotDir, 'commit.json'), JSON.stringify(commit, null, 2), 'utf8');
+
+    // Rename the registry entry from the temp clone path's auto-assigned
+    // name to the qualified `<repoName>@<shortHash>` form the UI expects.
+    const entries = await readRegistry();
+    const idx = entries.findIndex((e) => e && e.path === sourceDir);
+    if (idx >= 0) {
+      entries[idx] = {
+        ...entries[idx],
+        name: snapshotName,
+        path: sourceDir,
+        storagePath: join(sourceDir, '.gitnexus'),
+      };
+    } else {
+      let meta = {};
+      try {
+        meta = JSON.parse(await readFile(join(sourceDir, '.gitnexus', 'meta.json'), 'utf8'));
+      } catch {}
+      entries.push({
+        name: snapshotName,
+        path: sourceDir,
+        storagePath: join(sourceDir, '.gitnexus'),
+        indexedAt: meta.indexedAt || new Date().toISOString(),
+        lastCommit: commit.hash,
+        stats: meta.stats || {},
+      });
+    }
+    await writeRegistry(entries);
+
+    onPhase?.('done');
+    return { existing: false, snapshot: { name: snapshotName, path: sourceDir, commit, dir: snapshotDir } };
+  } catch (err) {
+    await rm(snapshotDir, { recursive: true, force: true }).catch(() => {});
+    throw err;
+  }
+}
+
+async function handleCreateSnapshot(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const commitRef = url.searchParams.get('commit') || 'HEAD';
+  try {
+    const result = await createSnapshot({ repoName, commitRef, api: opts.api });
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ ok: true, ...result }));
+  } catch (err) {
+    console.error('[snapshot] failed:', err);
+    const msg = err?.message || 'snapshot failed';
+    const code = /missing|not a git|not found/.test(msg) ? 400 : 500;
+    res.writeHead(code, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: msg }));
+  }
+}
+
+async function handleListSnapshots(url, res) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+
+  const includeHidden = url.searchParams.get('includeHidden') === 'true';
+  const repoSnapshotsDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries = [];
+  try {
+    entries = await readdir(repoSnapshotsDir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') {
+      res.writeHead(200, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ snapshots: [] }));
+      return;
+    }
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+    return;
+  }
+
+  const snapshots = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    const snapshotDir = join(repoSnapshotsDir, e.name);
+    const commitPath = join(snapshotDir, 'commit.json');
+    let commit = null;
+    try {
+      commit = JSON.parse(await readFile(commitPath, 'utf8'));
+    } catch {
+      // Skip directories without commit.json — they're half-built or
+      // unrelated; we don't want to surface broken entries to the UI.
+      continue;
+    }
+    // Baseline interne caché (commit-level time-travel §3.3) : exclu du
+    // listing par défaut, visible avec ?includeHidden=true (champ hidden).
+    const hidden = !!(await stat(hiddenMarkerPath(snapshotDir)).catch(() => null));
+    if (hidden && !includeHidden) continue;
+    snapshots.push({
+      key: e.name,
+      name: `${repoName}@${e.name}`,
+      path: join(snapshotDir, 'source'),
+      commit,
+      hidden,
+    });
+  }
+
+  // Newest commit first — `date` from git log is ISO 8601 so a string sort
+  // is correct without parsing.
+  snapshots.sort((a, b) => (b.commit.date || '').localeCompare(a.commit.date || ''));
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ snapshots }));
+}
+
+async function handleDeleteSnapshot(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const commitKey = url.searchParams.get('commit');
+  if (!repoName || !commitKey) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo or commit' }));
+    return;
+  }
+
+  const snapshotName = `${repoName}@${safeSnapshotKey(commitKey)}`;
+  const snapshotDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName), safeSnapshotKey(commitKey));
+
+  // Delete from the registry first via the gitnexus API — that flushes any
+  // open lbug handle on the server side. Then nuke the directory.
+  try {
+    await fetch(
+      `${opts.api}/api/repo?repo=${encodeURIComponent(snapshotName)}`,
+      { method: 'DELETE' },
+    );
+  } catch {
+    // If /api/repo isn't responsive, fall back to writing the registry
+    // directly so the user isn't blocked.
+    try {
+      const entries = await readRegistry();
+      const filtered = entries.filter((e) => e?.name !== snapshotName);
+      if (filtered.length !== entries.length) await writeRegistry(filtered);
+    } catch {}
+  }
+
+  await rm(snapshotDir, { recursive: true, force: true }).catch(() => {});
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ok: true, name: snapshotName }));
+}
+
+export async function handleSnapshotRoute(req, url, res, opts) {
+  if (url.pathname === '/snapshot' && req.method === 'POST') {
+    await handleCreateSnapshot(url, res, opts);
+    return true;
+  }
+  if (url.pathname === '/snapshots' && req.method === 'GET') {
+    await handleListSnapshots(url, res);
+    return true;
+  }
+  if (url.pathname === '/snapshot' && req.method === 'DELETE') {
+    await handleDeleteSnapshot(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-sysml-export-core.mjs b/docker-server-sysml-export-core.mjs
new file mode 100644
index 0000000..65f5880
--- /dev/null
+++ b/docker-server-sysml-export-core.mjs
@@ -0,0 +1,145 @@
+// upstream/docker-server-sysml-export-core.mjs
+//
+// Pure renderers for SysML export. No I/O. Consumes runtime ghosts (from
+// .gitnexus/ghosts.json) + a list of file paths.
+
+export function safeId(s) {
+  if (!s) return 'x';
+  const slug = String(s).replace(/[^a-zA-Z0-9]+/g, '_').replace(/^_+|_+$/g, '');
+  return slug.length === 0 ? 'x' : slug;
+}
+
+function tierMajor(tier) {
+  if (!tier) return 'none';
+  const m = String(tier).match(/^(\d+)/);
+  return m ? m[1] : 'none';
+}
+
+function selectRenderableGhosts(ghosts, tierFilter) {
+  return (ghosts || []).filter((g) => {
+    if (g.status !== 'planned' && g.status !== 'expired') return false;
+    if (!tierFilter) return true;
+    return tierMajor(g.tier) === String(tierFilter);
+  });
+}
+
+export function renderPlantUml({ ghosts, files, repoName, tierFilter }) {
+  const selected = selectRenderableGhosts(ghosts, tierFilter);
+  const fileSet = new Set(files || []);
+  // Auto-include any file that a selected ghost satisfies.
+  for (const g of selected) for (const l of g.links || []) if (l.file) fileSet.add(l.file);
+
+  // Group ghosts by tier major.
+  const byTier = new Map();
+  for (const g of selected) {
+    const k = tierMajor(g.tier);
+    if (!byTier.has(k)) byTier.set(k, []);
+    byTier.get(k).push(g);
+  }
+
+  // Group files by tier (= tier of the ghost that satisfies them, fallback 'none').
+  const fileTier = new Map();
+  for (const g of selected) {
+    const k = tierMajor(g.tier);
+    for (const l of g.links || []) if (l.file && !fileTier.has(l.file)) fileTier.set(l.file, k);
+  }
+  for (const f of fileSet) if (!fileTier.has(f)) fileTier.set(f, 'none');
+  const filesByTier = new Map();
+  for (const [f, k] of fileTier) {
+    if (!filesByTier.has(k)) filesByTier.set(k, []);
+    filesByTier.get(k).push(f);
+  }
+
+  const lines = [];
+  lines.push('@startuml');
+  lines.push(`title gitnexus — Roadmap predictive SysML (${repoName || 'unknown'})`);
+  lines.push('');
+
+  const tiers = ['1', '2', '3', 'none'];
+  for (const t of tiers) {
+    const tGhosts = byTier.get(t) || [];
+    const tFiles = filesByTier.get(t) || [];
+    if (tGhosts.length === 0 && tFiles.length === 0) continue;
+    const label = t === 'none' ? 'Sans tier' : `Tier ${t}`;
+    lines.push(`package "${label}" {`);
+    for (const f of tFiles.sort()) {
+      lines.push(`  block "${f}" as B_${safeId(f)}`);
+    }
+    for (const g of tGhosts.sort((a, b) => a.id.localeCompare(b.id))) {
+      const title = (g.declared?.title || g.id).replace(/"/g, '\\"');
+      lines.push(`  requirement "${title}" as R_${safeId(g.id)}`);
+    }
+    for (const g of tGhosts.sort((a, b) => a.id.localeCompare(b.id))) {
+      for (const l of g.links || []) {
+        if (l.file && fileSet.has(l.file)) {
+          lines.push(`  R_${safeId(g.id)} ..> B_${safeId(l.file)} : <<satisfy>>`);
+        }
+      }
+      for (const depId of g.dependsOn || []) {
+        lines.push(`  R_${safeId(g.id)} ..> R_${safeId(depId)} : <<deriveReqt>>`);
+      }
+    }
+    lines.push('}');
+    lines.push('');
+  }
+
+  lines.push('@enduml');
+  return lines.join('\n') + '\n';
+}
+
+export function renderMermaid({ ghosts, files, repoName, tierFilter }) {
+  const selected = selectRenderableGhosts(ghosts, tierFilter);
+  const fileSet = new Set(files || []);
+  for (const g of selected) for (const l of g.links || []) if (l.file) fileSet.add(l.file);
+
+  const byTier = new Map();
+  for (const g of selected) {
+    const k = tierMajor(g.tier);
+    if (!byTier.has(k)) byTier.set(k, []);
+    byTier.get(k).push(g);
+  }
+  const fileTier = new Map();
+  for (const g of selected) {
+    const k = tierMajor(g.tier);
+    for (const l of g.links || []) if (l.file && !fileTier.has(l.file)) fileTier.set(l.file, k);
+  }
+  for (const f of fileSet) if (!fileTier.has(f)) fileTier.set(f, 'none');
+  const filesByTier = new Map();
+  for (const [f, k] of fileTier) {
+    if (!filesByTier.has(k)) filesByTier.set(k, []);
+    filesByTier.get(k).push(f);
+  }
+
+  const lines = [];
+  lines.push('graph TD');
+  lines.push(`%% gitnexus — Roadmap predictive (${repoName || 'unknown'})`);
+
+  const tiers = ['1', '2', '3', 'none'];
+  for (const t of tiers) {
+    const tGhosts = byTier.get(t) || [];
+    const tFiles = filesByTier.get(t) || [];
+    if (tGhosts.length === 0 && tFiles.length === 0) continue;
+    lines.push(`subgraph Tier_${t === 'none' ? 'none' : t}["${t === 'none' ? 'Sans tier' : `Tier ${t}`}"]`);
+    for (const f of tFiles.sort()) {
+      lines.push(`  B_${safeId(f)}[<<B>> ${f}]`);
+    }
+    for (const g of tGhosts.sort((a, b) => a.id.localeCompare(b.id))) {
+      const title = (g.declared?.title || g.id);
+      lines.push(`  R_${safeId(g.id)}[<<R>> ${title}]`);
+    }
+    lines.push('end');
+  }
+  for (const t of tiers) {
+    for (const g of (byTier.get(t) || [])) {
+      for (const l of g.links || []) {
+        if (l.file && fileSet.has(l.file)) {
+          lines.push(`R_${safeId(g.id)} -->|satisfy| B_${safeId(l.file)}`);
+        }
+      }
+      for (const depId of g.dependsOn || []) {
+        lines.push(`R_${safeId(g.id)} -->|deriveReqt| R_${safeId(depId)}`);
+      }
+    }
+  }
+  return lines.join('\n') + '\n';
+}
diff --git a/docker-server-sysml-export.mjs b/docker-server-sysml-export.mjs
new file mode 100644
index 0000000..e0647c0
--- /dev/null
+++ b/docker-server-sysml-export.mjs
@@ -0,0 +1,60 @@
+// upstream/docker-server-sysml-export.mjs
+import { renderPlantUml, renderMermaid } from './docker-server-sysml-export-core.mjs';
+import { readLatestGhosts } from './docker-server-ghosts.mjs';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+async function buildSysmlExport(repoPath, { format = 'plantuml', tierFilter, repoName }) {
+  const runtime = await readLatestGhosts(repoPath);
+  if (!runtime) return null;
+  const ghosts = runtime.ghosts || [];
+  // Collect referenced files from ghost.links — v1 doesn't include the full
+  // gitnexus graph (would explode the diagram). Files are only those that a
+  // ghost satisfies.
+  const files = [];
+  const seen = new Set();
+  for (const g of ghosts) for (const l of (g.links || [])) {
+    if (l.file && !seen.has(l.file)) { seen.add(l.file); files.push(l.file); }
+  }
+  if (format === 'mermaid') return renderMermaid({ ghosts, files, repoName, tierFilter });
+  return renderPlantUml({ ghosts, files, repoName, tierFilter });
+}
+
+export async function handleSysmlExport(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  const format = url.searchParams.get('format') || 'plantuml';
+  const tierFilter = url.searchParams.get('tier');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: 'missing repo' }));
+  }
+  if (format !== 'plantuml' && format !== 'mermaid') {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: `invalid format: ${format}` }));
+  }
+  const repo = await findRepoByName(repoName, opts.api);
+  if (!repo) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+  }
+  const repoPath = repo.repoPath || repo.path;
+  try {
+    const out = await buildSysmlExport(repoPath, { format, tierFilter, repoName });
+    if (out === null) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      return res.end(JSON.stringify({ error: 'No ghosts.json — run POST /ghosts/sync first.' }));
+    }
+    res.writeHead(200, { 'Content-Type': 'text/plain; charset=utf-8' });
+    res.end(out);
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+export async function handleSysmlExportRoute(req, url, res, opts) {
+  if (url.pathname === '/sysml-export' && req.method === 'GET') {
+    await handleSysmlExport(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-watches.mjs b/docker-server-watches.mjs
new file mode 100644
index 0000000..6bd9797
--- /dev/null
+++ b/docker-server-watches.mjs
@@ -0,0 +1,472 @@
+/**
+ * Watches & webhook alerting — ROADMAP Tier 2bis.3 (MVP).
+ *
+ * Endpoint:
+ *   GET /watches[?repo=<base>]
+ *     → list every declared watch (per `.gitnexus.json > watches`)
+ *       with its last evaluation state.
+ *
+ * Source of truth: each repo's `.gitnexus.json > watches` array
+ * (already parsed by docker-server-config.mjs from Tier 2bis.4). No
+ * dynamic POST/DELETE in the MVP — the user edits the YAML/JSON to
+ * add or remove a watch. Documented in CLAUDE.md and ROADMAP. The
+ * dynamic surface (POST /watches, DELETE /watches/:id) can come in a
+ * 2bis.3b follow-up when there's a real need for ad-hoc watches.
+ *
+ * Internal cron:
+ *   - Wakes every `WATCH_INTERVAL_MS` (default 5 min).
+ *   - For each indexed repo with `watches` declared, evaluates each
+ *     watch by fetching the corresponding metric from our own HTTP
+ *     endpoints (cheap; the cron loop is once every 5 min, not a hot
+ *     path). Localhost fetches via the same WEB_BASE used by the MCP
+ *     sidecar.
+ *   - If the condition triggers AND we haven't fired the webhook for
+ *     this (repo, watch) in the past `DEBOUNCE_MS` (default 1h), POST
+ *     the webhook payload.
+ *
+ * Storage: state is in-memory (a Map keyed by `${repo}:${watchIdx}`).
+ * Survives only until the next process restart. Documented limitation
+ * — for durable state, the user would either accept duplicate
+ * notifications across restarts (the webhook receiver should
+ * deduplicate by id+date) or wait for a 2bis.3b that adds disk
+ * persistence.
+ *
+ * --- Webhook payload ---
+ *
+ *   POST <webhook URL>
+ *   Content-Type: application/json
+ *   {
+ *     "repoBase": "hmm_studio",
+ *     "metric": "entropy.density",
+ *     "threshold": 0.05,
+ *     "op": ">",
+ *     "currentValue": 0.0631,
+ *     "triggeredAt": "2026-05-26T10:30:00.000Z",
+ *     "source": "gitnexus-watches/2bis.3"
+ *   }
+ *
+ * Slack-compatible: the payload also includes a `text` field so a
+ * Slack incoming webhook URL produces a readable message without a
+ * custom handler.
+ *
+ * --- Supported metrics ---
+ *
+ *   entropy.density            from /entropy (last point in timeline)
+ *   entropy.modularity         from /entropy (last point)
+ *   ownership.busFactor        from /ownership repoBusFactor
+ *   ownership.topAuthorShare   from /ownership repoAuthors[0].share
+ *   dissonance.purity          from /dissonance (skips if no domains)
+ *
+ * Unknown metrics are skipped with a one-shot warning. To add a new
+ * metric, register an evaluator in METRIC_EVALUATORS below.
+ *
+ * --- Configuration (env vars) ---
+ *
+ *   WATCH_INTERVAL_MS    300000   ms between cron ticks (5 min)
+ *   WATCH_DEBOUNCE_MS    3600000  ms between webhook fires for the
+ *                                  same (repo, watch) condition (1h)
+ *   WATCH_TIMEOUT_MS     30000    HTTP timeout for evaluator + webhook
+ *   WATCHES_ENABLED      true     set to "false" to disable the cron
+ *                                  (endpoint still serves config view)
+ */
+
+import process from 'node:process';
+import { getConfig } from './docker-server-config.mjs';
+import { maybeReindexRepo } from './docker-server-auto-reindex.mjs';
+import { maybePrewarmRepo } from './docker-server-prewarm.mjs';
+
+const WATCH_INTERVAL_MS = Number(process.env.WATCH_INTERVAL_MS) || 5 * 60 * 1000;
+const WATCH_DEBOUNCE_MS = Number(process.env.WATCH_DEBOUNCE_MS) || 60 * 60 * 1000;
+const WATCH_TIMEOUT_MS = Number(process.env.WATCH_TIMEOUT_MS) || 30 * 1000;
+const WATCHES_ENABLED = (process.env.WATCHES_ENABLED ?? 'true').toLowerCase() !== 'false';
+
+// In-memory eval state. Key = `${repo}:${watchKey}` where watchKey =
+// `${metric}|${op}|${threshold}|${webhook}` (stable across restarts as
+// long as the .gitnexus.json watch shape is unchanged).
+const _evalState = new Map();
+const _warnedMetrics = new Set();
+let _cronTimer = null;
+
+function metricKey(repo, watch) {
+  return `${repo}:${watch.metric}|${watch.op}|${watch.threshold}|${watch.webhook || ''}`;
+}
+
+// ── Evaluators per metric ────────────────────────────────────────────
+
+async function fetchJson(url) {
+  const controller = new AbortController();
+  const t = setTimeout(() => controller.abort(), WATCH_TIMEOUT_MS);
+  try {
+    const resp = await fetch(url, { signal: controller.signal, cache: 'no-store' });
+    if (!resp.ok) return { ok: false, error: `HTTP ${resp.status}` };
+    return { ok: true, body: await resp.json() };
+  } catch (err) {
+    return { ok: false, error: err.name === 'AbortError' ? 'timeout' : err.message };
+  } finally {
+    clearTimeout(t);
+  }
+}
+
+// All evaluators take (repo, webBase) and return
+// { ok: true, value: number } | { ok: false, error: string }.
+const METRIC_EVALUATORS = {
+  'entropy.density': async (repo, webBase) => {
+    const r = await fetchJson(`${webBase}/entropy?repo=${encodeURIComponent(repo)}`);
+    if (!r.ok) return r;
+    const last = (r.body?.timeline || []).slice(-1)[0];
+    if (!last || typeof last.density !== 'number') return { ok: false, error: 'no density in /entropy timeline' };
+    return { ok: true, value: last.density };
+  },
+  'entropy.modularity': async (repo, webBase) => {
+    const r = await fetchJson(`${webBase}/entropy?repo=${encodeURIComponent(repo)}`);
+    if (!r.ok) return r;
+    const last = (r.body?.timeline || []).slice(-1)[0];
+    if (!last || typeof last.modularity !== 'number') return { ok: false, error: 'no modularity in /entropy timeline' };
+    return { ok: true, value: last.modularity };
+  },
+  'ownership.busFactor': async (repo, webBase) => {
+    const r = await fetchJson(`${webBase}/ownership?repo=${encodeURIComponent(repo)}`);
+    if (!r.ok) return r;
+    if (typeof r.body?.repoBusFactor !== 'number') return { ok: false, error: 'no repoBusFactor' };
+    return { ok: true, value: r.body.repoBusFactor };
+  },
+  'ownership.topAuthorShare': async (repo, webBase) => {
+    const r = await fetchJson(`${webBase}/ownership?repo=${encodeURIComponent(repo)}`);
+    if (!r.ok) return r;
+    const top = r.body?.repoAuthors?.[0];
+    if (!top || typeof top.share !== 'number') return { ok: false, error: 'no top author share' };
+    return { ok: true, value: top.share };
+  },
+  'dissonance.purity': async (repo, webBase) => {
+    const r = await fetchJson(`${webBase}/dissonance?repo=${encodeURIComponent(repo)}`);
+    if (!r.ok) return r;
+    if (typeof r.body?.purity !== 'number') return { ok: false, error: 'no purity (no domains declared?)' };
+    return { ok: true, value: r.body.purity };
+  },
+  coupling: async (repo, webBase) => {
+    const r = await fetchJson(`${webBase}/coupling?repo=${encodeURIComponent(repo)}`);
+    if (!r.ok) return r;
+    if (typeof r.body?.pairsAboveThreshold !== 'number') return { ok: false, error: 'no pairsAboveThreshold' };
+    return { ok: true, value: r.body.pairsAboveThreshold };
+  },
+};
+
+function evaluateOp(currentValue, op, threshold) {
+  switch (op) {
+    case '>':  return currentValue > threshold;
+    case '>=': return currentValue >= threshold;
+    case '<':  return currentValue < threshold;
+    case '<=': return currentValue <= threshold;
+    case '==':
+    case '=':  return currentValue === threshold;
+    case '!=': return currentValue !== threshold;
+    default:   return false;
+  }
+}
+
+// ── Regression metric mapping ───────────────────────────────────────
+
+// Map a watch metric key to the /regression metric param. Returns null for
+// metrics /regression doesn't cover (→ no enrichment). See spec § 4.2.
+export function mapWatchToRegressionMetric(watchMetric) {
+  const MAP = {
+    'entropy.density': 'density',
+    'entropy.modularity': 'modularity',
+    'ownership.busFactor': 'ownership.busFactor',
+    'ownership.topAuthorShare': 'ownership.topAuthorShare',
+    'dissonance.purity': 'dissonance.purity',
+    coupling: 'coupling',
+  };
+  return MAP[watchMetric] || null;
+}
+
+// Build the watch webhook payload. `regression` is the /regression verdict or
+// null. Pure (except the triggeredAt timestamp). See spec § 4.2.
+export function buildWebhookPayload(repoBase, watch, currentValue, regression) {
+  let text = `🚨 GitNexus: \`${repoBase}\` ${watch.metric} = ${currentValue.toFixed(4)} ${watch.op} ${watch.threshold} (threshold)`;
+  const wc = regression && regression.worstCommit;
+  if (wc && wc.sha) {
+    const files = typeof wc.filesTouched === 'number'
+      ? wc.filesTouched
+      : (Array.isArray(wc.files) ? wc.files.length : null);
+    const filesStr = files !== null ? ` (${files} files)` : '';
+    const mode = regression.attribution ? ` [${regression.attribution}]` : '';
+    text += ` · Likely culprit: ${wc.shortSha || wc.sha.slice(0, 7)} by ${wc.author || 'unknown'}${filesStr}${mode}`;
+  }
+  const payload = {
+    repoBase, metric: watch.metric, threshold: watch.threshold, op: watch.op,
+    currentValue, triggeredAt: new Date().toISOString(),
+    source: 'gitnexus-watches/2bis.3', text,
+  };
+  if (regression) payload.regression = regression;
+  return payload;
+}
+
+// ── Webhook fire ─────────────────────────────────────────────────────
+
+// Fetch the /regression verdict for a watch metric (best-effort). Returns the
+// verdict body, or null if the metric isn't covered or the call fails/timeouts.
+async function fetchRegressionVerdict(repoBase, watchMetric, webBase) {
+  const m = mapWatchToRegressionMetric(watchMetric);
+  if (!m) return null;
+  const r = await fetchJson(`${webBase}/regression?repo=${encodeURIComponent(repoBase)}&metric=${encodeURIComponent(m)}`);
+  return r.ok ? r.body : null;
+}
+
+async function fireWebhook(repoBase, watch, currentValue, regression) {
+  if (!watch.webhook) return { ok: false, error: 'no webhook URL' };
+  const payload = buildWebhookPayload(repoBase, watch, currentValue, regression);
+  const controller = new AbortController();
+  const t = setTimeout(() => controller.abort(), WATCH_TIMEOUT_MS);
+  try {
+    const resp = await fetch(watch.webhook, {
+      method: 'POST',
+      headers: { 'Content-Type': 'application/json' },
+      body: JSON.stringify(payload),
+      signal: controller.signal,
+    });
+    return { ok: resp.ok, status: resp.status, error: resp.ok ? null : `HTTP ${resp.status}` };
+  } catch (err) {
+    return { ok: false, error: err.name === 'AbortError' ? 'timeout' : err.message };
+  } finally {
+    clearTimeout(t);
+  }
+}
+
+// ── Per-repo watch evaluation ────────────────────────────────────────
+
+async function evaluateRepoWatches(repo, repoPath, webBase, now) {
+  let cfg;
+  try {
+    cfg = await getConfig(repoPath);
+  } catch {
+    return [];
+  }
+  const watches = Array.isArray(cfg.watches) ? cfg.watches : [];
+  if (watches.length === 0) return [];
+
+  const out = [];
+  for (const w of watches) {
+    const k = metricKey(repo, w);
+    const evaluator = METRIC_EVALUATORS[w.metric];
+    let evalResult;
+    if (!evaluator) {
+      if (!_warnedMetrics.has(w.metric)) {
+        _warnedMetrics.add(w.metric);
+        process.stderr.write(`[watches] unknown metric: ${w.metric} (add an evaluator in docker-server-watches.mjs)\n`);
+      }
+      evalResult = { ok: false, error: `unknown metric: ${w.metric}` };
+    } else {
+      evalResult = await evaluator(repo, webBase);
+    }
+
+    const prior = _evalState.get(k) || { lastTriggeredAt: 0, lastValue: null };
+    const state = {
+      ...prior,
+      lastEvaluatedAt: now,
+      lastValue: evalResult.ok ? evalResult.value : prior.lastValue,
+      lastError: evalResult.ok ? null : evalResult.error,
+    };
+
+    let webhookFired = false;
+    let webhookOutcome = null;
+    if (evalResult.ok && evaluateOp(evalResult.value, w.op, Number(w.threshold))) {
+      const elapsedSinceLastTrigger = now - (prior.lastTriggeredAt || 0);
+      if (elapsedSinceLastTrigger >= WATCH_DEBOUNCE_MS) {
+        // "Auto" regression forensics: fetch the culprit before firing (best-
+        // effort — the webhook fires even if /regression fails). See spec § 4.3.
+        const regression = await fetchRegressionVerdict(repo, w.metric, webBase);
+        webhookOutcome = await fireWebhook(repo, w, evalResult.value, regression);
+        webhookFired = true;
+        state.lastTriggeredAt = now;
+        state.lastCulprit = regression && regression.worstCommit
+          ? {
+              sha: regression.worstCommit.sha,
+              shortSha: regression.worstCommit.shortSha || (regression.worstCommit.sha ? regression.worstCommit.sha.slice(0, 7) : null),
+              author: regression.worstCommit.author || null,
+              attribution: regression.attribution || null,
+              filesTouched: typeof regression.worstCommit.filesTouched === 'number' ? regression.worstCommit.filesTouched : (Array.isArray(regression.worstCommit.files) ? regression.worstCommit.files.length : null),
+              at: new Date(now).toISOString(),
+            }
+          : null;
+      } else {
+        webhookOutcome = { ok: false, error: 'debounced', secondsUntilEligible: Math.ceil((WATCH_DEBOUNCE_MS - elapsedSinceLastTrigger) / 1000) };
+      }
+    }
+
+    _evalState.set(k, state);
+    out.push({
+      repo,
+      watch: w,
+      lastEvaluatedAt: new Date(state.lastEvaluatedAt).toISOString(),
+      lastValue: state.lastValue,
+      lastError: state.lastError,
+      lastTriggeredAt: state.lastTriggeredAt ? new Date(state.lastTriggeredAt).toISOString() : null,
+      webhookFiredThisTick: webhookFired,
+      webhookOutcome,
+    });
+  }
+  return out;
+}
+
+// ── Cron loop ────────────────────────────────────────────────────────
+
+const _webBase = () => `http://127.0.0.1:${process.env.PORT || '4173'}`;
+
+async function fetchAllRepos(apiBase) {
+  const r = await fetchJson(`${apiBase}/api/repos`);
+  if (!r.ok) return [];
+  const list = Array.isArray(r.body) ? r.body : r.body?.repos;
+  return Array.isArray(list) ? list : [];
+}
+
+// ── Code Wiki auto-regeneration (rides on the same cron tick) ─────────
+const WIKI_WORKER_URL = process.env.WIKI_WORKER_URL || 'http://gitnexus:4748';
+
+// Runtime twin of gitnexus-web/src/lib/wiki-schedule.ts parseAutoEvery. The
+// .ts is the unit-tested canonical version; this .mjs copy exists because the
+// cron runs as plain Node ESM and can't import a .ts file. Keep them in sync.
+function parseAutoEveryMs(autoEvery) {
+  if (!autoEvery || autoEvery === 'off') return null;
+  const m = /^(\d+)([hd])$/.exec(String(autoEvery).trim());
+  if (!m) return null;
+  const n = Number(m[1]);
+  if (!Number.isFinite(n) || n <= 0) return null;
+  return m[2] === 'h' ? n * 3_600_000 : n * 86_400_000;
+}
+
+// Trigger a wiki regen for one repo if its configured interval elapsed.
+// Reads cadence from .gitnexus.json > wiki.autoEvery (default 'off'). Best-
+// effort: any failure (worker down, config error) just skips this tick.
+async function maybeRegenWiki(repoName, repoPath) {
+  let cfg;
+  try {
+    cfg = await getConfig(repoPath);
+  } catch {
+    return;
+  }
+  const intervalMs = parseAutoEveryMs(cfg?.wiki?.autoEvery);
+  if (intervalMs === null) return; // off or malformed → no auto-regen
+  let status;
+  try {
+    const sres = await fetch(`${WIKI_WORKER_URL}/status?repo=${encodeURIComponent(repoName)}`);
+    status = await sres.json();
+  } catch {
+    return; // worker unreachable this tick
+  }
+  if (status?.generating) return;
+  const lastMs = status?.lastGeneratedAt ? Date.parse(status.lastGeneratedAt) : null;
+  const due = lastMs === null ? true : Date.now() - lastMs >= intervalMs;
+  if (!due) return;
+  try {
+    await fetch(`${WIKI_WORKER_URL}/generate?repo=${encodeURIComponent(repoName)}`, { method: 'POST' });
+    process.stderr.write(`[watches] wiki auto-regen triggered for ${repoName}\n`);
+  } catch {
+    /* best-effort */
+  }
+}
+
+async function cronTick(apiBase) {
+  const webBase = _webBase();
+  const repos = await fetchAllRepos(apiBase);
+  const now = Date.now();
+  // Sequential, polite — N repos × M watches, neither is high. Avoids
+  // hammering our own endpoints with parallel git invocations.
+  for (const repo of repos) {
+    if (!repo?.name || repo.name.includes('@')) continue; // skip snapshots
+    const repoPath = repo.repoPath || repo.path;
+    if (!repoPath) continue;
+    await evaluateRepoWatches(repo.name, repoPath, webBase, now).catch((err) => {
+      process.stderr.write(`[watches] eval failed for ${repo.name}: ${err.message}\n`);
+    });
+    await maybeRegenWiki(repo.name, repoPath).catch(() => {});
+    await maybeReindexRepo(repo, apiBase).catch(() => {});
+    await maybePrewarmRepo(repo).catch(() => {});
+  }
+}
+
+export function startWatchesCron(apiBase) {
+  if (!WATCHES_ENABLED) {
+    process.stderr.write('[watches] cron disabled (WATCHES_ENABLED=false)\n');
+    return;
+  }
+  if (_cronTimer) return; // already running
+  // Stagger the first run by 10s so the stack has time to come up.
+  setTimeout(() => {
+    cronTick(apiBase).catch((err) =>
+      process.stderr.write(`[watches] initial cron tick failed: ${err.message}\n`),
+    );
+    _cronTimer = setInterval(() => {
+      cronTick(apiBase).catch((err) =>
+        process.stderr.write(`[watches] cron tick failed: ${err.message}\n`),
+      );
+    }, WATCH_INTERVAL_MS);
+    if (_cronTimer.unref) _cronTimer.unref();
+  }, 10_000);
+  process.stderr.write(
+    `[watches] cron enabled · interval=${WATCH_INTERVAL_MS}ms · debounce=${WATCH_DEBOUNCE_MS}ms · metrics=${Object.keys(METRIC_EVALUATORS).join(',')}\n`,
+  );
+}
+
+export function stopWatchesCron() {
+  if (_cronTimer) {
+    clearInterval(_cronTimer);
+    _cronTimer = null;
+  }
+}
+
+// ── HTTP handler ─────────────────────────────────────────────────────
+
+async function handleGetWatches(url, res, opts) {
+  const filterRepo = url.searchParams.get('repo');
+  const repos = await fetchAllRepos(opts.api);
+  const out = [];
+  for (const repo of repos) {
+    if (!repo?.name || repo.name.includes('@')) continue;
+    if (filterRepo && repo.name !== filterRepo) continue;
+    const repoPath = repo.repoPath || repo.path;
+    if (!repoPath) continue;
+    let cfg;
+    try {
+      cfg = await getConfig(repoPath);
+    } catch {
+      continue;
+    }
+    const watches = Array.isArray(cfg.watches) ? cfg.watches : [];
+    for (let i = 0; i < watches.length; i++) {
+      const w = watches[i];
+      const k = metricKey(repo.name, w);
+      const state = _evalState.get(k) || null;
+      out.push({
+        repo: repo.name,
+        index: i,
+        watch: w,
+        state: state ? {
+          lastEvaluatedAt: state.lastEvaluatedAt ? new Date(state.lastEvaluatedAt).toISOString() : null,
+          lastValue: state.lastValue,
+          lastError: state.lastError,
+          lastTriggeredAt: state.lastTriggeredAt ? new Date(state.lastTriggeredAt).toISOString() : null,
+          lastCulprit: state.lastCulprit || null,
+        } : null,
+      });
+    }
+  }
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({
+    watchesCount: out.length,
+    reposScanned: filterRepo ? 1 : repos.length,
+    cronEnabled: WATCHES_ENABLED,
+    intervalMs: WATCH_INTERVAL_MS,
+    debounceMs: WATCH_DEBOUNCE_MS,
+    supportedMetrics: Object.keys(METRIC_EVALUATORS),
+    watches: out,
+  }));
+}
+
+export async function handleWatchesRoute(req, url, res, opts) {
+  if (url.pathname === '/watches' && req.method === 'GET') {
+    await handleGetWatches(url, res, opts);
+    return true;
+  }
+  return false;
+}
