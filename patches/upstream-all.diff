+                          {m.confidence != null && ` · conf ${Math.round(m.confidence * 100)}%`}
+                        </div>
+                      </button>
+                    );
+                  })
+                ))}
+            </div>
+
+            {/* Domain-declared-but-no-community */}
+            {dissonanceData.domainWithoutCommunity.length > 0 && (
+              <div>
+                <button
+                  type="button"
+                  onClick={() => setShowOrphans((v) => !v)}
+                  className="flex w-full items-center gap-2 border-b border-border-subtle bg-elevated px-3 py-1.5 text-left transition-colors hover:bg-hover cursor-pointer"
+                >
+                  {showOrphans ? (
+                    <ChevronDown className="h-3 w-3 shrink-0 text-text-muted" />
+                  ) : (
+                    <ChevronRight className="h-3 w-3 shrink-0 text-text-muted" />
+                  )}
+                  <span className="text-[11px] font-semibold text-amber-300">
+                    Declared but no community
+                  </span>
+                  <span className="font-mono text-[10px] text-text-muted">
+                    {dissonanceData.domainWithoutCommunity.length}
+                  </span>
+                </button>
+                {showOrphans &&
+                  dissonanceData.domainWithoutCommunity.slice(0, 200).map((o) => (
+                    <div
+                      key={o.file}
+                      className="flex min-w-0 items-center gap-2 border-b border-border-subtle px-3 py-1 font-mono text-[10px] text-text-muted"
+                      title="No symbols → no community attribution. Typical for configs/docs."
+                    >
+                      <span className="shrink-0 rounded bg-elevated px-1 py-0">{o.domain}</span>
+                      <span className="truncate text-text-secondary">{o.file}</span>
+                    </div>
+                  ))}
+                {dissonanceData.domainWithoutCommunity.length > 200 && (
+                  <div className="px-3 py-1 text-[10px] italic text-text-muted">
+                    Showing 200 of {dissonanceData.domainWithoutCommunity.length}.
+                  </div>
+                )}
+              </div>
+            )}
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
