+function dimLabel(dim: string): string {
+  switch (dim) {
+    case 'density': return 'graph density';
+    case 'modularity': return 'modularity';
+    case 'busFactorNorm': return 'bus factor (norm)';
+    case 'topAuthorShare': return 'top-author share';
