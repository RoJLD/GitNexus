+    const archiveName = `${safeFilenameFromName(repoName)}.${mode === 'bundle' ? 'bundle' : 'gitnexus'}.zip`;
+    res.writeHead(200, {
+      'Content-Type': 'application/zip',
+      'Content-Disposition': `attachment; filename="${archiveName}"`,
+      'Cache-Control': 'no-store',
+    });
+
+    // `zip -r - <dir>` writes the archive to stdout. We pipe stdout to the
+    // HTTP response. The client gets a streamed download with the repo name
+    // as the top-level directory inside the archive.
+    const child = spawn('zip', ['-r', '-q', '-', basename(stagedRepoDir)], { cwd: stage });
+    child.stdout.pipe(res);
+    child.stderr.on('data', (d) => console.warn('[export][zip][stderr]', d.toString()));
+    child.on('error', (err) => {
+      console.error('[export] zip failed:', err);
+      if (!res.headersSent) {
+        res.writeHead(500);
+      }
+      res.end();
+    });
+    child.on('close', async () => {
+      await rm(stage, { recursive: true, force: true }).catch(() => {});
+    });
+  } catch (err) {
+    await rm(stage, { recursive: true, force: true }).catch(() => {});
+    console.error('[export] staging failed:', err);
+    if (!res.headersSent) {
+      res.writeHead(500, { 'Content-Type': 'application/json' });
+    }
+    res.end(JSON.stringify({ error: err?.message || 'export failed' }));
+  }
+}
