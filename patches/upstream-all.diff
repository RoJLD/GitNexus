new file mode 100644
index 0000000..24784c2
--- /dev/null
+++ b/docker-server-coupling.mjs
@@ -0,0 +1,256 @@
+/**
+ * Temporal coupling analytics — Phase 4B.
+ *
+ * Endpoint:
+ *   GET /coupling?repo=<baseRepoName>&top=<n>
+ *
+ * Across the snapshot timeline of <baseRepoName> (snapshots + live), for
+ * each consecutive transition we extract the set of FILES touched (a file
+ * is "touched" if any node attributed to it was added or removed). For
+ * every pair of files in that set we increment a co-occurrence counter,
+ * and we expose the strongest couplings ranked by Jaccard similarity.
+ *
+ * Interpretation:
+ *   - High Jaccard between A and B → "they almost always change together"
+ *     This is the bread and butter of architectural reverse-engineering:
+ *     a strong but non-architectural link (e.g. login.py always changes
+ *     with auth_test.py) reveals hidden coupling, design rules, or
+ *     repeated patterns.
+ *   - Low individual count + high Jaccard → coupling could be coincidence.
+ *     We expose `count` so the UI can filter out rare-but-paired files.
+ *
+ * Granularity = file. The node graph has tens of thousands of nodes;
+ * coupling per function/class would be too noisy for a top-N list and
+ * harder to act on. Files are the natural unit for "what tends to change
+ * together" in most refactoring/patterns analyses.
+ *
+ * Response shape:
+ *   {
+ *     totalTransitions: number,
+ *     timeline: [{ name, isLive, date }],
+ *     fileChangeCount: { [filePath]: number },
+ *     pairs: [{ a, b, count, jaccard }],   // sorted desc by jaccard
+ *     errors?: [...]
+ *   }
+ */
+
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { readdir, readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import { SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+async function listSnapshotNamesAndDates(repoName) {
+  const repoSnapshotsDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(repoSnapshotsDir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(
+        await readFile(join(repoSnapshotsDir, e.name, 'commit.json'), 'utf8'),
+      );
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built snapshot; skip
+    }
+  }
+  return out;
+}
+
+// Extract the owning file path from a node id. gitnexus IDs follow a few
+// conventions:
+//   File:<path>                              → the file itself
+//   Folder:<path>                            → not a file (skipped)
+//   Function:<path>:<name>[:<line>]          → owned by <path>
+//   Class:<path>:<name>[:<line>]             → owned by <path>
+//   Variable:<path>:<name>                   → owned by <path>
+//   Section:<path>:<L?>:<title>              → owned by <path>
+//   Community:<n>, Process:<n>, comm_<n>     → no file
+// We pick the segment immediately after the first ":" and treat it as the
+// owning file path. Returns null for things we can't attribute (e.g.
+// communities / processes — synthetic nodes).
+const NON_FILE_LABELS = new Set([
+  'Community',
+  'Process',
+  'Folder',
+  'Repository',
+  'Group',
+]);
+function fileOfNodeId(id) {
+  if (typeof id !== 'string' || !id.includes(':')) return null;
+  const colon = id.indexOf(':');
+  const label = id.slice(0, colon);
+  if (NON_FILE_LABELS.has(label)) return null;
+  // Synthetic ids like "comm_5" have no label / colon — already returned above.
+  const rest = id.slice(colon + 1);
+  // Everything up to the next ":" is the file path. Some node ids embed
+  // a path that itself contains nothing-but-letters (e.g. "Section:Quick" —
+  // but those are unlikely; we treat them as file path = `rest`).
+  const next = rest.indexOf(':');
+  return next === -1 ? rest : rest.slice(0, next);
+}
+
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+async function handleCoupling(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const top = Math.max(1, Math.min(500, Number(url.searchParams.get('top')) || 50));
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ].sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  if (timeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        totalTransitions: 0,
+        timeline,
+        pairs: [],
+        fileChangeCount: {},
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) to compute coupling.',
+      }),
+    );
+    return;
+  }
+
+  // Collect each snapshot's node-id set sequentially (same reason as
+  // /churn: the gitnexus REST lbug cache is single-entry, parallel access
+  // would thrash it).
+  const idSets = [];
+  const errors = [];
+  for (const point of timeline) {
+    try {
+      const ids = await fetchNodeIds(point.name, opts.api);
+      idSets.push(new Set(ids));
+    } catch (err) {
+      errors.push({ snapshot: point.name, error: err?.message || 'fetch failed' });
+      // Push an empty set so the downstream index alignment stays correct.
+      idSets.push(new Set());
+    }
+  }
+
+  // For each transition, build the set of FILES touched (any node added
+  // or removed maps to its owning file). Then bump cooccur for each pair.
+  const fileChangeCount = Object.create(null);
+  const pairCount = new Map(); // key: "a\0b" (sorted), val: count
+  const totalTransitions = idSets.length - 1;
+
+  for (let i = 0; i < totalTransitions; i++) {
+    const a = idSets[i];
+    const b = idSets[i + 1];
+    const touchedFiles = new Set();
+
+    // Added: in b but not in a.
+    for (const id of b) {
+      if (!a.has(id)) {
+        const file = fileOfNodeId(id);
+        if (file) touchedFiles.add(file);
+      }
+    }
+    // Removed: in a but not in b.
+    for (const id of a) {
+      if (!b.has(id)) {
+        const file = fileOfNodeId(id);
+        if (file) touchedFiles.add(file);
+      }
+    }
+
+    if (touchedFiles.size === 0) continue;
+
+    const filesArr = [...touchedFiles];
+    for (const f of filesArr) {
+      fileChangeCount[f] = (fileChangeCount[f] || 0) + 1;
+    }
+    // All unordered pairs of touched files. Sort the two paths so each
+    // pair has a canonical key regardless of which file is "a" or "b".
+    for (let x = 0; x < filesArr.length; x++) {
+      for (let y = x + 1; y < filesArr.length; y++) {
+        const [p, q] = filesArr[x] < filesArr[y]
+          ? [filesArr[x], filesArr[y]]
+          : [filesArr[y], filesArr[x]];
+        const key = `${p}\0${q}`;
+        pairCount.set(key, (pairCount.get(key) || 0) + 1);
+      }
+    }
+  }
+
+  // Compute Jaccard per pair. Symmetric measure: count(A ∩ B) / count(A ∪ B)
+  // where each "count" is the number of transitions touching that file (or
+  // both). |A ∪ B| = changes(A) + changes(B) - cooccur(A, B).
+  const pairs = [];
+  for (const [key, count] of pairCount) {
+    const [a, b] = key.split('\0');
+    const cA = fileChangeCount[a] || 1;
+    const cB = fileChangeCount[b] || 1;
+    const jaccard = count / (cA + cB - count);
+    pairs.push({ a, b, count, jaccard });
+  }
+  pairs.sort((x, y) => y.jaccard - x.jaccard || y.count - x.count);
+
+  const truncated = pairs.slice(0, top);
+
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(truncated, [
+      { key: 'a', header: 'fileA' },
+      { key: 'b', header: 'fileB' },
+      { key: 'count', header: 'coChanges' },
+      { key: 'jaccard' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-coupling.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalTransitions,
+      timeline,
+      fileChangeCount,
+      pairs: truncated,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+export async function handleCouplingRoute(req, url, res, opts) {
+  if (url.pathname === '/coupling' && req.method === 'GET') {
+    await handleCoupling(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-csv.mjs b/docker-server-csv.mjs
new file mode 100644
index 0000000..d9de47e
--- /dev/null
+++ b/docker-server-csv.mjs
@@ -0,0 +1,57 @@
+/**
+ * Minimal CSV serialization for the analytics endpoints' `?format=csv`
+ * branch. Tiny and self-contained — we don't pull in a CSV lib for the
+ * three operations we actually do (string quoting, joining, header
+ * row).
+ */
+
+/**
+ * Quote a single CSV cell. RFC 4180 rules:
+ *   - wrap in double quotes if the value contains `,`, `"`, CR, or LF
+ *   - inside the quotes, escape `"` as `""`
+ * Numbers / booleans are stringified untouched, null/undefined render
+ * as empty.
+ */
+function csvCell(v) {
+  if (v == null) return '';
+  const s = typeof v === 'string' ? v : String(v);
+  if (/[",\r\n]/.test(s)) return `"${s.replace(/"/g, '""')}"`;
+  return s;
+}
+
+/**
+ * Convert an array of row objects to a CSV string.
+ *   columns: ordered list of { key, header? }
+ * If `header` is omitted, `key` doubles as the header label.
+ *
+ * Streaming wasn't worth the complexity at our scale — analytics
+ * payloads are <100k rows in practice and fit in memory comfortably.
+ */
+export function toCsv(rows, columns) {
+  const header = columns.map((c) => csvCell(c.header ?? c.key)).join(',');
+  const body = rows
+    .map((row) => columns.map((c) => csvCell(row[c.key])).join(','))
+    .join('\n');
+  return header + '\n' + body + (body ? '\n' : '');
+}
+
+/**
+ * Helper for endpoint handlers: write the response with the right
+ * headers and a download-friendly filename derived from the repo name.
+ */
+export function writeCsv(res, filename, csv) {
+  res.writeHead(200, {
+    'Content-Type': 'text/csv; charset=utf-8',
+    'Content-Disposition': `attachment; filename="${filename}"`,
+    'Cache-Control': 'no-store',
+  });
+  res.end(csv);
+}
+
+/**
+ * Sanitize a string so it's safe as part of a CSV filename — keep
+ * alphanumerics, dashes, underscores, dots; replace the rest with `_`.
+ */
+export function safeFilename(s) {
+  return String(s).replace(/[^A-Za-z0-9._-]/g, '_').slice(0, 80) || 'export';
+}
diff --git a/docker-server-dissonance.mjs b/docker-server-dissonance.mjs
new file mode 100644
index 0000000..53700ab
--- /dev/null
+++ b/docker-server-dissonance.mjs
@@ -0,0 +1,355 @@
+/**
+ * Dissonance analytics — ROADMAP Tier 2.2.
+ *
+ * Endpoint:
+ *   GET /dissonance?repo=<baseRepoName>[&format=csv]
+ *
+ * Reads `<repoPath>/.gitnexus-domains.json` (a user-curated mapping of
+ * domain names to file-path globs) and compares the *declared* domain
+ * partition with gitnexus's *detected* community partition. Returns:
+ *
+ *   - per-file rows showing its declared domain, its dominant community,
+ *     and whether the two agree
+ *   - a contingency matrix domain × community (counts of files)
+ *   - a global "domain purity" score in [0,1]:
+ *       purity = Σ_d max_c |files(d) ∩ files(c)| / total_files
+ *     A purity of 1 means each domain lives entirely in one community —
+ *     architectural code-to-domain alignment. Lower = more leaky.
+ *   - a "misplaced" list: files whose community doesn't match the
+ *     majority community of their declared domain. These are the
+ *     candidates for refactoring or for re-categorisation.
+ *
+ * --- Why this design ---
+ *
+ * gitnexus's community detection runs on CALLS edges, so communities
+ * primarily group Functions/Classes/Methods. We climb back to the
+ * owning file via DEFINES (single hop), then pick the community that
+ * "wins" for each file by symbol count. Files with no defined symbols
+ * (configs, docs) have no community attribution — we list them
+ * separately so the user can decide whether to ignore them or extend
+ * their domain definition.
+ *
+ * --- The .gitnexus-domains.json format ---
+ *
+ * Lives at the repo root. JSON because Node has no YAML in stdlib and
+ * pulling a parser for one config file isn't worth it.
+ *
+ *   {
+ *     "domains": {
+ *       "auth":    ["src/auth/**", "src/middleware/auth*.py"],
+ *       "billing": ["src/billing/**", "tests/billing/**"],
+ *       "data":    ["src/db/**", "src/models/**"]
+ *     }
+ *   }
+ *
+ * Globs support `**` (any subpath including empty), `*` (any path
+ * segment, no slashes), and literal characters. First match wins —
+ * order domains from most specific to least specific in your file.
+ */
+
+import { readFile, stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const DOMAINS_FILENAME = '.gitnexus-domains.json';
+
+/**
+ * Convert a glob with `**` and `*` into a RegExp. Anchored at both
+ * ends. Doesn't try to be a full minimatch — supports just what the
+ * config format actually uses.
+ */
+function globToRegex(glob) {
+  // Escape regex metacharacters first.
+  let re = glob.replace(/[.+^$(){}|[\]\\]/g, '\\$&');
+  // Then translate ** → any (including empty + slashes) and * → no slash
+  // We use placeholders to avoid the single-* substitution catching the
+  // chars we just emitted for **.
+  re = re.replace(/\*\*/g, 'XGLOBSTARX').replace(/\*/g, 'XSTARX');
+  re = re.replace(/XGLOBSTARX/g, '.*').replace(/XSTARX/g, '[^/]*');
+  return new RegExp('^' + re + '$');
+}
+
+function loadDomains(jsonText) {
+  let parsed;
+  try {
+    parsed = JSON.parse(jsonText);
+  } catch (err) {
+    throw new Error(`Invalid JSON in ${DOMAINS_FILENAME}: ${err.message}`);
+  }
+  const domains = parsed?.domains;
+  if (!domains || typeof domains !== 'object' || Array.isArray(domains)) {
+    throw new Error(`${DOMAINS_FILENAME} must have a top-level "domains" object`);
+  }
+  // Compile globs once.
+  const out = [];
+  for (const [name, patterns] of Object.entries(domains)) {
+    if (!Array.isArray(patterns)) {
+      throw new Error(`Domain "${name}" must be an array of glob strings`);
+    }
+    out.push({ name, patterns, regexes: patterns.map(globToRegex) });
+  }
+  return out;
+}
+
+function classifyFile(filePath, domains) {
+  // First-match-wins, matching the user's mental model: explicit ordering
+  // in the config file controls which domain claims overlapping files.
+  for (const d of domains) {
+    for (const re of d.regexes) {
+      if (re.test(filePath)) return d.name;
+    }
+  }
+  return null;
+}
+
+/**
+ * For each file, find the community where it has the most defined
+ * symbols. Returns Map<filePath, { communityId, label, symbolCount }>.
+ *
+ * Files with no symbol-bearing children (e.g. README.md, mkdocs.yml)
+ * are absent from the map — we surface them in the "unclassified"
+ * bucket of the response.
+ */
+async function fetchFileCommunities(repoName, api) {
+  // The relationship is stored as a generic `CodeRelation` with a `type`
+  // property. We pull file + community + a count of symbols per file
+  // per community in one go, then pick the majority per file in JS.
+  const cypher = `
+    MATCH (f:File)-[:CodeRelation {type: 'DEFINES'}]->(s)
+          -[:CodeRelation {type: 'MEMBER_OF'}]->(c:Community)
+    RETURN f.filePath AS file, c.id AS community, c.heuristicLabel AS label, count(s) AS cnt
+  `;
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher, repo: repoName }),
+  });
+  if (!resp.ok) {
+    throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  }
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+
+  // Bucket by file, then pick the row with the highest cnt.
+  const perFile = new Map(); // file → [{community, label, cnt}, ...]
+  for (const row of rows) {
+    const file = row.file ?? row['f.filePath'];
+    const community = row.community ?? row['c.id'];
+    const label = row.label ?? row['c.heuristicLabel'] ?? null;
+    const cnt = Number(row.cnt ?? row['count(s)'] ?? 0);
+    if (typeof file !== 'string' || typeof community !== 'string') continue;
+    const arr = perFile.get(file) || [];
+    arr.push({ community, label, cnt });
+    perFile.set(file, arr);
+  }
+
+  const dominant = new Map();
+  for (const [file, arr] of perFile) {
+    arr.sort((a, b) => b.cnt - a.cnt);
+    const top = arr[0];
+    dominant.set(file, {
+      communityId: top.community,
+      label: top.label,
+      symbolCount: top.cnt,
+      // Confidence = winner share. 1 = unambiguous owner; 0.5 = split.
+      confidence: arr.reduce((s, x) => s + x.cnt, 0)
+        ? top.cnt / arr.reduce((s, x) => s + x.cnt, 0)
+        : 0,
+    });
+  }
+  return dominant;
+}
+
+async function handleDissonance(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+  const domainsPath = join(repoPath, DOMAINS_FILENAME);
+
+  let domainsText;
+  try {
+    domainsText = await readFile(domainsPath, 'utf8');
+  } catch (err) {
+    if (err && err.code === 'ENOENT') {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(
+        JSON.stringify({
+          error: `No ${DOMAINS_FILENAME} at ${repoPath}. Create one to enable dissonance analysis.`,
+          example: {
+            domains: {
+              auth: ['src/auth/**', 'src/middleware/auth*.py'],
+              data: ['src/db/**', 'src/models/**'],
+            },
+          },
+        }),
+      );
+      return;
+    }
+    throw err;
+  }
+
+  let domains;
+  try {
+    domains = loadDomains(domainsText);
+  } catch (err) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+    return;
+  }
+
+  // Get the file→community map. If gitnexus has no communities for this
+  // repo (e.g. it hasn't been analyzed with that phase), we still emit
+  // a sensible response with everything in "unclassified".
+  let fileToCommunity;
+  try {
+    fileToCommunity = await fetchFileCommunities(baseRepo, opts.api);
+  } catch (err) {
+    res.writeHead(502, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `community lookup failed: ${err.message}` }));
+    return;
+  }
+
+  // Collect all files involved (declared OR community-assigned). We need
+  // every file even if it has only a domain (so we can flag "domain
+  // declared but no symbols/community").
+  const allFiles = new Set();
+  for (const f of fileToCommunity.keys()) allFiles.add(f);
+  // For the declared side, we don't enumerate files — instead we apply
+  // globs against the set we already have. That keeps the response
+  // bounded to files gitnexus actually knows about.
+
+  // Per-file rows + contingency.
+  const rows = [];
+  const contingency = {}; // domain → { community → count }
+  const filesByDomain = {}; // domain → string[]
+  const filesByCommunity = {}; // communityId → string[]
+  let totalAttributed = 0;
+  let totalDomainAttributed = 0;
+
+  for (const file of allFiles) {
+    const domain = classifyFile(file, domains);
+    const comm = fileToCommunity.get(file) || null;
+    rows.push({
+      file,
+      domain: domain ?? null,
+      communityId: comm?.communityId ?? null,
+      communityLabel: comm?.label ?? null,
+      confidence: comm?.confidence ?? null,
+      symbolCount: comm?.symbolCount ?? 0,
+    });
+    if (domain && comm) {
+      contingency[domain] ??= {};
+      contingency[domain][comm.communityId] = (contingency[domain][comm.communityId] || 0) + 1;
+      filesByDomain[domain] ??= [];
+      filesByDomain[domain].push(file);
+      filesByCommunity[comm.communityId] ??= [];
+      filesByCommunity[comm.communityId].push(file);
+      totalAttributed++;
+    }
+    if (domain) totalDomainAttributed++;
+  }
+
+  // Per-domain majority community + purity contribution.
+  const perDomain = [];
+  let weightedPuritySum = 0;
+  for (const [domain, byComm] of Object.entries(contingency)) {
+    const total = Object.values(byComm).reduce((s, c) => s + c, 0);
+    const ranked = Object.entries(byComm)
+      .map(([cid, cnt]) => ({ communityId: cid, count: cnt, share: cnt / total }))
+      .sort((a, b) => b.count - a.count);
+    const dominant = ranked[0];
+    perDomain.push({
+      domain,
+      filesTotal: total,
+      dominantCommunity: dominant.communityId,
+      dominantShare: dominant.share,
+      communitiesTouched: ranked.length,
+      breakdown: ranked,
+    });
+    weightedPuritySum += dominant.count;
+  }
+  const purity = totalAttributed > 0 ? weightedPuritySum / totalAttributed : 0;
+
+  // Misplaced files: file is in a community that's not its domain's
+  // dominant community. Surfaces the concrete refactor candidates.
+  const dominantByDomain = Object.fromEntries(
+    perDomain.map((d) => [d.domain, d.dominantCommunity]),
+  );
+  const misplaced = [];
+  for (const r of rows) {
+    if (!r.domain || !r.communityId) continue;
+    const expected = dominantByDomain[r.domain];
+    if (expected && r.communityId !== expected) {
+      misplaced.push({
+        file: r.file,
+        domain: r.domain,
+        actualCommunity: r.communityId,
+        actualCommunityLabel: r.communityLabel,
+        expectedCommunity: expected,
+        confidence: r.confidence,
+      });
+    }
+  }
+  misplaced.sort((a, b) => a.domain.localeCompare(b.domain) || a.file.localeCompare(b.file));
+
+  // Files with a domain but no community signal (typical for configs /
+  // docs). Surfaced separately so users can decide between extending
+  // their domain definition vs ignoring them.
+  const domainWithoutCommunity = rows
+    .filter((r) => r.domain && !r.communityId)
+    .map((r) => ({ file: r.file, domain: r.domain }));
+
+  // CSV branch: long-format per-file rows.
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(rows, [
+      { key: 'file' },
+      { key: 'domain' },
+      { key: 'communityId' },
+      { key: 'communityLabel' },
+      { key: 'symbolCount' },
+      { key: 'confidence' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-dissonance.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      repo: baseRepo,
+      totals: {
+        filesKnown: allFiles.size,
+        filesWithDomain: totalDomainAttributed,
+        filesAttributed: totalAttributed, // both domain AND community
+        domainsDeclared: domains.length,
+        communitiesSeen: Object.keys(filesByCommunity).length,
+      },
+      purity,
+      dissonance: 1 - purity,
+      perDomain,
+      misplaced,
+      domainWithoutCommunity,
+      contingency,
+    }),
+  );
+}
+
+export async function handleDissonanceRoute(req, url, res, opts) {
+  if (url.pathname === '/dissonance' && req.method === 'GET') {
+    await handleDissonance(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-entropy.mjs b/docker-server-entropy.mjs
new file mode 100644
index 0000000..c57e279
--- /dev/null
+++ b/docker-server-entropy.mjs
@@ -0,0 +1,178 @@
+/**
+ * Structural entropy / health metrics — Tier 1.4 of the ROADMAP.
+ *
+ * Endpoint:
+ *   GET /entropy?repo=<baseRepoName>
+ *
+ * For each snapshot (+ live), exposes a small set of *interpretable*
+ * structural-health metrics extracted from the snapshot's own
+ * `.gitnexus/meta.json`. We deliberately avoid inventing a single
+ * "magic score" — the underlying numbers are simple, defensible, and
+ * the UI can derive a top-line indicator (density delta vs first
+ * snapshot) without us baking opinions into the wire format.
+ *
+ * Returned per point:
+ *   nodes        — total node count (gitnexus stat)
+ *   edges        — total edge count (gitnexus stat)
+ *   communities  — number of communities detected by gitnexus
+ *   density      — graph density = 2*edges / (nodes*(nodes-1)).
+ *                  Range [0, 1]. Real-world healthy projects are
+ *                  typically << 0.01; numbers approaching 0.1 hint at
+ *                  "everything-touches-everything" monolithic shape.
+ *   modularity   — communities / nodes. Higher = more autonomous units
+ *                  (services / packages); lower = monolith.
+ *   filesCount   — file count for cross-referencing growth charts
+ *
+ * Reading from meta.json keeps this endpoint cheap (~5ms total even
+ * for many snapshots) — we never touch the lbug database for these,
+ * so it doesn't trigger the per-path connection cache.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+function compute(stats) {
+  const nodes = Number(stats?.nodes) || 0;
+  const edges = Number(stats?.edges) || 0;
+  const communities = Number(stats?.communities) || 0;
+  const filesCount = Number(stats?.files) || 0;
+  // Density: undefined for graphs with <2 nodes (no possible edges).
+  // Reporting 0 in that edge case avoids special-casing in the UI.
+  const denom = nodes * (nodes - 1);
+  const density = denom > 0 ? (2 * edges) / denom : 0;
+  // Modularity ratio: 0 when no communities, else communities/nodes.
+  // Always in [0, 1] (can't have more communities than nodes).
+  const modularity = nodes > 0 ? communities / nodes : 0;
+  return { nodes, edges, communities, density, modularity, filesCount };
+}
+
+async function readMeta(storagePath) {
+  try {
+    return JSON.parse(await readFile(join(storagePath, 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+async function listSnapshotMetas(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    const snapshotDir = join(dir, e.name);
+    // commit.json gives us the date, meta.json gives us the stats.
+    let commit = null;
+    let meta = null;
+    try {
+      commit = JSON.parse(await readFile(join(snapshotDir, 'commit.json'), 'utf8'));
+    } catch {
+      continue; // half-built; skip
+    }
+    meta = await readMeta(join(snapshotDir, 'source', '.gitnexus'));
+    out.push({
+      name: `${repoName}@${e.name}`,
+      date: commit.date,
+      isLive: false,
+      stats: meta?.stats || {},
+    });
+  }
+  return out;
+}
+
+async function handleEntropy(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  // Live stats are right there in the registry response.
+  const liveStats = liveEntry.stats || {};
+  // Live entry needs its meta.json too if we want full parity with snapshots —
+  // the registry view is sometimes thinned. Best-effort fallback.
+  const liveMeta = await readMeta(
+    join('/data/projects', baseRepo, '.gitnexus'),
+  ).catch(() => null);
+  const livePoint = {
+    name: baseRepo,
+    date: liveEntry.indexedAt,
+    isLive: true,
+    stats: liveMeta?.stats || liveStats,
+  };
+
+  const snapshots = await listSnapshotMetas(baseRepo);
+  const points = [...snapshots, livePoint].sort((a, b) =>
+    (a.date || '').localeCompare(b.date || ''),
+  );
+
+  const timeline = points.map((p) => ({
+    name: p.name,
+    date: p.date,
+    isLive: p.isLive,
+    ...compute(p.stats),
+  }));
+
+  // Headline number: density of the most-recent point vs the first.
+  // > 1 = densifying (less modular over time); < 1 = simplifying.
+  const first = timeline[0];
+  const last = timeline[timeline.length - 1];
+  const densityTrend = first && first.density > 0 ? last.density / first.density : null;
+
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(timeline, [
+      { key: 'name', header: 'snapshotName' },
+      { key: 'date' },
+      { key: 'isLive' },
+      { key: 'nodes' },
+      { key: 'edges' },
+      { key: 'communities' },
+      { key: 'density' },
+      { key: 'modularity' },
+      { key: 'filesCount' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-entropy.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalPoints: timeline.length,
+      timeline,
+      headline: {
+        currentDensity: last?.density ?? 0,
+        currentModularity: last?.modularity ?? 0,
+        densityTrend,
+      },
+    }),
+  );
+}
+
+export async function handleEntropyRoute(req, url, res, opts) {
+  if (url.pathname === '/entropy' && req.method === 'GET') {
+    await handleEntropy(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-growth-cross.mjs b/docker-server-growth-cross.mjs
new file mode 100644
index 0000000..7db9b38
--- /dev/null
+++ b/docker-server-growth-cross.mjs
@@ -0,0 +1,243 @@
+/**
+ * Cross-repo growth — ROADMAP Tier 1.3.
+ *
+ * Endpoint:
+ *   GET /growth/cross?repos=A,B[,C][&format=csv]
+ *
+ * For each input repo, gather the same per-snapshot counts the
+ * single-repo /growth endpoint produces, then merge them onto a *union
+ * timeline* sorted by date. For each timeline point, every repo
+ * contributes the counts of its most-recent snapshot at or before that
+ * point — so the chart shows a step function per repo, and the user
+ * can see code mass shift between repos over time.
+ *
+ * Use cases:
+ *   - Monolith → microservices migration: total counts in monolith
+ *     plateau or decrease while new-service counts climb.
+ *   - Cross-team workload: which repo carried the most new code in
+ *     the last quarter.
+ *   - Documentation drift: docs-repo growth vs source-repo growth.
+ *
+ * Implementation notes:
+ *   - Per-repo counts come from each snapshot's `meta.json` (cheap, no
+ *     lbug touch) — same pattern as /entropy. This means we never
+ *     contend for the lbug cache, so multi-repo scans stay parallel-safe.
+ *   - Union-timeline interpolation uses a stable "use the most recent
+ *     known counts" rule. Before a repo's first snapshot it contributes
+ *     zeros across every label. The frontend stacks those into a chart
+ *     that naturally tells the migration story.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const MAX_REPOS = 8;
+
+async function readMeta(storagePath) {
+  try {
+    return JSON.parse(await readFile(join(storagePath, 'meta.json'), 'utf8'));
+  } catch {
+    return null;
+  }
+}
+
+async function listSnapshotMetas(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    const snapshotDir = join(dir, e.name);
+    let commit = null;
+    try {
+      commit = JSON.parse(await readFile(join(snapshotDir, 'commit.json'), 'utf8'));
+    } catch {
+      continue;
+    }
+    const meta = await readMeta(join(snapshotDir, 'source', '.gitnexus'));
+    out.push({
+      name: `${repoName}@${e.name}`,
+      date: commit.date,
+      isLive: false,
+      stats: meta?.stats || {},
+    });
+  }
+  return out;
+}
+
+async function gatherRepoTimeline(repoName, api) {
+  const liveEntry = await findRepoByName(repoName, api);
+  if (!liveEntry) return null;
+  const liveStats = liveEntry.stats || {};
+  const liveMeta = await readMeta(
+    join('/data/projects', repoName, '.gitnexus'),
+  ).catch(() => null);
+  const livePoint = {
+    name: repoName,
+    date: liveEntry.indexedAt,
+    isLive: true,
+    stats: liveMeta?.stats || liveStats,
+  };
+  const snapshots = await listSnapshotMetas(repoName);
+  return [...snapshots, livePoint].sort((a, b) =>
+    (a.date || '').localeCompare(b.date || ''),
+  );
+}
+
+// Convert one snapshot's raw `meta.stats` into a counts-by-category map
+// shaped like the single-repo /growth endpoint. The mapping mirrors
+// gitnexus stat keys → label names so frontends can share the same
+// color palette across both endpoints.
+function statsToCounts(stats) {
+  const counts = {};
+  if (!stats || typeof stats !== 'object') return counts;
+  for (const [k, v] of Object.entries(stats)) {
+    if (typeof v !== 'number') continue;
+    // Keep gitnexus naming: "nodes", "edges", "files", "communities",
+    // "processes", "embeddings" stay as-is so the frontend's existing
+    // labels-vs-counts logic still works.
+    counts[k] = v;
+  }
+  return counts;
+}
+
+async function handleGrowthCross(url, res, opts) {
+  const reposParam = url.searchParams.get('repos');
+  if (!reposParam) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repos (comma-separated)' }));
+    return;
+  }
+  const repoNames = reposParam
+    .split(',')
+    .map((s) => s.trim())
+    .filter(Boolean)
+    .filter((s) => !s.includes('@'))
+    .slice(0, MAX_REPOS);
+  if (repoNames.length < 2) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'need at least 2 distinct repos' }));
+    return;
+  }
+
+  const perRepoTimelines = {};
+  for (const name of repoNames) {
+    const tl = await gatherRepoTimeline(name, opts.api);
+    if (!tl) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${name}` }));
+      return;
+    }
+    perRepoTimelines[name] = tl;
+  }
+
+  // Union timeline: every distinct date from any repo, sorted ascending.
+  // Using a Set keyed by ISO string is enough — collisions are rare and
+  // would only deduplicate truly-simultaneous events.
+  const dateSet = new Set();
+  for (const tl of Object.values(perRepoTimelines)) {
+    for (const p of tl) dateSet.add(p.date || '');
+  }
+  const dates = [...dateSet].filter(Boolean).sort();
+  if (dates.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        repos: repoNames,
+        timeline: [],
+        labels: [],
+        warning: 'Need at least 2 timeline points across the selected repos.',
+      }),
+    );
+    return;
+  }
+
+  // Per-repo cursor walk: for each timeline date, take each repo's most
+  // recent snapshot at-or-before that date. Linear in (dates × repos).
+  const cursors = Object.fromEntries(repoNames.map((n) => [n, 0]));
+  const lastKnown = Object.fromEntries(repoNames.map((n) => [n, null]));
+  const labelsSet = new Set();
+  const enriched = [];
+
+  for (const date of dates) {
+    for (const name of repoNames) {
+      const tl = perRepoTimelines[name];
+      while (cursors[name] < tl.length && (tl[cursors[name]].date || '') <= date) {
+        lastKnown[name] = tl[cursors[name]];
+        cursors[name]++;
+      }
+    }
+    const byRepo = {};
+    for (const name of repoNames) {
+      const point = lastKnown[name];
+      const counts = point ? statsToCounts(point.stats) : {};
+      for (const k of Object.keys(counts)) labelsSet.add(k);
+      byRepo[name] = counts;
+    }
+    enriched.push({ date, byRepo });
+  }
+
+  // Sort labels by max count across all repos, all points — same
+  // convention as /growth so the color palette is stable.
+  const maxPerLabel = {};
+  for (const point of enriched) {
+    for (const name of repoNames) {
+      const counts = point.byRepo[name];
+      for (const [lbl, c] of Object.entries(counts)) {
+        if (!maxPerLabel[lbl] || c > maxPerLabel[lbl]) maxPerLabel[lbl] = c;
+      }
+    }
+  }
+  const labels = Object.keys(maxPerLabel).sort((a, b) => maxPerLabel[b] - maxPerLabel[a]);
+
+  if (url.searchParams.get('format') === 'csv') {
+    // Long-format: (date, repo, label, count) — easier to pivot in
+    // pandas than a wide table per repo.
+    const rows = [];
+    for (const point of enriched) {
+      for (const name of repoNames) {
+        const counts = point.byRepo[name];
+        for (const lbl of labels) {
+          rows.push({ date: point.date, repo: name, label: lbl, count: counts[lbl] || 0 });
+        }
+      }
+    }
+    const csv = toCsv(rows, [
+      { key: 'date' },
+      { key: 'repo' },
+      { key: 'label' },
+      { key: 'count' },
+    ]);
+    writeCsv(res, `${safeFilename(repoNames.join('-vs-'))}-growth-cross.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      repos: repoNames,
+      timeline: enriched,
+      labels,
+    }),
+  );
+}
+
+export async function handleGrowthCrossRoute(req, url, res, opts) {
+  if (url.pathname === '/growth/cross' && req.method === 'GET') {
+    await handleGrowthCross(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-growth.mjs b/docker-server-growth.mjs
new file mode 100644
index 0000000..4e22daa
--- /dev/null
+++ b/docker-server-growth.mjs
@@ -0,0 +1,185 @@
+/**
+ * Growth-by-category analytics — Phase 4D.
+ *
+ * Endpoint:
+ *   GET /growth?repo=<baseRepoName>
+ *
+ * For each snapshot of <baseRepoName> (plus the live entry), counts nodes
+ * by their label (File, Function, Class, Method, Section, Variable, …).
+ * The label is extracted from the node id's first segment — gitnexus ids
+ * follow `<Label>:<rest>`, so a single Cypher `MATCH (n) RETURN n.id`
+ * round-trip per snapshot is enough; we never need to enumerate labels
+ * upfront.
+ *
+ * Response:
+ *   {
+ *     timeline: [
+ *       { name, date, isLive, counts: { File: 123, Function: 456, ... } },
+ *       ...
+ *     ],
+ *     labels: ['File', 'Function', ...]   // sorted desc by max count, so
+ *                                          // the most-impactful categories
+ *                                          // get the brightest colors in
+ *                                          // the chart legend by default
+ *   }
+ *
+ * Sequential snapshot iteration (same lbug-cache reasoning as /churn and
+ * /coupling): parallel access would thrash gitnexus's per-path connection
+ * pool.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+async function listSnapshotNamesAndDates(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built snapshot; skip
+    }
+  }
+  return out;
+}
+
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+function labelOf(id) {
+  // <Label>:<...> for nearly all ids; the few synthetic ones without a
+  // colon ("comm_5", "proc_1") get bucketed under "Other" so they don't
+  // disappear from the chart.
+  if (!id.includes(':')) return 'Other';
+  return id.slice(0, id.indexOf(':')) || 'Other';
+}
+
+async function handleGrowth(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ].sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  if (timeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        timeline: timeline.map((t) => ({ ...t, counts: {} })),
+        labels: [],
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) for a meaningful growth view.',
+      }),
+    );
+    return;
+  }
+
+  // Walk timeline, accumulate per-label counts and a global max-per-label
+  // (used to sort the label list so the most prominent categories drive
+  // the chart's color palette ordering).
+  const errors = [];
+  const maxPerLabel = Object.create(null);
+  const enriched = [];
+  for (const point of timeline) {
+    let counts = {};
+    try {
+      const ids = await fetchNodeIds(point.name, opts.api);
+      for (const id of ids) {
+        const lbl = labelOf(id);
+        counts[lbl] = (counts[lbl] || 0) + 1;
+      }
+    } catch (err) {
+      errors.push({ snapshot: point.name, error: err?.message || 'fetch failed' });
+    }
+    for (const [lbl, c] of Object.entries(counts)) {
+      if (!maxPerLabel[lbl] || c > maxPerLabel[lbl]) maxPerLabel[lbl] = c;
+    }
+    enriched.push({ ...point, counts });
+  }
+
+  const labels = Object.keys(maxPerLabel).sort((a, b) => maxPerLabel[b] - maxPerLabel[a]);
+
+  // CSV emits long-format rows: (snapshot, label, count) — easier to
+  // pivot in pandas/Excel than a wide table with one column per label.
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = [];
+    for (const point of enriched) {
+      for (const lbl of labels) {
+        rows.push({
+          snapshotName: point.name,
+          date: point.date,
+          isLive: point.isLive,
+          label: lbl,
+          count: point.counts[lbl] || 0,
+        });
+      }
+    }
+    const csv = toCsv(rows, [
+      { key: 'snapshotName' },
+      { key: 'date' },
+      { key: 'isLive' },
+      { key: 'label' },
+      { key: 'count' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-growth.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      timeline: enriched,
+      labels,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+export async function handleGrowthRoute(req, url, res, opts) {
+  if (url.pathname === '/growth' && req.method === 'GET') {
+    await handleGrowth(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-lifespan.mjs b/docker-server-lifespan.mjs
new file mode 100644
index 0000000..f05ff52
--- /dev/null
+++ b/docker-server-lifespan.mjs
@@ -0,0 +1,258 @@
+/**
+ * Lifespan analytics — Phase 4C.
+ *
+ * Endpoint:
+ *   GET /lifespan?repo=<baseRepoName>
+ *
+ * For every node id ever seen across the snapshot timeline (+ live), we
+ * compute the index of its first and last appearance, then bucket it:
+ *
+ *   - foundational : present in the very first snapshot AND in live (it's
+ *                    the load-bearing skeleton that survived all changes).
+ *   - recent       : appeared after the first snapshot, still in live
+ *                    (innovations that stuck).
+ *   - discontinued : present at some point, but gone in live (deleted /
+ *                    refactored away).
+ *   - ephemeral    : appeared after the first snapshot AND gone before
+ *                    live (tried, didn't survive).
+ *
+ * For the user's "reverse-engineering / find patterns that worked" use
+ * case, `foundational` and `recent` are the survivors (= proven), while
+ * `discontinued` and `ephemeral` are the cautionary tales (= patterns
+ * that were tried but didn't stick).
+ *
+ * Response:
+ *   {
+ *     totalPoints: number,
+ *     timeline: [{ name, date, isLive }],
+ *     counts: { foundational, recent, discontinued, ephemeral },
+ *     nodes: {
+ *       foundational: [{ id, label, name, path }],
+ *       recent:       [{ id, label, name, path, firstSeen, firstSeenDate }],
+ *       discontinued: [{ id, label, name, path, lastSeen, lastSeenDate }],
+ *       ephemeral:    [{ id, label, name, path, firstSeen, lastSeen, firstSeenDate, lastSeenDate }],
+ *     }
+ *   }
+ *
+ * Each bucket is capped at 1000 entries (sorted by file path) so a giant
+ * repo doesn't ship a 50 MB JSON to the browser. The frontend already
+ * shows counts so the user knows the bucket may be truncated.
+ *
+ * Same sequential snapshot iteration as the other analytics endpoints —
+ * avoids thrashing gitnexus's per-path lbug cache.
+ */
+
+import { join } from 'node:path';
+import { readdir, readFile } from 'node:fs/promises';
+import {
+  findRepoByName,
+  SNAPSHOTS_ROOT,
+  safeSnapshotKey,
+} from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const MAX_NODES_PER_BUCKET = 1000;
+
+async function listSnapshotNamesAndDates(repoName) {
+  const dir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(dir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(await readFile(join(dir, e.name, 'commit.json'), 'utf8'));
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built; skip
+    }
+  }
+  return out;
+}
+
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+// Parse the display fields out of a node id. gitnexus ids follow a few
+// shapes; we extract:
+//   label  → the leading segment ("File", "Function", "Section", ...)
+//   path   → the file path that owns the node, if there is one
+//   name   → the symbol's display name (function/class/section name)
+// Returns minimal info even when the id is non-standard (e.g. "comm_5").
+function parseId(id) {
+  if (!id.includes(':')) return { label: 'Other', path: '', name: id };
+  const parts = id.split(':');
+  const label = parts[0];
+  if (parts.length === 1) return { label, path: '', name: '' };
+  // For File / Folder nodes, the whole rest is the path.
+  if (label === 'File' || label === 'Folder' || label === 'Repository') {
+    return { label, path: parts.slice(1).join(':'), name: parts[parts.length - 1] };
+  }
+  // For everything else (Function, Class, Method, Section, Variable…),
+  // index 1 is the file path and the rest is the symbol identifier.
+  const path = parts[1];
+  const name = parts.slice(2).join(':') || parts[1];
+  return { label, path, name };
+}
+
+async function handleLifespan(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ].sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  if (timeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        totalPoints: timeline.length,
+        timeline,
+        counts: { foundational: 0, recent: 0, discontinued: 0, ephemeral: 0 },
+        nodes: { foundational: [], recent: [], discontinued: [], ephemeral: [] },
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) to compute lifespan.',
+      }),
+    );
+    return;
+  }
+
+  // Walk timeline once, recording per-id (first, last) indices.
+  const perId = new Map(); // id → { first, last }
+  const errors = [];
+  for (let i = 0; i < timeline.length; i++) {
+    let ids;
+    try {
+      ids = await fetchNodeIds(timeline[i].name, opts.api);
+    } catch (err) {
+      errors.push({ snapshot: timeline[i].name, error: err?.message || 'fetch failed' });
+      continue;
+    }
+    for (const id of ids) {
+      const cur = perId.get(id);
+      if (cur === undefined) perId.set(id, { first: i, last: i });
+      else cur.last = i;
+    }
+  }
+
+  const lastIdx = timeline.length - 1;
+  const buckets = { foundational: [], recent: [], discontinued: [], ephemeral: [] };
+
+  for (const [id, span] of perId) {
+    const parsed = parseId(id);
+    const presentInLive = span.last === lastIdx;
+    const presentAtStart = span.first === 0;
+    let bucket;
+    if (presentAtStart && presentInLive) bucket = 'foundational';
+    else if (!presentAtStart && presentInLive) bucket = 'recent';
+    else if (presentAtStart && !presentInLive) bucket = 'discontinued';
+    else bucket = 'ephemeral';
+
+    const entry = { id, ...parsed };
+    if (bucket === 'recent' || bucket === 'ephemeral') {
+      entry.firstSeen = span.first;
+      entry.firstSeenDate = timeline[span.first]?.date;
+    }
+    if (bucket === 'discontinued' || bucket === 'ephemeral') {
+      entry.lastSeen = span.last;
+      entry.lastSeenDate = timeline[span.last]?.date;
+    }
+    buckets[bucket].push(entry);
+  }
+
+  // Sort each bucket by path then name for a stable, scannable order.
+  // Then truncate to the per-bucket cap.
+  const counts = { foundational: 0, recent: 0, discontinued: 0, ephemeral: 0 };
+  for (const k of Object.keys(buckets)) {
+    counts[k] = buckets[k].length;
+    buckets[k].sort((a, b) => {
+      const p = (a.path || '').localeCompare(b.path || '');
+      if (p !== 0) return p;
+      return (a.name || '').localeCompare(b.name || '');
+    });
+    if (buckets[k].length > MAX_NODES_PER_BUCKET) {
+      buckets[k] = buckets[k].slice(0, MAX_NODES_PER_BUCKET);
+    }
+  }
+
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = [];
+    for (const bucket of Object.keys(buckets)) {
+      for (const n of buckets[bucket]) {
+        rows.push({
+          bucket,
+          id: n.id,
+          label: n.label,
+          name: n.name,
+          path: n.path,
+          firstSeen: n.firstSeen ?? '',
+          firstSeenDate: n.firstSeenDate ?? '',
+          lastSeen: n.lastSeen ?? '',
+          lastSeenDate: n.lastSeenDate ?? '',
+        });
+      }
+    }
+    const csv = toCsv(rows, [
+      { key: 'bucket' },
+      { key: 'id' },
+      { key: 'label' },
+      { key: 'name' },
+      { key: 'path' },
+      { key: 'firstSeen' },
+      { key: 'firstSeenDate' },
+      { key: 'lastSeen' },
+      { key: 'lastSeenDate' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-lifespan.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalPoints: timeline.length,
+      timeline,
+      counts,
+      nodes: buckets,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+export async function handleLifespanRoute(req, url, res, opts) {
+  if (url.pathname === '/lifespan' && req.method === 'GET') {
+    await handleLifespan(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-ownership.mjs b/docker-server-ownership.mjs
new file mode 100644
index 0000000..b9a666a
--- /dev/null
+++ b/docker-server-ownership.mjs
@@ -0,0 +1,226 @@
+/**
+ * Ownership / bus-factor analytics — ROADMAP Tier 1.1.
+ *
+ * Endpoint:
+ *   GET /ownership?repo=<baseRepoName>[&format=csv]
+ *
+ * Walks the *live* git history (a single `git log --name-only` call —
+ * O(commits), much cheaper than running `git blame` per file) and
+ * aggregates, per file:
+ *
+ *   - totalCommits  number of non-merge commits that touched the file
+ *   - authors       top contributors by commit share (max 5)
+ *   - busFactor     smallest N authors whose commits cover ≥ BUS_FACTOR_PCT
+ *                   of the file's history. busFactor=1 means one person
+ *                   owns the file's history — fragile.
+ *
+ * We use commit counts (not blame'd line counts) for cost reasons:
+ * blame is per-file, per-line, on a working-tree clone, while
+ * `git log --name-only` returns everything in one pass. The semantic
+ * difference matters at the edges (someone who wrote a lot but
+ * disappeared shows up in blame but not in recent log activity), but
+ * for the "who owns this code today" question the log-based view is
+ * usually the right one.
+ *
+ * Response (JSON):
+ *   {
+ *     totalFiles: number,
+ *     authorsCount: number,           // distinct authors across the repo
+ *     busFactorThreshold: number,     // the % used to compute busFactor
+ *     files: [{ path, totalCommits, busFactor, authors: [...] }],   // sorted
+ *                                                                    // by busFactor asc, then totalCommits desc
+ *                                                                    // (most fragile + most active first)
+ *     repoBusFactor: number,          // bus factor of the repo as a whole
+ *     repoAuthors: [{ name, commits, share }]
+ *   }
+ */
+
+import { join } from 'node:path';
+import { stat } from 'node:fs/promises';
+import { spawn } from 'node:child_process';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const BUS_FACTOR_PCT = 0.8;
+const TOP_AUTHORS_PER_FILE = 5;
+const MAX_FILES = 2000; // cap response size
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+/**
+ * Parse `git log --pretty=format:%an --name-only --no-merges` output.
+ * Format alternates:
+ *   <author>\n
+ *   <file1>\n
+ *   <file2>\n
+ *   \n  (blank between commits)
+ * Returns Map<filePath, Map<author, commitCount>>.
+ */
+function parseLog(stdout) {
+  const filesByAuthor = new Map();
+  let currentAuthor = null;
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      currentAuthor = null;
+      continue;
+    }
+    if (currentAuthor === null) {
+      currentAuthor = line;
+      continue;
+    }
+    const filePath = line;
+    let m = filesByAuthor.get(filePath);
+    if (!m) {
+      m = new Map();
+      filesByAuthor.set(filePath, m);
+    }
+    m.set(currentAuthor, (m.get(currentAuthor) || 0) + 1);
+  }
+  return filesByAuthor;
+}
+
+function busFactorFromAuthors(authorMap) {
+  const sorted = [...authorMap.entries()].sort((a, b) => b[1] - a[1]);
+  const total = sorted.reduce((sum, [, c]) => sum + c, 0);
+  if (total === 0) return { busFactor: 0, authors: [], totalCommits: 0 };
+  let cum = 0;
+  let bf = 0;
+  for (const [, count] of sorted) {
+    bf++;
+    cum += count;
+    if (cum / total >= BUS_FACTOR_PCT) break;
+  }
+  return {
+    busFactor: bf,
+    totalCommits: total,
+    authors: sorted.slice(0, TOP_AUTHORS_PER_FILE).map(([name, commits]) => ({
+      name,
+      commits,
+      share: commits / total,
+    })),
+  };
+}
+
+async function handleOwnership(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+  if (!(await stat(join(repoPath, '.git')).catch(() => null))) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        error: `repo at ${repoPath} is not a git repository — ownership requires git history`,
+      }),
+    );
+    return;
+  }
+
+  let logOut;
+  try {
+    logOut = await runCmd('git', [
+      '-C',
+      repoPath,
+      'log',
+      '--pretty=format:%an',
+      '--name-only',
+      '--no-merges',
+    ]);
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `git log failed: ${err.message}` }));
+    return;
+  }
+
+  const filesByAuthor = parseLog(logOut);
+
+  // Per-file bus factor.
+  const fileRows = [];
+  const overallAuthors = new Map();
+  for (const [path, authorMap] of filesByAuthor) {
+    const summary = busFactorFromAuthors(authorMap);
+    fileRows.push({ path, ...summary });
+    for (const [name, count] of authorMap) {
+      overallAuthors.set(name, (overallAuthors.get(name) || 0) + count);
+    }
+  }
+  // Sort: most fragile (low bus factor) first, then most active (commits desc).
+  // That puts "you only have one expert on a hot file" at the top of the list,
+  // which is the exact thing the user wants to see.
+  fileRows.sort((a, b) => a.busFactor - b.busFactor || b.totalCommits - a.totalCommits);
+
+  // Repo-level bus factor: smallest N authors covering 80% of all commits.
+  const repoSummary = busFactorFromAuthors(overallAuthors);
+
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = fileRows.slice(0, MAX_FILES).map((f) => ({
+      path: f.path,
+      busFactor: f.busFactor,
+      totalCommits: f.totalCommits,
+      topAuthor: f.authors[0]?.name || '',
+      topAuthorShare: f.authors[0]?.share ?? 0,
+      secondAuthor: f.authors[1]?.name || '',
+      secondAuthorShare: f.authors[1]?.share ?? 0,
+      thirdAuthor: f.authors[2]?.name || '',
+      thirdAuthorShare: f.authors[2]?.share ?? 0,
+    }));
+    const csv = toCsv(rows, [
+      { key: 'path' },
+      { key: 'busFactor' },
+      { key: 'totalCommits' },
+      { key: 'topAuthor' },
+      { key: 'topAuthorShare' },
+      { key: 'secondAuthor' },
+      { key: 'secondAuthorShare' },
+      { key: 'thirdAuthor' },
+      { key: 'thirdAuthorShare' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-ownership.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalFiles: fileRows.length,
+      authorsCount: overallAuthors.size,
+      busFactorThreshold: BUS_FACTOR_PCT,
+      files: fileRows.slice(0, MAX_FILES),
+      repoBusFactor: repoSummary.busFactor,
+      repoAuthors: repoSummary.authors,
+      truncated: fileRows.length > MAX_FILES ? fileRows.length : undefined,
+    }),
+  );
+}
+
+export async function handleOwnershipRoute(req, url, res, opts) {
+  if (url.pathname === '/ownership' && req.method === 'GET') {
+    await handleOwnership(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-semantic-labels.mjs b/docker-server-semantic-labels.mjs
new file mode 100644
index 0000000..254682a
--- /dev/null
+++ b/docker-server-semantic-labels.mjs
@@ -0,0 +1,191 @@
+/**
+ * Semantic-labels cache — ROADMAP Tier 2.1, server side.
+ *
+ * Endpoints:
+ *   GET  /semantic-labels?repo=<base>
+ *        Reads the on-disk cache and returns it, or an empty payload
+ *        if no labels have been generated yet. Cheap and idempotent.
+ *
+ *   POST /semantic-labels?repo=<base>   body: { labels: {…}, provider?, model? }
+ *        Merges the incoming labels into the cache, last-write-wins
+ *        per communityId. We persist a tiny audit trail (when, with
+ *        which provider/model) so a future "regenerate stale labels"
+ *        feature can decide what's old.
+ *
+ * The LLM call itself is done by the *frontend* (`semantic-labeler.ts`),
+ * because the user already has provider credentials configured for the
+ * chat panel — no point asking them to re-enter API keys server-side
+ * or wiring per-provider clients here. This module just owns the cache.
+ *
+ * Cache file: <repoPath>/.gitnexus/semantic-labels.json
+ *
+ *   {
+ *     "schemaVersion": 1,
+ *     "labels": {
+ *       "community-id-1": {
+ *         "label": "Authentication",
+ *         "confidence": 0.85,
+ *         "evidenceNodes": ["src/auth/login.py:login", ...],
+ *         "labeledAt": "2026-05-22T10:00:00.000Z",
+ *         "provider": "anthropic",
+ *         "model": "claude-sonnet-4-20250514"
+ *       },
+ *       ...
+ *     }
+ *   }
+ */
+
+import { readFile, writeFile, mkdir } from 'node:fs/promises';
+import { join, dirname } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+
+const CACHE_FILENAME = 'semantic-labels.json';
+const SCHEMA_VERSION = 1;
+
+async function loadCache(cachePath) {
+  try {
+    const raw = await readFile(cachePath, 'utf8');
+    const parsed = JSON.parse(raw);
+    if (parsed?.schemaVersion === SCHEMA_VERSION && parsed?.labels && typeof parsed.labels === 'object') {
+      return parsed;
+    }
+    // Future-proofing: if the schema bumps, we won't error — we'll just
+    // start fresh rather than serve incompatible data.
+    return { schemaVersion: SCHEMA_VERSION, labels: {} };
+  } catch (err) {
+    if (err && err.code === 'ENOENT') {
+      return { schemaVersion: SCHEMA_VERSION, labels: {} };
+    }
+    throw err;
+  }
+}
+
+async function saveCache(cachePath, cache) {
+  await mkdir(dirname(cachePath), { recursive: true });
+  await writeFile(cachePath, JSON.stringify(cache, null, 2), 'utf8');
+}
+
+async function handleGet(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+  const repoPath = repo.repoPath || repo.path;
+  const cachePath = join(repoPath, '.gitnexus', CACHE_FILENAME);
+  const cache = await loadCache(cachePath);
+  res.writeHead(200, { 'Content-Type': 'application/json', 'Cache-Control': 'no-store' });
+  res.end(JSON.stringify({ repo: baseRepo, ...cache }));
+}
+
+async function handlePost(url, req, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const repo = await findRepoByName(baseRepo, opts.api);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  // Read JSON body (small — at most a few KB per repo's worth of labels).
+  let body = '';
+  for await (const chunk of req) body += chunk;
+  let payload;
+  try {
+    payload = body ? JSON.parse(body) : {};
+  } catch (err) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `invalid JSON: ${err.message}` }));
+    return;
+  }
+  const incoming = payload?.labels;
+  if (!incoming || typeof incoming !== 'object' || Array.isArray(incoming)) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'body.labels must be an object {communityId: {...}}' }));
+    return;
+  }
+  const provider = typeof payload.provider === 'string' ? payload.provider : 'unknown';
+  const model = typeof payload.model === 'string' ? payload.model : 'unknown';
+  const now = new Date().toISOString();
+
+  const repoPath = repo.repoPath || repo.path;
+  const cachePath = join(repoPath, '.gitnexus', CACHE_FILENAME);
+  const cache = await loadCache(cachePath);
+
+  // Validate each entry, drop garbage rather than corrupting the cache.
+  let merged = 0;
+  for (const [communityId, entry] of Object.entries(incoming)) {
+    if (typeof communityId !== 'string' || communityId.length > 200) continue;
+    if (!entry || typeof entry !== 'object') continue;
+    const label = typeof entry.label === 'string' && entry.label.trim().length > 0
+      ? entry.label.trim().slice(0, 80)
+      : null;
+    if (!label) continue;
+    const confidence = typeof entry.confidence === 'number' && entry.confidence >= 0 && entry.confidence <= 1
+      ? entry.confidence
+      : 0.5;
+    const evidenceNodes = Array.isArray(entry.evidenceNodes)
+      ? entry.evidenceNodes.filter((s) => typeof s === 'string').slice(0, 20)
+      : [];
+    // Tier 2.5b.bis: accept optional embedding vector + provenance.
+    // We tolerate the absence of these (cache entries without embeddings
+    // are still valid — they just won't contribute to centroid cosine
+    // in /similarity). When present we sanity-check it's a numeric array
+    // of reasonable length (truncate at 4096 dims — current largest
+    // commodity model is 3072).
+    let embedding;
+    let embeddingProvider;
+    let embeddingModel;
+    if (Array.isArray(entry.embedding)) {
+      const cleaned = entry.embedding
+        .filter((n) => typeof n === 'number' && Number.isFinite(n))
+        .slice(0, 4096);
+      if (cleaned.length > 0) {
+        embedding = cleaned;
+        embeddingProvider = typeof entry.embeddingProvider === 'string' ? entry.embeddingProvider : provider;
+        embeddingModel = typeof entry.embeddingModel === 'string' ? entry.embeddingModel : model;
+      }
+    }
+    cache.labels[communityId] = {
+      label,
+      confidence,
+      evidenceNodes,
+      labeledAt: now,
+      provider,
+      model,
+      ...(embedding ? { embedding, embeddingProvider, embeddingModel } : {}),
+    };
+    merged++;
+  }
+
+  await saveCache(cachePath, cache);
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ok: true, merged, total: Object.keys(cache.labels).length }));
+}
+
+export async function handleSemanticLabelsRoute(req, url, res, opts) {
+  if (url.pathname !== '/semantic-labels') return false;
+  if (req.method === 'GET') {
+    await handleGet(url, res, opts);
+    return true;
+  }
+  if (req.method === 'POST') {
+    await handlePost(url, req, res, opts);
+    return true;
+  }
+  return false;
+}
