+    }
+    case 'ollama': {
+      const c = config as OllamaConfig;
+      return new OllamaEmbeddings({
+        baseUrl: c.baseUrl ?? DEFAULT_OLLAMA_BASE_URL,
+        model: DEFAULT_EMBEDDING_MODELS.ollama,
+      });
+    }
+    // No native embeddings: Anthropic, OpenRouter, MiniMax, GLM.
+    // Caller falls back to lexical similarity.
