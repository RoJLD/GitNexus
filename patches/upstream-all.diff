+        <div className="absolute top-1/2 right-0 left-0 h-px -translate-y-1/2 bg-border-default" />
+        {points.map((p, i) => {
+          const isActive = i === activeIdx;
+          return (
+            <button
+              key={p.name}
+              type="button"
+              onClick={() => {
+                if (p.name !== projectName) switchRepo(p.name);
+              }}
+              style={{ left: `${positionFor(i)}%` }}
+              className={`absolute top-1/2 -translate-x-1/2 -translate-y-1/2 cursor-pointer rounded-full transition-all ${
+                isActive
+                  ? 'h-3.5 w-3.5 ring-2 ring-accent ring-offset-2 ring-offset-deep'
+                  : 'h-2.5 w-2.5 hover:scale-150'
+              } ${
+                p.isLive
+                  ? 'bg-emerald-500'
+                  : isActive
+                    ? 'bg-accent'
+                    : 'bg-accent/60 hover:bg-accent'
+              }`}
+              title={
+                p.isLive
+                  ? `Live • current working tree\n${new Date(p.date).toLocaleString()}`
+                  : `${p.shortHash} • ${p.message}\n${p.author ? p.author + ' • ' : ''}${new Date(p.date).toLocaleString()}`
+              }
+            >
+              {/* Camera icon overlay for snapshot dots (so live vs snapshot is glanceable) */}
+              {isActive && !p.isLive && (
+                <Camera className="absolute top-1/2 left-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 text-white" />
+              )}
+            </button>
+          );
+        })}
+      </div>
+
+      {/* Right side: short summary of the active point */}
+      {activeIdx >= 0 && (
+        <div className="flex shrink-0 items-center gap-2 text-xs">
+          {points[activeIdx].isLive ? (
+            <span className="rounded bg-emerald-500/15 px-1.5 py-0.5 font-mono text-[10px] font-semibold text-emerald-400">
+              LIVE
+            </span>
+          ) : (
+            <span className="rounded bg-accent/15 px-1.5 py-0.5 font-mono text-[10px] font-semibold text-accent">
+              {points[activeIdx].shortHash}
+            </span>
+          )}
+          <span className="max-w-[280px] truncate text-text-secondary">
+            {points[activeIdx].message}
+          </span>
+        </div>
+      )}
+    </div>
+  );
+};
diff --git a/gitnexus-web/src/components/WhatIfPanel.tsx b/gitnexus-web/src/components/WhatIfPanel.tsx
new file mode 100644
index 0000000..a370295
--- /dev/null
+++ b/gitnexus-web/src/components/WhatIfPanel.tsx
@@ -0,0 +1,348 @@
+import { useState } from 'react';
+import {
+  X,
+  FlaskConical,
+  Sparkles,
+  Trash2,
+  Play,
+  AlertCircle,
+  ChevronRight,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+import type { Mutation } from '../services/mutation-engine';
+
+/**
+ * What-if simulator panel — Tier 2.3.
+ *
+ * The user builds an ordered list of structural mutations (rename
+ * symbol, move file, delete file/node). Click "Preview" to project
+ * them onto the live graph — the canvas re-renders with the diff
+ * coloring (red = removed by mutation, green = added).
+ *
+ * No mutation is ever written to disk; everything happens in-memory
+ * on a clone of the loaded graph. "Exit" restores the original.
+ *
+ * Position: top-right, same slot as Coupling/Ownership/Dissonance,
+ * enforced via Timeline toggle. Different *concern* than the others
+ * (interactive form vs read-only metric) so we keep it self-contained
+ * in its own component rather than reusing CouplingPanel's chrome.
+ */
+
+const PANEL_WIDTH_PX = 400;
+
+type MutationKind = Mutation['kind'];
+
+const KIND_META: Record<MutationKind, { label: string; help: string }> = {
+  rename: {
+    label: 'Rename symbol',
+    help: 'Find every node named "oldName" and rewrite it to "newName". Edges follow.',
+  },
+  move: {
+    label: 'Move file/folder',
+    help: 'Substitute the leading path of every node attributed to oldPath.',
+  },
+  delete: {
+    label: 'Delete node or file',
+    help: 'Remove a node id, or cascade-remove every node attributed to a file path.',
+  },
+};
+
+export const WhatIfPanel = () => {
+  const {
+    whatIfPanelOpen,
+    whatIfActive,
+    whatIfMutations,
+    whatIfError,
+    setWhatIfMutations,
+    enterWhatIfMode,
+    exitWhatIfMode,
+    diffData,
+  } = useAppState();
+  // Draft state for the "add mutation" form. We accept everything as
+  // strings, validate at submit time, and reset after a successful add.
+  const [kind, setKind] = useState<MutationKind>('rename');
+  const [renameOld, setRenameOld] = useState('');
+  const [renameNew, setRenameNew] = useState('');
+  const [renameLabel, setRenameLabel] = useState<string>('');
+  const [moveOld, setMoveOld] = useState('');
+  const [moveNew, setMoveNew] = useState('');
+  const [deleteTarget, setDeleteTarget] = useState('');
+  const [deleteIsFile, setDeleteIsFile] = useState(true);
+
+  // Whether the form has enough content to be added. Tight per-kind
+  // validation so the user can't queue a no-op mutation.
+  const canAdd =
+    (kind === 'rename' && renameOld.trim() && renameNew.trim()) ||
+    (kind === 'move' && moveOld.trim() && moveNew.trim() && moveOld !== moveNew) ||
+    (kind === 'delete' && deleteTarget.trim());
+
+  const handleAdd = () => {
+    let m: Mutation | null = null;
+    if (kind === 'rename') {
+      m = {
+        kind: 'rename',
+        oldName: renameOld.trim(),
+        newName: renameNew.trim(),
+        ...(renameLabel ? { label: renameLabel } : {}),
+      };
+    } else if (kind === 'move') {
+      m = { kind: 'move', oldPath: moveOld.trim(), newPath: moveNew.trim() };
+    } else if (kind === 'delete') {
+      m = deleteIsFile
+        ? { kind: 'delete', filePath: deleteTarget.trim() }
+        : { kind: 'delete', nodeId: deleteTarget.trim() };
+    }
+    if (!m) return;
+    setWhatIfMutations([...whatIfMutations, m]);
+    // Reset only the inputs that match the kind we just added.
+    if (kind === 'rename') {
+      setRenameOld('');
+      setRenameNew('');
+      setRenameLabel('');
+    } else if (kind === 'move') {
+      setMoveOld('');
+      setMoveNew('');
+    } else {
+      setDeleteTarget('');
+    }
+  };
+
+  const handleRemove = (idx: number) => {
+    const next = whatIfMutations.slice();
+    next.splice(idx, 1);
+    setWhatIfMutations(next);
+  };
+
+  const renderMutationSummary = (m: Mutation) => {
+    if (m.kind === 'rename') {
+      return `rename ${m.label ? `[${m.label}] ` : ''}"${m.oldName}" → "${m.newName}"`;
+    }
+    if (m.kind === 'move') {
+      return `move "${m.oldPath}" → "${m.newPath}"`;
+    }
+    if (m.kind === 'delete') {
+      return m.filePath ? `delete file "${m.filePath}"` : `delete node "${m.nodeId}"`;
+    }
+    return '';
+  };
+
+  // The panel is visible whenever the user has summoned it via the
+  // Timeline toggle (whatIfPanelOpen) OR is mid-preview (whatIfActive).
+  // Mutation list and error state alone don't summon it — those only
+  // matter once the user has opened the panel.
+  if (!whatIfPanelOpen && !whatIfActive) return null;
+
+  return (
+    <div
+      className="pointer-events-auto absolute top-3 right-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width: PANEL_WIDTH_PX, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <FlaskConical className="h-3.5 w-3.5 text-amber-300" />
+        <span className="text-xs font-semibold text-text-primary">What-if simulator</span>
+        {whatIfActive && diffData && (
+          <span className="font-mono text-[10px] text-text-muted">
+            {diffData.counts.nodes.onlyInA} removed · {diffData.counts.nodes.onlyInB} added ·{' '}
+            {diffData.counts.nodes.inBoth} unchanged
+          </span>
+        )}
+        <button
+          type="button"
+          onClick={() => exitWhatIfMode()}
+          className="ml-auto shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+          title="Discard mutations and restore the original graph"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+
+      {whatIfError && (
+        <div className="flex items-start gap-2 border-b border-border-subtle bg-red-500/5 px-3 py-2 text-xs text-red-400">
+          <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+          <span>{whatIfError}</span>
+        </div>
+      )}
+
+      {/* Add-mutation form (hidden while previewing — locked-in mutations
+          shouldn't change mid-preview). */}
+      {!whatIfActive && (
+        <div className="space-y-2 border-b border-border-subtle bg-elevated px-3 py-2">
+          <div className="flex gap-1 rounded-md bg-void p-0.5">
+            {(['rename', 'move', 'delete'] as MutationKind[]).map((k) => (
+              <button
+                key={k}
+                type="button"
+                onClick={() => setKind(k)}
+                className={`flex-1 cursor-pointer rounded px-2 py-1 text-[10px] font-medium transition-all ${
+                  kind === k
+                    ? 'bg-accent text-white'
+                    : 'text-text-muted hover:text-text-primary'
+                }`}
+              >
+                {KIND_META[k].label}
+              </button>
+            ))}
+          </div>
+          <p className="text-[10px] text-text-muted">{KIND_META[kind].help}</p>
+
+          {kind === 'rename' && (
+            <div className="space-y-1.5">
+              <input
+                type="text"
+                value={renameOld}
+                onChange={(e) => setRenameOld(e.target.value)}
+                placeholder="old symbol name (e.g. validateUser)"
+                className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+                spellCheck={false}
+              />
+              <input
+                type="text"
+                value={renameNew}
+                onChange={(e) => setRenameNew(e.target.value)}
+                placeholder="new symbol name (e.g. verifyUser)"
+                className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+                spellCheck={false}
+              />
+              <select
+                value={renameLabel}
+                onChange={(e) => setRenameLabel(e.target.value)}
+                className="w-full cursor-pointer rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[10px] text-text-secondary outline-none focus:border-accent/40"
+              >
+                <option value="">any label</option>
+                <option value="Function">Function only</option>
+                <option value="Class">Class only</option>
+                <option value="Method">Method only</option>
+                <option value="Variable">Variable only</option>
+              </select>
+            </div>
+          )}
+
+          {kind === 'move' && (
+            <div className="space-y-1.5">
+              <input
+                type="text"
+                value={moveOld}
+                onChange={(e) => setMoveOld(e.target.value)}
+                placeholder="old path (e.g. src/old_module)"
+                className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+                spellCheck={false}
+              />
+              <input
+                type="text"
+                value={moveNew}
+                onChange={(e) => setMoveNew(e.target.value)}
+                placeholder="new path (e.g. src/new_module)"
+                className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+                spellCheck={false}
+              />
+            </div>
+          )}
+
+          {kind === 'delete' && (
+            <div className="space-y-1.5">
+              <div className="flex gap-1 rounded-md bg-void p-0.5 text-[10px]">
+                <button
+                  type="button"
+                  onClick={() => setDeleteIsFile(true)}
+                  className={`flex-1 cursor-pointer rounded px-2 py-1 ${
+                    deleteIsFile ? 'bg-accent text-white' : 'text-text-muted'
+                  }`}
+                >
+                  by file path
+                </button>
+                <button
+                  type="button"
+                  onClick={() => setDeleteIsFile(false)}
+                  className={`flex-1 cursor-pointer rounded px-2 py-1 ${
+                    !deleteIsFile ? 'bg-accent text-white' : 'text-text-muted'
+                  }`}
+                >
+                  by node id
+                </button>
+              </div>
+              <input
+                type="text"
+                value={deleteTarget}
+                onChange={(e) => setDeleteTarget(e.target.value)}
+                placeholder={
+                  deleteIsFile ? 'file path (cascades to symbols)' : 'exact node id'
+                }
+                className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+                spellCheck={false}
+              />
+            </div>
+          )}
+
+          <button
+            type="button"
+            onClick={handleAdd}
+            disabled={!canAdd}
+            className="flex w-full items-center justify-center gap-1.5 rounded-md bg-accent/15 px-2 py-1 text-[10px] font-medium text-accent transition-all hover:bg-accent/25 disabled:cursor-not-allowed disabled:opacity-40 cursor-pointer"
+          >
+            <Sparkles className="h-2.5 w-2.5" />
+            Queue mutation
+          </button>
+        </div>
+      )}
+
+      {/* Queued mutations list */}
+      <div className="flex-1 overflow-y-auto">
+        {whatIfMutations.length === 0 && (
+          <div className="px-3 py-3 text-[11px] italic text-text-muted">
+            No mutations queued yet. Pick a kind above and "Queue mutation".
+          </div>
+        )}
+        {whatIfMutations.map((m, idx) => (
+          <div
+            key={idx}
+            className="group flex items-start gap-2 border-b border-border-subtle px-3 py-1.5"
+          >
+            <span className="mt-0.5 shrink-0 rounded bg-elevated px-1 py-0 font-mono text-[9px] text-text-muted">
+              {idx + 1}
+            </span>
+            <ChevronRight className="mt-0.5 h-3 w-3 shrink-0 text-text-muted" />
+            <span className="min-w-0 flex-1 break-all font-mono text-[10px] text-text-secondary">
+              {renderMutationSummary(m)}
+            </span>
+            {!whatIfActive && (
+              <button
+                type="button"
+                onClick={() => handleRemove(idx)}
+                className="cursor-pointer rounded p-1 text-text-muted/40 transition-all group-hover:text-text-muted hover:!text-red-400"
+                title="Remove this mutation"
+              >
+                <Trash2 className="h-3 w-3" />
+              </button>
+            )}
+          </div>
+        ))}
+      </div>
+
+      {/* Preview action */}
+      {whatIfMutations.length > 0 && (
+        <div className="shrink-0 border-t border-border-subtle bg-elevated px-3 py-2">
+          {!whatIfActive ? (
+            <button
+              type="button"
+              onClick={() => enterWhatIfMode()}
+              className="flex w-full cursor-pointer items-center justify-center gap-2 rounded-md bg-accent px-3 py-1.5 text-[11px] font-medium text-white transition-all hover:bg-accent/90"
+            >
+              <Play className="h-3 w-3" />
+              Preview ({whatIfMutations.length} mutation
+              {whatIfMutations.length > 1 ? 's' : ''})
+            </button>
+          ) : (
+            <button
+              type="button"
+              onClick={() => exitWhatIfMode()}
+              className="flex w-full cursor-pointer items-center justify-center gap-2 rounded-md border border-border-subtle bg-surface px-3 py-1.5 text-[11px] font-medium text-text-secondary transition-all hover:bg-hover hover:text-text-primary"
+            >
+              <X className="h-3 w-3" />
+              Exit preview · restore original
+            </button>
+          )}
+        </div>
+      )}
+    </div>
+  );
+};
