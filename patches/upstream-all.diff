+// hues so the matrix reads at a glance; the others (semantic-axis
+// dependent) are listed for future use.
+const QUADRANT_COLORS: Record<string, string> = {
+  'Jumeaux actifs': 'bg-emerald-500/40 hover:bg-emerald-500/60 border-emerald-500/60',
+  'Jumeaux isolés': 'bg-amber-500/40 hover:bg-amber-500/60 border-amber-500/60',
+  'Jumeaux (isolation intentionnelle)': 'bg-slate-500/30 hover:bg-slate-500/50 border-slate-500/50',
+  'Patterns + collision': 'bg-orange-500/40 hover:bg-orange-500/60 border-orange-500/60',
+  'Patterns partagés': 'bg-sky-500/40 hover:bg-sky-500/60 border-sky-500/60',
+  'Collision réelle': 'bg-red-500/40 hover:bg-red-500/60 border-red-500/60',
+  'Domaines parallèles': 'bg-indigo-500/30 hover:bg-indigo-500/50 border-indigo-500/50',
+  'Couplage caché': 'bg-fuchsia-500/40 hover:bg-fuchsia-500/60 border-fuchsia-500/60',
+  'Indépendants': 'bg-elevated hover:bg-hover border-border-default',
