+          )}
+
+          <button
+            type="button"
+            onClick={handleAdd}
+            disabled={!canAdd}
+            className="flex w-full items-center justify-center gap-1.5 rounded-md bg-accent/15 px-2 py-1 text-[10px] font-medium text-accent transition-all hover:bg-accent/25 disabled:cursor-not-allowed disabled:opacity-40 cursor-pointer"
+          >
+            <Sparkles className="h-2.5 w-2.5" />
