+++ b/gitnexus-web/src/components/DiffBanner.tsx
@@ -0,0 +1,95 @@
+import { GitBranch, X, Loader2, AlertCircle } from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Floating banner shown while comparing two repos. Renders the legend (red /
+ * green / gray), the count of nodes in each bucket, and an exit button that
+ * restores the original (single-repo) graph.
+ *
+ * Mounted unconditionally; renders nothing when no diff is active.
+ */
+export const DiffBanner = () => {
+  const { diffMode, diffData, diffLoading, diffError, exitDiffMode } = useAppState();
+
+  if (!diffMode && !diffLoading && !diffError) return null;
+
+  return (
+    <div className="pointer-events-auto absolute top-3 left-1/2 z-40 w-[min(640px,calc(100%-1.5rem))] -translate-x-1/2">
+      <div className="flex items-center gap-3 rounded-xl border border-border-subtle bg-surface/95 px-3 py-2 shadow-xl backdrop-blur">
+        <GitBranch className="h-4 w-4 shrink-0 text-text-secondary" />
+
+        {diffLoading && (
+          <div className="flex flex-1 items-center gap-2 text-sm text-text-secondary">
+            <Loader2 className="h-3.5 w-3.5 animate-spin" />
+            Computing diff…
+          </div>
+        )}
+
+        {diffError && !diffLoading && (
+          <div className="flex flex-1 items-center gap-2 text-sm text-red-400">
+            <AlertCircle className="h-3.5 w-3.5" />
+            <span className="truncate">{diffError}</span>
+          </div>
+        )}
+
+        {diffMode && diffData && !diffLoading && (
+          <div className="flex min-w-0 flex-1 items-center gap-3">
+            <div className="flex min-w-0 items-center gap-1.5 truncate text-xs">
+              <span className="font-medium text-text-primary truncate">{diffMode.repoA}</span>
+              <span className="shrink-0 text-text-muted">vs</span>
+              <span className="font-medium text-text-primary truncate">{diffMode.repoB}</span>
+            </div>
+
+            <div className="ml-auto flex shrink-0 items-center gap-3 text-xs">
+              <Legend
+                color="bg-red-500"
+                label="only in A"
+                count={diffData.counts.nodes.onlyInA}
+                title={`${diffData.counts.nodes.onlyInA} nodes only in ${diffMode.repoA}`}
+              />
+              <Legend
+                color="bg-emerald-500"
+                label="only in B"
+                count={diffData.counts.nodes.onlyInB}
+                title={`${diffData.counts.nodes.onlyInB} nodes only in ${diffMode.repoB}`}
+              />
+              <Legend
+                color="bg-gray-500"
+                label="in both"
+                count={diffData.counts.nodes.inBoth}
+                title={`${diffData.counts.nodes.inBoth} nodes in both`}
+              />
+            </div>
+          </div>
+        )}
+
+        <button
+          type="button"
+          onClick={() => exitDiffMode()}
+          className="shrink-0 cursor-pointer rounded-md p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+          title="Exit diff mode"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+    </div>
+  );
+};
+
+const Legend = ({
+  color,
+  label,
+  count,
+  title,
+}: {
+  color: string;
+  label: string;
+  count: number;
+  title: string;
+}) => (
+  <span className="flex items-center gap-1.5" title={title}>
+    <span className={`inline-block h-2 w-2 rounded-full ${color}`} />
+    <span className="text-text-muted">{label}</span>
+    <span className="font-mono font-semibold text-text-primary">{count}</span>
+  </span>
+);
diff --git a/gitnexus-web/src/components/DissonancePanel.tsx b/gitnexus-web/src/components/DissonancePanel.tsx
