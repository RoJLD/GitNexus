--- /dev/null
+++ b/docker-server-connectors-core.mjs
@@ -0,0 +1,44 @@
+// upstream/docker-server-connectors-core.mjs
+//
+// Pure helpers for connector framework (Section B of the
+// roadmap-predictive Cleanup + Connectors plan, 2026-05-26).
+//
+// Exposes:
+//   - tokenize(s)           : string → token array (lowercase, alphanum)
+//   - jaccardSimilarity(a,b): array, array → number in [0, 1]
+//   - fuzzyMatchTicketToGhost(ticket, ghosts, threshold) :
+//       returns { ghost, score } | null
+
+export function tokenize(s) {
+  if (!s || typeof s !== 'string') return [];
+  return s.toLowerCase().split(/[^a-z0-9]+/).filter(Boolean);
+}
+
+export function jaccardSimilarity(a, b) {
+  const sa = new Set(a);
+  const sb = new Set(b);
+  if (sa.size === 0 && sb.size === 0) return 1;
+  let intersect = 0;
+  for (const x of sa) if (sb.has(x)) intersect++;
+  const union = sa.size + sb.size - intersect;
+  return union === 0 ? 0 : intersect / union;
+}
+
+export function fuzzyMatchTicketToGhost(ticket, ghosts, threshold = 0.7) {
+  const ticketTokens = [
+    ...tokenize(ticket.title || ''),
+    ...tokenize(ticket.description || ''),
+  ];
+  let best = null;
+  for (const g of ghosts || []) {
+    const ghostTokens = [
+      ...tokenize(g.title || ''),
+      ...tokenize(g.declared?.description || ''),
+    ];
+    const score = jaccardSimilarity(ticketTokens, ghostTokens);
+    if (score >= threshold && (!best || score > best.score)) {
+      best = { ghost: g, score };
+    }
+  }
+  return best;
+}
diff --git a/docker-server-connectors.mjs b/docker-server-connectors.mjs
new file mode 100644
index 0000000..d16bdbb
--- /dev/null
+++ b/docker-server-connectors.mjs
@@ -0,0 +1,126 @@
+// upstream/docker-server-connectors.mjs
+//
+// `/ghosts/connector-suggestions` endpoint — reads .gitnexus.json's
+// `connectors.*` config for a repo, runs each enabled connector's
+// fetchOpenWorkItems + fetchClosedWorkItems, fuzzy-matches each ticket
+// against the latest ghosts, and returns
+//   { suggestions: [{ ghostId, connectorName, ticketRef, suggestedAction, ... }] }
+//
+// Connectors live under ./connectors/*.mjs. Each one must export an
+// object with `fetchOpenWorkItems(cfg)` and `fetchClosedWorkItems(cfg)`.
+
+import { fuzzyMatchTicketToGhost } from './docker-server-connectors-core.mjs';
+import { readLatestGhosts } from './docker-server-ghosts.mjs';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { planeConnector } from './connectors/plane.mjs';
+import { linearConnector } from './connectors/linear.mjs';
+import { githubConnector } from './connectors/github.mjs';
+import { jiraConnector } from './connectors/jira.mjs';
+import { readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+
+const CONNECTORS = {
+  plane: planeConnector,
+  linear: linearConnector,
+  github: githubConnector,
+  jira: jiraConnector,
+};
+
+async function loadConnectorConfig(repoPath) {
+  try {
+    const raw = await readFile(join(repoPath, '.gitnexus.json'), 'utf8');
+    const cfg = JSON.parse(raw);
+    return cfg?.connectors || {};
+  } catch { return {}; }
+}
+
+function envFor(name) {
+  switch (name) {
+    case 'plane': return process.env.PLANE_API_KEY;
+    case 'linear': return process.env.LINEAR_API_KEY;
+    case 'github': return process.env.GITHUB_TOKEN;
+    case 'jira': return process.env.JIRA_API_TOKEN;
+    default: return null;
+  }
+}
+
+export async function buildConnectorSuggestions(repoPath) {
+  const runtime = await readLatestGhosts(repoPath);
+  if (!runtime) return { suggestions: [] };
+  const ghosts = runtime.ghosts || [];
+  const connectorConfig = await loadConnectorConfig(repoPath);
+
+  const suggestions = [];
+  for (const [name, connector] of Object.entries(CONNECTORS)) {
+    const cfg = connectorConfig[name];
+    if (!cfg || cfg.enabled !== true) continue;
+    const apiKey = cfg.apiKey || envFor(name);
+    let openItems = [], closedItems = [];
+    try {
+      openItems = await connector.fetchOpenWorkItems({ ...cfg, apiKey });
+      closedItems = await connector.fetchClosedWorkItems({ ...cfg, apiKey });
+    } catch (err) {
+      suggestions.push({ connectorName: name, error: err.message });
+      continue;
+    }
+    for (const ticket of openItems) {
+      const match = fuzzyMatchTicketToGhost(ticket, ghosts, cfg.matchThreshold ?? 0.7);
+      if (match) {
+        suggestions.push({
+          ghostId: match.ghost.id,
+          connectorName: name,
+          ticketRef: ticket.id,
+          ticketTitle: ticket.title,
+          suggestedAction: 'reaffirm',
+          rationale: `${name} ticket "${ticket.title}" still open (score ${match.score.toFixed(2)})`,
+          externalUrl: ticket.externalUrl,
+        });
+      }
+    }
+    for (const ticket of closedItems) {
+      const match = fuzzyMatchTicketToGhost(ticket, ghosts, cfg.matchThreshold ?? 0.7);
+      if (match) {
+        suggestions.push({
+          ghostId: match.ghost.id,
+          connectorName: name,
+          ticketRef: ticket.id,
+          ticketTitle: ticket.title,
+          suggestedAction: 'cancel',
+          rationale: `${name} ticket "${ticket.title}" closed (score ${match.score.toFixed(2)})`,
+          externalUrl: ticket.externalUrl,
+        });
+      }
+    }
+  }
+  return { suggestions };
+}
+
+async function handleConnectorSuggestions(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: 'missing repo' }));
+  }
+  const repo = await findRepoByName(repoName, opts.api);
+  if (!repo) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    return res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+  }
+  const repoPath = repo.repoPath || repo.path;
+  try {
+    const result = await buildConnectorSuggestions(repoPath);
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify(result));
+  } catch (err) {
+    res.writeHead(500, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err.message }));
+  }
+}
+
+export async function handleConnectorsRoute(req, url, res, opts) {
+  if (url.pathname === '/ghosts/connector-suggestions' && req.method === 'GET') {
+    await handleConnectorSuggestions(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-coupling-cross.mjs b/docker-server-coupling-cross.mjs
new file mode 100644
index 0000000..0f8e30e
--- /dev/null
+++ b/docker-server-coupling-cross.mjs
@@ -0,0 +1,289 @@
+/**
+ * Cross-repo temporal coupling — ROADMAP Tier 1.2.
+ *
+ * Endpoint:
+ *   GET /coupling/cross?repos=A,B[,C][&windowHours=24][&top=100][&format=csv]
+ *
+ * Detects pairs of files in *different* repos that tend to change in
+ * the same time window. The signal is "hidden inter-service coupling"
+ * — when a contract change in repo A reliably triggers a follow-up in
+ * repo B, you have a soft dependency the repo graphs don't show.
+ *
+ * --- Why git log rather than snapshots ---
+ *
+ * The single-repo /coupling endpoint diffs snapshots because that's
+ * what gitnexus persists. Cross-repo is sparser: two repos rarely have
+ * snapshots taken at exactly the same time, so consecutive-snapshot
+ * diffing would miss the actual co-change events. Git commit dates are
+ * the source of truth — they're continuous, every change is timestamped
+ * the moment the developer committed, and the windowing approach maps
+ * naturally onto "what was touched in the same hour / day".
+ *
+ * --- Algorithm ---
+ *
+ *   1. For each repo, run `git log --pretty=format:%aI --name-only --no-merges`.
+ *      One row per (commit date ISO, file path) tuple.
+ *   2. Bucket each row into a window of `windowHours` hours
+ *      (rounded down from epoch). Same window → same bucket id.
+ *   3. For each bucket, collect the set of (repo, file) entries touched.
+ *   4. For every cross-repo pair within a bucket, increment a counter.
+ *   5. Jaccard per pair using the totals from step 2.
+ *
+ * Pairs are sorted by Jaccard desc, then count desc. We cap at `top`
+ * (default 100) so a multi-thousand-file scan doesn't ship a 5 MB
+ * response.
+ */
+
+import { spawn } from 'node:child_process';
+import { stat } from 'node:fs/promises';
+import { join } from 'node:path';
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const DEFAULT_WINDOW_HOURS = 24;
+const DEFAULT_TOP = 100;
+const MAX_REPOS = 8;
+
+function runCmd(cmd, args, opts = {}) {
+  return new Promise((resolve, reject) => {
+    const child = spawn(cmd, args, opts);
+    let stdout = '';
+    let stderr = '';
+    child.stdout?.on('data', (d) => (stdout += d.toString()));
+    child.stderr?.on('data', (d) => (stderr += d.toString()));
+    child.on('error', reject);
+    child.on('close', (code) => {
+      if (code === 0) resolve(stdout);
+      else reject(new Error(`${cmd} exited ${code}: ${stderr.trim()}`));
+    });
+  });
+}
+
+/**
+ * Parse `git log --pretty=format:%aI --name-only --no-merges` output.
+ * Returns an array of { date: ISO, files: string[] } (one per commit).
+ *
+ * The format alternates:
+ *   <iso-date>\n
+ *   file1\n
+ *   file2\n
+ *   \n   (blank line between commits)
+ */
+function parseLog(stdout) {
+  const commits = [];
+  let date = null;
+  let files = [];
+  for (const rawLine of stdout.split('\n')) {
+    const line = rawLine.trimEnd();
+    if (line === '') {
+      if (date !== null) {
+        commits.push({ date, files });
+        date = null;
+        files = [];
+      }
+      continue;
+    }
+    if (date === null) {
+      date = line;
+      continue;
+    }
+    files.push(line);
+  }
+  if (date !== null) commits.push({ date, files });
+  return commits;
+}
+
+function bucketIdOf(isoDate, windowMs) {
+  const t = Date.parse(isoDate);
+  if (!Number.isFinite(t)) return null;
+  return Math.floor(t / windowMs);
+}
+
+async function handleCouplingCross(url, res, opts) {
+  const reposParam = url.searchParams.get('repos');
+  if (!reposParam) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repos (comma-separated)' }));
+    return;
+  }
+  const repoNames = reposParam
+    .split(',')
+    .map((s) => s.trim())
+    .filter(Boolean)
+    .filter((s) => !s.includes('@')) // snapshots don't make sense cross-repo
+    .slice(0, MAX_REPOS);
+  if (repoNames.length < 2) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'need at least 2 distinct repos' }));
+    return;
+  }
+
+  const windowHours = Math.max(1, Math.min(720, Number(url.searchParams.get('windowHours')) || DEFAULT_WINDOW_HOURS));
+  const windowMs = windowHours * 3600 * 1000;
+  const top = Math.max(1, Math.min(1000, Number(url.searchParams.get('top')) || DEFAULT_TOP));
+
+  // Resolve each repo and pull its git log. Fail loudly on any
+  // not-found / not-git so the user fixes the input rather than
+  // silently getting empty data.
+  const repos = [];
+  for (const name of repoNames) {
+    const meta = await findRepoByName(name, opts.api);
+    if (!meta) {
+      res.writeHead(404, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `repo not found: ${name}` }));
+      return;
+    }
+    const repoPath = meta.repoPath || meta.path;
+    const hasGit = await stat(join(repoPath, '.git')).catch(() => null);
+    if (!hasGit) {
+      res.writeHead(400, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `${name} at ${repoPath} is not a git repo (cross-repo needs git history)` }));
+      return;
+    }
+    repos.push({ name, repoPath });
+  }
+
+  // Sequential log scans — these are I/O-bound but cheap; parallelizing
+  // doesn't help much and lets stderr from one repo bleed into another.
+  const allCommits = [];
+  for (const r of repos) {
+    let log;
+    try {
+      log = await runCmd('git', [
+        '-C',
+        r.repoPath,
+        'log',
+        '--pretty=format:%aI',
+        '--name-only',
+        '--no-merges',
+      ]);
+    } catch (err) {
+      res.writeHead(500, { 'Content-Type': 'application/json' });
+      res.end(JSON.stringify({ error: `git log failed for ${r.name}: ${err.message}` }));
+      return;
+    }
+    const commits = parseLog(log);
+    for (const c of commits) {
+      for (const f of c.files) {
+        allCommits.push({ repo: r.name, date: c.date, file: f });
+      }
+    }
+  }
+
+  // Build per-bucket sets of (repo, file). Same-bucket = "touched in
+  // the same window". We use a colon-based composite key — neither
+  // repo names from /api/repos nor file paths contain whitespace
+  // sentinels like "~~::~~", so we use that as a delimiter.
+  const SEP = "~~::~~";
+  const PAIR_SEP = "~~//~~";
+  const bucketMembers = new Map();
+  const fileTotals = new Map();
+  const repoEarliest = new Map();
+  const repoLatest = new Map();
+
+  for (const { repo, date, file } of allCommits) {
+    const bid = bucketIdOf(date, windowMs);
+    if (bid === null) continue;
+    const key = repo + SEP + file;
+    let set = bucketMembers.get(bid);
+    if (!set) { set = new Set(); bucketMembers.set(bid, set); }
+    if (!set.has(key)) {
+      set.add(key);
+      fileTotals.set(key, (fileTotals.get(key) || 0) + 1);
+    }
+    if (!repoEarliest.has(repo) || date < repoEarliest.get(repo)) repoEarliest.set(repo, date);
+    if (!repoLatest.has(repo) || date > repoLatest.get(repo)) repoLatest.set(repo, date);
+  }
+
+  const splitEntry = (k) => {
+    const i = k.indexOf(SEP);
+    return [k.slice(0, i), k.slice(i + SEP.length)];
+  };
+
+  // For every bucket, all *cross-repo* pairs of members. Same-repo
+  // pairs are skipped — that is what the single-repo /coupling does.
+  const pairCount = new Map();
+  for (const set of bucketMembers.values()) {
+    if (set.size < 2) continue;
+    const arr = [...set];
+    for (let i = 0; i < arr.length; i++) {
+      const [repoA] = splitEntry(arr[i]);
+      for (let j = i + 1; j < arr.length; j++) {
+        const [repoB] = splitEntry(arr[j]);
+        if (repoA === repoB) continue;
+        const [p, q] = arr[i] < arr[j] ? [arr[i], arr[j]] : [arr[j], arr[i]];
+        const pairKey = p + PAIR_SEP + q;
+        pairCount.set(pairKey, (pairCount.get(pairKey) || 0) + 1);
+      }
+    }
+  }
+
+  // Compute Jaccard per pair.
+  const pairs = [];
+  for (const [key, count] of pairCount) {
+    const sepIdx = key.indexOf(PAIR_SEP);
+    const pa = key.slice(0, sepIdx);
+    const pb = key.slice(sepIdx + PAIR_SEP.length);
+    const [repoA, fileA] = splitEntry(pa);
+    const [repoB, fileB] = splitEntry(pb);
+    const cA = fileTotals.get(pa) || 1;
+    const cB = fileTotals.get(pb) || 1;
+    const jaccard = count / (cA + cB - count);
+    pairs.push({
+      a: { repo: repoA, path: fileA },
+      b: { repo: repoB, path: fileB },
+      count,
+      jaccard,
+    });
+  }
+  pairs.sort((x, y) => y.jaccard - x.jaccard || y.count - x.count);
+  const truncated = pairs.slice(0, top);
+
+  const meta = {
+    repos: repoNames,
+    windowHours,
+    totalBuckets: bucketMembers.size,
+    totalCrossPairs: pairs.length,
+    perRepoSpan: Object.fromEntries(
+      repoNames.map((name) => [
+        name,
+        {
+          earliest: repoEarliest.get(name) || null,
+          latest: repoLatest.get(name) || null,
+        },
+      ]),
+    ),
+  };
+
+  if (url.searchParams.get('format') === 'csv') {
+    const rows = truncated.map((p) => ({
+      repoA: p.a.repo,
+      fileA: p.a.path,
+      repoB: p.b.repo,
+      fileB: p.b.path,
+      coChanges: p.count,
+      jaccard: p.jaccard,
+    }));
+    const csv = toCsv(rows, [
+      { key: 'repoA' },
+      { key: 'fileA' },
+      { key: 'repoB' },
+      { key: 'fileB' },
+      { key: 'coChanges' },
+      { key: 'jaccard' },
+    ]);
+    writeCsv(res, `${safeFilename(repoNames.join('-vs-'))}-coupling-cross.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(JSON.stringify({ ...meta, pairs: truncated }));
+}
+
+export async function handleCouplingCrossRoute(req, url, res, opts) {
+  if (url.pathname === '/coupling/cross' && req.method === 'GET') {
+    await handleCouplingCross(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-coupling.mjs b/docker-server-coupling.mjs
new file mode 100644
index 0000000..e1e2ebd
--- /dev/null
+++ b/docker-server-coupling.mjs
@@ -0,0 +1,266 @@
+/**
+ * Temporal coupling analytics — Phase 4B.
+ *
+ * Endpoint:
+ *   GET /coupling?repo=<baseRepoName>&top=<n>
+ *
+ * Across the snapshot timeline of <baseRepoName> (snapshots + live), for
+ * each consecutive transition we extract the set of FILES touched (a file
+ * is "touched" if any node attributed to it was added or removed). For
+ * every pair of files in that set we increment a co-occurrence counter,
+ * and we expose the strongest couplings ranked by Jaccard similarity.
+ *
+ * Interpretation:
+ *   - High Jaccard between A and B → "they almost always change together"
+ *     This is the bread and butter of architectural reverse-engineering:
+ *     a strong but non-architectural link (e.g. login.py always changes
+ *     with auth_test.py) reveals hidden coupling, design rules, or
+ *     repeated patterns.
+ *   - Low individual count + high Jaccard → coupling could be coincidence.
+ *     We expose `count` so the UI can filter out rare-but-paired files.
+ *
+ * Granularity = file. The node graph has tens of thousands of nodes;
+ * coupling per function/class would be too noisy for a top-N list and
+ * harder to act on. Files are the natural unit for "what tends to change
+ * together" in most refactoring/patterns analyses.
+ *
+ * Response shape:
+ *   {
+ *     totalTransitions: number,
+ *     timeline: [{ name, isLive, date }],
+ *     fileChangeCount: { [filePath]: number },
+ *     pairs: [{ a, b, count, jaccard }],   // sorted desc by jaccard
+ *     errors?: [...]
+ *   }
+ */
+
+import { findRepoByName } from './docker-server-snapshots.mjs';
+import { readdir, readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+import { SNAPSHOTS_ROOT, safeSnapshotKey } from './docker-server-snapshots.mjs';
+import { toCsv, writeCsv, safeFilename } from './docker-server-csv.mjs';
+
+const COUPLING_REGRESSION_THRESHOLD = Number(process.env.COUPLING_REGRESSION_THRESHOLD) || 0.5;
+
+async function listSnapshotNamesAndDates(repoName) {
+  const repoSnapshotsDir = join(SNAPSHOTS_ROOT, safeSnapshotKey(repoName));
+  let entries;
+  try {
+    entries = await readdir(repoSnapshotsDir, { withFileTypes: true });
+  } catch (err) {
+    if (err && err.code === 'ENOENT') return [];
+    throw err;
+  }
+  const out = [];
+  for (const e of entries) {
+    if (!e.isDirectory()) continue;
+    try {
+      const commit = JSON.parse(
+        await readFile(join(repoSnapshotsDir, e.name, 'commit.json'), 'utf8'),
+      );
+      out.push({ name: `${repoName}@${e.name}`, date: commit.date, isLive: false });
+    } catch {
+      // half-built snapshot; skip
+    }
+  }
+  return out;
+}
+
+// Extract the owning file path from a node id. gitnexus IDs follow a few
+// conventions:
+//   File:<path>                              → the file itself
+//   Folder:<path>                            → not a file (skipped)
+//   Function:<path>:<name>[:<line>]          → owned by <path>
+//   Class:<path>:<name>[:<line>]             → owned by <path>
+//   Variable:<path>:<name>                   → owned by <path>
+//   Section:<path>:<L?>:<title>              → owned by <path>
+//   Community:<n>, Process:<n>, comm_<n>     → no file
+// We pick the segment immediately after the first ":" and treat it as the
+// owning file path. Returns null for things we can't attribute (e.g.
+// communities / processes — synthetic nodes).
+const NON_FILE_LABELS = new Set([
+  'Community',
+  'Process',
+  'Folder',
+  'Repository',
+  'Group',
+]);
+function fileOfNodeId(id) {
+  if (typeof id !== 'string' || !id.includes(':')) return null;
+  const colon = id.indexOf(':');
+  const label = id.slice(0, colon);
+  if (NON_FILE_LABELS.has(label)) return null;
+  // Synthetic ids like "comm_5" have no label / colon — already returned above.
+  const rest = id.slice(colon + 1);
+  // Everything up to the next ":" is the file path. Some node ids embed
+  // a path that itself contains nothing-but-letters (e.g. "Section:Quick" —
+  // but those are unlikely; we treat them as file path = `rest`).
+  const next = rest.indexOf(':');
+  return next === -1 ? rest : rest.slice(0, next);
+}
+
+async function fetchNodeIds(repoName, api) {
+  const resp = await fetch(`${api}/api/query`, {
+    method: 'POST',
+    headers: { 'Content-Type': 'application/json' },
+    body: JSON.stringify({ cypher: 'MATCH (n) RETURN n.id AS id', repo: repoName }),
+  });
+  if (!resp.ok) throw new Error(`cypher failed for ${repoName}: ${resp.status}`);
+  const data = await resp.json();
+  const rows = data?.result || data?.rows || [];
+  return rows
+    .map((row) => (typeof row === 'object' && row !== null ? row.id ?? row['n.id'] : null))
+    .filter((id) => typeof id === 'string');
+}
+
+async function handleCoupling(url, res, opts) {
+  const repoName = url.searchParams.get('repo');
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+  const baseRepo = repoName.split('@')[0];
+  const top = Math.max(1, Math.min(500, Number(url.searchParams.get('top')) || 50));
+  const asOf = url.searchParams.get('asOf');
+
+  const liveEntry = await findRepoByName(baseRepo, opts.api);
+  if (!liveEntry) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${baseRepo}` }));
+    return;
+  }
+
+  const snapshots = await listSnapshotNamesAndDates(baseRepo);
+  const timeline = [
+    ...snapshots,
+    { name: baseRepo, date: liveEntry.indexedAt, isLive: true },
+  ].sort((a, b) => (a.date || '').localeCompare(b.date || ''));
+
+  let effectiveTimeline = timeline;
+  if (asOf) {
+    const cut = Date.parse(asOf);
+    if (Number.isFinite(cut)) effectiveTimeline = timeline.filter((t) => Date.parse(t.date) <= cut);
+  }
+
+  if (effectiveTimeline.length < 2) {
+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        totalTransitions: 0,
+        timeline,
+        pairs: [],
+        fileChangeCount: {},
+        warning: 'Need at least 2 snapshots (or 1 snapshot + live) to compute coupling.',
+      }),
+    );
+    return;
+  }
+
+  // Collect each snapshot's node-id set sequentially (same reason as
+  // /churn: the gitnexus REST lbug cache is single-entry, parallel access
+  // would thrash it).
+  const idSets = [];
+  const errors = [];
+  for (const point of effectiveTimeline) {
+    try {
+      const ids = await fetchNodeIds(point.name, opts.api);
+      idSets.push(new Set(ids));
+    } catch (err) {
+      errors.push({ snapshot: point.name, error: err?.message || 'fetch failed' });
+      // Push an empty set so the downstream index alignment stays correct.
+      idSets.push(new Set());
+    }
+  }
+
+  // For each transition, build the set of FILES touched (any node added
+  // or removed maps to its owning file). Then bump cooccur for each pair.
+  const fileChangeCount = Object.create(null);
+  const pairCount = new Map(); // key: "a\0b" (sorted), val: count
+  const totalTransitions = idSets.length - 1;
+
+  for (let i = 0; i < totalTransitions; i++) {
+    const a = idSets[i];
+    const b = idSets[i + 1];
+    const touchedFiles = new Set();
+
+    // Added: in b but not in a.
+    for (const id of b) {
+      if (!a.has(id)) {
+        const file = fileOfNodeId(id);
+        if (file) touchedFiles.add(file);
+      }
+    }
+    // Removed: in a but not in b.
+    for (const id of a) {
+      if (!b.has(id)) {
+        const file = fileOfNodeId(id);
+        if (file) touchedFiles.add(file);
+      }
+    }
+
+    if (touchedFiles.size === 0) continue;
+
+    const filesArr = [...touchedFiles];
+    for (const f of filesArr) {
+      fileChangeCount[f] = (fileChangeCount[f] || 0) + 1;
+    }
+    // All unordered pairs of touched files. Sort the two paths so each
+    // pair has a canonical key regardless of which file is "a" or "b".
+    for (let x = 0; x < filesArr.length; x++) {
+      for (let y = x + 1; y < filesArr.length; y++) {
+        const [p, q] = filesArr[x] < filesArr[y]
+          ? [filesArr[x], filesArr[y]]
+          : [filesArr[y], filesArr[x]];
+        const key = `${p}\0${q}`;
+        pairCount.set(key, (pairCount.get(key) || 0) + 1);
+      }
+    }
+  }
+
+  // Compute Jaccard per pair. Symmetric measure: count(A ∩ B) / count(A ∪ B)
+  // where each "count" is the number of transitions touching that file (or
+  // both). |A ∪ B| = changes(A) + changes(B) - cooccur(A, B).
+  const pairs = [];
+  for (const [key, count] of pairCount) {
+    const [a, b] = key.split('\0');
+    const cA = fileChangeCount[a] || 1;
+    const cB = fileChangeCount[b] || 1;
+    const jaccard = count / (cA + cB - count);
+    pairs.push({ a, b, count, jaccard });
+  }
+  pairs.sort((x, y) => y.jaccard - x.jaccard || y.count - x.count);
+
+  const truncated = pairs.slice(0, top);
+
+  if (url.searchParams.get('format') === 'csv') {
+    const csv = toCsv(truncated, [
+      { key: 'a', header: 'fileA' },
+      { key: 'b', header: 'fileB' },
+      { key: 'count', header: 'coChanges' },
+      { key: 'jaccard' },
+    ]);
+    writeCsv(res, `${safeFilename(baseRepo)}-coupling.csv`, csv);
+    return;
+  }
+
+  res.writeHead(200, { 'Content-Type': 'application/json' });
+  res.end(
+    JSON.stringify({
+      totalTransitions,
+      timeline,
+      fileChangeCount,
+      pairs: truncated,
+      pairsAboveThreshold: pairs.filter((p) => typeof p.jaccard === 'number' && p.jaccard >= COUPLING_REGRESSION_THRESHOLD).length,
+      errors: errors.length ? errors : undefined,
+    }),
+  );
+}
+
+export async function handleCouplingRoute(req, url, res, opts) {
+  if (url.pathname === '/coupling' && req.method === 'GET') {
+    await handleCoupling(url, res, opts);
+    return true;
+  }
+  return false;
+}
diff --git a/docker-server-csv.mjs b/docker-server-csv.mjs
new file mode 100644
index 0000000..d9de47e
--- /dev/null
+++ b/docker-server-csv.mjs
@@ -0,0 +1,57 @@
+/**
+ * Minimal CSV serialization for the analytics endpoints' `?format=csv`
+ * branch. Tiny and self-contained — we don't pull in a CSV lib for the
+ * three operations we actually do (string quoting, joining, header
+ * row).
+ */
+
+/**
+ * Quote a single CSV cell. RFC 4180 rules:
+ *   - wrap in double quotes if the value contains `,`, `"`, CR, or LF
+ *   - inside the quotes, escape `"` as `""`
+ * Numbers / booleans are stringified untouched, null/undefined render
+ * as empty.
+ */
+function csvCell(v) {
+  if (v == null) return '';
+  const s = typeof v === 'string' ? v : String(v);
+  if (/[",\r\n]/.test(s)) return `"${s.replace(/"/g, '""')}"`;
+  return s;
+}
+
+/**
+ * Convert an array of row objects to a CSV string.
+ *   columns: ordered list of { key, header? }
+ * If `header` is omitted, `key` doubles as the header label.
+ *
+ * Streaming wasn't worth the complexity at our scale — analytics
+ * payloads are <100k rows in practice and fit in memory comfortably.
+ */
+export function toCsv(rows, columns) {
+  const header = columns.map((c) => csvCell(c.header ?? c.key)).join(',');
+  const body = rows
+    .map((row) => columns.map((c) => csvCell(row[c.key])).join(','))
+    .join('\n');
+  return header + '\n' + body + (body ? '\n' : '');
+}
+
+/**
+ * Helper for endpoint handlers: write the response with the right
+ * headers and a download-friendly filename derived from the repo name.
+ */
+export function writeCsv(res, filename, csv) {
+  res.writeHead(200, {
+    'Content-Type': 'text/csv; charset=utf-8',
+    'Content-Disposition': `attachment; filename="${filename}"`,
+    'Cache-Control': 'no-store',
+  });
+  res.end(csv);
+}
+
+/**
+ * Sanitize a string so it's safe as part of a CSV filename — keep
+ * alphanumerics, dashes, underscores, dots; replace the rest with `_`.
+ */
+export function safeFilename(s) {
+  return String(s).replace(/[^A-Za-z0-9._-]/g, '_').slice(0, 80) || 'export';
+}
diff --git a/docker-server-dissonance.mjs b/docker-server-dissonance.mjs
