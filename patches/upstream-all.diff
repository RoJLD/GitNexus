+    // List the archive first so we can detect its shape (single top-level dir
+    // or already-rooted) and reject anything fishy without writing to disk.
+    const listOut = await runCmd('unzip', ['-Z1', archivePath]);
+    const entries = listOut.split('\n').map((l) => l.trim()).filter(Boolean);
+    if (entries.length === 0) {
+      throw new Error('archive is empty');
+    }
+    if (entries.some((e) => e.includes('..'))) {
+      throw new Error('archive contains path traversal entries');
+    }
+
+    // Detect whether all entries share a single top-level directory (the
+    // export endpoint always wraps content this way). We strip that prefix
+    // when extracting so the receiver picks the *target* path, not whatever
+    // the sender called the folder.
+    const topLevels = new Set(entries.map((e) => e.split('/')[0]));
+    const singleTop =
+      topLevels.size === 1 && entries.every((e) => e.startsWith([...topLevels][0] + '/') || e === [...topLevels][0] + '/');
+    const stripPrefix = singleTop ? [...topLevels][0] + '/' : null;
+
+    // Extract into a staging dir first, then move into place. This avoids
+    // half-extracted state if something goes wrong mid-way.
+    const extractDir = join(stage, 'extract');
+    await mkdir(extractDir, { recursive: true });
+    await runCmd('unzip', ['-q', archivePath, '-d', extractDir]);
+
+    // Pick the source dir to copy from, depending on whether we stripped.
+    const sourceDir = stripPrefix ? join(extractDir, stripPrefix.replace(/\/$/, '')) : extractDir;
+
+    // Make sure the target exists.
+    await mkdir(target, { recursive: true });
+
+    // Copy everything from sourceDir into target. -a preserves attrs; the
+    // trailing dot syntax copies *contents*, not the dir itself.
+    await runCmd('sh', ['-c', `cp -a "${sourceDir}/." "${target}/"`]);
