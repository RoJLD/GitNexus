+          PCA
+        </button>
+        <button
+          type="button"
+          onClick={() => setMethod('umap')}
+          className={`cursor-pointer rounded px-1.5 py-0 text-[9px] font-medium transition-all ${
+            method === 'umap'
+              ? 'bg-cyan-500/20 text-cyan-200'
