+  if (highS && highSem && !highT) return 'Jumeaux isolés';
+  if (highS && !highSem && highT) return 'Patterns + collision';
+  if (highS && !highSem && !highT) return 'Patterns partagés';
+  if (!highS && highSem && highT) return 'Collision réelle';
