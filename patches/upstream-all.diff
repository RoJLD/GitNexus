+        )}
+      </div>
+      <svg
+        width="100%"
+        height={GALAXY_HEIGHT}
+        viewBox={`0 0 ${GALAXY_WIDTH} ${GALAXY_HEIGHT}`}
+        className="rounded border border-border-subtle bg-void"
+      >
+        {/* Edges below dots so dots draw on top. */}
+        {edges.map(({ a, b, strength, pair }, idx) => {
+          const { cx: ax, cy: ay } = project(a.x, a.y);
+          const { cx: bx, cy: by } = project(b.x, b.y);
+          const isSelected =
+            selectedPair &&
+            ((selectedPair.a === a.name && selectedPair.b === b.name) ||
+              (selectedPair.a === b.name && selectedPair.b === a.name));
+          return (
+            <line
+              key={`edge-${idx}`}
+              x1={ax}
+              y1={ay}
+              x2={bx}
+              y2={by}
+              stroke={isSelected ? '#22d3ee' : '#475569'}
+              strokeWidth={isSelected ? 2 : 0.5 + (strength - GALAXY_EDGE_THRESHOLD) * 4}
+              strokeOpacity={isSelected ? 0.9 : 0.4}
+            >
+              <title>
+                {a.name} ↔ {b.name}: {pair.quadrant} (avg strength {strength.toFixed(2)})
+              </title>
+            </line>
+          );
+        })}
+        {/* Dots + labels */}
+        {pts.map((p) => {
+          const { cx, cy } = project(p.x, p.y);
+          const color = quadrantHex(dominantQuadrant.get(p.name) || '');
+          const isBase = p.name === baseRepo;
+          const isSelected =
+            selectedPair && (selectedPair.a === p.name || selectedPair.b === p.name);
+          return (
+            <g
+              key={p.name}
+              onClick={() => onSelectRepo(p.name)}
+              style={{ cursor: 'pointer' }}
+            >
+              <circle
+                cx={cx}
+                cy={cy}
+                r={isSelected ? GALAXY_DOT_RADIUS + 2 : GALAXY_DOT_RADIUS}
+                fill={color}
+                stroke={isBase ? '#ffffff' : isSelected ? '#22d3ee' : '#1e293b'}
+                strokeWidth={isBase ? 2 : isSelected ? 2 : 1}
+                opacity={0.9}
+              >
+                <title>
+                  {p.name}
+                  {isBase ? ' ★' : ''}: {dominantQuadrant.get(p.name) || ''}
+                </title>
+              </circle>
+              <text
+                x={cx + GALAXY_DOT_RADIUS + 4}
+                y={cy + 3}
