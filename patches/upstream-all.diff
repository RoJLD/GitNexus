+async function handleListDir(url, res) {
+  const requested = url.searchParams.get('path') || BROWSE_ROOT;
+  const target = resolveBrowsePath(requested);
+  if (!target) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'invalid path' }));
+    return;
+  }
+
+  let entries;
+  try {
+    entries = await readdir(target, { withFileTypes: true });
+  } catch (err) {
+    const status = err && err.code === 'ENOENT' ? 404 : 500;
+    res.writeHead(status, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: err?.message || 'readdir failed' }));
+    return;
+  }
+
+  // Only directories. Mark git repos and previously-indexed projects so the
+  // UI can highlight them — that's where the user almost always wants to go.
+  const dirs = entries.filter((e) => e.isDirectory() && !SKIP_DIRS.has(e.name));
+  const annotated = await Promise.all(
+    dirs.map(async (d) => {
+      const childPath = join(target, d.name);
+      const [hasGit, hasGitnexus] = await Promise.all([
+        stat(join(childPath, '.git')).then(() => true).catch(() => false),
+        stat(join(childPath, '.gitnexus')).then(() => true).catch(() => false),
+      ]);
+      return { name: d.name, path: childPath, hasGit, hasGitnexus };
+    }),
+  );
+
+  annotated.sort((a, b) => a.name.localeCompare(b.name));
+
+  res.writeHead(200, {
+    'Content-Type': 'application/json; charset=utf-8',
+    'Cache-Control': 'no-store',
+  });
+  res.end(
+    JSON.stringify({
+      path: target,
+      parent: target === BROWSE_ROOT ? null : target.split('/').slice(0, -1).join('/') || '/',
+      root: BROWSE_ROOT,
+      entries: annotated,
+    }),
+  );
+}
