+  if (n === null) return '—';
+  return n.toFixed(2);
+}
+
+// ── Galaxy view (Tier 2.6) ──────────────────────────────────────────
+//
+// PCA-projected 2D scatter of repos. Points colored by their dominant
+// pairwise quadrant (most-frequent quadrant they appear in). Edges
+// drawn for pairs with strong total similarity (struct + sem + temp
+// average above a threshold) so the user sees "constellation".
+//
+// SVG over Canvas: <=8 repos fit happily, SVG is more accessible
+// (hover titles, no manual hit-testing) and re-renders without state.
