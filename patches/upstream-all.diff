new file mode 100644
index 0000000..5a069d6
--- /dev/null
+++ b/gitnexus-web/src/components/LifespanPanel.tsx
@@ -0,0 +1,251 @@
+import { useMemo, useState } from 'react';
+import {
+  X,
+  History,
+  Loader2,
+  AlertCircle,
+  ChevronRight,
+  ChevronDown,
+  Download,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+import type { LifespanBucket, LifespanNode } from '../hooks/useAppState';
+
+/**
+ * Lifespan analysis panel. Splits every node ever seen across the
+ * snapshot timeline into four buckets:
+ *
+ *   foundational  — present in the first snapshot AND in live (proven)
+ *   recent        — appeared later, still alive in live (innovation that stuck)
+ *   discontinued  — was there, gone in live (removed / refactored)
+ *   ephemeral     — appeared mid-timeline AND gone before live (tried, dropped)
+ *
+ * Each section collapses independently so the user can focus on what
+ * matters. Click any node row to highlight it in the graph (only nodes
+ * that still exist in the live graph can be highlighted; otherwise the
+ * row is disabled).
+ *
+ * Position: right side, below the CouplingPanel slot so they don't
+ * overlap. Both can be open simultaneously — different analytics, no
+ * visual conflict.
+ */
+
+const PANEL_WIDTH_PX = 360;
+
+const BUCKET_META: Record<
+  LifespanBucket,
+  { label: string; color: string; help: string; bg: string }
+> = {
+  foundational: {
+    label: 'Foundational',
+    color: 'text-emerald-300',
+    bg: 'bg-emerald-500/10 border-emerald-500/30',
+    help: 'Present in first snapshot AND in live — the load-bearing skeleton.',
+  },
+  recent: {
+    label: 'Recent',
+    color: 'text-cyan-300',
+    bg: 'bg-cyan-500/10 border-cyan-500/30',
+    help: 'Appeared after the start, still in live — innovations that stuck.',
+  },
+  discontinued: {
+    label: 'Discontinued',
+    color: 'text-amber-300',
+    bg: 'bg-amber-500/10 border-amber-500/30',
+    help: 'Was there at the start, gone in live — removed or refactored away.',
+  },
+  ephemeral: {
+    label: 'Ephemeral',
+    color: 'text-red-300',
+    bg: 'bg-red-500/10 border-red-500/30',
+    help: 'Appeared mid-timeline AND gone before live — tried, did not stick.',
+  },
+};
+
+export const LifespanPanel = () => {
+  const {
+    projectName,
+    lifespanActive,
+    lifespanLoading,
+    lifespanError,
+    lifespanData,
+    graph,
+    setHighlightedNodeIds,
+    exitLifespanMode,
+  } = useAppState();
+  const baseRepo = (projectName || '').split('@')[0];
+  const [open, setOpen] = useState<Record<LifespanBucket, boolean>>({
+    foundational: false, // usually huge — collapsed by default
+    recent: true,
+    discontinued: true,
+    ephemeral: true,
+  });
+  const [search, setSearch] = useState('');
+
+  // Build a set of node ids currently in the live graph so we can mark
+  // discontinued/ephemeral nodes as un-highlightable (their nodes don't
+  // exist in the active graph any more).
+  const liveIds = useMemo(() => {
+    if (!graph) return new Set<string>();
+    return new Set(graph.nodes.map((n) => n.id));
+  }, [graph]);
+
+  if (!lifespanActive && !lifespanLoading && !lifespanError) return null;
+
+  const renderNode = (n: LifespanNode) => {
+    const canHighlight = liveIds.has(n.id);
+    const displayName = n.name || n.id;
+    const displayPath = n.path || '';
+    return (
+      <button
+        key={n.id}
+        type="button"
+        onClick={() => {
+          if (!canHighlight) return;
+          setHighlightedNodeIds(new Set([n.id]));
+        }}
+        disabled={!canHighlight}
+        className="group flex w-full flex-col gap-0.5 border-b border-border-subtle px-2.5 py-1.5 text-left transition-colors hover:bg-hover disabled:cursor-not-allowed disabled:opacity-50"
+        title={
+          canHighlight
+            ? `Click to highlight in graph\n${n.id}`
+            : `Not in live graph any more\n${n.id}`
+        }
+      >
+        <div className="flex min-w-0 items-center gap-1.5 font-mono text-[11px]">
+          <span className="shrink-0 rounded bg-elevated px-1 py-0 text-[9px] text-text-muted">
+            {n.label}
+          </span>
+          <span className="truncate text-text-primary">{displayName}</span>
+        </div>
+        {displayPath && (
+          <div className="truncate font-mono text-[10px] text-text-muted">{displayPath}</div>
+        )}
+      </button>
+    );
+  };
+
+  return (
+    <div
+      className="pointer-events-auto absolute right-3 bottom-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width: PANEL_WIDTH_PX, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <History className="h-3.5 w-3.5 text-amber-300" />
+        <span className="text-xs font-semibold text-text-primary">Lifespan</span>
+        {lifespanData && (
+          <span className="font-mono text-[10px] text-text-muted">
+            over {lifespanData.totalPoints} points
+          </span>
+        )}
+        {lifespanData && (
+          <a
+            href={`/lifespan?repo=${encodeURIComponent(baseRepo)}&format=csv`}
+            download
+            className="ml-auto shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+            title="Download all buckets as CSV"
+          >
+            <Download className="h-3.5 w-3.5" />
+          </a>
+        )}
+        <button
+          type="button"
+          onClick={() => exitLifespanMode()}
+          className={`${lifespanData ? '' : 'ml-auto'} shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary`}
+          title="Close lifespan panel"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+
+      {lifespanLoading && (
+        <div className="flex items-center justify-center gap-2 py-6 text-xs text-text-muted">
+          <Loader2 className="h-3.5 w-3.5 animate-spin" />
+          Computing lifespan…
+        </div>
+      )}
+      {lifespanError && (
+        <div className="flex items-start gap-2 px-3 py-3 text-xs text-red-400">
+          <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+          <span>{lifespanError}</span>
+        </div>
+      )}
+
+      {lifespanData && !lifespanLoading && (
+        <>
+          <div className="shrink-0 border-b border-border-subtle px-3 py-2">
+            <input
+              type="text"
+              value={search}
+              onChange={(e) => setSearch(e.target.value)}
+              placeholder="Filter by name or path…"
+              className="w-full rounded-md border border-border-default bg-void px-2 py-1 font-mono text-[11px] text-text-primary outline-none placeholder:text-text-muted focus:border-accent/40"
+              spellCheck={false}
+              autoComplete="off"
+            />
+          </div>
+
+          <div className="flex-1 overflow-y-auto">
+            {(Object.keys(BUCKET_META) as LifespanBucket[]).map((bucket) => {
+              const meta = BUCKET_META[bucket];
+              const all = lifespanData.nodes[bucket] || [];
+              const q = search.trim().toLowerCase();
+              const filtered = q
+                ? all.filter(
+                    (n) =>
+                      (n.name || '').toLowerCase().includes(q) ||
+                      (n.path || '').toLowerCase().includes(q),
+                  )
+                : all;
+              const total = lifespanData.counts[bucket] || 0;
+              const isOpen = open[bucket];
+              return (
+                <div key={bucket} className="border-b border-border-subtle">
+                  <button
+                    type="button"
+                    onClick={() => setOpen((prev) => ({ ...prev, [bucket]: !prev[bucket] }))}
+                    className="flex w-full items-center gap-2 px-3 py-1.5 text-left transition-colors hover:bg-hover cursor-pointer"
+                    title={meta.help}
+                  >
+                    {isOpen ? (
+                      <ChevronDown className="h-3 w-3 shrink-0 text-text-muted" />
+                    ) : (
+                      <ChevronRight className="h-3 w-3 shrink-0 text-text-muted" />
+                    )}
+                    <span className={`text-[11px] font-semibold ${meta.color}`}>{meta.label}</span>
+                    <span
+                      className={`shrink-0 rounded border px-1.5 py-0 font-mono text-[10px] ${meta.bg} ${meta.color}`}
+                    >
+                      {total}
+                    </span>
+                    {q && filtered.length !== total && (
+                      <span className="font-mono text-[10px] text-text-muted">
+                        ({filtered.length} matching)
+                      </span>
+                    )}
+                  </button>
+                  {isOpen && (
+                    <>
+                      {filtered.length === 0 ? (
+                        <div className="px-3 py-2 text-[10px] text-text-muted italic">
+                          {total === 0 ? 'None' : 'No matches for current filter.'}
+                        </div>
+                      ) : (
+                        filtered.map(renderNode)
+                      )}
+                      {total > all.length && (
+                        <div className="px-3 py-1 text-[10px] text-text-muted italic">
+                          Showing first {all.length} of {total} (truncated server-side)
+                        </div>
+                      )}
+                    </>
+                  )}
+                </div>
+              );
+            })}
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
diff --git a/gitnexus-web/src/components/OwnershipPanel.tsx b/gitnexus-web/src/components/OwnershipPanel.tsx
new file mode 100644
index 0000000..cf9a466
--- /dev/null
+++ b/gitnexus-web/src/components/OwnershipPanel.tsx
@@ -0,0 +1,237 @@
+import { useMemo, useState } from 'react';
+import {
+  X,
+  Users,
+  Loader2,
+  AlertCircle,
+  Download,
+  AlertTriangle,
+} from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Ownership / bus-factor panel — ROADMAP Tier 1.1.
+ *
+ * Lists files sorted by *fragility*: the lowest bus factor (=1 means one
+ * person has touched 80%+ of the file's history) first. Within the same
+ * bus factor, busier files (more commits) rank higher because they
+ * matter more.
+ *
+ * Filter by path/author. Click a row to highlight the file in the live
+ * graph (skipped if the file no longer exists). A header strip shows
+ * the *repo-level* bus factor — your "how many people could leave
+ * before the codebase is in trouble" number.
+ *
+ * Position: top-right (same slot as CouplingPanel — they're mutually
+ * exclusive, since both are "list of things by metric" panels and
+ * stacking would be noisy).
+ */
+
+const PANEL_WIDTH_PX = 380;
+
