+    res.writeHead(200, { 'Content-Type': 'application/json' });
+    res.end(
+      JSON.stringify({
+        ok: true,
+        targetPath: target,
+        mode: registerOnly ? 'register-only' : skipAnalyze ? 'skip-analyze' : 'analyze',
+        registryEntry,
+        register: registerResp
+          ? { status: registerResp.status, body: registerJson }
+          : null,
+      }),
+    );
+  } catch (err) {
+    console.error('[import] failed:', err);
+    res.writeHead(500, { 'Content-Type': 'application/json' });
