+                <span className="text-[11px] font-semibold text-red-300">Misplaced files</span>
+                <span className="font-mono text-[10px] text-text-muted">
+                  {filteredMisplaced.length}
+                  {filteredMisplaced.length !== dissonanceData.misplaced.length &&
+                    ` of ${dissonanceData.misplaced.length}`}
+                </span>
+              </button>
+              {showMisplaced &&
+                (filteredMisplaced.length === 0 ? (
+                  <div className="px-3 py-2 text-[10px] italic text-text-muted">
+                    {dissonanceData.misplaced.length === 0
+                      ? 'None — every file matches its domain\'s dominant community. ✓'
+                      : 'No matches for current filter.'}
+                  </div>
+                ) : (
+                  filteredMisplaced.map((m) => {
+                    const fileId = fileIdByPath.get(m.file);
+                    const canHighlight = !!fileId;
+                    return (
+                      <button
+                        key={m.file}
+                        type="button"
+                        onClick={() => {
+                          if (!canHighlight) return;
+                          setHighlightedNodeIds(new Set([fileId!]));
