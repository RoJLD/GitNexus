+const GALAXY_WIDTH = 420;
+const GALAXY_HEIGHT = 280;
+const GALAXY_PADDING = 24;
+const GALAXY_EDGE_THRESHOLD = 0.6; // avg of 3 normalized axes
+const GALAXY_DOT_RADIUS = 6;
+
+type GalaxyProps = {
+  repos: SimilarityRepo[];
+  pairs: SimilarityPair[];
+  selectedPair: SimilarityPair | null;
+  baseRepo: string;
+  onSelectRepo: (name: string) => void;
+};
+
+function quadrantHex(q: string): string {
+  // Stand-alone hex colors matching the Tailwind classes used in the
+  // matrix. SVG fill doesn't pick up class-based vars cleanly.
+  if (q.startsWith('Jumeaux actifs')) return '#34d399';        // emerald-400
+  if (q.startsWith('Jumeaux isolés')) return '#fbbf24';        // amber-400
+  if (q.startsWith('Jumeaux (isolation')) return '#94a3b8';    // slate-400
+  if (q === 'Patterns + collision') return '#fb923c';          // orange-400
+  if (q === 'Patterns partagés') return '#38bdf8';             // sky-400
+  if (q === 'Collision réelle') return '#f87171';              // red-400
+  if (q === 'Domaines parallèles') return '#a5b4fc';           // indigo-300
+  if (q === 'Couplage caché') return '#e879f9';                // fuchsia-400
+  return '#6b7280';                                            // gray-500 fallback
+}
+
+function GalaxyView({ repos, pairs, selectedPair, baseRepo, onSelectRepo }: GalaxyProps) {
+  // Projection method toggle (Tier 2.6 = PCA from backend, 2.6.bis =
+  // UMAP computed client-side via umap-js). UMAP gives better
+  // neighborhood preservation but degenerates < ~5 points; PCA is
+  // smoother for the small-N case (2-4 repos) but doesn't pick up
+  // nonlinear cluster shape. We default to PCA because it ships
+  // already-computed in the backend response (no extra import cost).
+  const [method, setMethod] = useState<'pca' | 'umap'>('pca');
+  const [umapCoords, setUmapCoords] = useState<Map<string, [number, number]> | null>(null);
+  const [umapError, setUmapError] = useState<string | null>(null);
+
+  // Compute UMAP lazily on first switch to 'umap' for the active repo
+  // set. Re-runs when repos change (new index, refetch). Dynamic
+  // import keeps umap-js out of the bundle for users who never open
+  // the galaxy.
+  const reposKey = repos.map((r) => r.name).join('|');
+  useEffect(() => {
+    if (method !== 'umap') return;
+    let cancelled = false;
+    void (async () => {
+      try {
+        // Build the raw identity matrix from each repo's identityVector
+        // — same dims the backend used for PCA, but we re-project from
+        // scratch via UMAP for fairness (UMAP needs the original space
+        // to find neighborhoods).
+        const labeled = repos.filter((r) => Object.keys(r.identityVector).length > 0);
+        if (labeled.length < 2) {
+          setUmapError('UMAP needs ≥2 repos.');
+          return;
+        }
+        const dims = Object.keys(labeled[0].identityVector);
+        const data = labeled.map((r) => dims.map((d) => r.identityVector[d] ?? 0));
+        // umap-js requires nNeighbors ≤ N-1. For tiny N the result is
+        // basically scaled PCA, but it doesn't error out.
+        const nNeighbors = Math.max(2, Math.min(15, labeled.length - 1));
+        const { UMAP } = await import('umap-js');
+        // Seeded RNG so the projection is stable across refetches —
+        // umap-js takes a `random` function returning [0, 1). A simple
+        // mulberry32 keyed on the repo-set hash gives deterministic
+        // output without rotating on every page reload.
+        let seed = 0;
+        for (let i = 0; i < reposKey.length; i++) seed = (seed * 31 + reposKey.charCodeAt(i)) >>> 0;
+        const rng = () => {
+          seed = (seed + 0x6d2b79f5) >>> 0;
+          let t = seed;
+          t = Math.imul(t ^ (t >>> 15), t | 1);
+          t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
+          return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
+        };
+        const umap = new UMAP({
+          nNeighbors,
+          minDist: 0.1,
+          nComponents: 2,
+          random: rng,
+        });
+        const embedding = umap.fit(data);
+        if (cancelled) return;
+        const coords = new Map<string, [number, number]>();
+        for (let i = 0; i < labeled.length; i++) {
+          coords.set(labeled[i].name, [embedding[i][0], embedding[i][1]]);
+        }
+        setUmapCoords(coords);
+        setUmapError(null);
+      } catch (err) {
+        if (!cancelled) setUmapError(err instanceof Error ? err.message : 'UMAP failed');
+      }
+    })();
+    return () => {
+      cancelled = true;
+    };
+  }, [method, reposKey, repos]);
