+    const stagedRepoDir = join(stage, basename(repoPath));
+    await mkdir(stagedRepoDir, { recursive: true });
+
+    if (mode === 'bundle') {
+      // Copy everything to staging, then prune heavy junk. Two-step rather
+      // than one (cpio/rsync) so we don't depend on tools that aren't always
+      // present in busybox alpine.
+      await runCmd('sh', [
+        '-c',
+        `cp -a "${repoPath}/." "${stagedRepoDir}/" && ` +
+          `cd "${stagedRepoDir}" && ` +
+          `find . -depth -type d \\( -name node_modules -o -name .git -o -name .next -o -name .turbo -o -name .venv -o -name venv -o -name __pycache__ -o -name dist -o -name build -o -name .cache \\) -exec rm -rf {} +`,
+      ]);
+    } else {
+      // Index-only: just `.gitnexus/`.
+      await runCmd('cp', ['-a', dotGitnexus, stagedRepoDir + '/']);
+    }
