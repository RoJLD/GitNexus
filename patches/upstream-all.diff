diff --git a/gitnexus-web/src/components/GrowthChart.tsx b/gitnexus-web/src/components/GrowthChart.tsx
new file mode 100644
index 0000000..f0d6351
--- /dev/null
+++ b/gitnexus-web/src/components/GrowthChart.tsx
@@ -0,0 +1,305 @@
+import { useMemo, useState } from 'react';
+import { X, Loader2, AlertCircle, TrendingUp, Download } from '@/lib/lucide-icons';
+import { useAppState } from '../hooks/useAppState';
+
+/**
+ * Multi-line growth chart, rendered as a self-contained SVG so we don't
+ * pull in a charting library for one view. Each category (File, Function,
+ * Class, …) is a line; the X axis is the snapshot timeline (evenly
+ * spaced, same convention as the Timeline component); the Y axis is the
+ * node count per category at each point.
+ *
+ * Interactions:
+ *   - Click a legend chip to hide/show that category's line. The Y scale
+ *     auto-rescales so hiding a "noisy" series (e.g. Section nodes)
+ *     reveals the trends of the rest.
+ *   - Hover a point on the chart to see exact counts in a tooltip.
+ *
+ * Positioned bottom-left so it doesn't fight CouplingPanel for screen
+ * real-estate (top-right). Both panels can be open at once.
+ */
+
+const PANEL_WIDTH_PX = 480;
+const PANEL_HEIGHT_PX = 320;
+const CHART_PAD = { top: 12, right: 12, bottom: 28, left: 44 };
+
+// Distinct hues for the legend. Order matches the labels[] order from
+// the backend (sorted desc by max count), so the most prominent series
+// get the most vivid colors.
+const PALETTE = [
+  '#3b82f6', // blue
+  '#10b981', // emerald
+  '#f59e0b', // amber
+  '#ec4899', // pink
+  '#a855f7', // purple
+  '#06b6d4', // cyan
+  '#ef4444', // red
+  '#14b8a6', // teal
+  '#84cc16', // lime
+  '#6366f1', // indigo
+  '#f97316', // orange
+  '#8b5cf6', // violet
+];
+const colorFor = (i: number) => PALETTE[i % PALETTE.length];
+
+export const GrowthChart = () => {
+  const { projectName, growthActive, growthLoading, growthError, growthData, exitGrowthMode } = useAppState();
+  const baseRepo = (projectName || '').split('@')[0];
+  const [hidden, setHidden] = useState<Set<string>>(new Set());
+  const [hover, setHover] = useState<{ x: number; y: number; idx: number } | null>(null);
+
+  const visibleLabels = useMemo(
+    () => (growthData?.labels || []).filter((l) => !hidden.has(l)),
+    [growthData, hidden],
+  );
+
+  // Y-max recomputed from visible series only — hiding a dominant series
+  // makes the others readable instead of squashed near the bottom.
+  const yMax = useMemo(() => {
+    if (!growthData) return 0;
+    let max = 0;
+    for (const point of growthData.timeline) {
+      for (const lbl of visibleLabels) {
+        const v = point.counts[lbl] || 0;
+        if (v > max) max = v;
+      }
+    }
+    return max || 1;
+  }, [growthData, visibleLabels]);
+
+  if (!growthActive && !growthLoading && !growthError) return null;
+
+  const width = PANEL_WIDTH_PX;
+  const height = PANEL_HEIGHT_PX;
+  const innerW = width - CHART_PAD.left - CHART_PAD.right;
+  const innerH = height - CHART_PAD.top - CHART_PAD.bottom - 80; // 80 reserved for legend rows
+
+  const points = growthData?.timeline || [];
+  const n = points.length;
+  const xFor = (i: number) => (n === 1 ? innerW / 2 : (i / (n - 1)) * innerW);
+  const yFor = (v: number) => innerH - (v / yMax) * innerH;
+
+  return (
+    <div
+      className="pointer-events-auto absolute bottom-3 left-3 z-30 flex flex-col overflow-hidden rounded-xl border border-border-subtle bg-surface/95 shadow-xl backdrop-blur"
+      style={{ width, maxHeight: 'calc(100% - 1.5rem)' }}
+    >
+      {/* Header */}
+      <div className="flex shrink-0 items-center gap-2 border-b border-border-subtle px-3 py-2">
+        <TrendingUp className="h-3.5 w-3.5 text-cyan-400" />
+        <span className="text-xs font-semibold text-text-primary">Growth by category</span>
+        {growthData && (
+          <span className="font-mono text-[10px] text-text-muted">
+            {n} points • {growthData.labels.length} categories
+          </span>
+        )}
+        {growthData && (
+          <a
+            href={`/growth?repo=${encodeURIComponent(baseRepo)}&format=csv`}
+            download
+            className="ml-auto shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary"
+            title="Download long-format CSV (snapshot × label × count)"
+          >
+            <Download className="h-3.5 w-3.5" />
+          </a>
+        )}
+        <button
+          type="button"
+          onClick={() => exitGrowthMode()}
+          className={`${growthData ? '' : 'ml-auto'} shrink-0 cursor-pointer rounded p-1 text-text-muted transition-colors hover:bg-hover hover:text-text-primary`}
+          title="Close growth chart"
+        >
+          <X className="h-3.5 w-3.5" />
+        </button>
+      </div>
+
+      {growthLoading && (
+        <div className="flex items-center justify-center gap-2 py-8 text-xs text-text-muted">
+          <Loader2 className="h-3.5 w-3.5 animate-spin" />
+          Computing growth…
+        </div>
+      )}
+      {growthError && (
+        <div className="flex items-start gap-2 px-3 py-3 text-xs text-red-400">
+          <AlertCircle className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+          <span>{growthError}</span>
+        </div>
+      )}
+
+      {growthData && !growthLoading && (
+        <>
+          <div className="relative shrink-0 px-3 pt-2">
+            <svg width={width - 24} height={innerH + CHART_PAD.top + CHART_PAD.bottom}>
+              <g transform={`translate(${CHART_PAD.left},${CHART_PAD.top})`}>
+                {/* Grid: 4 horizontal lines + Y labels */}
+                {[0, 0.25, 0.5, 0.75, 1].map((t) => {
+                  const y = innerH - t * innerH;
+                  return (
+                    <g key={t}>
+                      <line
+                        x1={0}
+                        x2={innerW}
+                        y1={y}
+                        y2={y}
+                        stroke="#2a2a3a"
+                        strokeDasharray={t === 0 ? '0' : '2,3'}
+                      />
+                      <text
+                        x={-6}
+                        y={y + 3}
+                        textAnchor="end"
+                        fontSize="9"
+                        fill="#5a5a70"
+                        fontFamily="monospace"
+                      >
+                        {Math.round(t * yMax)}
+                      </text>
+                    </g>
+                  );
+                })}
+
+                {/* X axis ticks: index labels at the bottom — dates are in tooltips */}
+                {points.map((_, i) => (
+                  <line
+                    key={`xt-${i}`}
+                    x1={xFor(i)}
+                    x2={xFor(i)}
+                    y1={innerH}
+                    y2={innerH + 3}
+                    stroke="#2a2a3a"
+                  />
+                ))}
+
+                {/* One polyline per visible category */}
+                {visibleLabels.map((lbl) => {
+                  const colorIdx = growthData.labels.indexOf(lbl);
+                  const stroke = colorFor(colorIdx);
+                  const d = points
+                    .map((p, i) => `${i === 0 ? 'M' : 'L'}${xFor(i)},${yFor(p.counts[lbl] || 0)}`)
+                    .join(' ');
+                  return (
+                    <g key={lbl}>
+                      <path d={d} fill="none" stroke={stroke} strokeWidth={1.5} />
+                      {/* Dots so single-point series and inflexions are visible */}
+                      {points.map((p, i) => (
+                        <circle
+                          key={`${lbl}-${i}`}
+                          cx={xFor(i)}
+                          cy={yFor(p.counts[lbl] || 0)}
+                          r={hover && hover.idx === i ? 3 : 2}
+                          fill={stroke}
+                          opacity={hover && hover.idx !== i ? 0.5 : 1}
+                        />
+                      ))}
+                    </g>
+                  );
+                })}
+
+                {/* Invisible hover targets at each x position so the user
+                    gets a tooltip for the full vertical column of values */}
+                {points.map((p, i) => (
+                  <rect
+                    key={`hv-${i}`}
+                    x={xFor(i) - 12}
+                    y={0}
+                    width={24}
+                    height={innerH}
+                    fill="transparent"
+                    onMouseEnter={() => setHover({ x: xFor(i), y: 0, idx: i })}
+                    onMouseLeave={() => setHover(null)}
+                  />
+                ))}
+
+                {/* Vertical guide on hover */}
+                {hover && (
+                  <line
+                    x1={hover.x}
+                    x2={hover.x}
+                    y1={0}
+                    y2={innerH}
+                    stroke="#7c3aed"
+                    strokeDasharray="2,3"
+                    opacity={0.6}
+                  />
+                )}
+              </g>
+            </svg>
+
+            {/* Tooltip */}
+            {hover && points[hover.idx] && (
+              <div
+                className="pointer-events-none absolute z-10 max-w-[260px] rounded-md border border-border-subtle bg-deep px-2 py-1.5 text-[10px] shadow-lg"
+                style={{
+                  left: Math.min(width - 270, CHART_PAD.left + hover.x + 8),
+                  top: CHART_PAD.top + 4,
+                }}
+              >
+                <div className="mb-1 flex items-center gap-1.5">
+                  {points[hover.idx].isLive ? (
+                    <span className="rounded bg-emerald-500/15 px-1 py-0 font-mono font-semibold text-emerald-400">
+                      LIVE
+                    </span>
+                  ) : (
+                    <span className="rounded bg-accent/15 px-1 py-0 font-mono font-semibold text-accent">
+                      {points[hover.idx].name.split('@')[1] || ''}
+                    </span>
+                  )}
+                  <span className="font-mono text-text-muted">
+                    {new Date(points[hover.idx].date).toLocaleDateString()}
+                  </span>
+                </div>
+                <div className="space-y-0.5">
+                  {visibleLabels.map((lbl) => (
+                    <div key={lbl} className="flex items-center gap-1.5 text-text-secondary">
+                      <span
+                        className="inline-block h-1.5 w-1.5 rounded-full"
+                        style={{ backgroundColor: colorFor(growthData.labels.indexOf(lbl)) }}
+                      />
+                      <span className="flex-1">{lbl}</span>
+                      <span className="font-mono text-text-primary">
+                        {points[hover.idx].counts[lbl] || 0}
+                      </span>
+                    </div>
+                  ))}
+                </div>
+              </div>
+            )}
+          </div>
+
+          {/* Legend — clickable chips for show/hide */}
+          <div className="flex max-h-[100px] flex-wrap gap-1 overflow-y-auto border-t border-border-subtle px-3 py-2">
+            {growthData.labels.map((lbl, i) => {
+              const isHidden = hidden.has(lbl);
+              return (
+                <button
+                  key={lbl}
+                  type="button"
+                  onClick={() => {
+                    setHidden((prev) => {
+                      const next = new Set(prev);
+                      if (next.has(lbl)) next.delete(lbl);
+                      else next.add(lbl);
+                      return next;
+                    });
+                  }}
+                  className={`flex items-center gap-1 rounded-md border px-1.5 py-0.5 text-[10px] font-mono transition-all cursor-pointer ${
+                    isHidden
+                      ? 'border-border-subtle bg-elevated text-text-muted/60'
+                      : 'border-border-subtle bg-elevated text-text-secondary hover:bg-hover'
+                  }`}
+                  title={isHidden ? `Show ${lbl}` : `Hide ${lbl}`}
+                >
+                  <span
+                    className="inline-block h-1.5 w-1.5 rounded-full"
+                    style={{ backgroundColor: colorFor(i), opacity: isHidden ? 0.3 : 1 }}
+                  />
+                  {lbl}
+                </button>
+              );
+            })}
+          </div>
+        </>
+      )}
+    </div>
+  );
+};
