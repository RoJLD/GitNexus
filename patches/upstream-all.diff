+ * Whether the active provider can do embeddings. Frontend uses this to
+ * decide whether to show the "Embed labels" button.
+ */
+export const providerSupportsEmbeddings = (config: ProviderConfig): boolean => {
+  return (
+    config.provider === 'openai' ||
+    config.provider === 'azure-openai' ||
+    config.provider === 'gemini' ||
+    config.provider === 'ollama'
+  );
+};
