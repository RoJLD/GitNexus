+    cx: GALAXY_PADDING + ((x - xMin) / xRange) * (GALAXY_WIDTH - 2 * GALAXY_PADDING),
+    // SVG y is inverted; flip so up = positive PC2.
+    cy: GALAXY_HEIGHT - GALAXY_PADDING - ((y - yMin) / yRange) * (GALAXY_HEIGHT - 2 * GALAXY_PADDING),
+  });
