+    let registerResp;
+    let registryEntry = null;
+    if (registerOnly) {
+      try {
+        registryEntry = await registerLocally(target);
+      } catch (err) {
+        console.warn('[import] direct register failed:', err?.message);
+      }
+    } else if (!skipAnalyze) {
+      try {
+        registerResp = await fetch(`${GITNEXUS_API}/api/analyze`, {
+          method: 'POST',
+          headers: { 'Content-Type': 'application/json' },
+          body: JSON.stringify({ path: target, force: false }),
+        });
+      } catch (err) {
+        console.warn('[import] failed to call /api/analyze:', err?.message);
+      }
+    }
