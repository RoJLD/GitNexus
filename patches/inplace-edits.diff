+   * `properties.filePath` exactly equals one of the touched paths.
+   * Files we can't match are surfaced in `unresolvedFiles` so the UI
+   * can hint "3/5 highlighted, 2 not found in current graph".
+   */
+  const loadCommitFootprint = useCallback(
+    async (sha: string) => {
+      if (!projectName) {
+        setCommitFootprintError('No active repo.');
+        return;
+      }
+      const baseRepo = projectName.split('@')[0];
+      setCommitFootprintLoading(true);
+      setCommitFootprintError(null);
+      try {
+        const resp = await fetch(
+          `/commit/footprint?repo=${encodeURIComponent(baseRepo)}&sha=${encodeURIComponent(sha)}`,
+          { cache: 'no-store' },
+        );
+        if (!resp.ok) {
+          const body = await resp.json().catch(() => ({}));
+          throw new Error(body?.error || `HTTP ${resp.status}`);
+        }
+        const data = await resp.json();
+        const touchedPaths = new Set<string>(
+          (data.filesTouched || []).map((f: CommitFootprintFile) => f.path),
+        );
