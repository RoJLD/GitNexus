+// Validate a browse-target path: must resolve to BROWSE_ROOT or a descendant.
+// Rejects path-traversal attempts (.., absolute paths outside the root, etc.).
+function resolveBrowsePath(requested) {
+  if (typeof requested !== 'string' || !requested) return null;
+  if (requested.includes('\0')) return null;
+  const abs = resolve(requested);
+  if (abs !== BROWSE_ROOT && !abs.startsWith(BROWSE_ROOT + '/')) return null;
+  return abs;
