+async function handleImport(url, req, res) {
+  const targetRequested = url.searchParams.get('targetPath');
+  const target = resolveBrowsePath(targetRequested);
+  if (!target) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing or invalid targetPath' }));
+    return;
