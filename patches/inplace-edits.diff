index 860ee70c..de1d3c10 100644
--- a/gitnexus-web/test/setup.ts
+++ b/gitnexus-web/test/setup.ts
@@ -1,8 +1,24 @@
 import { beforeEach } from 'vitest';
 import '@testing-library/jest-dom/vitest';
 
+// Node v25 ships a native WebStorage that raises when --localstorage-file is
+// absent.  Guard every access so the suite stays green on Node ≥ 25.
+function safeRemoveItem(storage: Storage | undefined, key: string): void {
+  try {
+    storage?.removeItem(key);
+  } catch {
+    // Native WebStorage unavailable — no-op (jsdom storage cleared per-test anyway)
+  }
+}
+
 // Reset storage between tests
 beforeEach(() => {
-  sessionStorage.removeItem('gitnexus-llm-settings');
-  localStorage.removeItem('gitnexus-llm-settings'); // legacy key (migration)
+  safeRemoveItem(
+    typeof sessionStorage !== 'undefined' ? sessionStorage : undefined,
+    'gitnexus-llm-settings',
+  );
+  safeRemoveItem(
+    typeof localStorage !== 'undefined' ? localStorage : undefined,
+    'gitnexus-llm-settings', // legacy key (migration)
+  );
 });
