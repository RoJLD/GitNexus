+  // Spool the upload to a temp file, then unzip it. We don't hand the request
+  // stream straight to unzip because unzip needs to seek (zip's central
+  // directory is at the end of the file).
+  const stage = await mkdtemp(join(tmpdir(), 'gitnexus-import-'));
+  const archivePath = join(stage, 'upload.zip');
