+  try {
+    await new Promise((resolveProm, rejectProm) => {
+      const out = createWriteStream(archivePath);
+      req.on('error', rejectProm);
+      out.on('error', rejectProm);
+      out.on('finish', resolveProm);
+      req.pipe(out);
