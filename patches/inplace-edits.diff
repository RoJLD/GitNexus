+    const archiveName = `${safeFilenameFromName(repoName)}.${mode === 'bundle' ? 'bundle' : 'gitnexus'}.zip`;
+    res.writeHead(200, {
+      'Content-Type': 'application/zip',
+      'Content-Disposition': `attachment; filename="${archiveName}"`,
+      'Cache-Control': 'no-store',
+    });
