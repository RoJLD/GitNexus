+    // `zip -r - <dir>` writes the archive to stdout. We pipe stdout to the
+    // HTTP response. The client gets a streamed download with the repo name
+    // as the top-level directory inside the archive.
+    const child = spawn('zip', ['-r', '-q', '-', basename(stagedRepoDir)], { cwd: stage });
+    child.stdout.pipe(res);
+    child.stderr.on('data', (d) => console.warn('[export][zip][stderr]', d.toString()));
+    child.on('error', (err) => {
+      console.error('[export] zip failed:', err);
