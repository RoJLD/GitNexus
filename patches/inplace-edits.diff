+async function findRepoByName(name) {
+  try {
+    const res = await fetch(`${GITNEXUS_API}/api/repos`);
+    if (!res.ok) return null;
+    const data = await res.json();
+    const list = Array.isArray(data) ? data : data.repos;
+    if (!Array.isArray(list)) return null;
+    return list.find((r) => r.name === name) || null;
+  } catch {
+    return null;
+  }
+}
+
+function safeFilenameFromName(name) {
+  return name.replace(/[^a-zA-Z0-9._-]/g, '_').slice(0, 80) || 'export';
+}
+
+async function handleExport(url, res) {
+  const repoName = url.searchParams.get('repo');
+  const mode = url.searchParams.get('mode') === 'bundle' ? 'bundle' : 'index';
+  if (!repoName) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'missing repo' }));
+    return;
+  }
+
+  const repo = await findRepoByName(repoName);
+  if (!repo) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: `repo not found: ${repoName}` }));
+    return;
+  }
+
+  const repoPath = resolveBrowsePath(repo.repoPath || repo.path);
+  if (!repoPath) {
+    res.writeHead(400, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: 'repo path is outside the mounted projects root' }));
+    return;
+  }
+
+  const dotGitnexus = join(repoPath, '.gitnexus');
+  const exists = await stat(dotGitnexus).catch(() => null);
+  if (!exists?.isDirectory()) {
+    res.writeHead(404, { 'Content-Type': 'application/json' });
+    res.end(JSON.stringify({ error: '.gitnexus folder not found for repo' }));
+    return;
+  }
+
+  // Stage a copy of the data we want to zip in a temp dir, so we can rewrite
+  // meta.json without touching the originals.
+  const stage = await mkdtemp(join(tmpdir(), 'gitnexus-export-'));
+  try {
+    const stagedRepoDir = join(stage, basename(repoPath));
+    await mkdir(stagedRepoDir, { recursive: true });
+
+    if (mode === 'bundle') {
+      // Copy everything to staging, then prune heavy junk. Two-step rather
+      // than one (cpio/rsync) so we don't depend on tools that aren't always
+      // present in busybox alpine.
+      await runCmd('sh', [
+        '-c',
+        `cp -a "${repoPath}/." "${stagedRepoDir}/" && ` +
+          `cd "${stagedRepoDir}" && ` +
+          `find . -depth -type d \\( -name node_modules -o -name .git -o -name .next -o -name .turbo -o -name .venv -o -name venv -o -name __pycache__ -o -name dist -o -name build -o -name .cache \\) -exec rm -rf {} +`,
+      ]);
+    } else {
+      // Index-only: just `.gitnexus/`.
+      await runCmd('cp', ['-a', dotGitnexus, stagedRepoDir + '/']);
+    }
+
+    // Rewrite meta.json to drop our absolute path so the receiver's machine
+    // doesn't get a stale value when it imports.
+    const metaPath = join(stagedRepoDir, '.gitnexus', 'meta.json');
+    try {
+      const raw = await readFile(metaPath, 'utf8');
+      const meta = JSON.parse(raw);
+      delete meta.repoPath;
+      meta.exportedFromRepoName = repoName;
+      meta.exportedAt = new Date().toISOString();
+      meta.exportMode = mode;
+      await writeFile(metaPath, JSON.stringify(meta, null, 2), 'utf8');
+    } catch {
