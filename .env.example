# Per-machine config. Copy this file to .env and edit PROJECTS_ROOT.
#
# PROJECTS_ROOT must be an absolute path to the host folder you want GitNexus
# to be able to index. Every repo under this path will be reachable as
# /data/projects/<sub-path> from inside the containers.
#
# Use forward slashes (/) on Windows — Docker Desktop / Rancher accept both,
# but forward slashes avoid YAML/.env escaping pitfalls.
#
# Examples:
#   Windows:  PROJECTS_ROOT=C:/Users/jdupont/Code
#   macOS:    PROJECTS_ROOT=/Users/jdupont/code
#   Linux:    PROJECTS_ROOT=/home/jdupont/code

PROJECTS_ROOT=C:/Users/CHANGE_ME/Code
